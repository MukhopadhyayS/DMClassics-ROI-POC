--GO

IF  EXISTS (SELECT * FROM sys.foreign_keys WHERE object_id = OBJECT_ID(N'[dbo].[FK_CDII_CDI_ImnetDateDeleted]') AND parent_object_id = OBJECT_ID(N'[dbo].[Cab_Del_Items_InUse]'))
ALTER TABLE [dbo].[Cab_Del_Items_InUse] CHECK CONSTRAINT [FK_CDII_CDI_ImnetDateDeleted]
GO
IF Not EXISTS (SELECT * FROM sys.default_constraints WHERE object_id = OBJECT_ID(N'[dbo].[DF_CDII_Created_Dt]') AND parent_object_id = OBJECT_ID(N'[dbo].[Cab_Del_Items_InUse]'))
Begin
IF NOT EXISTS (SELECT * FROM dbo.sysobjects WHERE id = OBJECT_ID(N'[DF_CDII_Created_Dt]') AND type = 'D')
BEGIN
ALTER TABLE [dbo].[Cab_Del_Items_InUse] ADD  CONSTRAINT [DF_CDII_Created_Dt]  DEFAULT (getdate()) FOR [CDII_Created_Dt]
END
End
GO

IF Not EXISTS (SELECT * FROM sys.default_constraints WHERE object_id = OBJECT_ID(N'[dbo].[DF_CDII_Created_By_Seq]') AND parent_object_id = OBJECT_ID(N'[dbo].[Cab_Del_Items_InUse]'))
Begin
IF NOT EXISTS (SELECT * FROM dbo.sysobjects WHERE id = OBJECT_ID(N'[DF_CDII_Created_By_Seq]') AND type = 'D')
BEGIN
ALTER TABLE [dbo].[Cab_Del_Items_InUse] ADD  CONSTRAINT [DF_CDII_Created_By_Seq]  DEFAULT ((1)) FOR [CDII_Created_By_Seq]
END
End
GO

IF Not EXISTS (SELECT * FROM sys.default_constraints WHERE object_id = OBJECT_ID(N'[dbo].[DF_CDII_Modified_Dt]') AND parent_object_id = OBJECT_ID(N'[dbo].[Cab_Del_Items_InUse]'))
Begin
IF NOT EXISTS (SELECT * FROM dbo.sysobjects WHERE id = OBJECT_ID(N'[DF_CDII_Modified_Dt]') AND type = 'D')
BEGIN
ALTER TABLE [dbo].[Cab_Del_Items_InUse] ADD  CONSTRAINT [DF_CDII_Modified_Dt]  DEFAULT (getdate()) FOR [CDII_Modified_Dt]
END
End
GO

IF Not EXISTS (SELECT * FROM sys.default_constraints WHERE object_id = OBJECT_ID(N'[dbo].[DF_CDII_Modified_By_Seq]') AND parent_object_id = OBJECT_ID(N'[dbo].[Cab_Del_Items_InUse]'))
Begin
IF NOT EXISTS (SELECT * FROM dbo.sysobjects WHERE id = OBJECT_ID(N'[DF_CDII_Modified_By_Seq]') AND type = 'D')
BEGIN
ALTER TABLE [dbo].[Cab_Del_Items_InUse] ADD  CONSTRAINT [DF_CDII_Modified_By_Seq]  DEFAULT ((1)) FOR [CDII_Modified_By_Seq]
END
End
GO

IF Not EXISTS (SELECT * FROM sys.default_constraints WHERE object_id = OBJECT_ID(N'[dbo].[DF_CDII_Record_Version]') AND parent_object_id = OBJECT_ID(N'[dbo].[Cab_Del_Items_InUse]'))
Begin
IF NOT EXISTS (SELECT * FROM dbo.sysobjects WHERE id = OBJECT_ID(N'[DF_CDII_Record_Version]') AND type = 'D')
BEGIN
ALTER TABLE [dbo].[Cab_Del_Items_InUse] ADD  CONSTRAINT [DF_CDII_Record_Version]  DEFAULT ((1)) FOR [CDII_Record_Version]
END
End
GO

