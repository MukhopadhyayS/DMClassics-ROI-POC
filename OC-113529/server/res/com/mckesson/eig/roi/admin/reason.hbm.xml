<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>

<class name="com.mckesson.eig.roi.admin.model.Reason"
           table="ROI_Reason"
           dynamic-update="true"
           optimistic-lock="version" >

        <id name="id" >
            <column name="ROI_Reason_Seq" sql-type="int"/>
            <generator class="identity"/>
        </id>

        <version name="recordVersion" column="Record_Version" type="integer" />

        <property name="name" >
            <column name="Name" sql-type="varchar(60)" not-null="true" />
        </property>

        <property name="displayText" >
            <column name="DisplayText" sql-type="varchar(60)" not-null="true" />
        </property>

        <property name="status" >
            <column name="Status" sql-type="tinyint" not-null="true" />
        </property>

        <property name="type" >
            <column name="Type" sql-type="varchar(60)" not-null="true" />
        </property>

        <property name="active" >
            <column name="Active" sql-type="bit" not-null="true" />
        </property>

        <property name="tpo" >
            <column name="TPO" sql-type="bit" not-null="true" />
        </property>

        <property name="nonTpo" >
            <column name="NonTPO" sql-type="bit" not-null="true" />
        </property>

        <property name="createdBy" >
            <column name="Created_By_Seq" sql-type="int" not-null="true" />
        </property>

        <property name="modifiedBy" >
            <column name="Modified_By_Seq" sql-type="int" not-null="true" />
        </property>

        <property name="orgId" >
            <column name="Organization_Seq" sql-type="int" not-null="true" />
        </property>

        <property name="modifiedDt" >
            <column name="Modified_Dt" sql-type="smalldatetime" not-null="true" />
        </property>

     </class>

     <query name="getReasonByName">
     <![CDATA[
       SELECT r FROM com.mckesson.eig.roi.admin.model.Reason r
       WHERE r.name = ?0 AND r.type = ?1
      ]]>
    </query>

    <query name="getReasonByDispText">
     <![CDATA[
       SELECT r FROM com.mckesson.eig.roi.admin.model.Reason r
       WHERE r.displayText = ?0 AND r.type = ?1
      ]]>
    </query>

    <query name="getStatusReasonByName">
     <![CDATA[
       SELECT r FROM com.mckesson.eig.roi.admin.model.Reason r
       WHERE r.type = ?0 AND r.name = ?1 AND r.status = ?2
      ]]>
    </query>

    <query name="getStatusReasonByDispText">
     <![CDATA[
       SELECT r FROM com.mckesson.eig.roi.admin.model.Reason r
       WHERE r.type = ?0 AND r.displayText = ?1 AND r.status = ?2
      ]]>
    </query>

    <query name="retrieveAllReasonsByType">
       <![CDATA[
         select r from com.mckesson.eig.roi.admin.model.Reason r
         where r.type = ?0 order by r.name asc
       ]]>
     </query>

         <query name="retrieveAllRequestStatus">
       <![CDATA[
         select r from com.mckesson.eig.roi.admin.model.Reason r
         where r.type = ?0 order by r.status asc
       ]]>
    </query>

    <query name="getReasonsByStatus">
       <![CDATA[
         select r.name from com.mckesson.eig.roi.admin.model.Reason r
         where r.status = ?0
       ]]>
    </query>

</hibernate-mapping>
