<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>

<class name="com.mckesson.eig.roi.admin.model.AdminLoV"
           table="ROI_Reason"
           dynamic-update="true"
           optimistic-lock="version" >

        <id name="id" >
            <column name="ROI_Reason_Seq" sql-type="int"/>
            <generator class="identity"/>
        </id>

        <discriminator column="type" type="string"></discriminator>

        <version name="recordVersion" column="Record_Version" type="integer" />

        <property name="name" >
            <column name="Name" sql-type="varchar(60)" not-null="true" />
        </property>

        <property name="description" >
            <column name="DisplayText" sql-type="varchar(60)" not-null="true" />
        </property>

        <property name="status" >
            <column name="Status" sql-type="tinyint" not-null="true" />
        </property>

        <property name="active" >
            <column name="Active" sql-type="bit" not-null="true" />
        </property>

        <property name="tpo" >
            <column name="TPO" sql-type="bit" not-null="true" />
        </property>

        <property name="nonTpo" >
            <column name="NonTPO" sql-type="bit" not-null="true" />
        </property>

        <property name="createdBy" >
            <column name="Created_By_Seq" sql-type="int" not-null="true" />
        </property>

        <property name="modifiedBy" >
            <column name="Modified_By_Seq" sql-type="int" not-null="true" />
        </property>

        <property name="orgId" >
            <column name="Organization_Seq" sql-type="int" not-null="true" />
        </property>

        <property name="modifiedDt" >
            <column name="Modified_Dt" sql-type="smalldatetime" not-null="true" />
        </property>

        <subclass name="com.mckesson.eig.roi.admin.model.Note" discriminator-value="notes"></subclass>

        <subclass name="com.mckesson.eig.roi.admin.model.SSNMask" discriminator-value="ssnmask"></subclass>
     </class>

    <query name="retrieveAllNotes">
        <![CDATA[
         SELECT r.id, r.name, r.description
         FROM com.mckesson.eig.roi.admin.model.Note r
         ORDER BY r.name ASC
       ]]>
    </query>

    <query name="getNoteByName">
    <![CDATA[
      select n from com.mckesson.eig.roi.admin.model.Note n
      where n.name = ?0
    ]]>
  </query>

</hibernate-mapping>
