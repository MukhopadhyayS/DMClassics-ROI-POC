<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
 <class name="com.mckesson.eig.roi.admin.model.BillingTier"
       table="ROI_BillingTier" dynamic-update="true"
       optimistic-lock="version" >

    <id name="id" >
        <column name="ROI_BillingTier_Seq" sql-type="int"/>
        <generator class="identity"/>
    </id>

    <version name="recordVersion" column="Record_Version" type="integer" />

    <property name="name" >
        <column name="Name" sql-type="varchar(60)" not-null="true" />
    </property>

    <property name="description" >
        <column name="Description" sql-type="varchar(255)"/>
    </property>

    <property name="createdBy" >
        <column name="Created_By_Seq" sql-type="int" not-null="true"/>
    </property>

    <property name="modifiedDate" >
        <column name="Modified_Dt" sql-type="smalldatetime" not-null="true"/>
    </property>

    <property name="modifiedBy" >
        <column name="Modified_By_Seq" sql-type="int" not-null="true"/>
    </property>

    <property name="orgId" >
        <column name="Organization_Seq" sql-type="int" not-null="true"/>
    </property>

    <property name="baseCharge" >
        <column name="FlatCharge" sql-type="money" not-null="true"/>
    </property>

    <property name="active" >
        <column name="Active" sql-type="bit" not-null="true"/>
    </property>

    <property name="defaultPageCharge" >
        <column name="DefaultPageCharge" sql-type="money" not-null="true"/>
    </property>
    
    <property name="salesTax" >
        <column name="SalesTaxEnable" sql-type="char(1)" not-null="true"/>
    </property>

    <set name="pageLevelTier"  cascade="all,delete-orphan" fetch="join"
         lazy="false" order-by="page asc" >
        <key column="ROI_BillingTier_Seq" not-null="true"/>
        <one-to-many class="com.mckesson.eig.roi.admin.model.PageLevelTier" />
    </set>

  <many-to-one name="mediaType"
               class="com.mckesson.eig.roi.admin.model.MediaType"
               column="ROI_MediaType_Seq"
               lazy="false"
               fetch="join" >
  </many-to-one>

 </class>

  <query name="retrieveBillingTierAndMediaTypeName">
  <![CDATA[
    SELECT bt.id, bt.name,  bt.salesTax, mediaType.name
    FROM com.mckesson.eig.roi.admin.model.BillingTier as bt
    JOIN bt.mediaType as mediaType
    ]]>
  </query>

    <query name="retrieveBillingTierByName">
    <![CDATA[
       SELECT billingTier FROM  com.mckesson.eig.roi.admin.model.BillingTier billingTier
       WHERE billingTier.name = ?
    ]]>
  </query>

    <query name="getAssociatedRequestorTypeCountForBillingTier">
    <![CDATA[
        SELECT count(r.billingTierId) FROM com.mckesson.eig.roi.admin.model.RelatedBillingTier r
        WHERE r.billingTierId = ?
    ]]>
    </query>

  <query name="retrieveBillingTierByMediaTypeName">
  <![CDATA[
    SELECT bt.id FROM com.mckesson.eig.roi.admin.model.BillingTier bt
    WHERE bt.mediaType.name = ?
    ]]>
  </query>
  
  <query name="retrieveAllStandardBillingTiers">
  <![CDATA[
    SELECT bt FROM com.mckesson.eig.roi.admin.model.BillingTier bt
    WHERE bt.id < 0
    ]]>
  </query>
 
</hibernate-mapping>
