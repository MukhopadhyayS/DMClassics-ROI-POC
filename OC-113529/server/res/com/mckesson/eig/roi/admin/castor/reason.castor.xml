<?xml version="1.0" encoding="UTF-8"?>
<mapping xmlns:eig="urn:eig.mckesson.com">
	<class name="com.mckesson.eig.roi.admin.model.Reason">
		<map-to xml="reason" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />

		<field name="id" type="long">
			<bind-xml name="eig:id" node="element" />
		</field>

		<field name="name" type="string">
			<bind-xml name="eig:name" node="element" />
		</field>

		<field name="displayText" type="string">
			<bind-xml name="eig:displayText" node="element" />
		</field>

		<field name="type" type="string">
			<bind-xml name="eig:type" node="element" />
		</field>

		<field name="status" type="int">
			<bind-xml name="eig:status" node="element" />
		</field>

		<field name="tpo" type="boolean">
			<bind-xml name="eig:tpo" node="element" />
		</field>

		<field name="nonTpo" type="boolean">
			<bind-xml name="eig:nonTpo" node="element" />
		</field>

		<field name="recordVersion" type="int">
			<bind-xml name="eig:recordVersion" node="element" />
		</field>
	</class>

	<class name="com.mckesson.eig.roi.admin.model.ReasonsList">
		<map-to xml="reasons" ns-prefix="eig" ns-uri="urn:eig.mckesson.com" />

		<field name="reasons"
			type="com.mckesson.eig.roi.admin.model.Reason"
			collection="arraylist">
			<bind-xml name="eig:reasons" node="element" />
		</field>
	</class>

    <class name="com.mckesson.eig.roi.admin.model.Reasons">
        <map-to xml="statusReason" ns-prefix="eig" ns-uri="urn:eig.mckesson.com" />

        <field name="statusReasons" type="string" collection="arraylist">
            <bind-xml name="eig:statusReason" node="element" />
        </field>
    </class>

</mapping>
