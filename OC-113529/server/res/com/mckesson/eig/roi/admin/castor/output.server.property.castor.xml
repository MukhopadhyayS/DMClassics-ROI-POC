<?xml version="1.0" encoding="UTF-8"?>
<mapping xmlns:eig="urn:eig.mckesson.com">
    <class name="com.mckesson.eig.roi.admin.model.OutputServerProperties">
        <map-to xml="outputServerProperties" ns-prefix="eig"
            ns-uri="urn:eig.mckesson.com" />

        <field name="enabled" type="boolean">
            <bind-xml name="eig:enabled" node="element" />
        </field>

        <field name="hostName" type="string">
            <bind-xml name="eig:hostName" node="element" />
        </field>

        <field name="port" type="long">
            <bind-xml name="eig:port" node="element" />
        </field>

        <field name="protocol" type="string">
            <bind-xml name="eig:protocol" node="element" />
        </field>
    </class>
</mapping>
