<?xml version="1.0" encoding="UTF-8"?>
<mapping>
    <class name="com.mckesson.eig.roi.billing.letter.model.LetterData">
        <map-to xml="billing-doc"/>

        <field name="epnEnabled" type="boolean">
            <bind-xml name="epn-enabled" node="element" />
        </field>

        <field name="invoicePrebillDate" type="string">
            <bind-xml name="invoice-prebill-date" node="element" />
        </field>

        <field name="invoicePrebillId" type="string">
            <bind-xml name="invoice-prebill-id" node="element" />
        </field>

        <field name="requestDt" type="string">
            <bind-xml name="request-dt" node="element" />
        </field>
		
		<field name="invoiceDueDate" type="string">
            <bind-xml name="invoice-due-date" node="element" />
        </field>
		
		<field name="overwriteDueDate" type="boolean">
            <bind-xml name="overwrite-due-date" node="element" />
        </field>
		
        <field name="billingInfo" type="com.mckesson.eig.roi.billing.letter.model.BillingInfo">
            <bind-xml name="billing-info" node="element" />
        </field>

        <field name="requestor" type="com.mckesson.eig.roi.billing.letter.model.RequestorInfo">
            <bind-xml name="requestorInfo" node="element" />
        </field>

        <field name="patientsList" type="com.mckesson.eig.roi.billing.letter.model.RequestItem"
               collection="arraylist">
            <bind-xml name="requestItem" node="element" />
        </field>

        <field name="notesList" type="com.mckesson.eig.roi.billing.letter.model.Note"
               collection="arraylist">
            <bind-xml name="notes" node="element" />
        </field>

        <field name="reasonsList" type="com.mckesson.eig.roi.billing.letter.model.Note"
               collection="arraylist">
            <bind-xml name="status-reasons" node="element" />
        </field>

        <field name="requestStatus" type="string">
            <bind-xml name="request-status" node="element" />
        </field>

        <field name="requestId" type="string">
            <bind-xml name="request.id" node="element" />
        </field>

        <field name="templateName" type="string">
            <bind-xml name="lettertemplate-name" node="element" />
        </field>

        <field name="salesTaxPercentage" type="string">
            <bind-xml name="sales-tax-percentage" node="element" />
        </field>

        <field name="outputMethod" type="string">
            <bind-xml name="output-method" node="element" />
        </field>

        <field name="queuePassword" type="string">
            <bind-xml name="queue-password" node="element" />
        </field>

        <field name="requestBalanceDue" type="string">
            <bind-xml name="request-balance-due" node="element" />
        </field>

        <field name="requestOriginalBalance" type="string">
            <bind-xml name="request-original-balance" node="element" />
        </field>

        <field name="requestPaymentAmount" type="string">
            <bind-xml name="request-payment-amount" node="element" />
        </field>

        <field name="requestCreditAmount" type="string">
            <bind-xml name="request-credit-amount" node="element" />
        </field>

        <field name="requestDebitAmount" type="string">
            <bind-xml name="request-debit-amount" node="element" />
        </field>

        <field name="requestSalesTax" type="string">
            <bind-xml name="request-sales-tax" node="element" />
        </field>

    </class>

    <class name="com.mckesson.eig.roi.billing.letter.model.BillingInfo">
        <map-to xml="billing-info"/>

        <field name="charges" type="com.mckesson.eig.roi.billing.letter.model.Charge"
               collection="arraylist">
            <bind-xml name="charges" node="element" />
        </field>

        <field name="shippingInfo" type="com.mckesson.eig.roi.billing.letter.model.ShippingInfo">
            <bind-xml name="shipping-info" node="element" />
        </field>

    </class>

    <class name="com.mckesson.eig.roi.billing.letter.model.Charge">
        <map-to xml="charges"/>

        <field name="name" type="string">
            <bind-xml name="name" node="element" />
        </field>

        <field name="chargeTotal" type="string">
            <bind-xml name="charge-total" node="element" />
        </field>

        <field name="chargeItems" type="com.mckesson.eig.roi.billing.letter.model.ChargeItem"
               collection="arraylist">
            <bind-xml name="child-item" node="element" />
        </field>

        <field name="docCharge" type="com.mckesson.eig.roi.billing.letter.model.Charge"
               collection="arraylist">
            <bind-xml name="DocumentCharge" node="element" />
        </field>

        <field name="feeCharge" type="com.mckesson.eig.roi.billing.letter.model.Charge"
               collection="arraylist">
            <bind-xml name="FeeCharge" node="element" />
        </field>

        <field name="txns" type="com.mckesson.eig.roi.billing.letter.model.Charge"
               collection="arraylist">
            <bind-xml name="request-transaction" node="element" />
        </field>

        <field name="releases" type="com.mckesson.eig.roi.billing.letter.model.ReleaseInfo"
               collection="arraylist">
            <bind-xml name="release-info" node="element" />
        </field>

        <field name="shippingCharge" type="com.mckesson.eig.roi.billing.letter.model.Charge"
               collection="arraylist">
            <bind-xml name="shipping-charge" node="element" />
        </field>

        <field name="creditAdjustmentTotal" type="string">
            <bind-xml name="credit-adjustment-total" node="element" />
        </field>

        <field name="debitAdjustmentTotal" type="string">
            <bind-xml name="debit-adjustment-total" node="element" />
        </field>

        <field name="paymentTotal" type="string">
            <bind-xml name="payment-total" node="element" />
        </field>

        <field name="adjustmentPaymentTotal" type="string">
            <bind-xml name="adjustment-payment-total" node="element" />
        </field>

        <field name="taxableAmount" type="string">
            <bind-xml name="taxable-amt" node="element" />
        </field>

        <field name="nonTaxableAmount" type="string">
            <bind-xml name="non-tax-amt" node="element" />
        </field>

        <field name="taxCharge" type="string">
            <bind-xml name="tax-charge" node="element" />
        </field>

        <field name="pages" type="string">
            <bind-xml name="pages" node="element" />
        </field>

        <field name="copies" type="string">
            <bind-xml name="copies" node="element" />
        </field>

        <field name="documentChargeTotal" type="string">
            <bind-xml name="document-charge-total" node="element" />
        </field>

        <field name="documentChargeTaxTotal" type="string">
            <bind-xml name="document-charge-salestax-total" node="element" />
        </field>
        
        <field name="feeChargeTotal" type="string">
            <bind-xml name="fee-charge-total" node="element" />
        </field>

        <field name="feeChargeTaxTotal" type="string">
            <bind-xml name="fee-charge-salestax-total" node="element" />
        </field>

        <field name="customFeeChargeTaxTotal" type="string">
            <bind-xml name="customfee-charge-salestax-total" node="element" />
        </field>
        
        <field name="invoices" type="com.mckesson.eig.roi.billing.letter.model.InvoiceCharge">
            <bind-xml name="invoice-info" node="element" />
        </field>

    </class>

    <class name="com.mckesson.eig.roi.billing.letter.model.ChargeItem">
        <map-to xml="child-item"/>

        <field name="name" type="string">
            <bind-xml name="name" node="element" />
        </field>

        <field name="amount" type="string">
            <bind-xml name="amount" node="element" />
        </field>

        <field name="pages" type="string">
            <bind-xml name="pages" node="element" />
        </field>

        <field name="billingTierName" type="string">
            <bind-xml name="billingtier-name" node="element" />
        </field>

        <field name="billingTierId" type="string">
            <bind-xml name="billingtier-id" node="element" />
        </field>

        <field name="copies" type="string">
            <bind-xml name="copies" node="element" />
        </field>

        <field name="type" type="string">
            <bind-xml name="type" node="element" />
        </field>

        <field name="date" type="string">
            <bind-xml name="date" node="element" />
        </field>

        <field name="description" type="string">
            <bind-xml name="description" node="element" />
        </field>

        <field name="paymentMode" type="string">
            <bind-xml name="payment-mode" node="element" />
        </field>

        <field name="transactionType" type="string">
            <bind-xml name="transaction-type" node="element" />
        </field>

        <field name="debt" type="string">
            <bind-xml name="is-debit" node="element" />
        </field>

        <field name="feeType" type="string">
            <bind-xml name="feetype" node="element" />
        </field>
    </class>

    <class name="com.mckesson.eig.roi.billing.letter.model.ShippingInfo">
        <map-to xml="shipping-info"/>

        <field name="address1" type="string">
            <bind-xml name="address1" node="element" />
        </field>

        <field name="address2" type="string">
            <bind-xml name="address2" node="element" />
        </field>

        <field name="address3" type="string">
            <bind-xml name="address3" node="element" />
        </field>

        <field name="city" type="string">
            <bind-xml name="city" node="element" />
        </field>

        <field name="state" type="string">
            <bind-xml name="state" node="element" />
        </field>

        <field name="postalCode" type="string">
            <bind-xml name="postalcode" node="element" />
        </field>

        <field name="shippingURL" type="string">
            <bind-xml name="shipping-url" node="element" />
        </field>

        <field name="trackingNumber" type="string">
            <bind-xml name="tracking-number" node="element" />
        </field>

        <field name="willReleaseShipped" type="string">
            <bind-xml name="will-release-shipped" node="element" />
        </field>

        <field name="shippingWt" type="string">
            <bind-xml name="shipping-weight" node="element" />
        </field>

        <field name="addressType" type="string">
            <bind-xml name="address-type" node="element" />
        </field>

        <field name="shippingMethod" type="string">
            <bind-xml name="shipping-method" node="element" />
        </field>

        <field name="shippingMethodId" type="string">
            <bind-xml name="shipping-method-id" node="element" />
        </field>

        <field name="outputMethod" type="string">
            <bind-xml name="output-method" node="element" />
        </field>

    </class>

    <class name="com.mckesson.eig.roi.billing.letter.model.RequestorInfo">
        <map-to xml="requestorInfo"/>

        <field name="id" type="string">
            <bind-xml name="requestorid" node="element" />
        </field>

        <field name="name" type="string">
            <bind-xml name="requestorname" node="element" />
        </field>

        <field name="type" type="string">
            <bind-xml name="requestortypename" node="element" />
        </field>

        <field name="phone" type="string">
            <bind-xml name="requestorphone" node="element" />
        </field>

    </class>

    <class name="com.mckesson.eig.roi.billing.letter.model.RequestItem">
        <map-to xml="requestItem"/>

        <field name="name" type="string">
            <bind-xml name="patientname" node="element" />
        </field>

        <field name="epn" type="string">
            <bind-xml name="patientepn" node="element" />
        </field>

        <field name="mrn" type="string">
            <bind-xml name="patientmrn" node="element" />
        </field>

        <field name="ssn" type="string">
            <bind-xml name="patientssn" node="element" />
        </field>

        <field name="facility" type="string">
            <bind-xml name="facility" node="element" />
        </field>

        <field name="encounterFacility" type="string">
            <bind-xml name="encounterfacility" node="element" />
        </field>

        <field name="requestItems" type="com.mckesson.eig.roi.billing.letter.model.RequestItem"
               collection="arraylist">
            <bind-xml name="child-item" node="element" />
        </field>
    </class>

    <class name="com.mckesson.eig.roi.billing.letter.model.ReleaseInfo">
        <map-to xml="release-info"/>

        <field name="totPages" type="string">
            <bind-xml name="total-pages" node="element" />
        </field>

        <field name="releaseCost" type="string">
            <bind-xml name="release-cost" node="element" />
        </field>

        <field name="releaseDt" type="string">
            <bind-xml name="release-date" node="element" />
        </field>

        <field name="previouslyReleasedCost" type="string">
            <bind-xml name="previously-released-cost" node="element" />
        </field>

        <field name="balanceDue" type="string">
            <bind-xml name="balance-due" node="element" />
        </field>

        <field name="totalCost" type="string">
            <bind-xml name="total-request-cost" node="element" />
        </field>

        <field name="totalPagesReleased" type="string">
            <bind-xml name="total-pages-released" node="element" />
        </field>

    </class>

    <class name="com.mckesson.eig.roi.billing.letter.model.Note">
        <map-to xml="notes"/>

        <field name="description" type="string">
            <bind-xml name="description" node="element" />
        </field>

        <field name="childItems" type="com.mckesson.eig.roi.billing.letter.model.Note"
               collection="arraylist">
            <bind-xml name="child-item" node="element" />
        </field>
    </class>
    
     <class name="com.mckesson.eig.roi.billing.letter.model.InvoiceCharge">
        <map-to xml="invoice-info"/>

        <field name="invoiceId" type="string" >
            <bind-xml name="inv-id" node="element" />
        </field>

        <field name="invoiceBillingLocation" type="string" >
            <bind-xml name="inv-billing-loc-name" node="element" />
        </field>

        <field name="invoiceDate" type="string" >
            <bind-xml name="inv-date" node="element" />
        </field>
        
        <field name="baseCharge" type="string" >
            <bind-xml name="base-charge" node="element" />
        </field>
       
        <field name="amountPaid" type="string" >
            <bind-xml name="amount-paid" node="element" />
        </field>
       
        <field name="invoiceBalanceDue" type="string" >
            <bind-xml name="inv-balance-due" node="element" />
        </field>
      
        <field name="invoiceSalesTax" type="string" >
            <bind-xml name="inv-sales-tax" node="element" />
        </field>
               
        <field name="requestId" type="string" >
            <bind-xml name="request.id" node="element" />
        </field>
      
        <field name="overDueDays" type="string" >
            <bind-xml name="inv-overdue-days" node="element" />
        </field>

    </class>
    
    <class name="com.mckesson.eig.roi.billing.letter.model.RequestorLetters">
        <map-to xml="requestor-letter"/>

		 <field name="shippingInfo" type="com.mckesson.eig.roi.billing.letter.model.ShippingInfo">
            <bind-xml name="shipping-info" node="element" />
        </field>
        
        <field name="queuePassword" type="string">
            <bind-xml name="queue-password" node="element" />
        </field>
        
        <field name="requestor" type="com.mckesson.eig.roi.billing.letter.model.RequestorInfo">
            <bind-xml name="requestorInfo" node="element" />
        </field>

        <field name="invoices" type="com.mckesson.eig.roi.billing.letter.model.InvoiceCharge"
               collection="arraylist">
            <bind-xml name="invoice-info" location="invoices" node="element" />
        </field>

        <field name="notesList" type="string" collection="arraylist">
            <bind-xml name="description" location="notes/child-item" node="element" />
        </field>
    </class>

</mapping>