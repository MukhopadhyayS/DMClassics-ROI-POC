<!-- START SNIPPET: xbean -->
<beans xmlns="http://activemq.org/config/1.0">

  <bean xmlns="" id="datasource" class="org.apache.commons.dbcp.BasicDataSource" destroy-method="close">
    <property name="driverClassName" value="net.sourceforge.jtds.jdbc.Driver"/>
    <property name="url" value="jdbc:jtds:sqlserver://eigqc235:1433;DatabaseName=cabinet"/>
    <property name="username" value="roi"/>
    <property name="password" value="roipazz"/>
    <property name="poolPreparedStatements" value="true"/>
    <property name="initialSize" value="5"/>
    <property name="maxActive" value="15"/>
    <property name="maxIdle" value="10"/>
    <property name="minIdle" value="5"/>
    <property name="minEvictableIdleTimeMillis" value="60000"/>
    <property name="validationQuery" value="select getdate()"/>
  </bean>

  <broker useJmx="true">

	<!-- In ActiveMQ 4, you can setup destination policies. note: this xml format may still change a bit -->
    <destinationPolicy>
      <policyMap><policyEntries>

          <policyEntry queue="queue.eigAudit">
            <deadLetterStrategy>
		      <sharedDeadLetterStrategy>
			    <deadLetterQueue>
			      <queue name="queue/eigDLQ" physicalName="queue.eigDLQ"/>
		        </deadLetterQueue>
		      </sharedDeadLetterStrategy>
	        </deadLetterStrategy>
            <dispatchPolicy>
              <strictOrderDispatchPolicy />
            </dispatchPolicy>
            <subscriptionRecoveryPolicy>
              <lastImageSubscriptionRecoveryPolicy />
            </subscriptionRecoveryPolicy>
          </policyEntry>

      </policyEntries></policyMap>
    </destinationPolicy>

    <persistenceAdapter>
        <jdbcPersistenceAdapter dataSource="#datasource" useDatabaseLock="false" >
        </jdbcPersistenceAdapter >
    </persistenceAdapter>

<!-- Commented for issue in journaling in ActiveMQ to be resolved in 5.3 version
    <persistenceAdapter>
			<journaledJDBC
				journalLogFiles="5"
				dataDirectory="activemq-data"
				dataSource="#datasource"
				useDatabaseLock="false" > -->
<!-- For SQLServer <adapter><imageBasedJDBCAdaptor/></adapter> -->
	 <!-- 		</journaledJDBC>
		</persistenceAdapter> -->

    <transportConnectors>
      <!-- prefixing a connector with discovery: causes the connector to be advertiesed over rendezvous -->
      <transportConnector uri="tcp://localhost:61616" discoveryUri="multicast://default"/>
    </transportConnectors>

  </broker>


</beans>
