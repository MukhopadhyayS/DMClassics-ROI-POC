  <!-- **********************************************************************
		*   Check in file(s)
		*
		*	To avoid future issues and help understand exactly what it does, 
		*	attributes are specifically defined even though it matches with 
		*	the default value.
		********************************************************************** -->
  <target name="checkin">
    <exec dir="${starteam.cp.client.dir}" executable="${starteam.cp.client.dir}/stcmd" failonerror="true">
      <arg value="ci"/>
      <arg value="-p"/>
      <arg value="${starteam.username}:${starteam.password}@${starteam.servername}:${starteam.serverport}/${starteam.projectname}/${starteam.viewname}/${starteam.branch.path}/${starteam.file.path}" />
      <arg value="-u"/>
      <arg value="-r" />
      <arg value="&quot;${starteam.checkin.comment}.&quot;" />
      <arg value="${starteam.file.name}"/>
    </exec>
  </target>

