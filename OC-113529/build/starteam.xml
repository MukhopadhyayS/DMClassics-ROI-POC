  <!-- **********************************************************************
		*   Label the source
		*
		*	To avoid future issues and help understand exactly what it does, 
		*	attributes are specifically defined even though it matches with 
		*	the default value.
		********************************************************************** -->
  <target name="label" >
    <tstamp>
      <format property="nowstamp" pattern="yyyyMMddhhmmss" locale="en"/>
    </tstamp>
    <echo message="Labeling SourceSafe = [${starteam.label}]" />
    <!--<stlabel 
					servername="${starteam.servername}" 
					serverport="${starteam.serverport}"
					projectname="${starteam.projectname}" 
					viewname="${starteam.viewname}"
					username="${starteam.username}"
					password="${starteam.password}"
					lastbuild="${nowstamp}"
					description="${starteam.label.description}"
					revisionlabel="${starteam.revisionlabel}"
					buildlabel="${starteam.buildlabel}"
					label="${starteam.label}"
			/>-->
    <echo message="Labeling SourceSafe Completed." />
  </target>


  <!-- **********************************************************************
		*   Add the source
		*
		********************************************************************** -->
  <target name="add">
    <antcall target="checkin">
      <property name="starteam.checkin.comment" value="Added by automatic build"/>
    </antcall>
  </target>

		<!-- **********************************************************************
		*   Label the source using stcmd utility
		*
		********************************************************************** -->
	<target name="label-stcmd">
		<exec dir="${starteam.cp.client.dir}" executable="${starteam.cp.client.dir}/stcmd" failonerror="true">
			<arg value="label"/>
			<arg value="-p"/>
			<arg value="${starteam.username}:${starteam.password}@${starteam.servername}:${starteam.serverport}/${starteam.projectname}/${starteam.viewname}/${starteam.branch.path}/${starteam.file.path}" />
			<arg value="-nl" />
			<arg value="${starteam.label}" />
			<arg value="-b"/>	  
		</exec>
  </target>

  <target name="checkin-label">
    <echo message="${starteam.cp.client.dir}/stcmd ci -p ${starteam.username}:${starteam.password}@${starteam.servername}:${starteam.serverport}/${starteam.viewname}/${starteam.branch.path}/${starteam.file.path} -nologo -x -o -fp &quot;${starteam.local.file.path}&quot; -vl &quot;${starteam.label}&quot; -r &quot;Nightly Build Generated File.&quot;"/>

    <exec dir="${starteam.cp.client.dir}" executable="${starteam.cp.client.dir}/stcmd" failonerror="true">
      <arg value="ci"/>
      <arg value="-p"/>
      <arg value="${starteam.username}:${starteam.password}@${starteam.servername}:${starteam.serverport}/${starteam.projectname}/${starteam.viewname}/${starteam.branch.path}/${starteam.file.path}" />
      <arg value="-x" />
      <arg value="-o" />
      <arg value="-fp" />
      <arg value="&quot;${starteam.local.file.path}&quot;" />
      <arg value="-vl" />
      <arg value="&quot;${starteam.label}&quot;" />
      <arg value="-r" />
      <arg value="&quot;Nightly Build Generated File.&quot;" />
      <arg value="${starteam.file.to.check.in}"/>
    </exec>
  </target>
</project>