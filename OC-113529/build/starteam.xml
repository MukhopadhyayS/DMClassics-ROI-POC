  <!-- **********************************************************************
	*   Gets the source from StarTeam with a given label
	*
	*	To avoid future issues and help understand exactly what it does, 
	*	attributes are specifically defined even though it matches with 
	*	the default value.
	********************************************************************** -->
	
	<target name="get-with-label">
		<exec executable="${starteam.cp.client.dir}/bco.bat">
			<arg line="-p '${starteam.username}:${starteam.password}@${starteam.servername}:${starteam.serverport}/${starteam.projectname}/${starteam.viewname}/${starteam.branch.path}/${starteam.file.path}' -useca starteamapp:49260 -cfgl ${starteam.label} -is -vb -cmp -cwf -o -t" />
		</exec>
  </target>

