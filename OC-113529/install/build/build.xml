<project default="build-installs" basedir="../">
	
	<property name="dir.src" value="../" />
	<property file="../build/props/${build.config.file.name}" />
	<property file="../build/props/base.properties" />
	<property file="../build/version.txt" />

	<property name="dir.src.build" value="${dir.src}/build" />

    <taskdef resource="net/sf/antcontrib/antcontrib.properties" />

	<!-- **********************************************************************
             *  Target : Building Server & Client Installs
             *  target to do all the installs build activities in sequence
         ********************************************************************** -->

		<target name="build-installs">
			<echo message="**** Started Building server and client installs*****" />

			<!-- builds client click once installation -->
			<ant antfile="${basedir}/build/build.client.install.xml" target="build-client-install"/>
			<!-- builds ROI Config util -->
			<!--ant antfile="${basedir}/roi.config.util/build/build.xml" target="build">
			    <property name="basedir" value="${basedir}/roi.config.util" />
			</ant-->
			<!-- builds server installation -->
			<ant antfile="${basedir}/build/build.server.install.xml" target="build-server-install"/>

		</target>

</project>
