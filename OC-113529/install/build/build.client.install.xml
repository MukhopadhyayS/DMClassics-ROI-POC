<project default="build-client-install" basedir="../">

	<property file="../build/props/${build.config.file.name}" />
	<property file="../build/props/base.properties" />

	<property file="../build/version.txt" />

	<property environment="env" />

	<property name="dir.src" value="../" />
    <property name="appName" value="McK.EIG.ROI.Client.App" />
	<property name="dir.client" value="${dir.src}/client" />
	<property name="dir.client.app" value="${dir.src}/${dir.client}/${appName}"/>
	<property file="${dir.build}/version.txt" />
	    	
    <!-- Copies to the install area -->
	<property name="dir.install.files" value="${basedir}/bin/MPFServer/webapps/ROOT/ROIClient" />
	<property name="dir.bin" value="${dir.client.app}/bin" />
	<property name="PublishDir" value="${jboss.home}/server/default/deploy/ROOT.war/ROIClient/" />

	<target name="build-client-install" description="Creates the ClickOnce install files for the ROI Client" >
		<echo message="dir.client.app = ${dir.client.app}" />
		<antcall target="update-setup-exe" />
		<antcall target="publish-client"/>
		<antcall target="copy-dependent-dll-to-publish-dir"/>
        <!--antcall target="clear-applicattion-files" />
        <antcall target="copy-to-web-server-area" /-->
	</target>
	
	 <target name = "copy-dependent-dll-to-publish-dir">
		<property name="publish-directory" value="${dir.install.files}\Application Files\McK.EIG.ROI.Client.App_${build.major}_${build.minor}_${build.servicePack}_${build.number}" />
		<property name="3rdparty-lib-dir" value="${dir.src}/${dir.client}\3rdparty\lib" />
		<echo message="Copying dependent dll From ${3rdparty-lib-dir} to ${publish-directory}" />
		<copy todir="${publish-directory}" failonerror="true" overwrite="true">
			<fileset dir="${3rdparty-lib-dir}">
        		<include name="log4net.dll"/>
        		<include name="McKesson.Capture.Common.dll"/>
			<include name="McKesson.Capture.Model.dll"/>
			<include name="McKesson.Capture.Utility.dll"/>
			<include name="McKesson.EIG.WinDSS.dll"/>
			<include name="EIG_Logging.dll"/>
			<include name="McKesson.EIG.WebService.dll"/>
        		<include name="interop.EPRSCryptography.dll"/>
        	</fileset>
		</copy>
    </target>

	<target name="publish-client">
		<property name="ApplicationRevision" Value="${build.number}" />
		<property name="executable" value="msbuild.exe" />
		<property name="startDir" value="${dir.client.app}" />

		<property name="cmdLine" value='/t:publish /p:PublishUrl="${dir.install.files}",InstallUrl="http://${env.COMPUTERNAME}:8080/ROIClient/",PublishDir="${dir.install.files}\",MinimumRequiredVersion="${build.major}.${build.minor}.${build.servicePack}.${build.number}",ApplicationVersion="${build.major}.${build.minor}.${build.servicePack}.${build.number}",PostBuildEvent=""'/>
		<echo message='Command line parameters=${cmdLine}'/>
		<exec
			executable="${executable}"
			dir="${dir.client.app}"
			resolveexecutable="true"
			searchpath="true"
			resultproperty="result.property"
		    >
		<arg line="${cmdLine}"/>
		<env key="VSINSTALLDIR" value="C:\Program Files\Microsoft Visual Studio 10.0" />
		<env key="VCINSTALLDIR" value="${env.VSINSTALLDIR}\VC" />
		<env key="FrameworkDir" value="C:\WINDOWS\Microsoft.NET\Framework" />
		<env key="FrameworkVersion" value="v3.5" />
		<env key="FrameworkSDKDir" value="${env.VSINSTALLDIR}\SDK\v3.5" />
		<env key="DevEnvDir" value="${env.VSINSTALLDIR}\Common7\IDE" />
		<env key="PATH" value="${env.VSINSTALLDIR}\Common7\IDE;${env.VSINSTALLDIR}\VC\BIN;${env.VSINSTALLDIR}\Common7\Tools;${env.VSINSTALLDIR}\Common7\Tools\bin;${env.VSINSTALLDIR}\VC\PlatformSDK\bin;${env.VSINSTALLDIR}\SDK\v2.0\bin;C:\WINDOWS\Microsoft.NET\Framework\v4.0.30319;${env.VSINSTALLDIR}\VC\VCPackages;%PATH%" />
		<env key="INCLUDE" value="${env.VSINSTALLDIR}\VC\ATLMFC\INCLUDE;${env.VSINSTALLDIR}\VC\INCLUDE;${env.VSINSTALLDIR}\VC\PlatformSDK\include;${env.VSINSTALLDIR}\SDK\v2.0\include;%INCLUDE%" />
		<env key="LIB" value="${env.VSINSTALLDIR}\VC\ATLMFC\LIB;${env.VSINSTALLDIR}\VC\LIB;${env.VSINSTALLDIR}\VC\PlatformSDK\lib;${env.VSINSTALLDIR}\SDK\v2.0\lib;%LIB%" />
		<env key="LIBPATH" value="C:\WINDOWS\Microsoft.NET\Framework\v3.5;${env.VSINSTALLDIR}\VC\ATLMFC\LIB" />

		</exec>
	</target>

    <!-- Update the setup.exe -->
    <target name = "update-setup-exe">
	<copy file ="${dir.install.files}\setup.exe" tofile="${dir.install.files}\temp.exe" failonerror="false" />
    <property name="executable" value="temp.exe"/>
        <property name="cmdLine" value='"-url=http://${env.COMPUTERNAME}:8080/ROIClient/" /dest=setup.exe /hide_progress'/>
        <exec executable="${executable}"
              dir ="${dir.install.files}"
              resolveexecutable="true"
              searchpath="true">
        <arg line="${cmdLine}"/>
        </exec>
    </target>

    <!-- Clears click once fils in jboss web directiry.  -->
    <target name="clear-applicattion-files">
        <delete failonerror="false">
        	<fileset dir="${PublishDir}">
        		<exclude name="Help/**"/>
        	</fileset>
    	</delete>
        <delete file="${dir.install.files}/${appName}.application" failonerror="false"  verbose="true"/>
         <exec executable="cmd"
              dir ="${dir.install.files}"
              searchpath="true">
               <arg value="/c"/>
               <arg value="${dir.install.files}/ClearAppFiles.bat"/>
               <arg value="-p"/>
       </exec>
    </target>

    <!-- Copy prerequisite, setup.exe files web server area  -->
    <target name="copy-to-web-server-area">

		<delete file = "${dir.install.files}\temp.exe" failonerror="false" />
    	<antcall target="clean-folder">
            <param name="dir.to.clean" value="${dir.install.files}/Help" />
    		<param name="exclude.name" value="" />
        </antcall>
        <copy todir="${dir.install.files}/Help" failonerror="true" verbose="true">
        	<fileset dir="${dir.src}/Help" >
    			<exclude name="Documentation/**" />
	       	</fileset>
        </copy>

    	<antcall target="clean-folder">
            <param name="dir.to.clean" value="${PublishDir}" />
    		<param name="exclude.name" value="Help/**" />
        </antcall>
        <copy todir="${PublishDir}" failonerror="false" verbose="true">
          <fileset dir="${dir.install.files}">
          	<exclude name="Help/**" />
      	  </fileset>
        </copy>

    </target>

	 <!-- **********************************************************************
	             *  Target : clean-folder
	             *  target to to clean a specified directory
	             ********************************************************************** -->
    <target name="clean-folder">
        <echo message="Cleaning... ${dir.to.clean}" />
        <delete failonerror="false" includeemptydirs="true">
            <fileset dir="${dir.to.clean}" defaultexcludes="yes" includes="**/*">
            	<exclude name="${exclude.name}" />
            </fileset>
        </delete>
    </target>
 </project>