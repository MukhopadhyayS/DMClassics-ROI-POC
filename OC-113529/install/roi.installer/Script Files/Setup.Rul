//////////////////////////////////////////////////////////////////////////////
// OnFirstUIBefore
//
// First Install UI Sequence - Before Move Data
//
// The OnFirstUIBefore event is called by OnShowUI when the setup is
// running in first install mode. By default this event displays UI allowing
// the end user to specify installation parameters.
//
// Note: This event will not be called automatically in a
// program...endprogram style setup.
//////////////////////////////////////////////////////////////////////////////

function OnFirstUIBefore()
    number  nResult, nLevel, nSize, nSetupType;
    string  szTitle, szMsg, szOpt1, szOpt2, szLicenseFile;
    string  szName, szCompany, szTargetPath, szDir, szFeatures;
    BOOL    bLicenseAccepted;
    string memory,opSys, memoryValue, osValue, spValue, svString;
    number nMemory, nOpSys;
	STRING  defJbossPath, existingJboss, newJboss;
	NUMBER nNewJboss, nExistingJboss, nValue, nvJava32;

begin
	Enable(FULLWINDOWMODE);
	Enable(BACKGROUND);
	SetColor(BACKGROUND,BK_BLUE);
    nSetupType = COMPLETE;
    szDir = TARGETDIR;
    szName = "";
    szCompany = "McKesson";
    bLicenseAccepted = FALSE;
	nNewJboss = TRUE;
	nExistingJboss = FALSE;
	jbossPath = TARGETDIR ^ "\jboss";
	FeatureSetTarget(MEDIA, "<JBOSS_HOME>", jbossPath);

// Beginning of UI Sequence
Dlg_Start:
    nResult = 0;

Dlg_SdWelcome:
	szTitle = GetValueFromStringTable("ID_WELCOME_TITLE");
	szMsg = GetValueFromStringTable("ID_WELCOME_MSG");
    nResult = SdWelcome(szTitle, szMsg);
    if (nResult = BACK) goto Dlg_Start;

Dlg_SdLicense2:
    szTitle = "";
    szOpt1 = "";
    szOpt2 = "";
    szLicenseFile = LICENSE_FILE;
    nResult = SdLicense2Rtf(szTitle, szOpt1, szOpt2, szLicenseFile, bLicenseAccepted);
    if (nResult = BACK) then
        goto Dlg_SdWelcome;
    else
        bLicenseAccepted = TRUE;
    endif;

Dlg_SdRegisterUser:
    szMsg = "";
    szTitle = "";
    nResult = SdRegisterUser(szTitle, szMsg, szName, szCompany);
    if (nResult = BACK) goto Dlg_SdLicense2;
    LogMessage("User Information - User Name : " + szName + ", Company Name : " + szCompany);

Dlg_SdAskDestPath2:
	szTitle = "";
    szMsg = "";
	nResult = SdAskDestPath2(szTitle, szMsg, szDir);
    if (CreateDir (szDir) = 0) then
     	LogMessage("Destination For ROI Folder is created " + szDir);
     	//MessageBox ("Destination For ROI Folder is created " , WARNING);
    else 
     	MessageBox ("Choose a valid Path" , WARNING); 
     	goto Dlg_SdAskDestPath2;
    endif;
 
    TARGETDIR = szDir;
    jbossPath = TARGETDIR ^ "\jboss";
    outputJbossPath = TARGETDIR ^ "\output.jboss";
    FeatureSetTarget(MEDIA, "<JBOSS_HOME>", jbossPath);
    FeatureSetTarget(MEDIA, "<OUTPUT_JBOSS_HOME>", outputJbossPath);
    CreateLogFolder();
    if (nResult = BACK) goto Dlg_SdRegisterUser;
    LogMessage("Install Dir : " + szDir);
	
Dlg_NotifyPrerequisites:
	nResult = NotifyPrerequisites();
    if (nResult = BACK) goto Dlg_SdAskDestPath2;
    //ValidateSystemInfo();      
    
    szVarValue = TARGETDIR + JAVA_LOCATION;     
    if (SYSINFO.bIsWow64 != 0) then
		szVarValue = TARGETDIR + JAVA_64_BIT_LOCATION;     
	else          
		szVarValue = TARGETDIR + JAVA_LOCATION;
    endif;
    LogMessage("Install Dir : " + szDir);   
 	
	
Dlg_SetupType2:
    szTitle = "";
    szMsg = "";
    nResult = CUSTOM;
    nResult = SetupType2(szTitle, szMsg, "", nSetupType, 0);
    if (nResult = BACK) then  
    	goto Dlg_NotifyPrerequisites; 
    else
        nSetupType = nResult;
        if (nSetupType != CUSTOM) then
        	LogMessage("Selected Install type : Complete");
            szTargetPath = TARGETDIR;
            nSize = 0;
            ConfirmAtLeastOneSelection();
            FeatureCompareSizeRequired(MEDIA, szTargetPath, nSize);
            if (nSize != 0) then
                MessageBox(szSdStr_NotEnoughSpace, WARNING);
                goto Dlg_SetupType2;
            endif;
        endif;
    endif;
    if (nSetupType = CUSTOM) then
    	LogMessage("Selected Install type : Custom");
    endif;

Dlg_SdFeatureTree:
	listInfo = ListCreate(STRINGLIST);
	ListDeleteAll(listInfo);
    szTitle = "";
    szMsg = "";
    szFeatures = "";
    nLevel = 2;
    if (nSetupType = CUSTOM) then
        nResult = SdFeatureTree(szTitle, szMsg, TARGETDIR, szFeatures, nLevel);
        if (nResult = BACK) goto Dlg_SetupType2;
    endif;
    if (ConfirmAtLeastOneSelection() < 1) goto Dlg_SdFeatureTree;
    if (nSetupType != CUSTOM) goto Dlg_SdStartCopy2;
    //if (noRoiJboss) goto Dlg_SdStartCopy2;

Dlg_SdStartCopy2:
    szTitle = "";
    szMsg = "";
    nResult = ConfirmBeforeCopy();
    //if ((nResult = BACK) && (noRoiJboss)) goto Dlg_SdFeatureTree;
    if ((nResult = BACK) && (nSetupType = CUSTOM)) goto Dlg_SdFeatureTree;
    if ((nResult = BACK) && (nSetupType != CUSTOM)) goto Dlg_SetupType2;

    // Added in 11.0 - Set appropriate StatusEx static text.
    SetStatusExStaticText(SdLoadString(IDS_IFX_STATUSEX_STATICTEXT_FIRSTUI));
    return 0;
end;



////////////////////////////////////////////////////////////////////////////////
// Function : ConfirmAtLeastOneSelection()
//
// Check the FEATURE selected by user under custom selection.
// also it logs the information.
////////////////////////////////////////////////////////////////////////////////
function int ConfirmAtLeastOneSelection()
int nvInfo, featureCount, nRoiServer, nRoiClientServer;
string svInfo, countString, pathString, listOfComponentsString;
begin
		// selected feature count
		featureCount = 0;
		ListAddString(listInfo, GetValueFromStringTable("ID_INSTALLATION_PATH") + " --> "+ TARGETDIR , AFTER );
		ListAddString(listInfo," " , AFTER);
		ListAddString(listInfo, GetValueFromStringTable("ID_LIST_OF_FEATURES_TO_BE_INSTALLED") , AFTER);
		ListAddString(listInfo," " , AFTER);

        // checking whether ROIServer is selected by user or not
		FeatureGetData( MEDIA, ROIServer, FEATURE_FIELD_SELECTED, nRoiServer, svInfo );
		// if nvInfo is true mean ROIServer(ROI Server) has been selected by user
    	if nRoiServer then
	    	featureCount = featureCount + 1;
	    	NumToStr (countString, featureCount);
	    	// add selected feature into infoList.
			ListAddString(listInfo, STR_DEFTAB+STR_DEFTAB+countString+") "+ROIServer, AFTER);
			LogMessage("ROI Server - selected for installation");
		endif;

		// if nvInfo is true mean ROIClientInstallation(ROI Client Installation Server) has beeb selected by user
		FeatureGetData(MEDIA, ROIClientInstallation, FEATURE_FIELD_SELECTED, nRoiClientServer, svInfo);
    	if nRoiClientServer then
    		featureCount = featureCount + 1;
    		NumToStr(countString, featureCount);
	    	// add selected feature into infoList.
			ListAddString(listInfo, STR_DEFTAB+STR_DEFTAB+countString+") "+ROIClientInstallation, AFTER);
			LogMessage("ROI Client Installer Server - selected for installation");
		endif;

		//if (!nRoiServer && !nRoiClientServer) then
			//LogMessage("ROI Server and Client Installer Server not selected");
			//noRoiJboss = TRUE;
			//FeatureSetData(MEDIA, "Jboss", FEATURE_FIELD_SELECTED, FALSE, svInfo);
		//else
			//FeatureSetData(MEDIA, "Jboss", FEATURE_FIELD_SELECTED, TRUE, svInfo);
			//noRoiJboss = FALSE;
		//endif;

		// if nvInfo is true mean OutputService(Output Service Server) has beeb selected by user
		FeatureGetData(MEDIA, OutputService, FEATURE_FIELD_SELECTED, nvInfo, svInfo);
    	if nvInfo then
    		outputJbossPath = TARGETDIR ^ "\output.jboss";
			FeatureSetTarget(MEDIA, "<OUTPUT_JBOSS_HOME>", outputJbossPath);
    		featureCount = featureCount + 1;
    		NumToStr(countString, featureCount);
	    	// add selected feature into infoList.
			ListAddString(listInfo, STR_DEFTAB+STR_DEFTAB+countString+") "+OutputService, AFTER);
			LogMessage("Output Service Server - selected for installation");
		endif;

		// if nvInfo is true mean Fax Service(Fax Service Server) has beeb selected by user
		FeatureGetData(MEDIA, FaxService, FEATURE_FIELD_SELECTED, nvInfo, svInfo);
    	if nvInfo then
    		featureCount = featureCount + 1;
    		NumToStr(countString, featureCount);
	    	// add selected feature into infoList.
			ListAddString(listInfo, STR_DEFTAB+STR_DEFTAB+countString+") "+FaxService, AFTER);
			LogMessage("Fax Service - selected for installation");
		endif;

		// checking if feature selection count is less then 1
		if(featureCount<1) then
			LogMessage("Atleast one component should be selected");
	    	MessageBox(GetValueFromStringTable("ID_PLZ_SELECT_ONE"), INFORMATION);
		endif;

		return featureCount;
 end;


////////////////////////////////////////////////////////////////////////////////
// Function : ConfirmBeforeCopy()
//
// Creates the Installation component list & display summary screen to user
// before the actual copyof files on target system.
////////////////////////////////////////////////////////////////////////////////
function int ConfirmBeforeCopy()
   STRING  szTitle, szMsg, msgString;
   NUMBER  nvReturn;

begin
   // Create a list to hold system information.
   ListAddString(listInfo," " , AFTER );
   ListAddString(listInfo, GetValueFromStringTable("ID_CLICK_NEXT_TO_INSTALL"), AFTER);

   // Set up title and message parameters for call to SdShowInfoList.
   szTitle = GetValueFromStringTable("ID_CONFIRM_INSTALLATION");
   szMsg = GetValueFromStringTable("ID_CONFIRM_FEATURE_INSTALL");

   // Display the information.
   nvReturn = SdShowInfoList(szTitle, szMsg, listInfo);
   return nvReturn;
end;

////////////////////////////////////////////////////////////////////////////////
// Function : NotifyPrerequisites()
//
// Creates the Installation component list & display summary screen to user
// before the actual copy of files on target system.
////////////////////////////////////////////////////////////////////////////////
function number NotifyPrerequisites()
   STRING  szTitle, szMsg, msgString;
   number  nvReturn;
   LIST notificationInfo;

begin
   LogEnterMessage("NotifyPrerequisites()");
   notificationInfo = ListCreate(STRINGLIST);
   // Create a list to hold other software prerequisites information.
   ListAddString(notificationInfo," " , AFTER);
   //ListAddString(notificationInfo, GetValueFromStringTable("SYSTEM_PREREQUISITES"), AFTER);
   //ListAddString(notificationInfo," " , AFTER);
   //ListAddString(notificationInfo, STR_DEFTAB + "1. " + GetValueFromStringTable("OS_PRE_REQ"), AFTER);
   //ListAddString(notificationInfo, STR_DEFTAB + "2. " + GetValueFromStringTable("MEMORY_PRE_REQ"), AFTER);
   //ListAddString(notificationInfo," " , AFTER);
   ListAddString(notificationInfo, GetValueFromStringTable("OTHER_PRE_REQ"), AFTER);
   ListAddString(notificationInfo," " , AFTER);
   ListAddString(notificationInfo, STR_DEFTAB+"1. " + GetValueFromStringTable("HPF_DB_PRE_REQ"), AFTER);
   ListAddString(notificationInfo," " , AFTER);
   ListAddString(notificationInfo, GetValueFromStringTable("CLICK_NEXT_TO_CONTINUE"), AFTER);

   // Set up title and message parameters for call to SdShowInfoList.
   szTitle = GetValueFromStringTable("PRE_REQ_TITLE");
   szMsg = GetValueFromStringTable("PRE_REQ_MESSAGE");

   // Display the information.
   nvReturn = SdShowInfoList(szTitle, szMsg, notificationInfo);
   LogExitMessage("NotifyPrerequisites()");
   return nvReturn;
end;


////////////////////////////////////////////////////////////////////////////////
// Function : GetValueFromStringTable(identifierString)
//
//
//
////////////////////////////////////////////////////////////////////////////////
function string GetValueFromStringTable(identifierString)
   STRING  value;

begin
   LoadStringFromStringTable(identifierString, value);
   return value;
end;

//---------------------------------------------------------------------------
// OnFirstUIAfter
//
// First Install UI Sequence - After Move Data
//
// The OnFirstUIAfter event called by OnShowUI after the file transfer
// of the setup when the setup is running in first install mode. By default
// this event displays UI that informs the end user that the setup has been
// completed successfully.
//
// Note: This event will not be called automatically in a
// program...endprogram style setup.
//---------------------------------------------------------------------------
function OnFirstUIAfter()
    STRING szTitle, szMsg1, szMsg2, szOpt1, szOpt2;
    NUMBER bvOpt1, bvOpt2;
    number  nvReturn;
begin

    ShowObjWizardPages(NEXT);

    szTitle = "";
    szMsg1 = "";
    szMsg2 = "";
    szOpt1 = "";
    szOpt2 = "";
	bvOpt1   = FALSE;
    bvOpt2   = FALSE;

	nvReturn = SdFinishReboot(szTitle , szMsg1 , SYS_BOOTMACHINE , szMsg2 , 0);
	if (nvReturn == NEXT) then
		LogMessage("Not Rebooting the system");
		LaunchConfigureServerUtility();
	else
		LogMessage("Rebooting the system");
	endif;
end;

function InstallJDK()
	STRING szProgram, szCmdLine, szJavaHome;
begin                
    if(SYSINFO.bIsWow64 != 0) then  
    	FeatureSelectItem(MEDIA, "Java32bit-1.7.0", FALSE);
    	FeatureSelectItem(MEDIA, "Java64bit-1.7.0", TRUE);
    else                 
    	FeatureSelectItem(MEDIA, "Java32bit-1.7.0", TRUE);
    	FeatureSelectItem(MEDIA, "Java64bit-1.7.0", FALSE);
    endif;	
end;  

///////////////////////////////////////////////////////////////////////////////
//        Create Registry key for Jboss Server
//
///////////////////////////////////////////////////////////////////////////////
function CreateJbossRegKey()
begin
    LogEnterMessage("CreateJbossRegKey()");
    StrRemoveLastSlash(jbossPath);
    //setting the registry root for ROI Jboss server registry key.
    RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
	// Checking the existance of key in the registry.
    if(RegDBKeyExist(JBOSS_REGISTRY_STRING) < 0) then
    	// if key dosen't exists then create the key.
    	RegDBCreateKeyEx(JBOSS_REGISTRY_STRING, "");
    	LogMessage("Jboss reg Key Created Successfully");
    else
    	LogMessage("Jboss reg Key already exists");
    endif ;

    // add value to registry key
    LogMessage("Key -> " + JBOSS_REG_KEY);
    if (RegDBSetKeyValueEx(JBOSS_REGISTRY_STRING, JBOSS_REG_KEY, REGDB_STRING, jbossPath, -1) == 0) then
    	LogMessage("Key Value has been added successfully: " + jbossPath);
    else
    	LogMessage("Unable to add Key Value");
    endif;
   	LogExitMessage("CreateJbossRegKey()");

end;

///////////////////////////////////////////////////////////////////////////////
//  		Modify JBOSS roi.run.bat File.
//
///////////////////////////////////////////////////////////////////////////////
 function ModifyJbossFile()
 string svAddStr,svAddStr1,szFileName,svValue, szPath, szKey, szFileName1;
 string szSearchStr0,szSearchStr1,szSearchStr2, szSearchStr3, svReturnLine, svInfo, svReturnLine1;
 number nvLineNumber, nvSize, nvType, roiInfo, outputInfo, nvLineNumber1;
 begin
    LogEnterMessage("ModifyJbossFile");     
   	svValue = GetRegValue(JBOSS_REGISTRY_STRING, JBOSS_REG_KEY, "");
   	szFileName = svValue + JBOSS_BAT_FILE_PATH;
   	svAddStr=";" + svValue + CONFIG_FILES_PATH;
	svAddStr1 = SET_JAVA_HOME + szVarValue;
	szSearchStr0 = JAVA_HOME_SEARCH_STR;
	szSearchStr1 = JBOSS_CLASSPATH_SEARCH_STR1;
	szSearchStr3 = OO_START_UP;
		//Modifying JBOSS_HOME in roi.run.bat (JBOSS)
	if((svValue != ""))  then

		// checking whether ROIServer is selected by user or not
		FeatureGetData(MEDIA, ROIServer, FEATURE_FIELD_SELECTED, roiInfo, svInfo );
		FeatureGetData(MEDIA, OutputService, FEATURE_FIELD_SELECTED, outputInfo, svInfo);

		if (!roiInfo) then

        	// finding open office start up
        	FileGrep(szFileName, szSearchStr3, svReturnLine, nvLineNumber, RESTART );

	    	FileDeleteLine(szFileName, nvLineNumber, nvLineNumber );
		endif;

    	// Trying to set JAVA_HOME setting.
    	LogMessage("Setting JAVA_HOME in roi.run.bat");   
    	// checks the roi.run.bat, if java home is laready set
    	if (FileGrep(szFileName, SET_JAVA_HOME, svReturnLine, nvLineNumber, RESTART) < 0) then
    		FileGrep(szFileName, szSearchStr0, svReturnLine, nvLineNumber, RESTART);
    		FileInsertLine(szFileName, svAddStr1, nvLineNumber, BEFORE);     
    	else
    		FileInsertLine(szFileName, svAddStr1, nvLineNumber, REPLACE);     
    	endif; 
    		
	   	// finding JBOSS_CLASSPATH inside roi.run.bat of JBOSS
    	LogMessage("Setting JBOSS_CLASSPATH in roi.run.bat");
		FileGrep(szFileName, szSearchStr1, svReturnLine, nvLineNumber, RESTART );

		// Delete the specific line where pattern was found first
    	FileDeleteLine(szFileName, nvLineNumber, nvLineNumber);

    	//Insert Modified entry to deleted line number
    	FileInsertLine(szFileName, szSearchStr1+svAddStr, nvLineNumber, BEFORE);
       	LogMessage("roi.run.bat modified");
		endif;

   	LogExitMessage("Finished ModifyingJbossFile");
 end;

///////////////////////////////////////////////////////////////////////////////
//  		Modify ROI JBOSS shutdown.bat File.
//
///////////////////////////////////////////////////////////////////////////////
 function ModifyJbossShutdownBatFile()
 string svAddStr,szFileName,svValue;
 string szSearchStr0, svReturnLine, svInfo, svReturnLine1;
 number nvLineNumber;
 begin
    LogEnterMessage("Modify Jboss ShutDown.Bat File");     
   	svValue = GetRegValue(JBOSS_REGISTRY_STRING, JBOSS_REG_KEY, "");
 	szFileName = svValue + JBOSS_SHUTDOWN_BAT_FILE_PATH;
   	svAddStr = SET_JAVA_HOME + szVarValue;
	szSearchStr0 = SHUTDOWN_BAT_FILE_JAVA_HOME_SEARCH_STR;
		
	if((svValue != ""))  then

		// Trying to set JAVA_HOME in shutdown.bat.
    	LogMessage("Setting JAVA_HOME in shutdown.bat" + szFileName);
    	FileGrep(szFileName, szSearchStr0, svReturnLine, nvLineNumber, RESTART);
    	FileInsertLine(szFileName, svAddStr, nvLineNumber, BEFORE);
  	
  		LogMessage("shutdown.bat modified");
	endif;

   	LogExitMessage("Finished ModifyingJboss shutdown.bat File");
 end;

///////////////////////////////////////////////////////////////////////////////
//  Function:     InstallDotNet4_0()
//  puropose: 	  it installs dot net Framework 4.0.
///////////////////////////////////////////////////////////////////////////////

function InstallDotNET4_0()
STRING szProgram, szCmdLine;
begin
  	LogEnterMessage("InstallDotNET4_0()");
	szCmdLine = "/q";

	if (!IsDotNET4_0Installed()) then
		LogMessage ("Launching the .NET 4.0 installer " + "DOTNET " +szCmdLine );

		//LAAW_PARAMETERS.szStatusText = GetValueFromStringTable("DOTNET_INSTALLING");
		// will pick up dotnetfx.exe from support dir
		szProgram = SUPPORTDIR ^ "dotNetFx40_Full_x86_x64.exe";
		//it will launch the dotnetfx.exe & wait untill it finishes.
		LaunchAppAndWait(szProgram, szCmdLine, WAIT);
  	else
	  	LogMessage(".Net Framework already exists, Not installing framework");
	endif;

  	LogExitMessage("InstallDotNET4_0()");
end;

 ///////////////////////////////////////////////////////////////////////////////
 //  Function :		IsDotNET4_0Installed()
 //  purpose  :		it checks registry to detect if DotNet Framework
 //					4.0 is installed.
 ///////////////////////////////////////////////////////////////////////////////

 function BOOL IsDotNET4_0Installed()
    NUMBER nReturn;
    BOOL bDotNETInstalled;
 begin
  	LogEnterMessage("IsDotNET4_0Installed()");

  	bDotNETInstalled = FALSE;
    LogMessage ("Checking if .NET 4.0 is installed");
    // Get the list of subkeys.
    RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);  
    nReturn = RegDBKeyExist ("SOFTWARE\\Microsoft\\NET Framework Setup\\NDP\\v4\\Client");
    
    if (nReturn = 1) then 
    	bDotNETInstalled = TRUE; 
    endif;
  	LogExitMessage("IsDotNET4_0Installed()");
    return bDotNETInstalled;
end;

//////////////////////////////////////////////////////////////////////////////
//
//  FUNCTION:   GetRegValue()
//
//  Purpose:    Get a registry value from HKEY_LOCAL_MACHINE
//
///////////////////////////////////////////////////////////////////////////////
function STRING GetRegValue(szPath, szKey, szDefault)
	STRING svValue;
	NUMBER nvType;
	NUMBER nvSize;
begin
	nvType=REGDB_STRING;
	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
	RegDBGetKeyValueEx(szPath, szKey, nvType, svValue, nvSize);

	if svValue = "" then
		return szDefault;
	else
		return svValue;
	endif;
end;


///////////////////////////////////////////////////////////////////////////////
//		Modify config.util.properties file in roi.config.util.
//
///////////////////////////////////////////////////////////////////////////////
function ModifyConfigureROIServerProperites()
 string svAddStr,svAddStr1,szFileName;
 string szSearchStr0,szSearchStr1,szSearchStr2,svReturnLine;
 number nvLineNumber, nvSize, nvType;
 begin

    LogEnterMessage("Start Modifying configure server properties file");
	szFileName = CONFIG_UTIL_PROPS_FILE;
	StrRemoveLastSlash(jbossPath);
	svAddStr = "jboss.home=" + jbossPath;
	szSearchStr0 = "jboss.home=";

   	// finding jboss.home in config.util.props
   	LogMessage("Setting jboss.home in config.util.props");
	FileGrep(szFileName, szSearchStr0, svReturnLine, nvLineNumber, RESTART );

	// Delete the specific line where pattern was found first
   	FileDeleteLine (szFileName, nvLineNumber, nvLineNumber);

   	//Insert Modified entry to deleted line number
   	FileInsertLine (szFileName, svAddStr, nvLineNumber, BEFORE);

	LogMessage("config.util.properties jboss.home modified");

   	LogExitMessage("Finished Modifying configure server properties file");
end;



///////////////////////////////////////////////////////////////////////////////
//		Modify JBoss default port in the Output JBoss
//
///////////////////////////////////////////////////////////////////////////////
function ModifyJBossPort()
 string szFileName,svAddStr,szSearchStr0;
 begin

    LogEnterMessage("Start Modifying OUTPUT_JBOSS_CONF_MIN_FILE JBoss Port file");
	szFileName = outputJbossPath + OUTPUT_BROKER_CONFIG_FILE;
	svAddStr = "<transportConnector uri=\"tcp://localhost:61617\" discoveryUri=\"multicast://default\"/>";
	szSearchStr0 ="<transportConnector uri=";
	//modify the Output jboss port in broker.config.xml
	ModifyOutputJbossPort(szFileName,svAddStr,szSearchStr0);
	LogMessage("output JBoss activeMQ Output.Broker.config modified");

   	LogMessage("output JBoss Ports are modified");
   	LogExitMessage("Finished Modifying output jboss port");
end;


///////////////////////////////////////////////////////////////////////////////
//		Modify the port no into the output JBoss file based on input string.
//
///////////////////////////////////////////////////////////////////////////////
function ModifyOutputJbossPort(szFileName,svAddStr,szSearchStr0)
 string svAddStr1;
 string szSearchStr1,szSearchStr2,svReturnLine;
 number nvLineNumber, nvSize, nvType;
 begin

	// finding output jboss port
   	LogMessage("Modifying jboss port");
	FileGrep(szFileName, szSearchStr0, svReturnLine, nvLineNumber, RESTART );

	// Delete the specific line where pattern was found first
   	FileDeleteLine (szFileName, nvLineNumber, nvLineNumber);

   	//Insert Modified entry to deleted line number
   	FileInsertLine (szFileName, svAddStr, nvLineNumber, BEFORE);

end;

