///////////////////////////////////////////////////////////////////////////////
//	Launches configure server utility
//
///////////////////////////////////////////////////////////////////////////////
function LaunchConfigureServerUtility()
 string svValue, szProgram, szCmd, szSearchStr, szFilePath;
 number fileHandle, nvLineNumber;
 begin
    svValue = GetRegValue(JBOSS_REGISTRY_STRING, JBOSS_REG_KEY, "");
    LogEnterMessage("Launching the ROI Configurator");
    if((svValue != ""))  then
    ChangeDirectory(CONFIG_UTIL_HOME);   
    
    if (SYSINFO.bIsWow64 != 0) then                  
		szCmd = "set path=" + TARGETDIR ^ JAVA_64_BIT_LOCATION ^ JAVA_BIN_LOCATION + ";%path%";
	else                                                                             
		szCmd = "set path=" + TARGETDIR ^ JAVA_LOCATION ^ JAVA_BIN_LOCATION + ";%path%";
    endif;
                  
    szCmd = "set path=" + TARGETDIR ^ JAVA_LOCATION ^ JAVA_BIN_LOCATION + ";%path%";
    szFilePath = CONFIG_UTIL_HOME ^ CONFIG_UTIL_BAT_FILE_NAME;
	  
	// finding to set java home
	FileInsertLine(szFilePath, szCmd, 0, BEFORE);
	
    szProgram = CONFIG_UTIL_BAT_FILE_NAME;
	//it will launch the ROIConfigUtil.exe & wait untill it finishes.
		
    if (LaunchAppAndWait(szProgram, "", WAIT) < 0)
    then
   	  LogMessage("Failed to launch the ROI Utility.");
	  MessageBox("Failed to launch the ROI Utility.", INFORMATION);
    endif;
    endif;
    LogExitMessage("Finished launching the ROI Configurator.");
end;


///////////////////////////////////////////////////////////////////////////////
//	Launches Fax Service installation
//
///////////////////////////////////////////////////////////////////////////////
function InstallFaxService()
string svValue;
begin
	LogEnterMessage("InstallDotNET4_0_Installing()");
	InstallDotNET4_0();  
	ModifyFaxServiceInstallBatFile();  
	ModifyFaxServiceUnInstallBatFile();
	LogExitMessage("InstallDotNET4_0_Installed()");
    LogEnterMessage("Launching the Fax Service Installation");

    LogMessage("Fax service installtion command : " + FAX_SERVICE_INSTALL_BAT);
    if(LaunchAppAndWait(FAX_SERVICE_INSTALL_BAT, "", WAIT) < 0) then
   	   LogMessage("Failed to launch the Fax Service installation");
    endif;

    LogMessage("rfcomapi.dll register command : " + "regsvr32 " + FAX_SERVICE_REGISTER_DLL + " /s");
    if(LaunchAppAndWait("regsvr32", FAX_SERVICE_REGISTER_DLL + " /s", WAIT) < 0) then
   	   LogMessage("Failed to register rfcomapi.dll");
    endif;

    LogExitMessage("Finished launching the Fax Service installation.");
end;    

///////////////////////////////////////////////////////////////////////////////
//  		Modify Fax Server as installFaxServerAsService.bat File.
//
///////////////////////////////////////////////////////////////////////////////
 function ModifyFaxServiceInstallBatFile()
 string svAddStr,szFileName,svValue;
 string szSearchStr0, svReturnLine, svInfo, svReturnLine1;
 number nvLineNumber;
 begin
    LogEnterMessage("Modifying Fax Server installFaxServerAsService.bat File");     
  
	// to retrieve the path where the .net framework installed
	svValue = GetRegValue(DOTNET_FRAMEWORK_REGISTRY_STRING, DOTNET_FRAMEWORK_REG_KEY, "");
	
	// path where the FAX bat file is located
 	szFileName = FAX_SERVICE_INSTALL_BAT;
   	
	svAddStr = "\"" + svValue + FAX_SERVICE_INSTALL_STRING;
	
	// The string needs to search in the batch file
	szSearchStr0 = FAX_INSTALL_FRAMEWORK_SEARCH_STR;
		
	if((svValue != ""))  then

		// Trying to set Framework version in installFaxServerAsService.bat.
    	LogMessage("Setting .net Framework version in installFaxServerAsService.bat" + szFileName);
    
		FileGrep(szFileName, szSearchStr0, svReturnLine, nvLineNumber, RESTART);
    	// Delete the specific line where pattern was found first
   		FileDeleteLine (szFileName, nvLineNumber, nvLineNumber);
    	FileInsertLine(szFileName, svAddStr, nvLineNumber, REPLACE);
  	
  		LogMessage("Setting .net Framework version in installFaxServerAsService.bat is successful");
	endif;

   	LogExitMessage("Finished Modifying .net Framework version in installFaxServerAsService.bat");
 end;

