///////////////////////////////////////////////////////////////////////////////
//Personalize config.util.properties file in roi.config.util.
//
///////////////////////////////////////////////////////////////////////////////
function CustomizeConfigUtilProps()
 string svAddStr,svAddStr1,svAddStr2,szFileName, svInfo;
 string szSearchStr0,szSearchStr1,szSearchStr2,svReturnLine;
 number nvLineNumber, nvSize, nvType;
 int nvInfo;
 begin

	szFileName = CONFIG_UTIL_PROPS_FILE;
    LogEnterMessage("Started customizing configure util properties file");

	// checking whether ROIServer is selected by user or not
	FeatureGetData( MEDIA, ROIServer, FEATURE_FIELD_SELECTED, nvInfo, svInfo );
	// if nvInfo is true mean ROIServer(ROI Server) has been selected by user
	szSearchStr0 = "roi.server.installed=";
	if nvInfo then
		svAddStr = "roi.server.installed=true";
		FileGrep(szFileName, szSearchStr0, svReturnLine, nvLineNumber, RESTART );
		FileDeleteLine (szFileName, nvLineNumber, nvLineNumber);
		FileInsertLine (szFileName, svAddStr, nvLineNumber, BEFORE);
	else
		svAddStr = "roi.server.installed=false";
		FileGrep(szFileName, szSearchStr0, svReturnLine, nvLineNumber, RESTART );
		FileDeleteLine (szFileName, nvLineNumber, nvLineNumber);
		FileInsertLine (szFileName, svAddStr, nvLineNumber, BEFORE);
	endif;

	// if nvInfo is true mean ROIClientInstallation(ROI Client Installation Server) has beeb selected by user
	FeatureGetData(MEDIA, ROIClientInstallation, FEATURE_FIELD_SELECTED, nvInfo, svInfo);
	szSearchStr0 = "roi.client.installer.installed=";
	if nvInfo then
		svAddStr = "roi.client.installer.installed=true";
		FileGrep(szFileName, szSearchStr0, svReturnLine, nvLineNumber, RESTART );
		FileDeleteLine (szFileName, nvLineNumber, nvLineNumber);
		FileInsertLine (szFileName, svAddStr, nvLineNumber, BEFORE);
	else
		svAddStr = "roi.client.installer.installed=false";
		FileGrep(szFileName, szSearchStr0, svReturnLine, nvLineNumber, RESTART );
		FileDeleteLine (szFileName, nvLineNumber, nvLineNumber);
		FileInsertLine (szFileName, svAddStr, nvLineNumber, BEFORE);
	endif;

	// if nvInfo is true mean OutputService(Output Service Server) has beeb selected by user
	FeatureGetData(MEDIA, OutputService, FEATURE_FIELD_SELECTED, nvInfo, svInfo);
	szSearchStr0 = "output.server.installed=";
	if nvInfo then
		svAddStr = "output.server.installed=true";
		FileGrep(szFileName, szSearchStr0, svReturnLine, nvLineNumber, RESTART );
		FileDeleteLine (szFileName, nvLineNumber, nvLineNumber);
		FileInsertLine (szFileName, svAddStr, nvLineNumber, BEFORE);
	else
		svAddStr = "output.server.installed=false";
		FileGrep(szFileName, szSearchStr0, svReturnLine, nvLineNumber, RESTART );
		FileDeleteLine (szFileName, nvLineNumber, nvLineNumber);
		FileInsertLine (szFileName, svAddStr, nvLineNumber, BEFORE);
	endif;

	// if nvInfo is true mean FaxService(Fax Service) has beeb selected by user
	FeatureGetData(MEDIA, FaxService, FEATURE_FIELD_SELECTED, nvInfo, svInfo);
	szSearchStr0 = "fax.server.installed=";
	if nvInfo then
        svAddStr = "fax.server.installed=true";
		FileGrep(szFileName, szSearchStr0, svReturnLine, nvLineNumber, RESTART );
		FileDeleteLine (szFileName, nvLineNumber, nvLineNumber);
		FileInsertLine (szFileName, svAddStr, nvLineNumber, BEFORE);
	else
        svAddStr = "fax.server.installed=false";
		FileGrep(szFileName, szSearchStr0, svReturnLine, nvLineNumber, RESTART );
		FileDeleteLine (szFileName, nvLineNumber, nvLineNumber);
		FileInsertLine (szFileName, svAddStr, nvLineNumber, BEFORE);
	endif;

   	LogExitMessage("Finished customizing config util properties");
end;


///////////////////////////////////////////////////////////////////////////////
//Creates shortcut for Output Server.
//
///////////////////////////////////////////////////////////////////////////////
function CreateOutputServerShortcut()
 string svAddStr,svStartMenuPath,svWd,svValue, svInfo;
 string szSearchStr0,szSearchStr1,szSearchStr2,svReturnLine;
 number nvLineNumber, nvSize, nvType;
 int roiInfo, outputInfo;
 begin

	svValue = GetRegValue(JBOSS_REGISTRY_STRING, JBOSS_REG_KEY, "");
    LogEnterMessage("Started creating Output Server shortcut");
    svWd =   svValue + "\\bin";
    svValue = "\"" + outputJbossPath + OUTPUT_RUN_BAT_FILE + "\"";
    svStartMenuPath = FOLDER_PROGRAMS ^ "\\Mckesson\\ROI Server";


	// checking whether ROIServer is selected by user or not
	FeatureGetData( MEDIA, ROIServer, FEATURE_FIELD_SELECTED, roiInfo, svInfo );
	FeatureGetData(MEDIA, OutputService, FEATURE_FIELD_SELECTED, outputInfo, svInfo);

	if (outputInfo)then
		AddFolderIcon (FOLDER_DESKTOP, "Output Server", svValue, svWd, "", 0, "", REPLACE );
		AddFolderIcon (svStartMenuPath, "Output Server", svValue, svWd, "", 0, "", REPLACE );
	endif;
	if (!roiInfo && outputInfo)then
		FeatureSelectItem(MEDIA, "Jboss Component", FALSE);
		DeleteDir("Jboss Component", ALLCONTENTS);
	endif;

   	LogExitMessage("Finished creating Output Server shortcut");
end;   

