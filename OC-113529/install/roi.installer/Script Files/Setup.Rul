	szSearchStr0 = FAX_UNINSTALL_FRAMEWORK_SEARCH_STR;
		
	if((svValue != ""))  then

		// Trying to set Framework version in uninstallFaxServerAsService.bat.
    	LogMessage("Setting .net Framework version in uninstallFaxServerAsService.bat" + szFileName);
    
		FileGrep(szFileName, szSearchStr0, svReturnLine, nvLineNumber, RESTART);
