 begin
    LogEnterMessage("CreateConfigUtilBat");
 	szCmd = "\"" + szVarValue + JAVA_BIN_LOCATION + "\\javaw\"" + " -jar " + "\"" + CONFIG_UTIL_HOME+"\\roi.config.util.jar" + "\"";
 	LogMessage("Command to launch the Config Utility" + szCmd);
	szFilePath = CONFIG_UTIL_HOME;
	CreateFile(fileHandle, szFilePath, CONFIG_UTIL_BAT_FILE_NAME);
	OpenFileMode(FILE_MODE_APPEND);
	WriteLine(fileHandle, szCmd);
	CloseFile(fileHandle);   
	LogMessage("ConfigUtil Batch file Created at : " + szFilePath);
	
	//Modify ROIConfigUtil.exe.config
	ReplaceFromFile(CONFIG_UTIL_CONF_FILE,"configutil.bat" , CONFIG_UTIL_BAT_FILE_NAME);
	
	//LogMessage("Configuring SSL Batch File");
    //szSSLBatchFile = CONFIG_UTIL_HOME + "\\..\\SSL\\SSL.Bat";
    //LogMessage("ROI SSL Batch File :" + szSSLBatchFile);
	//FileInsertLine(szSSLBatchFile, SET_ROI_JAVA_HOME + szVarValue, 1, BEFORE);
	//LogMessage("ROI Java Home :" + SET_ROI_JAVA_HOME + szVarValue);	
	//LogMessage("Configured SSL Batch File");
	
   	LogExitMessage("ConfigUtilans SSL Batch files are updated");
 end;

///////////////////////////////////////////////////////////////////////////////
//  		Modify JBOSS start-output.bat File.
//
///////////////////////////////////////////////////////////////////////////////
 function ModifyStartOutputBat()
 string svAddStr,svAddStr1,szFileName, szPath, szKey;
 string szSearchStr0, svReturnLine, szSearchStr1, szSearchStr2, szFileName1;
 number nvLineNumber, nvSize, nvType;
 begin
    LogEnterMessage("ModifyStartOutputBat");  
	szFileName = outputJbossPath + START_OUTPUT_BAT_FILE_PATH;
	szFileName1 = outputJbossPath + JBOSS_SHUTDOWN_BAT_FILE_PATH;
	svAddStr1= SET_JAVA_HOME + szVarValue;
	svAddStr=";" + outputJbossPath + CONFIG_FILES_PATH;

	szSearchStr0 = JAVA_HOME_SEARCH_STR;
	szSearchStr1 = JBOSS_CLASSPATH_SEARCH_STR1;
	szSearchStr2 = SHUTDOWN_BAT_FILE_JAVA_HOME_SEARCH_STR;

		//Modifying JAVA_HOME in start-output.bat (JBOSS)
	if((outputJbossPath != ""))  then
    	// Trying to set JAVA_HOME setting.
    	LogMessage("Setting JAVA_HOME in output.run.bat");
    	FileGrep(szFileName, szSearchStr0, svReturnLine, nvLineNumber, RESTART);
    	//FileDeleteLine(szFileName, nvLineNumber, nvLineNumber);
    	FileInsertLine(szFileName, svAddStr1, nvLineNumber, BEFORE);

		 // Trying to set JAVA_HOME in shutdown.bat.
    	LogMessage("Setting JAVA_HOME in shutdown.bat");
    	FileGrep(szFileName1, szSearchStr2, svReturnLine, nvLineNumber, RESTART);
    	//FileDeleteLine(szFileName, nvLineNumber, nvLineNumber);
    	FileInsertLine(szFileName1, svAddStr1, nvLineNumber, BEFORE);

	    // finding JBOSS_CLASSPATH inside roi.run.bat of JBOSS
    	LogMessage("Setting JBOSS_CLASSPATH in output.run.bat");
		FileGrep(szFileName, szSearchStr1, svReturnLine, nvLineNumber, RESTART );

		// Delete the specific line where pattern was found first
    	FileDeleteLine(szFileName, nvLineNumber, nvLineNumber);

    	//Insert Modified entry to deleted line number
    	FileInsertLine(szFileName, szSearchStr1+svAddStr, nvLineNumber, BEFORE);
     	
     	LogMessage("start-output.bat modified");
		endif;

	LogExitMessage("Finished Modifying start-output.bat");
end;

 //////////////////////////////////////////////////////////////////////////////
//
//  FUNCTION:   DeleteJbossDirOnUninstallation()
//
//  Purpose:    To delete the jboss directory on uninstallation
//
///////////////////////////////////////////////////////////////////////////////
function DeleteJbossDirOnUninstallation()
	STRING svValue;
begin
	svValue = GetRegValue(JBOSS_REGISTRY_STRING, JBOSS_REG_KEY, "");
	DeleteDir(svValue, ALLCONTENTS);
	 if(LaunchAppAndWait("rmdir", "/S /Q " + svValue, WAIT) < 0) then
   	   LogMessage("Jboss uninstalled");
    endif;
end;

////////////////////////////////////////////////////////////////////////////////
// The Installed event is sent after the feature jboss
// is installed.
////////////////////////////////////////////////////////////////////////////////  
function InstallROIJBossService() 
STRING szProgram, szCmdLine;
begin
    LogEnterMessage("InstallROIJBossAsService()");
    szProgram = jbossPath + ROI_JBOSS_SERVICE_BAT_FILE_PATH;
    szCmdLine = "install";
    
    LogMessage("To install the ROI JBoss as Windows service use " + szProgram + " " + szCmdLine);
    
    //it will create a JBoss as a window service
    LaunchAppAndWait(szProgram, szCmdLine, WAIT);
    LogExitMessage("InstallROIJBossAsService()");
end;

///////////////////////////////////////////////////////////////////////////////
//  Function:     UnInstallROIJBossService(szSvcName)
//  puropose:       it uninstalls the old ROI windows services from the system.
///////////////////////////////////////////////////////////////////////////////
function UnInstallROIJBossService(szSvcName)
    STRING szProgram, szCmdLine, szCmd, szCmd1, svValue, svReturnLine;
    string szFilePath, szJniport, szJbossPath, szShutdownCommand;    
	NUMBER fileHandle, nvLineNumber; 
	int nRet, nState; 
    int nCanbeRemoved;  
    STRING szScriptFile;  
    int nLineNumber, nvError;
begin
    LogEnterMessage("UnInstallROIJBossService(szSvcName)");
   	svValue = GetRegValue(JBOSS_REGISTRY_STRING, JBOSS_REG_KEY, "");
    szCmd = "sc stop " + szSvcName;
    szFilePath = svValue + BIN_FOLDER_PATH;
    szProgram = svValue + ROI_JBOSS_SERVICE_STOP_BAT_FILE;
    LogMessage("Command to stop the "+ szSvcName +" JBoss Service" + szCmd + " from " + szProgram);
   
    if(IsFileExists(szProgram) = TRUE) then       
        LaunchAppAndWait(szProgram, "", WAIT);
    endif;
    
    CreateFile(fileHandle, szFilePath, ROI_JBOSS_SERVICE_STOP_BAT_FILE);
    OpenFileMode(FILE_MODE_APPEND);
    WriteLine(fileHandle, szCmd);
    CloseFile(fileHandle);
    
    LaunchAppAndWait(szFilePath,"ookill.bat" , WAIT);
    
    szJbossPath = svValue ^ JBOSS_SHUTDOWN_BAT_FILE_PATH;
    
 	// finding to delete the pause option in the shutdown batch file
	if (FileGrep(szJbossPath, "pause", svReturnLine, nvLineNumber, RESTART) = 0) then
		FileDeleteLine(szJbossPath, nvLineNumber, nvLineNumber );                        
	endif;
   	
   	szJniport = GetJniServicePort(svValue ^ ROI_JBOSS_PORT_CONF_FILE); 
   	szShutdownCommand = "-s localhost:" + szJniport + " -S";
   	LaunchAppAndWait(szJbossPath, szShutdownCommand, WAIT);    
    
    LogMessage("To UnInstall ROI JBoss Windows service use " + szProgram + " " + szCmdLine);
    LaunchAppAndWait("", szCmd, WAIT);
    // once the server is stopped the soffice instance is killed
    StopSofficeBin();     
    
    if(ServiceExistsService (szSvcName) == TRUE ) then  
   	   nCanbeRemoved = TRUE;	
   	   nRet = ServiceGetServiceState ( szSvcName, nState);
   	   if(nRet >= ISERR_SUCCESS && nState == SERVICE_RUNNING) then
		   if(ServiceStopService(szSvcName) >= ISERR_SUCCESS ) then
		   		LogMessage( "(" + szSvcName + ")" + " service stopped successfully");
		   else
		   		LogMessage( "(" + szSvcName + ")" + " service failed to stop");
		   		nCanbeRemoved = FALSE;
		   		GetExtendedErrInfo(szScriptFile, nLineNumber, nvError);
		   		LogMessage("Error: " + FormatMessage(nvError));  
			endif;
	   else
	   	   LogMessage( "(" + szSvcName + ")" + " service is not running");
	   endif;	
	   if(nCanbeRemoved == TRUE) then
		   if(ServiceRemoveService(szSvcName) >= ISERR_SUCCESS) then
	   		   LogMessage( "(" + szSvcName + ")" + " service removed successfully");
           else
	   		   LogMessage( "(" + szSvcName + ")" + " service failed to remove");
	   		   GetExtendedErrInfo(szScriptFile, nLineNumber, nvError);
		   	   LogMessage("Error: " + FormatMessage(nvError));  
	   	   endif;	
		endif;
	else
		LogMessage( "(" + szSvcName + ")" + " service not exists");
	endif;
	
    LogExitMessage("UnInstallROIJBossService(szSvcName)");  
    
end;

////////////////////////////////////////////////////////////////////////////////
// The Installed event is sent after the feature jboss
// is installed.
////////////////////////////////////////////////////////////////////////////////
function InstallOutputJBossService() 
STRING szProgram, szCmdLine;
begin
    LogEnterMessage("InstallOutputJBossAsService()");
    szProgram = outputJbossPath + OUTPUT_JBOSS_SERVICE_BAT_FILE_PATH;
    szCmdLine = "install";
    
    LogMessage("To install the Output JBoss as Windows service use " + szProgram + " " + szCmdLine);
    
    //it will create a JBoss as a window service
    LaunchAppAndWait(szProgram, szCmdLine, WAIT);
    LogExitMessage("InstallOutputJBossAsService()");
end;

///////////////////////////////////////////////////////////////////////////////
//  Function:     UnInstallOutputJBossService(szSvcName)
//  puropose:       it uninstalls the Old OUTPUT windows services from the system.
///////////////////////////////////////////////////////////////////////////////    
function UnInstallOutputJBossService(szSvcName)
    STRING szProgram, szCmdLine, szFilePath, szProgram1, szOutputJbossDir, svReturnLine; 
    STRING svValue, szCmd, szCmd1, szJniport, szJbossPath, szShutdownCommand;
 	NUMBER fileHandle, nvLineNumber; 
 	int nRet, nState; 
    int nCanbeRemoved; 
    STRING szScriptFile;  
    int nLineNumber, nvError;
begin
    LogEnterMessage("UnInstallOutputJBossService(szSvcName)");
    szOutputJbossDir = TARGETDIR + "\\output.jboss";
    szProgram1 = szProgram + OUTPUT_JBOSS_SERVICE_BAT_FILE_PATH;
    szCmdLine = "uninstall";
    szCmd = "sc stop " + szSvcName;
    szFilePath = szOutputJbossDir + BIN_FOLDER_PATH;
    szProgram = szFilePath + OUTPUT_JBOSS_SERVICE_STOP_BAT_FILE;
    LogMessage("Command to stop the "+ szServiceName +" JBoss Service" + szCmd + " from " + szProgram);
  
    if(IsFileExists(szProgram) = TRUE) then       
        LaunchAppAndWait(szProgram, "", WAIT);
    endif;   
    
    CreateFile(fileHandle, szFilePath, OUTPUT_JBOSS_SERVICE_STOP_BAT_FILE);
    OpenFileMode(FILE_MODE_APPEND);
    WriteLine(fileHandle, szCmd);
    CloseFile(fileHandle);
    
    LaunchAppAndWait(szFilePath,"ookill.bat" , WAIT);
    
    szJbossPath = szOutputJbossDir ^ JBOSS_SHUTDOWN_BAT_FILE_PATH;
    // finding to delete the pause option in the shutdown batch file
	if (FileGrep(szJbossPath, "pause", svReturnLine, nvLineNumber, RESTART) = 0) then
		FileDeleteLine(szJbossPath, nvLineNumber, nvLineNumber );                        
	endif;
	
    szJniport = GetJniServicePort(szOutputJbossDir ^ ROI_JBOSS_PORT_CONF_FILE);
	szShutdownCommand = "-s localhost:" + szJniport + " -S";
   	LaunchAppAndWait(szJbossPath, szShutdownCommand, WAIT);    
       
    LogMessage("To UnInstall Output JBoss Windows service use " + szProgram + " " + szCmdLine);
    
    //it will uninstall the JBoss service
   	LaunchAppAndWait("", szCmd, WAIT);  
   	
   	if(ServiceExistsService (szSvcName) == TRUE ) then  
   	   nCanbeRemoved = TRUE;	
   	   nRet = ServiceGetServiceState ( szSvcName, nState);
   	   if(nRet >= ISERR_SUCCESS && nState == SERVICE_RUNNING) then
		   if(ServiceStopService(szSvcName) >= ISERR_SUCCESS ) then
		   		LogMessage( "(" + szSvcName + ")" + " service stopped successfully");
		   else
		   		LogMessage( "(" + szSvcName + ")" + " service failed to stop");
		   		nCanbeRemoved = FALSE;
		   		GetExtendedErrInfo(szScriptFile, nLineNumber, nvError);
		   		LogMessage("Error: " + FormatMessage(nvError));  
			endif;
	   else
	   	   LogMessage( "(" + szSvcName + ")" + " service is not running");
	   endif;	
	   if(nCanbeRemoved == TRUE) then
		   if(ServiceRemoveService(szSvcName) >= ISERR_SUCCESS) then
	   		   LogMessage( "(" + szSvcName + ")" + " service removed successfully");
           else
	   		   LogMessage( "(" + szSvcName + ")" + " service failed to remove");
	   		   GetExtendedErrInfo(szScriptFile, nLineNumber, nvError);
		   	   LogMessage("Error: " + FormatMessage(nvError));  
	   	   endif;	
		endif;
	else
		LogMessage( "(" + szSvcName + ")" + " service not exists");
	endif;
	
    LogExitMessage("UnInstallOutputJBossService(szSvcName)");
end;

 
 ///////////////////////////////////////////////////////////////////////////////
//  		IsFileExists
//
///////////////////////////////////////////////////////////////////////////////

 function BOOL IsFileExists(fileName)                        
BOOL exists;
NUMBER nResult;
begin                 
	exists = FALSE;
	LogEnterMessage("IsFileExists(" + fileName + ")");    
	nResult = Is(FILE_EXISTS,fileName);
	if (nResult = TRUE) then
	    exists = TRUE;
	elseif (nResult = FALSE) then
	    exists = FALSE;
	else
	    LogMessage(" OOOPS!!!! unable to validate the file existance");
	endif;
	LogExitMessage("IsFileExists(" + fileName + ")");
	return exists;
end;


///////////////////////////////////////////////////////////////////////////////
//  		Logs message
//
///////////////////////////////////////////////////////////////////////////////

function LogMessage(dbgMsg)
begin
	WriteLine(nvFileHandle, dbgMsg);
end;

///////////////////////////////////////////////////////////////////////////////
//  		Logs message on function entry
//
///////////////////////////////////////////////////////////////////////////////

function LogEnterMessage(dbgMsg)
begin
	WriteLine(nvFileHandle, "Entering " + dbgMsg );
end;

///////////////////////////////////////////////////////////////////////////////
//  		Logs message on function exit
//
///////////////////////////////////////////////////////////////////////////////

function LogExitMessage(dbgMsg)
begin
	WriteLine(nvFileHandle, "Exit " + dbgMsg );
end;
//---------------------------------------------------------------------------
// OnSetTARGETDIR
//
// OnSetTARGETDIR is called directly by the framework to initialize
// TARGETDIR to it's default value.
//
// Note: This event is called for all setups.
//---------------------------------------------------------------------------
function OnSetTARGETDIR()
number nId, nIgnore, nResult;
string szId, szTARGETDIR, sCompName;
begin

    // In maintenance mode the value of TARGETDIR is read from the log file.
    if( MAINTENANCE ) then
        return ISERR_SUCCESS;
    endif;   
    
    // Set TARGETDIR to script default.
    TARGETDIR = "<FOLDER_APPLICATIONS>\\<IFX_COMPANY_NAME>\\<IFX_PRODUCT_NAME>";

    // Read TARGETDIR from the media.
    nResult = MediaGetData( MEDIA, MEDIA_FIELD_TARGETDIR, nIgnore, szTARGETDIR );

    // Use the TARGETDIR from the media if anything was read.
    if( nResult >= ISERR_SUCCESS && StrLengthChars( szTARGETDIR ) ) then
        TARGETDIR = szTARGETDIR;
    endif;
        
	// Customize the default TARGETDIR for multi-instance application.
	// TODO: If you want something different customize the code below.	
	if( MAINT_OPTION = MAINT_OPTION_MULTI_INSTANCE  && MULTI_INSTANCE_COUNT > 0) then

		// Start with the current multi-instance count plus one.
		nId = MULTI_INSTANCE_COUNT + 1;

		// Find a unique TARGETDIR.
		while( ExistsDir( TARGETDIR ) = EXISTS )
			
			// Convert to string.
			NumToStr( szId, nId );
			
			// Update IFX_MULTI_INSTANCE_SUFFIX
			IFX_MULTI_INSTANCE_SUFFIX = "_" + szId;
		
			// Update TARGETDIR
			TARGETDIR = TARGETDIR + IFX_MULTI_INSTANCE_SUFFIX;
			
			// Update nId
			nId = nId + 1;

		endwhile;

	endif;

end;      

                                                                               
////////////////////////////////////////////////////////////////////////////////
// OnSetUpdateMode
//
// OnSetUpdateMode is called directly by the framework to set the UPDATEMODE
// InstallShield system variable appropriately to control which UI events
// are called by OnShowUI.
//
// Note: This event is called for all setups.
////////////////////////////////////////////////////////////////////////////////
function OnSetUpdateMode()
	number	nIgnore, nMediaFlags, nInstalledVersion, nUpdateVersion, nResult;
	string	szVersion, szIgnore, szMsg;
begin
	
	UPDATEMODE = FALSE; // Non-update mode by default.
    //IFX_INSTALLED_VERSION = 15.01;
	// Added 11.5 - Don't set UPDATEMODE when running from Add/Remove
	if( ADDREMOVE ) then
		return ISERR_SUCCESS;
	endif;

	// Added 11.5 - Don't set UPDATEMODE when REMOVEONLY is specified
	if( REMOVEONLY ) then
		return ISERR_SUCCESS;
	endif;

	// Get the media flags.
	MediaGetData( MEDIA, MEDIA_FIELD_MEDIA_FLAGS, nMediaFlags, szIgnore );

	if( ! ( nMediaFlags & MEDIA_FLAG_UPDATEMODE_SUPPORTED ) ) then
		return ISERR_SUCCESS; // Update mode not supported by the setup.
	endif;

	// TODO: If you are updating an application that was installed by a previous
	// version of InstallShield, IFX_INSTALLED_VERSION will be empty, and
	// VERSION_COMPARE_RESULT_NOT_INSTALLED will be returned by
	// VerProductCompareVersions. Change the value of IFX_INSTALLED_VERSION (and
	// IFX_INSTALLED_DISPLAY_VERSION) here based on application specific version
	// information determined by the setup. Only do this if IFX_INSTALLED_VERSION
	// is empty.
	//if ( !StrLengthChars( IFX_INSTALLED_VERSION ) && MAINTENANCE ) then
	//	IFX_INSTALLED_VERSION = "X.XX.XXX";
	//	IFX_INSTALLED_DISPLAY_VERSION = IFX_INSTALLED_VERSION;
	//endif;

	// Verify that the installed version is valid.
	if( !StrLengthChars( IFX_INSTALLED_VERSION ) && MAINTENANCE ) then
		// If this error occurs, IFX_INSTALLED_VERSION needs to be set manually.
		szMsg = SdLoadString( IDS_IFX_ERROR_UPDATE_NO_INSTALLED_VERSION );
		MessageBox( szMsg, SEVERE );
		abort;
	endif;

	// Verify that the product version is valid.
	if( !StrLengthChars( IFX_PRODUCT_VERSION ) ) then
		// If this error occures, IFX_PRODUCT_VERSION was not initialized correctly.
		szMsg = SdLoadString( IDS_IFX_ERROR_UPDATE_NO_PRODUCT_VERSION );
		MessageBox( szMsg, SEVERE );
		abort;
	endif;

	// Do the version comparison.
	nResult = VerProductCompareVersions();

	// Make sure that valid data was returned by VerProductCompareVersions
	if( nResult < ISERR_SUCCESS ) then
		szMsg = SdLoadString( IDS_IFX_ERROR_UPDATE_VERSION_COMPARE_FAILURE );
		MessageBox( szMsg, SEVERE );
		abort;
	endif;

	// Set update mode if this is a differential media or the product is already installed and the versions do not match.
	UPDATEMODE = ( nMediaFlags & MEDIA_FLAG_FORMAT_DIFFERENTIAL || ( MAINTENANCE && ( nResult != VERSION_COMPARE_RESULT_SAME ) ) );

end;


///////////////////////////////////////////////////////////////////////////////
//  Function:     OnUpdateUIBefore()
//  puropose:     when the upgradation of the servers finishes, this event is called
///////////////////////////////////////////////////////////////////////////////    
function OnUpdateUIBefore ()  
string szMessage, szTitle, szIgnore, szMsg, szInstalledJbossVersion, svInfo;
string installedVersion, szErrTitle, szErrMsg1, szErrMsg2, szDialogTitle;  
string szclientRoot, szclientFolder, szClientpath1, szClientpath2;
number nResult, nSelectedOption, nvLineNumber;
number nId1, nId2, nMediaFlags, nvJava32, nvInfo; 
begin                    
       
    CreateLogFolder();           
    installedVersion = getInstalledVersion();
    // Determine the update media type.	
	MediaGetData( MEDIA, MEDIA_FIELD_MEDIA_FLAGS, nMediaFlags, szIgnore );
	// Do the version comparison.
	nResult = VerProductCompareVersions();     
	
	// if the installed version is same as the current version 
	if (nResult == VERSION_COMPARE_RESULT_SAME) then
	   
	   szErrTitle = "ROI Already Installed"; 
	   szErrMsg1  = "ROI " + installedVersion + " is already installed.";    
	   szErrMsg2  = "";
	   SdSubstituteProductInfo( szErrMsg1 ); 
	   SdFinish(szErrTitle, szErrMsg1, szErrMsg2 , "", "", nId1, nId2);  
	   abort;
	endif;
	
	if (nResult == VERSION_COMPARE_RESULT_OLDER) then   
	   
	   szErrTitle = "ROI Installed"; 
	   szErrMsg1  = "ROI " + installedVersion + " is installed. Upgrade from higher version " + installedVersion + " to lower version %VS not allowed.";
	   szErrMsg2  = "";
	   SdSubstituteProductInfo( szErrMsg1 ); 
	   SdFinish(szErrTitle, szErrMsg1, szErrMsg2 , "", "", nId1, nId2);
	   abort;
	endif;  
	
	szInstalledJbossVersion = getJbossVersion(installedVersion);
	szTitle="ROI Upgrade from " + installedVersion + " to %VS";
    szMessage="";
	SdSubstituteProductInfo( szTitle ); 
   
	jbossPath = TARGETDIR ^ "\jboss";
    outputJbossPath = TARGETDIR ^ "\output.jboss";   

	if (SYSINFO.bIsWow64 != 0) then
		szVarValue = TARGETDIR + JAVA_64_BIT_LOCATION;     
	else          
		szVarValue = TARGETDIR + JAVA_LOCATION;
    endif;
	
	 // finding client folder path
    FileGrep(CONFIG_UTIL_PROPS_FILE, "click.once.path", szclientRoot, nvLineNumber, RESTART );
    StrSub ( szClientpath1, szclientRoot, 16, (StrLength(szclientRoot) - 16));
    // finding client folder
    FileGrep(CONFIG_UTIL_PROPS_FILE, "client.config.version", szclientFolder, nvLineNumber, RESTART );
    StrSub ( szClientpath2, szclientFolder, 22, (StrLength(szclientFolder) - 22));
    
    szROIClientFolder = jbossPath ^  szClientpath1 ^  szClientpath2;   
    LogMessage("Client folder is:" +  szROIClientFolder);
        
	dlg_showWarning:
			// onclick cancel exits the set up automatically.
			nSelectedOption = SdWelcome(szTitle, szMessage);  
			
			SdShowMsg("Taking backup of Existing Configurations", TRUE);
			// installs the autoconfigurator in which configurations are backed up.
			// take back up of the config util.properties file
			CopyFile(CONFIG_UTIL_PROPS_FILE, TARGETDIR ^ "config.util.properties");
			
			// uninstall the old config utility
			FeatureSelectItem(MEDIA, "Common Components", FALSE);  
			FeatureTransferData(MEDIA);  
			
			FeatureSelectItem(MEDIA, "Java32bit-1.7.0", TRUE);
			
			// reinstall the current config utility
			FeatureSelectItem(MEDIA, "Common Components", TRUE);  
			FeatureTransferData(MEDIA);  
			CopyFile(CONFIG_UTIL_PROPS_FILE, CONFIG_UTIL_PROPS_FILE + "-backup");
			CopyFile(TARGETDIR ^ "config.util.properties", CONFIG_UTIL_PROPS_FILE);
			DeleteFile(TARGETDIR ^ "config.util.properties");
			BackUpConfigurations();         
			CopyFile(CONFIG_UTIL_PROPS_FILE + "-backup", CONFIG_UTIL_PROPS_FILE); 
			
			SdShowMsg("Taking backup of Existing ROI Configurations", FALSE);
	Dlg_ObjDialogs:
	    
	    StopSofficeBin();
	    FeatureSelectNew(MEDIA, TRUE);
	    nResult = ShowObjWizardPages( nResult );    
		if( nMediaFlags & MEDIA_FLAG_FORMAT_DIFFERENTIAL ) then
			// Differential installs patch media.
			FeaturePatch();
		else
			// Update reinstalls (updates) all features in media.
			FeatureReinstall();
		endif;
	
	    // Added in 11.0 - Set appropriate StatusEx static text.
	    szMsg = SdLoadString( IDS_IFX_STATUSEX_STATICTEXT_UPDATEUI );
	    StrReplace(szMsg, "%VI", installedVersion, 0);
		SdSubstituteProductInfo( szMsg );
	    SetStatusExStaticText( szMsg );
	
end;     

   
///////////////////////////////////////////////////////////////////////////////
//  Function:     OnUpdateUIAfter()
//  puropose:     when the upgradation of the servers finishes, this event is called
///////////////////////////////////////////////////////////////////////////////    
function OnUpdateUIAfter ()  
string szTitle, szMsg1, szMsg2, szOpt1, szOpt2; 
number nvReturn; 
begin           
    
    ShowObjWizardPages(NEXT);

    szTitle = "";
    szMsg1 = "";
    szMsg2 = "";
    szOpt1 = "";
    szOpt2 = "";

	DeleteDir(szROIClientFolder, ALLCONTENTS);	
	nvReturn = SdFinishReboot(szTitle , szMsg1 , SYS_BOOTMACHINE , szMsg2 , 0);
	if (nvReturn == NEXT) then
		LogMessage("Not Rebooting the system");
		LaunchConfigureServerUtility();
	else
		LogMessage("Rebooting the system");
	endif;
	
end; 

////////////////////////////////////////////////////////////////////////////////
//  		ModifyAutoConfiguratorBat()
//		    java home is set Auto Configurator bat 
//                                                                        	 
///////////////////////////////////////////////////////////////////////////////
 function ModifyAutoConfiguratorBat()
 string szFilePath, svValue, szCmd, szSearchStr, svReturnLine;
 number fileHandle, nvLineNumber;
 begin
    LogEnterMessage("ModifyAutoConfiguratorBat");
 	szCmd = "set path=" + TARGETDIR ^ JAVA_LOCATION ^ JAVA_BIN_LOCATION + ";%path%";
 	LogMessage("Command to launch the auto Config Utility" + szCmd);
	szFilePath = AUTO_CONFIGURATOR_FILEPATH; 
	szSearchStr = "set PATH=<JAVA_HOME>\\bin;%PATH%";
	  
	// finding to set java home
	FileGrep(szFilePath, szSearchStr, svReturnLine, nvLineNumber, RESTART );
	FileDeleteLine(szFilePath, nvLineNumber, nvLineNumber );       
	FileInsertLine(szFilePath, szCmd, nvLineNumber, BEFORE);
	
   	LogExitMessage("Auto Configurator ConfigUtil Batch file modified at : " + szFilePath);
 end;     

///////////////////////////////////////////////////////////////////////////////
//
//  Function  BackUpCon3figurations ()  
//
//	Event     The existing preloaded configurations are loaded from the installed servers
//
///////////////////////////////////////////////////////////////////////////////
function BackUpConfigurations ()  
string installedVersion, currentVersion, szTargetDir;
string szCurrentJbossVersion, szProgram, szCommandLine, szInstalledJbossVersion, szSubStr; 
number nResult;
begin
	
	installedVersion = getInstalledVersion();   
	currentVersion = IFX_PRODUCT_VERSION; 
	     
	szInstalledJbossVersion = getJbossVersion(installedVersion);
	ChangeDirectory(CONFIG_UTIL_HOME);
	if (LaunchAppAndWait("", AUTO_CONFIGURATOR_FILEPATH + " " + szInstalledJbossVersion, WAIT) == 0) then
		LogMessage("Back up of ROI Configuration is taken successfully");
	else 
		LogMessage("Unable to retrieve Configuration Details");
	endif;
	
	UnInstallROIServices(0); 
	// deletes the ROI and Output servers	
	LogEnterMessage("Deleting ROI Server");
    RemoveExistingJBoss(TARGETDIR ^ "jboss");   
    LogEnterMessage("Deleting ROI Output Server");
    RemoveExistingJBoss(TARGETDIR ^ "output.jboss");     
    LogEnterMessage("Deleting Fax Server");
    RemoveExistingJBoss(TARGETDIR ^ "FaxService");
end;   

//////////////////////////////////////////////////////////////////////////////
//
//  FUNCTION:   RemoveExistingJBoss()
//
//  EVENT:      This function will remove the exising JBoss
//				
//////////////////////////////////////////////////////////////////////////////
function RemoveExistingJBoss(serverLocation)
begin

	LogEnterMessage("Entering RemoveExistingJboss" + serverLocation);
	
	if (DeleteDir(serverLocation, ALLCONTENTS)= 0) then
 		LogMessage("Deleting " + serverLocation + " is successful");
 	else
 		LogMessage("Unable to delete " + serverLocation);
 	endif;	
 	                                        
 	LogEnterMessage("Existing RemoveExistingJboss");
end;   

//////////////////////////////////////////////////////////////////////////////
//
//  FUNCTION:   UnInstallROIServices(int nRemoveAll)
//
//  EVENT:      This function will uninstall all the services
//				
//////////////////////////////////////////////////////////////////////////////
function UnInstallROIServices(nRemoveAll)
begin

	LogEnterMessage("Entering UnInstallROIServices");
	UnInstallROIJBossService(ROI151_JBOSS_SERVICE_NAME);
	UnInstallROIJBossService(ROI160_JBOSS_SERVICE_NAME);
	UnInstallOutputJBossService(OUTPUT151_JBOSS_SERVICE_NAME);              
	UnInstallOutputJBossService(OUTPUT160_JBOSS_SERVICE_NAME);
	UninstallFaxService(FAX_OLD_SERVICE_NAME, nRemoveAll);

	if(nRemoveAll == 1) then
		UnInstallROIJBossService(ROI_NEW_JBOSS_SERVICE_NAME);
		UnInstallOutputJBossService(OUTPUT_NEW_JBOSS_SERVICE_NAME);
		UninstallFaxService(FAX_NEW_SERVICE_NAME, nRemoveAll);
	endif;
	
	LogEnterMessage("Existing UnInstallROIServices");
end;    

 //////////////////////////////////////////////////////////////////////////////
//
//  FUNCTION:   StopSofficeBin()
//
//  EVENT:      This function will stop soffice.bin
//				
//////////////////////////////////////////////////////////////////////////////
function StopSofficeBin()      
STRING szCmd,szFilePath;
begin 

	LogEnterMessage("Entering StopSofficeBin");      
	szCmd = "taskkill /F /FI \"imagename eq soffice*\" /T"; 
	LaunchAppAndWait("", szCmd , WAIT);
	LogEnterMessage("Existing StopSofficeBin");
end;    

//---------------------------------------------------------------------------
// OnMaintUIBefore
//
// Maintenance UI Sequence - Before Move Data
//
// The OnMaintUIBefore event is called by OnShowUI when the setup is
// running in maintenance mode. By default this event displays UI that
// allows the end user to add or remove features, repair currently
// installed features or uninstall the application.
//
// Note: This event will not be called automatically in a
// program...endprogram style setup.
//---------------------------------------------------------------------------
function OnMaintUIBefore()
    number	nResult, nType, nMediaFlags;
    string	szTitle, szMsg, szIgnore; 
    LIST currentListInfo,oldListInfo; 

begin
	
	// nType defaults to MODIFY.
	nType = MODIFY;
  
	jbossPath = TARGETDIR ^ "\jboss";
	outputJbossPath = TARGETDIR ^ "\output.jboss";
	// If the machine is 64bit machine, java 64 bit is installed
	if (SYSINFO.bIsWow64 != 0) then
		szVarValue = TARGETDIR + JAVA_64_BIT_LOCATION;     
	else          
		szVarValue = TARGETDIR + JAVA_LOCATION;
    endif;
    
// Beginning of UI Sequence
Dlg_Start:
    
    CreateLogFolder();
    // Added in Version 9.5 - Support for REMOVEONLY option.
    if( !REMOVEONLY ) then
    	// In standard mode show maintenance dialog
	    Disable( BACKBUTTON );
	    nType = SdWelcomeMaint( szTitle, szMsg, nType );
	    Enable( BACKBUTTON );
        nResult = NEXT;
    else
        // Hide the initial progress dialog as otherwise the user can
        // click on it, and hide the MessageBox.
        Disable( DIALOGCACHE );

        // In RemoveOnly mode, set to remove.
        nType = REMOVEALL;
    endif;

	// Show Uninstall Confirmation Dialog
    if ( nType = REMOVEALL ) then
		nResult = MessageBox( SdLoadString( IFX_MAINTUI_MSG ), MB_YESNO );
		if (nResult != IDYES ) then
            
            if( REMOVEONLY ) then
                // In REMOVEONLY mode, abort the setup.
                abort;
            else
                // In non-REMOVEONLY mode, redisplay the previous dialog.
			    goto Dlg_Start;
            endif;

		endif;
	endif;

Dlg_SdFeatureTree:
	if ( nType = MODIFY ) then
		szTitle = "";    
		                                  
		oldListInfo =ListCreate(STRINGLIST); 
		
		ListDeleteAll(oldListInfo);
				
		oldListInfo=CreateSelectionList();
		
        currentListInfo = ListCreate (STRINGLIST); 
        
        ListDeleteAll(currentListInfo);
	     		
		szMsg = SdLoadString( SD_STR_COMPONENT_MAINT_MSG );
		nResult = SdFeatureTree( szTitle, szMsg, TARGETDIR, "", -1 );
		if ( nResult = BACK ) goto Dlg_Start;                        
				
		currentListInfo = CreateSelectionList();
        
        if(CheckNewSelectOrDeSelectComponent(currentListInfo,oldListInfo)=0) then
			MessageBox("Please Select/De-select at least one component",INFORMATION);
			goto Dlg_SdFeatureTree;                        
		endif;
    endif;  

Dlg_ObjDialogs:
    nResult = ShowObjWizardPages( nResult );
    if ( ( nResult = BACK ) && ( nType != MODIFY ) ) goto Dlg_Start;
    if ( ( nResult = BACK ) && ( nType = MODIFY ) ) goto Dlg_SdFeatureTree;
                 
    isRepairMode = FALSE;
    StopSofficeBin();
	switch(nType)

        case REMOVEALL:
			
			// stops and uninstall all the servc
			UnInstallROIServices(1);
					
			// Ensure that all previously installed features are removed
			// for media that supports updating.
			MediaGetData( MEDIA, MEDIA_FIELD_MEDIA_FLAGS, nMediaFlags, szIgnore );
			
			if( nMediaFlags & MEDIA_FLAG_UPDATEMODE_SUPPORTED ) then
				FeatureRemoveAllInMediaAndLog();
			else
				FeatureRemoveAllInMedia();
			endif;

            // Added in 11.0 - Set appropriate StatusEx static text.
            SetStatusExStaticText( SdLoadString( IDS_IFX_STATUSEX_STATICTEXT_MAINTUI_REMOVEALL ) );

        case REPAIR:
		    isRepairMode = TRUE;
		   	UnInstallROIServices(0);
		    
		  	// Changed for DevStudio 9, Disk1 files are now always updated when installed
			// so when running from ADDREMOVE we need to prevent these files from being
			// updated since this will result in files being updated that are locked by the setup.
			// Updating these files when running from ADDREMOVE should not be needed since updates
			// are not run directly from Add/Remove.
            if( ADDREMOVE ) then
                // Reinstall all previously installed features, except
                // disk1 features.
                FeatureUpdate( "" );
            else
                // Reinstall all previously installed features.
                FeatureReinstall();
            endif;

            // Added in 11.0 - Set appropriate StatusEx static text.
            SetStatusExStaticText( SdLoadString( IDS_IFX_STATUSEX_STATICTEXT_MAINTUI_REPAIR ) );
            //to be done later
            //SetStatusExStaticText("Repair process is in progress");
        case MODIFY:
            
            // Added in 11.0 - Set appropriate StatusEx static text.
            SetStatusExStaticText( SdLoadString( IDS_IFX_STATUSEX_STATICTEXT_MAINTUI_MODIFY ) );
            
              //to be done later
              //SetStatusExStaticText("Modify process is in progress");
    endswitch;
 
end;   

//---------------------------------------------------------------------------
// OnMaintUIAfter
//
// The OnMaintUIAfter event called by OnShowUI after the file transfer
// of the setup when the setup is running in maintenance mode. By default
// this event displays UI that informs the end user that the maintenance setup
// has been completed successfully.
//
// Note: This event will not be called automatically in a
// program...endprogram style setup.
//---------------------------------------------------------------------------
function OnMaintUIAfter()
    STRING szTitle, szMsg1, szMsg2, szOpt1, szOpt2;  
    STRING configFileName;
    NUMBER bvOpt1, bvOpt2;    
    int nvInfo;
 	string svInfo;
 	LIST sListInfo;
begin            
	LogEnterMessage("OnMaintUIAfter()");

    ShowObjWizardPages(NEXT);
    
    // Added - Version 9.5 - Use appropriate strings for complete
    // uninstall.
    if( REMOVEALLMODE ) then
        szTitle = SdLoadString(IFX_SDFINISH_REMOVE_TITLE);
        szMsg1 =  "Components have been removed successfully";//SdLoadString(IFX_SDFINISH_REMOVE_MSG1);
    else
        szTitle = SdLoadString(IFX_SDFINISH_MAINT_TITLE);    
        szMsg1  = "Components have been modified successfully"; //SdLoadString(IFX_SDFINISH_MAINT_MSG1);
    endif;

	szMsg2 = "";    
    szOpt1 = "";
    szOpt2 = "";
	bvOpt1   = FALSE;
    bvOpt2   = FALSE;    

    if ( BATCH_INSTALL ) then 
    	if (isRepairMode) then 
    		// Restores ROI configuration files
    		LogMessage("Restores ROI configuration files");
    		
    		// checking whether ROIServer is selected by user or not
			FeatureGetData( MEDIA, ROIServer, FEATURE_FIELD_SELECTED, nvInfo, svInfo );
		
			// if nvInfo is true mean ROIServer has been selected by user
	    	if nvInfo then 
		        	
		    	// to modify the ROIServer properties in the config util property file
				ModifyConfigureROIServerProperites();   
				InstallROIJBossService();  
		  	endif;
			
			// if nvInfo is true mean OutputService has been selected by user
			FeatureGetData( MEDIA, OutputService, FEATURE_FIELD_SELECTED, nvInfo, svInfo );
	  		if nvInfo then
	    		
	    		// to modify the OutputService properties in the config util property file
				ModifyConfigureUtilProperitesForOutput();	
				InstallOutputJBossService();
		  	endif;                          
					
			// if nvInfo is true mean FaxService component has been selected by user
			FeatureGetData( MEDIA, FaxService, FEATURE_FIELD_SELECTED, nvInfo, svInfo );
	    	if nvInfo then
	    		    		
	    		// to modify the FaxService properties in the config util property file
				ModifyConfigureUtilProperitesForFax();
				InstallFaxService();
			endif;   
	    
	    	CustomizeConfigUtilProps();
	    	CreateConfigUtilBat();
	    	
	    endif;
	    	SdFinishReboot ( szTitle , szMsg1 , SYS_BOOTMACHINE , szMsg2 , 0 );
	    	CustomizeConfigUtilProps();
			LaunchConfigureServerUtility();
    else   
		// Restores Client config files
		LogEnterMessage("Restores ROI configuration details.");
		
		// checking whether ROIServer is selected by user or not
		FeatureGetData( MEDIA, ROIServer, FEATURE_FIELD_SELECTED, nvInfo, svInfo );
	
		// if nvInfo is true mean ROIServer has been selected by user
		if nvInfo then 
    	    	
    		// to modify the ROIServer properties in the config util property file
			ModifyConfigureROIServerProperites();
		endif;
	
		// if nvInfo is true mean OutputService has been selected by user
		FeatureGetData( MEDIA, OutputService, FEATURE_FIELD_SELECTED, nvInfo, svInfo );
		if nvInfo then
    		
    		// to modify the OutputService properties in the config util property file
			ModifyConfigureUtilProperitesForOutput();
		
		endif;                          
			
		// if nvInfo is true mean FaxService component has been selected by user
		FeatureGetData( MEDIA, FaxService, FEATURE_FIELD_SELECTED, nvInfo, svInfo );
		if nvInfo then
		    		
			// to modify the FaxService properties in the config util property file
			ModifyConfigureUtilProperitesForFax();
		endif;   

    	CustomizeConfigUtilProps();
    	CreateConfigUtilBat();
    	SdFinish ( szTitle , szMsg1 , szMsg2 , szOpt1 , szOpt2 , bvOpt1 , bvOpt2 );      
    	LaunchConfigureServerUtility();	    	
    endif;
	LogExitMessage("OnMaintUIAfter()");   
end;



////////////////////////////////////////////////////////////////////////////////
// CreateSelectionList()
//
// Function creates the lIST of component selected by user
// for installation.
//
////////////////////////////////////////////////////////////////////////////////
          
 
function LIST CreateSelectionList()
 int nvInfo;
 string svInfo;
 LIST sListInfo;
 begin   
 		sListInfo = ListCreate(STRINGLIST);
 		
        // checking whether ROIServer is selected by user or not
		FeatureGetData( MEDIA, ROIServer, FEATURE_FIELD_SELECTED, nvInfo, svInfo );
		
		// if nvInfo is true mean ROIServer has been selected by user
    	if nvInfo then 
	    	    	
	    	// add selected component into sListInfo.
			ListAddString( sListInfo, ROIServer, AFTER );
			
		endif;
		 
		// if nvInfo is true mean ROIClientInstallation has been selected by user 
		FeatureGetData( MEDIA, ROIClientInstallation, FEATURE_FIELD_SELECTED, nvInfo, svInfo );
    	if nvInfo then
    		    		
    		// add selected component into sListInfo.
			ListAddString( sListInfo, ROIClientInstallation, AFTER );
			
		endif;  
		
		// if nvInfo is true mean OutputService has been selected by user
		FeatureGetData( MEDIA, OutputService, FEATURE_FIELD_SELECTED, nvInfo, svInfo );
    	if nvInfo then
    		
    		// add selected component into sListInfo.
			ListAddString( sListInfo,OutputService, AFTER );
			
		endif;                          
				
		// if nvInfo is true mean FaxService component has been selected by user
		FeatureGetData( MEDIA, FaxService, FEATURE_FIELD_SELECTED, nvInfo, svInfo );
    	if nvInfo then
    		    		
    		// add selected component into sListInfo.
			ListAddString( sListInfo, FaxService, AFTER );
			
		endif;     
		
	return sListInfo;
		      
 end;         
 
////////////////////////////////////////////////////////////////////////////////
// CheckNewSelectOrDeSelectComponent()
//
// Function checks the difference in given two lIST of component 
// selected by user for installation.
// return 1 = user has modified the component list.
// return 0 = user has not modified the component list.
////////////////////////////////////////////////////////////////////////////////

function int CheckNewSelectOrDeSelectComponent(previousInfo , newInfo)
number nResult1,nResult2,nCount1,nCount2;

begin  
		ListSetIndex (previousInfo, 0); // Go to the top of the list
		ListSetIndex (newInfo, 0); // Go to the top of the list
		
		nCount1 = ListCount(previousInfo); 
		nCount2 = ListCount(newInfo);   
		
		// if count of element in two list is different means,
		// user has modified the previous installation list.
		if(nCount1 != nCount2) then
			return 1;
		else	
		
			// finding ROIServer is existing in two list.
			nResult1 = ListFindString (previousInfo, ROIServer);
			nResult2 = ListFindString (newInfo, ROIServer);  
			
			// if result of search is differentmeans
			// user has modifed the setup list.			
			if (nResult1 != nResult2) then
				return 1;
			endif; 
            
            // finding ROIClientInstallation is existing in two list.      
  		    nResult1 = ListFindString (previousInfo, ROIClientInstallation);
			nResult2 = ListFindString (newInfo, ROIClientInstallation);  
			
			// if result of search is differentmeans
			// user has modifed the setup list.			
			if (nResult1 != nResult2) then
				return 1;
			endif; 
		     
		    // finding OutputService is existing in two list. 
			nResult1 = ListFindString (previousInfo, OutputService);
			nResult2 = ListFindString (newInfo, OutputService);  
			
			// if result of search is differentmeans
			// user has modifed the setup list.			
			if (nResult1 != nResult2) then
				return 1;
			endif; 
		    
		   		
			// finding FaxService is existing in two list.
			nResult1 = ListFindString (previousInfo, FaxService);
			nResult2 = ListFindString (newInfo, FaxService);  
			
			// if result of search is differentmeans
			// user has modifed the setup list.			
			if (nResult1 != nResult2) then
				return 1;
			endif;
		endif ;
		
	return 0;
end;  

function string getInstalledVersion()  
string  szSubStr, installedVersion, szVersion, szResult1, szResult2, szResult3; 
number nvVarMinor, nvVarBuild, nvVarMajor;
begin
    
	installedVersion = IFX_INSTALLED_VERSION;
	
	StrSub(szSubStr, installedVersion, 0, 2);
	StrToNum(nvVarMajor, szSubStr); 
	 
	StrSub(szSubStr, installedVersion, 3, 2);
	StrToNum(nvVarMinor, szSubStr); 
	
	StrSub(szSubStr, installedVersion, 6, 3);
	StrToNum(nvVarBuild, szSubStr);  
	
	 NumToStr(szResult1, nvVarMajor);
	 NumToStr(szResult2, nvVarMinor);
	 NumToStr(szResult3, nvVarBuild);
	   
	szVersion = szResult1 + "." + szResult2 + "." +  szResult3;
	return szVersion;
end;  

function string getJbossVersion(version)
string  szSubStr, szInstalledJbossVersion;
begin
    StrSub ( szSubStr, version, 0, 4);
	if (szSubStr == "13.5" || szSubStr == "15.0") then
		szInstalledJbossVersion = "4";
	else 
	    szInstalledJbossVersion = "5";
	endif;
	return szInstalledJbossVersion;
end;           

////////////////////////////////////////////////////////////////////////////////
// ModifyMPFWConfiguration()
//
// Function updates MPFW Configuration
////////////////////////////////////////////////////////////////////////////////

function ModifyMPFWConfiguration(serverLocation, applicationName)       
string szProdLogFilePath, szStagLogFilePath, fileLocation; 
string szLogLocation ,hostname, sCompName;
begin
	LogEnterMessage("Start ModifyMPFWConfiguration in " + serverLocation);      
	szLogLocation = serverLocation + LOG_LOCATION;
	
	StrReplace (szLogLocation, "\\", "/", 0); 
	                                                  
	szProdLogFilePath = serverLocation ^ LOG_PRODUCTION_PROPS_FILE;   
	ReplaceFromFile(szProdLogFilePath, "$!LOG_PATH_FULL_XML!$", szLogLocation);
	                                                    
	szStagLogFilePath = serverLocation ^ LOG_STAGING_PROPS_FILE;             
	ReplaceFromFile(szStagLogFilePath, "$!LOG_PATH_FULL_XML!$", szLogLocation);
	      
	fileLocation = serverLocation ^ MPFW_ENCRYPTION_CONFIG_PATH;
	ReplaceFromFile(fileLocation,"$!PWD_ENCRYPT_CLASS!$" , DEFAULT_MPFW_ENCRYPTION_CLASS);
	
	fileLocation = serverLocation ^ MPFW_WEB_XML_PATH;
	ReplaceFromFile(fileLocation, "$!APPLICATION!$" , applicationName);
	
	GetEnvVar("ComputerName", sCompName);
	hostname = applicationName + ":" + sCompName;
	fileLocation = serverLocation ^ LOG_PRODUCTION_PROPS_FILE;
	ReplaceFromFile(fileLocation, "$!HPFW_HOSTNAME!$" , hostname); 
	
	LogExitMessage("Finished Modifying ModifyMPFWConfiguration in " + serverLocation);
end;  

////////////////////////////////////////////////////////////////////////////////
// ReplaceFromFile(string,string,string)
//
// Function Replace the given String from the given file
// selected by user for installation.
// 
////////////////////////////////////////////////////////////////////////////////
 
function ReplaceFromFile(filelocation, szSearchStr, szReplaceStr)
 string svReturnLine; 
 number nvLineNumber;
 
 begin

    LogEnterMessage("Start ReplaceFromFile" + filelocation);
    FileGrep(filelocation, szSearchStr, svReturnLine, nvLineNumber, RESTART );

    // Delete the specific line where pattern was found first
    FileDeleteLine (filelocation, nvLineNumber, nvLineNumber);

    StrReplace(svReturnLine, szSearchStr, szReplaceStr, 0);
   
       //Insert Modified entry to deleted line number
    FileInsertLine (filelocation, svReturnLine, nvLineNumber, BEFORE);
    LogExitMessage("Finished ReplaceFromFile");
end;

//////////////////////////////////////////////////////////////////////////////
//
//  FUNCTION:   OnBegin
//
//  EVENT:      Begin event is always sent as the first event during installation.
//
//////////////////////////////////////////////////////////////////////////////
function OnBegin()
begin
	FeatureSelectItem(MEDIA, "Java32bitComponent", FALSE);        
	FeatureSelectItem(MEDIA, "Java64bitComponent", FALSE);        
end;        

//////////////////////////////////////////////////////////////////////////////
//
//  FUNCTION:   readJniPort 
//
//  EVENT:      Jni serice port is taken from the service binding xml 
//
//////////////////////////////////////////////////////////////////////////////
function string GetJniServicePort(jbossBindingXmlFilePath)  
string szSearchStr, svReturnLine1, svReturnLine2, szString, szPortNumber;   
number nvLineNumber1, nvLineNumber2; 
LIST parsedString;
begin               
	
	parsedString = ListCreate(STRINGLIST); 
	ListDeleteAll(parsedString);
	
	// search for the jni port number
	FileGrep(jbossBindingXmlFilePath, JNI_BINDING_NAME, svReturnLine1, nvLineNumber1, RESTART);
	FileGrep(jbossBindingXmlFilePath, "name=\"port\"", svReturnLine2, nvLineNumber2, CONTINUE); 
	StrGetTokens(parsedString, svReturnLine2, ">");
	
	ListGetFirstString(parsedString, szString);
	
	ListGetNextString(parsedString, szString);
	ListDeleteAll(parsedString);
	
	StrGetTokens(parsedString, szString, "<");
	ListGetFirstString(parsedString, szPortNumber);
	return szPortNumber;
	
end;
		
