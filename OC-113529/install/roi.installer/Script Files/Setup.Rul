 end;


///////////////////////////////////////////////////////////////////////////////
//	Launches Fax Service uninstallation
//
///////////////////////////////////////////////////////////////////////////////
function UninstallFaxService(szSvcName, nUseBatchFile)
string szCmd;  
int nRet, nState; 
int nCanbeRemoved; 
STRING szScriptFile;  
int nLineNumber, nvError;
begin
    LogEnterMessage("Launching the Fax Service uninstallation");
 
 	// stops the fax server, if it is running
	LaunchAppAndWait("", FAX_SERVER_KILL_COMMAND, WAIT); 
	
    if(nUseBatchFile ==1) then 
	    if (LaunchApp(FAX_SERVICE_UNINSTALL_BAT, "") < 0)
	    then
	   	   LogMessage("Failed to launch the Fax Service uninstallation");
	    endif;
   endif;
  
   if(ServiceExistsService (szSvcName) == TRUE ) then  
   	   nCanbeRemoved = TRUE;	
   	   nRet = ServiceGetServiceState ( szSvcName, nState);
   	   if(nRet >= ISERR_SUCCESS && nState == SERVICE_RUNNING) then
		   if(ServiceStopService(szSvcName) >= ISERR_SUCCESS ) then
		   		LogMessage( "(" + szSvcName + ")" + " service stopped successfully");
		   else
		   		LogMessage( "(" + szSvcName + ")" + " service failed to stop");
		   		nCanbeRemoved = FALSE;
		   		GetExtendedErrInfo(szScriptFile, nLineNumber, nvError);
		   		LogMessage("Error: " + FormatMessage(nvError));  
			endif;
	   else
	   	   LogMessage( "(" + szSvcName + ")" + " service is not running");
	   endif;	
	   if(nCanbeRemoved == TRUE) then
		   if(ServiceRemoveService(szSvcName) >= ISERR_SUCCESS) then
	   		   LogMessage( "(" + szSvcName + ")" + " service removed successfully");
           else
	   		   LogMessage( "(" + szSvcName + ")" + " service failed to remove");
	   		   GetExtendedErrInfo(szScriptFile, nLineNumber, nvError);
		   	   LogMessage("Error: " + FormatMessage(nvError));  
	   	   endif;	
		endif;
	else
		LogMessage( "(" + szSvcName + ")" + " service not exists");
	endif;
	 
    LogExitMessage("Finished launching the Fax Service uninstallation.");
end;

////////////////////////////////////////////////////////////////////////////////
// CreateLogFolder
//
// Function creates the log folder/file "C\\ROILog\Install.log"
//
////////////////////////////////////////////////////////////////////////////////
function CreateLogFolder()
string svResult;
begin
	// Create/modify installation log file

    OpenFileMode(FILE_MODE_APPEND);
    //Creating Log Directory
    if(ExistsDir(LOG_FOLDER_LOCATION)=NOTEXISTS) then
   	  	CreateDir(LOG_FOLDER_LOCATION);
    endif;

	 // open file in Append Mode.
	OpenFileMode(FILE_MODE_APPEND);

 	 // creating Log file.
    CreateFile(nvFileHandle, LOG_FOLDER_LOCATION, LOG_FILE_NAME);

    // getting the current Date & time .
    GetSystemInfo(DATE, nvResult, svResult);
    Sprintf(svDate, "DATE: %s", svResult);
    GetSystemInfo(TIME, nvResult, svResult);
    Sprintf(svTime, "TIME: %s", svResult);

    OpenFileMode(FILE_MODE_APPEND);

    //adding log messages to log file.
    WriteLine(nvFileHandle, "--------------Log File---------------");
    WriteLine(nvFileHandle, "Created on --> " + svDate + " " + svTime);
    WriteLine(nvFileHandle, "Installing ROI component files");
end;

