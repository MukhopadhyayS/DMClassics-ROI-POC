<?xml version="1.0"?>
<configuration>
  <configSections>
  </configSections>
  <appSettings>
    <!--Logging configuration  -->
    <add key="LogConfigFileName" value="McK.EIG.COMMON.OUTPUT.FAX.Log.xml"/>

    <!--MQ configuration  -->
    <add key="MQServer" value="localhost"/>
    <add key="MQPort" value="61617"/>
    <add key="MQFaxTopicName" value="topic_eigFax"/>
    <add key="MQFaxStatusTopicName" value="topic_eigFaxStatus"/>
    <add key="MQFaxStatusResponseQueueName" value="queue.eigFaxStatusResponse"/>
    <add key="MQFaxStatusResponseQueuePhysicalName" value="queue.eigFaxStatusResponse"/>

    <!--TIFF converter configuration  -->
    <add key="OutputTempDir" value="./tiffTemp"/>
    <add key="Resolution" value="200"/>
    <add key="ColorTiff" value="true"/>
    <add key="CleanUp" value="true"/>

    <!--Fax Service Mode -->
    <add key="FaxServerType" value="RightFax" />

    <!--Fax Server configuration  -->
    <add key="FaxServerName" value="FAXSERVERNAME"/>
    <add key="FaxQueueName" value="ROI_FAX"/>
    <add key="FaxPassword" value=""/>
   
    <!--DB Configuration -->    
    <add key="dbServer" value="HPFDATA"/>
    <add key="roiUser" value="ROIUSER"/>
    <add key="roiAccess" value="ROIPASSWORD"/>
    <add key="dbName" value="Cabinet"/>
    <add key="spName" value="Output_UpdateFaxJobStatus"/>

    <!--Common Log Configuration -->
    <add key="globalName" value="Common Fax Service"/>
    <add key="globalIDretrievalSP" value="EPRS_stats_GetComponentID_ByName"/>
    <add key="dbLogQuery" value="INSERT INTO [cabinet].[dbo].[SYSERRORS_GLOBAL]([GlobalID],[OCCURRED],[ERROR_TYPE],[ERROR_DESC])
                 VALUES ('{0:d}',@log_date,@log_level,'ROI Fax: '+@message )"/>
    
	<add key="fax.status.refresh.time" value="300000"/>
  <add key="fax.send.sleep.time" value="20000"/>
  <add key="fax.send.max.retries" value="5"/>

  </appSettings>
<startup><supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.0"/></startup></configuration>
