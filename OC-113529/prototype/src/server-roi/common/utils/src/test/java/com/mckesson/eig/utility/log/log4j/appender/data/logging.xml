<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE log4j:configuration SYSTEM "log4j.dtd">

<log4j:configuration xmlns:log4j='http://jakarta.apache.org/log4j/'>

  <appender name="JMS" class="com.mckesson.eig.utility.log.log4j.appender.JMSQueueAppender">
	<param name="ProviderURL" value="tcp://127.0.0.1:61616" />
	<param name="InitialContextFactoryName" value="org.apache.activemq.jndi.ActiveMQInitialContextFactory" />
	<param name="QueueBindingName" value="queue/eigAlert" />
	<param name="QueuePhysicalName" value="queue.eigAlert" />
	<param name="QueueConnectionFactoryBindingName" value="QueueConnectionFactory" />
    <layout class="org.apache.log4j.PatternLayout">
      <param name="ConversionPattern" value="%m"/>
    </layout>
  </appender>

  <appender name="JMS_INVALID_QUEUE" class="com.mckesson.eig.utility.log.log4j.appender.JMSQueueAppender">
    <param name="ProviderURL" value="tcp://127.0.0.1" />
    <param name="InitialContextFactoryName" value="org.apache.activemq.jndi.ActiveMQInitialContextFactory" />
    <param name="QueueBindingName" value="test/test" />
    <param name="QueuePhysicalName" value="test.test" />
    <param name="QueueConnectionFactoryBindingName" value="QueueConnectionFactory" />
  </appender>

  <appender name="JMS_LAYOUT_ERROR" class="com.mckesson.eig.utility.log.log4j.appender.JMSQueueAppender">
    <param name="ProviderURL" value="tcp://127.0.0.1:61616" />
    <param name="InitialContextFactoryName" value="org.apache.activemq.jndi.ActiveMQInitialContextFactory" />
    <param name="QueueBindingName" value="queue/eigAlert" />
    <param name="QueuePhysicalName" value="queue.eigAlert" />
    <param name="QueueConnectionFactoryBindingName" value="QueueConnectionFactory" />
  </appender>

  <appender name="eigConsoleAppender"
              class="org.apache.log4j.ConsoleAppender">
        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern" value="%d{DATE} | %t | %X{ipaddress} | %X{userid} | %X{transactionid} | %c{1} | %m%n " />
        </layout>
    </appender>

    <!-- Log events through SNMP -->
    <appender name="TRAP_LOG" class="org.apache.log4j.ext.SNMPTrapAppender">
        <errorHandler class="org.jboss.logging.util.OnlyOnceErrorHandler"/>
        <param name="ImplementationClassName" value="org.apache.log4j.ext.JoeSNMPTrapSender"/>
        <param name="ManagementHost" value="127.0.0.1"/>
        <param name="ManagementHostTrapListenPort" value="162"/>
        <param name="EnterpriseOID" value="1.3.6.1.4.1.24.0"/>
        <param name="LocalIPAddress" value="127.0.0.1"/>
        <param name="LocalTrapSendPort" value="161"/>
        <param name="GenericTrapType" value="6"/>
        <param name="SpecificTrapType" value="12345678"/>
        <param name="CommunityString" value="public"/>
        <param name="ForwardStackTraceWithTrap" value="true"/>
        <param name="Threshold" value="DEBUG"/>
        <param name="ApplicationTrapOID" value="1.3.6.1.4.1.24.12.10.22.64"/>
        <layout class="org.apache.log4j.PatternLayout">
              <param name="ConversionPattern" value="%m"/>
        </layout>
    </appender>


  <category name="com.mckesson.eig.utility.log.log4j.appender.TestJMSQueueAppender" additivity="false">
    <priority value="fatal" />
    <appender-ref ref="JMS" />
    <appender-ref ref="eigConsoleAppender" />
  </category>

  <category name="com.mckesson.eig.utility.log.log4j.appender.TestJMSQueueAppender1" additivity="false">
    <priority value="fatal" />
    <appender-ref ref="JMS_INVALID_QUEUE" />
    <appender-ref ref="eigConsoleAppender" />
  </category>

  <category name="com.mckesson.eig.utility.log.log4j.appender.TestJMSQueueAppender2" additivity="false">
    <priority value="fatal" />
    <appender-ref ref="JMS_LAYOUT_ERROR" />
    <appender-ref ref="eigConsoleAppender" />
  </category>

</log4j:configuration>