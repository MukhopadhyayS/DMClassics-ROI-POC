<?xml version="1.0" encoding="UTF-8"?>
<mapping xmlns:eig="urn:eig.mckesson.com">

	<class name="com.mckesson.eig.roi.billing.model.ChargeHistory">
		<map-to xml="chargeHistory" ns-prefix="eig" ns-uri="urn:eig.mckesson.com" />
	
		<field name="totalFeeCharge" type="double">
			<bind-xml name="eig:totalFeeCharge" node="element" />
		</field>
	
		<field name="totalDocumentCharge" type="double">
			<bind-xml name="eig:totalDocumentCharge" node="element" />
		</field>
	
		<field name="totalShippingCharge" type="double">
			<bind-xml name="eig:totalShippingCharge" node="element" />
		</field>
	
		<field name="totalSalesTax" type="double">
			<bind-xml name="eig:totalSalesTax" node="element" />
		</field>
		
		<field name="releaseDate" type="date">
			<bind-xml name="eig:releaseDate" node="element" />
		</field>
		
		<field name="unbillableAmount" type="double">
			<bind-xml name="eig:unbillableAmount" node="element" />
		</field>
	</class>
	
	<class name="com.mckesson.eig.roi.billing.model.ChargeHistoryList">
		<map-to xml="chargeHistoryList" ns-prefix="eig" ns-uri="urn:eig.mckesson.com"/>
	
		<field name="chargeHistories" type="com.mckesson.eig.roi.billing.model.ChargeHistory" collection="arraylist">
			<bind-xml name="eig:chargeHistories" node="element" />
		</field>
	</class>
</mapping>