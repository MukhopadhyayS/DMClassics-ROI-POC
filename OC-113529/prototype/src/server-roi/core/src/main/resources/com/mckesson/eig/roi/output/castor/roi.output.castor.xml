<?xml version="1.0" encoding="UTF-8"?>
<mapping xmlns:eig="urn:eig.mckesson.com">
	
	<class name="com.mckesson.eig.roi.output.model.OutputRequest">
		<map-to xml="OutputRequest" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />
		
		<field name="requestParts" collection="arraylist" type="com.mckesson.eig.roi.output.model.RequestPart">
			<bind-xml name="eig:requestParts" node="element" />
		</field>
		<field name="destId" type="int">
			<bind-xml name="eig:destId" node="element" />
		</field>
		<field name="destName" type="string">
			<bind-xml name="eig:destName" node="element" />
		</field>
		<field name="destType" type="string">
			<bind-xml name="eig:destType" node="element" />
		</field>
		<field name="properties" collection="arraylist" type="com.mckesson.eig.roi.output.model.MapModel">
			<bind-xml name="eig:properties" node="element" />
		</field>
		<field name="labels" collection="arraylist" type="com.mckesson.eig.roi.output.model.MapModel">
			<bind-xml name="eig:labels" node="element" />
		</field>

		<field name="requestId" type="string">
			<bind-xml name="eig:requestId" node="element" />
		</field>
		
		<field name="submitInfo" type="com.mckesson.eig.roi.output.model.SubmitInfo">
			<bind-xml name="eig:submitInfo" node="element" />
		</field>
		
		<field name="outputTransforms" collection="arraylist" type="com.mckesson.eig.roi.output.model.OutputTransform">
			<bind-xml name="eig:outputTransforms" node="element" />
		</field>

	</class>
	
	<class name="com.mckesson.eig.roi.output.model.OutputFeature">
		<map-to xml="OutputFeature" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />
		
		<field name="outputFeatureId" type="long">
			<bind-xml name="eig:outputFeatureId" node="element" />
		</field>
		<field name="name" type="string">
			<bind-xml name="eig:name" node="element" />
		</field>
		<field name="description" type="string">
			<bind-xml name="eig:description" node="element" />
		</field>
		<field name="attributes" type="org.exolab.castor.mapping.MapItem" collection="map">
			<bind-xml name="eig:attributes" node="element" >
				<class name="org.exolab.castor.mapping.MapItem">
	                 <field name="key" type="string">
	                     <bind-xml name="eig:key" node="element" />
	                 </field>
	                 <field name="value" type="string">
	                     <bind-xml name="eig:value" node="element" />
	                 </field>
            	 </class>
            </bind-xml>
		</field>
		
	</class>
	
	
	
	<class name="com.mckesson.eig.roi.output.model.RequestPart">
		<map-to xml="RequestPart" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />
		
		<field name="contentId" type="string">
			<bind-xml name="eig:contentId" node="element" />
		</field>

		<field name="contentSourceName" type="string">
			<bind-xml name="eig:contentSourceName" node="element" />
		</field>
		
		<field name="contentSourceType" type="string">
			<bind-xml name="eig:contentSourceType" node="element" />
		</field>
		
		<field name="properties" collection="arraylist" type="com.mckesson.eig.roi.output.model.MapModel">
			<bind-xml name="eig:properties" node="element" />
		</field>
		
		<field name="outputTransforms" collection="arraylist" type="com.mckesson.eig.roi.output.model.MapModel">
			<bind-xml name="eig:outputTransforms" node="element" />
		</field>

	</class>
	
	<class name="com.mckesson.eig.roi.output.model.MapModel">
		<map-to xml="MapModel" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />
		
		<field name="key" type="string">
			<bind-xml name="eig:key" node="element" />
		</field>

		<field name="value" type="string">
			<bind-xml name="eig:value" node="element" />
		</field>
		
	</class>

	<class name="com.mckesson.eig.roi.output.model.OutputTransform">
		<map-to xml="OutputTransform" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />
			
		<field name="properties" collection="arraylist" type="com.mckesson.eig.roi.output.model.MapModel">
			<bind-xml name="eig:properties" node="element" />
		</field>

		<field name="transformName" type="string">
			<bind-xml name="eig:transformName" node="element" />
		</field>
		
		<field name="transformType" type="string">
			<bind-xml name="eig:transformType" node="element" />
		</field>
		
	</class>
	
    <class name="com.mckesson.eig.roi.output.model.SubmitInfo">
		<map-to xml="SubmitInfo" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />

		<field name="application" type="string">
			<bind-xml name="eig:application" node="element" />
		</field>

		<field name="submitDate" type="date">
			<bind-xml name="eig:submitDate" node="element" />
		</field>
		
		<field name="submitMachine" type="string">
			<bind-xml name="eig:submitMachine" node="element" />
		</field>
		
		<field name="submitterData" type="string">
			<bind-xml name="eig:submitterData" node="element" />
		</field>
		
		<field name="user" type="string">
			<bind-xml name="eig:user" node="element" />
		</field>
		
	</class>
	
	<class name="com.mckesson.eig.roi.output.model.StatusInfo">
		<map-to xml="StatusInfo" ns-prefix="eig" 
			ns-uri="urn:eig.mckesson.com" />
			
		<field name="statusCode" type="int">
			<bind-xml name="eig:statusCode" node="element" />
		</field>

		<field name="status" type="string">
			<bind-xml name="eig:status" node="element" />
		</field>
		
		<field name="detail" type="string">
			<bind-xml name="eig:detail" node="element" />
		</field>
		
		<field name="statusDate" type="date">
			<bind-xml name="eig:statusDate" node="element" />
		</field>
		
		<field name="statusSource" type="string">
			<bind-xml name="eig:statusSource" node="element" />
		</field>
		
		<field name="statusData" collection="arraylist" type="com.mckesson.eig.roi.output.model.MapModel">
			<bind-xml name="eig:statusData" node="element" />
		</field>

	</class>
	
	<class name="com.mckesson.eig.roi.output.model.PropertyDef">
		<map-to xml="PropertyDef" ns-prefix="eig" 
			ns-uri="urn:eig.mckesson.com" />
			
		<field name="propertyName" type="string">
			<bind-xml name="eig:propertyName" node="element" />
		</field>
		
		<field name="label" type="string">
			<bind-xml name="eig:label" node="element" />
		</field>
		
		<field name="description" type="string">
			<bind-xml name="eig:description" node="element" />
		</field>
		
		
		<field name="dataType" type="string">
			<bind-xml name="eig:dataType" node="element" />
		</field>
		
		
		<field name="defaultValue" type="string">
			<bind-xml name="eig:defaultValue" node="element" />
		</field>
		
		
		<field name="required" type="string">
			<bind-xml name="eig:required" node="element" />
		</field>
		
		<field name="bindingProperty" type="string">
			<bind-xml name="eig:bindingProperty" node="element" />
		</field>
		
		
		<field name="possibleValues" collection="array" type="string" >
			<bind-xml name="eig:possibleValues" node="element" />
		</field>
		
		
		<field name="index" type="string">
			<bind-xml name="eig:index" node="element" />
		</field>
		
		
		<field name="pairPropertyName" type="string">
			<bind-xml name="eig:pairPropertyName" node="element" />
		</field>
		
		
		<field name="rowCount" type="string">
			<bind-xml name="eig:rowCount" node="element" />
		</field>
		
		
		<field name="contextMenu" collection="array" type="string">
			<bind-xml name="eig:contextMenu" node="element" />
		</field>
		
		
		<field name="jsAction" type="string">
			<bind-xml name="eig:jsAction" node="element" />
		</field>
		
		
		<field name="size" type="string">
			<bind-xml name="eig:size" node="element" />
		</field>
		
		
		<field name="maxLength" type="string">
			<bind-xml name="eig:maxLength" node="element" />
		</field>

	</class>
	
	
	<class name="com.mckesson.eig.roi.output.model.DestInfoList">
		<map-to xml="DestInfoList" ns-prefix="eig" 
			ns-uri="urn:eig.mckesson.com" />
			
		<field name="destInfoList" collection="arraylist" type="com.mckesson.eig.roi.output.model.DestInfo">
			<bind-xml name="eig:destInfoList" node="element" />
		</field>
		

	</class>
	
	<class name="com.mckesson.eig.roi.output.model.DestInfo">
		<map-to xml="DestInfo" ns-prefix="eig" 
			ns-uri="urn:eig.mckesson.com" />
			
		<field name="serviceId" type="string">
			<bind-xml name="eig:serviceId" node="element" />
		</field>
		
		<field name="statusInfo"  type="com.mckesson.eig.roi.output.model.StatusInfo">
			<bind-xml name="eig:statusInfo" node="element" />
		</field>
		
		<field name="propertyDefs" collection="array" type="com.mckesson.eig.roi.output.model.PropertyDef">
			<bind-xml name="eig:propertyDefs" node="element" />
		</field>
		
		<field name="jobOptionDefs" collection="array" type="com.mckesson.eig.roi.output.model.PropertyDef">
			<bind-xml name="eig:jobOptionDefs" node="element" />
		</field>
		
		<field name="id" type="int">
			<bind-xml name="eig:id" node="element" />
		</field>
		
		<field name="name" type="string">
			<bind-xml name="eig:name" node="element" />
		</field>
		
		<field name="type" type="string">
			<bind-xml name="eig:type" node="element" />
		</field>
		
		<field name="description" type="string">
			<bind-xml name="eig:description" node="element" />
		</field>
		
		<field name="properties" type="org.exolab.castor.mapping.MapItem" collection="map">
			<bind-xml name="eig:properties" node="element" >
				<class name="org.exolab.castor.mapping.MapItem">
	                 <field name="key" type="string">
	                     <bind-xml name="eig:key" node="element" />
	                 </field>
	                 <field name="value">
	                     <bind-xml name="eig:value" node="element" />
	                 </field>
            	 </class>
            </bind-xml>
		</field>
		
	</class>
	
</mapping>
