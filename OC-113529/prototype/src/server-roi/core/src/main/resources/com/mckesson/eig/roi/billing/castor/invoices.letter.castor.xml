<?xml version="1.0" encoding="UTF-8"?>
<mapping xmlns:eig="urn:eig.mckesson.com">
 <class name="com.mckesson.eig.roi.billing.model.InvoiceAndLetterInfo">
    <map-to xml="InvoiceAndLetterInfo" ns-prefix="eig" ns-uri="urn:eig.mckesson.com"/>

    <field name="invoices"  collection="arraylist" type="com.mckesson.eig.roi.billing.model.RequestorInvoices">
        <bind-xml name="eig:invoices" node="element" />
    </field>

    <field name="invoiceTemplateId" type="long">
        <bind-xml name="eig:invoiceTemplateId" node="element" />
    </field>

    <field name="letterTemplateId" type="long">
        <bind-xml name="eig:letterTemplateId" node="element" />
    </field>

    <field name="requestorLetterTemplateId" type="long">
        <bind-xml name="eig:requestorLetterTemplateId" node="element" />
    </field>
    
    <field name="reqLetterNotes" type="string" collection="arraylist">
      <bind-xml name="eig:reqLetterNotes" node="element" />
    </field>

    <field name="invoiceNotes"  type="string" collection="arraylist">
      <bind-xml name="eig:invoiceNotes" node="element" />
    </field>
    
    <field name="pastInvIds" type="long" collection="array">
        <bind-xml name="eig:pastInvIds" node="element" />
    </field>
    
    <field name="isLetter" type="boolean">
         <bind-xml name="eig:isLetter" node="element"/>
    </field>
   
    <field name="isNewInvoice" type="boolean">
         <bind-xml name="eig:isNewInvoice" node="element"/>
    </field>
    
    <field name="isPastInvoice" type="boolean">
         <bind-xml name="eig:isPastInvoice" node="element"/>
    </field>

    <field name="outputInvoice" type="boolean">
         <bind-xml name="eig:outputInvoice" node="element"/>
    </field>
   
    
    <field name="properties" type="org.exolab.castor.mapping.MapItem" collection="map">
	    <bind-xml name="eig:properties" node="element">
	        <class name="org.exolab.castor.mapping.MapItem">
	            <field name="key" type="string">
	                <bind-xml name="eig:name" node="element" />
	            </field>
	            <field name="value" type="string">
	                <bind-xml name="eig:value" node="element" />
	            </field>
	        </class>
	    </bind-xml>
     </field>
     
     <field name="statementCriteria" type="com.mckesson.eig.roi.requestor.model.RequestorStatementCriteria">
		<bind-xml name="eig:statementCriteria" node="element"/>
	</field>

  </class>

  <class name="com.mckesson.eig.roi.billing.model.RequestorInvoices">
    <map-to xml="invoices" ns-prefix="eig" ns-uri="urn:eig.mckesson.com"/>

    <field name="invoiceIds" collection="array" type="long">
      <bind-xml name="eig:invoiceIds" node="element" />
    </field>

    <field name="requestorId" type="long">
      <bind-xml name="eig:requestorId" node="element" />
    </field>

    <field name="requestorName" type="string" >
      <bind-xml name="eig:requestorName" node="element" />
    </field>

    <field name="requestorType" type="string" >
      <bind-xml name="eig:requestorType" node="element" />
    </field>

  </class>

</mapping>