USE CABINET
GO

--FTS_INDEXING
IF EXISTS(SELECT 1 
			FROM SYSPARMS_GLOBAL 
			WHERE GLOBALNAME = 'FTS_Indexing.Index_Write')

BEGIN
	UPDATE SYSPARMS_GLOBAL
	SET [GlobalText] = 'The current status to write a full-text indexing for a document. false = Off, true = On, pause = Paused'
	WHERE [GlobalName] = 'FTS_Indexing.Index_Write' and 
		[GlobalText] not like 'The current status to write a full-text indexing for a document. false = Off, true = On, pause = Paused'
END
GO

--MPFCORE.CACHE_TMP_FILE_DIR
IF NOT EXISTS(SELECT 1 
				FROM SYSPARMS_GLOBAL
				WHERE GLOBALNAME = 'mpfcore.CACHE_TMP_FILE_DIR')

BEGIN
	INSERT [DBO].[SYSPARMS_GLOBAL] ([GlobalParentID], [GlobalName], [GlobalValueID], [GlobalVariant], [GlobalText], [CreatedDate], [CreatedById], [ModifiedDate], [ModifiedById], [RecordVersion]) VALUES (-104, N'mpfcore.CACHE_TMP_FILE_DIR', NULL, N'\\MPFDATA\global$\mpfcore\tmpcache', NULL, GETDATE(), 1,GETDATE(), 1, 1)
END
GO

