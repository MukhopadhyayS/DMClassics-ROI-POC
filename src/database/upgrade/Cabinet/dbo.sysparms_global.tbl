--ADI_WorkControl
IF NOT EXISTS(SELECT 1 
				FROM SYSPARMS_GLOBAL
				WHERE GLOBALNAME = 'ADI_Work_Control')
BEGIN
	SET IDENTITY_INSERT [DBO].[SYSPARMS_GLOBAL] ON

	INSERT [DBO].[SYSPARMS_GLOBAL] ([GlobalID], [GlobalParentID], [GlobalName], [GlobalValueID], [GlobalVariant], [GlobalText],	[CreatedDate], [CreatedById], [ModifiedDate], [ModifiedById], [RecordVersion]) 
	VALUES						   (-135, 1, N'ADI_Work_Control', NULL, 0, 'Value for ADI Work Control being passed to JAVA. 0 - Off, 1 - On.', GETDATE(), 1, GETDATE(), 1, 1)
	
	SET IDENTITY_INSERT [DBO].[SYSPARMS_GLOBAL] OFF
END
GO

-- mpfcore.outputservice_url
IF NOT EXISTS(SELECT 1 FROM SYSPARMS_GLOBAL WHERE GLOBALNAME = 'mpfcore.outputservice_url')
INSERT [DBO].[SYSPARMS_GLOBAL] ([GlobalParentID], [GlobalName], [GlobalValueID], [GlobalVariant], [GlobalText], [CreatedDate], [CreatedById], [ModifiedDate], [ModifiedById], [RecordVersion]) 
VALUES (-104, N'mpfcore.outputservice_url', NULL, 'http://localhost:8082/output', NULL, GETDATE(), 1,GETDATE(), 1, 1);
GO

