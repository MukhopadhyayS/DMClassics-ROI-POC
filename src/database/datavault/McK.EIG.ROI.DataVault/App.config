<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <configSections>
    <sectionGroup name="applicationSettings" type="System.Configuration.ApplicationSettingsGroup, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" >
      <section name="McK.EIG.ROI.Client.Properties.Settings" type="System.Configuration.ClientSettingsSection, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
    </sectionGroup>
  </configSections>
  
  <!-- Hpf Server Connection String-->
  <connectionStrings>
    <add name="DbProvider" providerName="System.Data.SqlClient" connectionString="Data Source=127.0.0.1; Initial Catalog=cabinet; UID=sa; PWD=sa;"/>
  </connectionStrings>
  
  <appSettings>
    
    <!-- Resources used in ROI-->
    <add key="roi.messages.resource" value=".Resources.Cultures.roi.messages"/>
    
    <add key="LogConfigFileName"  value="McK.EIG.ROI.DataVault.Log.xml"/>
    
    <!-- File name reflect the value from McK.EIG.ROI.DataVault.Log.xml, tag is VaultAppender-->
    <add key="ValidateLogFileName"  value="McK.EIG.ROI.Datavault.Validation.log"/>
    
    <add key ="UID"     value ="ADMIN"/>
    <add key ="PWD"     value ="1234"/>        
    
    <add key ="DataSet"           value = "../UploadFiles"/>
    <add key ="CsvDsnName"        value = "ROIDataVaultCsvFile"/>
    <add key ="XlsDsnName"        value = "ROIDataVaultExcelFile"/>
    <add key ="DataVaultFileType" value = "xls"/>

    <!--Alert server configuration  -->
    <add key="AlertServer"       value="127.0.0.1"/>
    <add key="AlertPort"         value="61616"/>
    <add key="AlertQueueName"    value="queue/eigAlert"/>
    <add key="AlertPhysicalName" value="queue.eigAlert"/>

    <!--File Trasnsfer -->
    <add key="ChunkEnabled" value="false"/>
    <add key="BlockSize"    value="10485760"/>

    <!--File Trasnsfer Servelet Url -->
    <add key="FileUploadServletUrl"   value="http://127.0.0.1:8080/roi/filetransfer/ROIFileUploadServlet"/>
    <add key="FileDownloadServletUrl" value="http://127.0.0.1:8080/roi/filedownload/BaseFileDownloader"/>

    <!-- This key is used in McK.EIG.Common.FileTransfer.dll not in ROI-->
    <add key="CultureResourcePath" value=".CultureResources.CultureResource"/>

    <add key="FileOwnerType" value="LetterTemplate"/>

    <!--Find Patinet search result threshold-->
    <add key="MaximumSearchResult" value="500"/>

    <!--Total Number of release of Request.-->
    <!--Release Count Minimum it should be 1 -->    
    <add key="ReleaseCounter" value="1"/>

    <!-- Content service URL -->
    <add key="ContentServiceUrl" value="http://eigdev195:8888"/>

  </appSettings>

  <applicationSettings>
    <McK.EIG.ROI.Client.Properties.Settings>
      <setting name="McK_EIG_ROI_Client_Web_References_HPFPatientWS_PatientService" serializeAs="String">
        <value>http://eigdev195:8888/portal/eig/iservices/patient</value>
      </setting>
      <setting name="McK_EIG_ROI_Client_Web_References_MedicalRecordWS_MedicalRecordService" serializeAs="String">
        <value>http://eigdev195:8888/portal/eig/iservices/medicalRecord</value>
      </setting>
      <setting name="McK_EIG_ROI_Client_Web_References_DeficiencyWS_DeficiencyService" serializeAs="String">
        <value>http://eigdev195:8888/portal/eig/iservices/deficiency</value>
      </setting>
      <setting name="McK_EIG_ROI_Client_Web_References_SigninWS_SigninService" serializeAs="String">
        <value>http://eigdev195:8888/portal/eig/iservices/signin</value>
      </setting>
      <setting name="McK_EIG_ROI_Client_Web_References_ConfigurationWS_ConfigurationService" serializeAs="String">
        <value>http://eigdev195:8888/portal/eig/iservices/configuration</value>
      </setting>
      <setting name="McK_EIG_ROI_Client_Web_References_PasswordWS_PasswordService" serializeAs="String">
        <value>http://eigdev195:8888/portal/eig/iservices/password</value>
      </setting>
      <setting name="McK_EIG_ROI_Client_Web_References_LogoutWS_LogoutService" serializeAs="String">
        <value>http://eigdev195:8888/portal/eig/iservices/logout</value>
      </setting>
      <setting name="McK_EIG_ROI_Client_Web_References_SecurityLogoffWS_SecurityLogoffService" serializeAs="String">
        <value>http://127.0.0.1:8080/roi/services/securitylogoff</value>
      </setting>
      <setting name="McK_EIG_ROI_Client_Web_References_ROIAdminWS_ROIAdminService" serializeAs="String">
        <value>http://127.0.0.1:8080/roi/services/ROIAdminService</value>
      </setting>
      <setting name="McK_EIG_ROI_Client_Web_References_BillingAdminWS_BillingAdminService" serializeAs="String">
        <value>http://127.0.0.1:8080/roi/services/BillingAdminService</value>
      </setting>
      <setting name="McK_EIG_ROI_Client_Web_References_ROIRequestorWS_RequestorService" serializeAs="String">
        <value>http://127.0.0.1:8080/roi/services/RequestorService</value>
      </setting>
      <setting name="McK_EIG_ROI_Client_Web_References_ROIRequestWS_RequestService" serializeAs="String">
        <value>http://127.0.0.1:8080/roi/services/RequestService</value>
      </setting>
      <setting name="McK_EIG_ROI_Client_Web_References_ROIHpfWS_ROIHPFService" serializeAs="String">
        <value>http://127.0.0.1:8080/roi/services/ROIHPFService</value>
      </setting>
      <setting name="McK_EIG_ROI_Client_Web_References_BillingWS_BillingService" serializeAs="String">
        <value>http://127.0.0.1:8080/roi/services/BillingService</value>
      </setting>
      <setting name="McK_EIG_ROI_Client_Web_References_InUseWS_InUseService" serializeAs="String">
        <value>http://127.0.0.1:8080/inuse/services/InUseService</value>
      </setting>
      <setting name="McK_EIG_ROI_Client_Web_References_ROISupplementalWS_ROISupplementalService" serializeAs="String">
        <value>http://127.0.0.1:8080/roi/services/ROISupplementalService</value>
      </setting>
    </McK.EIG.ROI.Client.Properties.Settings>
  </applicationSettings>
    
</configuration>