    <!-- **********************************************************************
           * Target : clean-binaries
           * target to clean the generated class files
           ********************************************************************** -->
	<target name="clean-binaries">
		<echo message="Cleaning ${dir.bin} folder..." />
		<delete failonerror="false" includeemptydirs="true">
			<fileset dir="${dir.bin}" defaultexcludes="yes" includes="**/*" />
		</delete>

	</target>

    <target name="generate-performance-report" >

        <!-- NANT call to generate performance report
             Server side performance report is generated based on the metrics logging made by client test cases
             Hence server performance report should be generated only when client test cases are running -->
        <if>
            <and>
                <equals arg1="${run.client.test.cases}" arg2="true" />
                <equals arg1="${build.serverside.components}" arg2="true" />
            </and>
            <then>

            	 <mkdir dir="${basedir}/build/temp" />
                 <copy todir="${basedir}/build/temp" failonerror="false" overwrite="true">
                     <fileset dir="${jboss.home}/server/default/log"
                              includes="eig-metrics*.log*"
                              excludes="eig-metrics.audit.log*" />
                 </copy>

        		  <!-- parse the log files and trim unwanted data -->
                 <replaceregexp match="(.*)\|(.*)\|(.*)\|(.*)\| (.*) \| Metric \|(.*)\|Duration\|(.*)\|(.*): (.*)"
                                replace="\5\|\8\|\9\|\7"
                                byline="true">
                  <fileset dir="${basedir}/build/temp" includes="eig-metrics*.log*" />
                 </replaceregexp>

                 <replaceregexp match="(.*)\$\$EnhancerByCGLIB\$\$(.*)\.(.*)"
                                replace="\1.\3"
                                byline="true">
                 <fileset dir="${basedir}/build/temp" includes="eig-metrics*.log*" />
                 </replaceregexp>

                 <concat destfile="${basedir}/build/temp/roi-metrics.properties" append="true">
                    <fileset dir="${basedir}/build/temp" includes="eig-metrics*.log*" />
                    <filterchain>
                        <tokenfilter>
