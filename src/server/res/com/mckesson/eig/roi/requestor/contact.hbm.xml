<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>

    <class name="com.mckesson.eig.roi.requestor.model.Contact"
           table="ROI_Contact"
           dynamic-update="true"
           optimistic-lock="version">

        <id name="id" >
            <column name="ROI_Contact_Seq" sql-type="int"/>
            <generator class="identity"/>
        </id>

        <version name="recordVersion" column="Record_Version" type="integer" />

        <property name="lastName" >
            <column name="NameLast" sql-type="varchar(256)" not-null="true"/>
        </property>

        <property name="createdBy" >
            <column name="Created_By_Seq" sql-type="int" not-null="true"/>
        </property>

        <property name="modifiedDate" >
            <column name="Modified_Dt" sql-type="smalldatetime" not-null="true"/>
        </property>

        <property name="modifiedBy" >
            <column name="Modified_By_Seq" sql-type="int" not-null="true"/>
        </property>

        <set name="contactEmailPhones" cascade="all,delete-orphan" lazy="false">
            <key column="ROI_Contact_Seq" not-null="true" />
            <one-to-many class="com.mckesson.eig.roi.requestor.model.ContactEmailPhone" />
        </set>

    </class>

</hibernate-mapping>
