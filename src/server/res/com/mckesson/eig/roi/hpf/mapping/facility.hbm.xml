<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
    <class name="com.mckesson.eig.roi.hpf.model.Facility"
     table="FACILITY_FILE">

	     <id name="facilityCode">
	        <column name="FACILITY_CODE" sql-type="char"/>
	         <generator class="identity"/>
	    </id>

	    <property name="facilityName" >
	        <column name="FACILITY_NAME" sql-type="char(25)" not-null="false"/>
	    </property>

	    <property name="documentSet" >
	        <column name="DOCUMENT_SET" sql-type="int" not-null="false"/>
	    </property>

   </class>

    <class name="com.mckesson.eig.roi.hpf.model.UserFacility"
    	table="user_facility" schema="dbo" catalog="cabinet">
    	<composite-id>
    		<key-property name="userId" type="int">
    			<column name="USER_ID" />
    		</key-property>
    		<key-property name="facility" type="string">
    			<column name="FACILITY" />
    		</key-property>
    	</composite-id>
    </class>

    <query name="retrieveAllFacilities">
    	<![CDATA[
            SELECT uf.facility
            FROM com.mckesson.eig.roi.hpf.model.UserFacility uf
            WHERE uf.userId = ?0 ORDER BY uf.facility ASC
        ]]>
    </query>
    
    <query name="getCodeSetIdForFacility">
         <![CDATA[
            SELECT a
            FROM com.mckesson.eig.roi.hpf.model.Facility a
            where a.facilityCode = ?0
        ]]>
	</query>

</hibernate-mapping>
