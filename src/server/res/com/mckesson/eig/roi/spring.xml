		class="com.mckesson.eig.wsfw.axis.CastorContext" lazy-init="true">
		<property name="mappingFile"
			value="com/mckesson/eig/roi/castor.xml" />
	</bean>

	<bean id="audit_castor_context"
		class="com.mckesson.eig.wsfw.axis.CastorContext" lazy-init="true">
		<property name="mappingFile"
			value="com/mckesson/eig/audit/webservices/webservice-mappings.xml" />
	</bean>
