	<bean id="dataSource" class="com.zaxxer.hikari.HikariDataSource" destroy-method="close">
	    <constructor-arg ref="hikariConfig" />
	</bean>
	
	<bean id="hikariConfig" class="com.zaxxer.hikari.HikariConfig">
		<property name="poolName" value="springHikariCP" />
		<property name="connectionTestQuery" value="SELECT 1" />
		<property name="driverClassName">
			<value>${jdbc.driver}</value>
		</property>
		<property name="jdbcUrl">
			<value>${jdbc.url}</value>
		</property>
		<property name="username">
			<value>${db.user}</value>
		</property>
		<property name="password">
			<value>${db.password}</value>
		</property>
		<property name="minimumIdle" value="30" />
		<property name="maximumPoolSize" value="90" />
		<!-- <property name="maxConnectionsPerPartition" value="30" />
        <property name="minConnectionsPerPartition" value="10" /> -->


		<!-- <property name="dataSourceProperties"> <props> <prop key="jdbcUrl">${startup.jdbc.url}</prop> 
			<prop key="username">${startup.jdbc.username}</prop> <prop key="password">${startup.jdbc.password}</prop> 
			</props> </property> -->
	</bean>
	
	<!-- Audit Configuration starts -->
	<bean id="defaultDataSourceMPF" parent="dataSource"/>
	
	<bean id="daoRegistry" class="com.mckesson.eig.iws.orm.SimpleDaoRegistry" >
		<property name="registry">
			<map>
				<entry key="AuditTrailHibernateDao">
					<ref bean="AuditTrailHibernateDao"/>
				</entry>
			</map>
		</property>
	</bean>

	<bean id="AuditTrailHibernateDao" class="com.mckesson.eig.audit.dao.hpf.AuditTrailHibernateDao">
		<property name="sessionFactory" ref ="sessionFactory"/>
	</bean>

	<!-- Audit Configuration Ends -->
	
	<bean id="transactionManager"
		class="org.springframework.orm.hibernate5.HibernateTransactionManager">
		<property name="sessionFactory">
			<ref bean="sessionFactory" />
		</property>
	</bean>
	

	<!--  Common transactionContext . Please do not remove  -->

	<tx:advice id="txAdvice" transaction-manager="transactionManager">
		<tx:attributes>
		    <tx:method name="retrieve*" read-only="true"/>
            <tx:method name="search*" read-only="true"/>
            <tx:method name="find*" read-only="true"/>
            <tx:method name="get*" read-only="true"/>
			<tx:method name="*" />
		</tx:attributes>
	</tx:advice>

	<aop:config proxy-target-class="true">
		<aop:advisor
			pointcut="execution(* com.mckesson.eig.roi.admin.service.BillingAdminServiceImpl.*(..))"
			advice-ref="txAdvice" />
	</aop:config>

	<aop:config proxy-target-class="true">
		<aop:advisor
			pointcut="execution(* com.mckesson.eig.roi.admin.service.ROIAdminServiceImpl.*(..))"
			advice-ref="txAdvice" />
	</aop:config>

	<aop:config proxy-target-class="true">
		<aop:advisor
			pointcut="execution(* com.mckesson.eig.roi.requestor.service.RequestorServiceImpl.*(..))"
			advice-ref="txAdvice" />
	</aop:config>

	<aop:config proxy-target-class="true">
		<aop:advisor
			pointcut="execution(* com.mckesson.eig.roi.hpf.service.HPFSecurityAuthenticationService.*(..))"
			advice-ref="txAdvice" />
	</aop:config>

	<aop:config proxy-target-class="true">
        <aop:advisor
            pointcut="execution(* com.mckesson.eig.roi.reports.service.ROIReportServiceImpl.*(..))"
            advice-ref="txAdvice" />
    </aop:config>

    <aop:config proxy-target-class="true">
        <aop:advisor
            pointcut="execution(* com.mckesson.eig.roi.admin.service.ROIAttachmentServiceImpl.*(..))"
            advice-ref="txAdvice" />
    </aop:config>

 	 <aop:config proxy-target-class="true">
        <aop:advisor
            pointcut="execution(* com.mckesson.eig.roi.request.service.RequestCoreServiceImpl.*(..))"
            advice-ref="txAdvice" />
    </aop:config>
 
 	<aop:config proxy-target-class="true">
        <aop:advisor
            pointcut="execution(* com.mckesson.eig.roi.billing.service.OverDueInvoiceCoreServiceImpl.*(..))"
            advice-ref="txAdvice" />
    </aop:config>

    <aop:config proxy-target-class="true">
        <aop:advisor
            pointcut="execution(* com.mckesson.eig.roi.supplementary.service.ROISupplementaryServiceImpl.*(..))"
            advice-ref="txAdvice" />
    </aop:config>
    
    <aop:config proxy-target-class="true">
        <aop:advisor
            pointcut="execution(* com.mckesson.eig.roi.billing.service.BillingCoreServiceImpl.*(..))"
            advice-ref="txAdvice" />
    </aop:config>
    
    <aop:config proxy-target-class="true">
        <aop:advisor pointcut="execution(* com.mckesson.eig.roi.inuse.service.InUseServiceImpl.*(..))" 
        advice-ref="txAdvice" />
    </aop:config>
    
	<import resource="dao.spring.xml" />
	<import resource="service.spring.xml" />

