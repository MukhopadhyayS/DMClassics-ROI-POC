<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
<class name="com.mckesson.eig.roi.inuse.model.InUseRecord"
       table="ROI_Activity"
       dynamic-update="true"
       optimistic-lock="version" >

    <id name="recordSequence" >
        <column name="ROI_Activity_Seq" sql-type="int"/>
        <generator class="identity"/>
    </id>

    <version name="recordVersion" column="Record_Version" type="integer" />

    <property name="objectType" >
        <column name="Activity" sql-type="varchar(255)" not-null="true" />
    </property>

    <property name="objectID" >
        <column name="ActivityID" sql-type="varchar(255)" not-null="true"/>
    </property>

    <property name="userID" >
        <column name="ActivityUserID" sql-type="varchar(255)" not-null="true"/>
    </property>

    <property name="applicationID" >
        <column name="ActivityDescription" sql-type="varchar(255)" not-null="true"/>
    </property>

    <property name="expiresMinutes" >
        <column name="ActivityCounter" sql-type="tinyint" not-null="true"/>
    </property>

    <property name="createdBy" >
        <column name="Created_By_Seq" sql-type="int" not-null="true" />
    </property>

    <property name="createdDate" >
        <column name="Created_Dt" sql-type="smalldatetime" not-null="true" />
    </property>

    <property name="modifiedDate" >
        <column name="Modified_Dt" sql-type="smalldatetime" not-null="true" />
    </property>

    <property name="modifiedBy" >
        <column name="Modified_By_Seq" sql-type="int" not-null="true" />
    </property>

 </class>

  <query name="retrieveExpiredRecords">
    <![CDATA[
      select m from com.mckesson.eig.roi.inuse.model.InUseRecord m
      where datediff(minute,dateadd(minute, m.expiresMinutes + ?, m.modifiedDate), ?) >= -1
    ]]>
  </query>

  <query name="retrieveAllForType">
    <![CDATA[
      select m from com.mckesson.eig.roi.inuse.model.InUseRecord m
      where m.objectType = ?
    ]]>
  </query>

  <query name="retrieveByAppIDAndUserID">
    <![CDATA[
      select m from com.mckesson.eig.roi.inuse.model.InUseRecord m
      where m.applicationID = ? and m.userID = ?
    ]]>
  </query>

  <query name="retrieveAll">
    <![CDATA[
      select m from com.mckesson.eig.roi.inuse.model.InUseRecord m
    ]]>
  </query>

  <query name="retrieveByObjectTypeAndID">
    <![CDATA[
      select m from com.mckesson.eig.roi.inuse.model.InUseRecord m
      where m.objectType = ? and m.objectID = ?
    ]]>
  </query>

  <query name="retrieveInUseRecordsByIds">
    <![CDATA[
      select m from com.mckesson.eig.roi.inuse.model.InUseRecord m
      where m.objectType = (:ObjType)
      and m.objectID in (:IDS)
      and (m.applicationID != (:appId) or m.userID  != (:userId))
    ]]>
  </query>

</hibernate-mapping>
