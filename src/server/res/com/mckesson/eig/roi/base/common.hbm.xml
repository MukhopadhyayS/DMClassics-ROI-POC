<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
<class name="com.mckesson.eig.roi.base.model.EmailPhoneType"
       table="ROI_EmailPhoneType"
       dynamic-update="false"
       optimistic-lock="none" >

    <id name="id" >
        <column name="ROI_EmailPhoneType_Seq" sql-type="int"/>
        <generator class="identity"/>
    </id>

    <property name="name" >
        <column name="Name" sql-type="varchar(256)" not-null="true" />
    </property>

 </class>

 <class name="com.mckesson.eig.roi.base.model.AddressType"
       table="ROI_AddressType"
       dynamic-update="false"
       optimistic-lock="none" >

    <id name="id" >
        <column name="ROI_AddressType_Seq" sql-type="int"/>
        <generator class="identity"/>
    </id>

    <property name="name" >
        <column name="Name" sql-type="varchar(256)" not-null="true" />
    </property>

 </class>

  <class name="com.mckesson.eig.roi.base.model.ContactType"
       table="ROI_ContactType"
       dynamic-update="false"
       optimistic-lock="none" >

    <id name="id" >
        <column name="ROI_ContactType_Seq" sql-type="int"/>
        <generator class="identity"/>
    </id>

    <property name="name" >
        <column name="Name" sql-type="varchar(256)" not-null="true" />
    </property>

 </class>


  <query name="getEmailPhoneTypes">
    <![CDATA[
      select m from com.mckesson.eig.roi.base.model.EmailPhoneType m
      order by m.name asc
    ]]>
  </query>

   <query name="getAddressTypes">
    <![CDATA[
      select a from com.mckesson.eig.roi.base.model.AddressType a
      order by a.name asc
    ]]>
  </query>

  <query name="getContactTypes">
    <![CDATA[
      select c from com.mckesson.eig.roi.base.model.ContactType c
      order by c.name asc
    ]]>
  </query>

</hibernate-mapping>
