<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
 "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
 "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>

	<sql-query name="retrieveAllGenders">
		<![CDATA[
		     SELECT Sex_Code code,
		     Sex_Description description
		     FROM cabinet.dbo.Gender
		]]>
	</sql-query>  

</hibernate-mapping>
