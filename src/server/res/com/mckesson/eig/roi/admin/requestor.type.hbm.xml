<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
 <class name="com.mckesson.eig.roi.admin.model.RequestorType"
       table="ROI_RequestorType"
       dynamic-update="true"
       optimistic-lock="version" >

    <id name="id" >
        <column name="ROI_RequestorType_Seq" sql-type="int"/>
        <generator class="identity"/>
    </id>
    <version name="recordVersion" column="Record_Version" type="integer" />

    <property name="name" >
        <column name="Name" sql-type="varchar(60)" not-null="true" />
    </property>

    <property name="description" >
        <column name="Description" sql-type="varchar(255)" />
    </property>

    <property name="createdBy" >
        <column name="Created_By_Seq" sql-type="int" not-null="true"/>
    </property>

    <property name="modifiedDate" >
        <column name="Modified_Dt" sql-type="smalldatetime" not-null="true"/>
    </property>

    <property name="modifiedBy" >
        <column name="Modified_By_Seq" sql-type="int" not-null="true"/>
    </property>

    <property name="orgId" >
        <column name="Organization_Seq" sql-type="int" not-null="true"/>
    </property>

    <property name="active" >
        <column name="Active" sql-type="bit" not-null="true"/>
    </property>

    <property name="rv">
        <column name="RecordView" sql-type="varchar(30)" not-null="true"></column>
    </property>

    <property name="rvDesc">
        <column name="RecordViewDescription" sql-type="varchar(255)" not-null="true"></column>
    </property>

	<property name="salesTax" >
        <column name="SalesTaxEnable" sql-type="char(1)" not-null="true"/>
    </property>
    
    <property name="invoiceOptional" >
        <column name="InvoiceOptional" sql-type="char(1)" not-null="true"/>
    </property>

    <set name="relatedBillingTemplate" fetch="join" cascade="all,delete-orphan" lazy="false">
        <key column="ROI_RequestorType_Seq" not-null="true"/>
        <one-to-many class="com.mckesson.eig.roi.admin.model.RelatedBillingTemplate"/>
    </set>

    <set name="relatedBillingTier" fetch="join" cascade="all,delete-orphan" lazy="false">
       <key column="ROI_RequestorType_Seq" not-null="true"/>
       <one-to-many class="com.mckesson.eig.roi.admin.model.RelatedBillingTier"/>
    </set>

 </class>

    <query name="getRequestorTypeByName">
    <![CDATA[
        SELECT requestorType
        FROM com.mckesson.eig.roi.admin.model.RequestorType requestorType
        WHERE requestorType.name = ?
    ]]>
    </query>

     <query name="retrieveRequestorTypesNames">
    <![CDATA[
        SELECT rt.id, rt.name, rt.salesTax
        FROM com.mckesson.eig.roi.admin.model.RequestorType rt order by rt.name
     ]]></query>

     <query name="getAssociatedRequestorCount">
         <![CDATA[
            select count(re.id) from com.mckesson.eig.roi.requestor.model.Requestor re
            where re.type = ?
        ]]>
    </query>

</hibernate-mapping>
