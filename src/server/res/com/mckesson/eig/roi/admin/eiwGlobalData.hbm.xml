<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
	<class name="com.mckesson.eig.roi.admin.model.EiwGlobalData"
		   schema ="dbo"
		   catalog="eiwdata"
		   table="EIWT_GLOBAL"
	       dynamic-update="false"
	       optimistic-lock="version">
		 
		   <id name="globalName" >
		        <column name="global_name" sql-type="char"/>
		        <generator class="identity"/>
	       </id>

	       <property name="globalIntValue" >
	           <column name="global_int_val" sql-type="int" not-null="false" />
	       </property>
	       
		   <property name="globalCharValue" >
		       <column name="global_char_val" sql-type="char" not-null="false"/>
		   </property>
		   
		   <property name="globalStrValue" >
		       <column name="global_str_val" sql-type="char" not-null="false"/>
		   </property>
		   
    </class>
    
    <query name="retrieveEIWDATAConfiguration">
      <![CDATA[
        select globalStrValue from com.mckesson.eig.roi.admin.model.EiwGlobalData eiwGlobal
        where eiwGlobal.globalName = ?
      ]]>
    </query>  
	 
</hibernate-mapping>

