<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:cxf="http://cxf.apache.org/core"
  xmlns:jaxws="http://cxf.apache.org/jaxws"
  xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
	http://cxf.apache.org/jaxrs http://cxf.apache.org/schemas/jaxrs.xsd http://cxf.apache.org/jaxws http://cxf.apache.org/schemas/jaxws.xsd
	http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd
	http://www.springframework.org/schema/util http://www.springframework.org/schema/util/spring-util.xsd"
	xmlns:util="http://www.springframework.org/schema/util">


	
	<bean id="AuthenticationInterceptor" class="com.mckesson.eig.wsfw.security.authentication.AuthenticationInterceptor">
		<constructor-arg>
		  <map>
		    <entry key="action"                value="UsernameToken Timestamp"/>
		    <entry key="passwordType"          value="PasswordText" />
		    <entry key="isBSPCompliant" value="false"/>
		  </map>
		</constructor-arg>
	</bean>
	
	<bean id="AuthorizationInterceptor" class="com.mckesson.eig.wsfw.security.authorization.AuthorizationInterceptor">
	</bean>
	
	<bean id="com.mckesson.eig.roi.inuse.service.InUseService"
        class="com.mckesson.eig.roi.inuse.service.InUseServiceImpl"
        lazy-init="false" 
        init-method="initService">
        <property name="scheduler" ref="InUseScheduler" />
    </bean>
    
    <bean id="InUseScheduler"
		class="org.springframework.scheduling.quartz.SchedulerFactoryBean" >
		<property name="autoStartup" value="false" />
		<property name="quartzProperties" value="com/mckesson/eig/roi/quartz.properties" />
	</bean>
	
	<bean id="com.mckesson.eig.roi.output.service.ROIOutputServiceImpl"
    	 class="com.mckesson.eig.roi.output.service.ROIOutputServiceImpl"
    	 lazy-init="true">
        <property name="webClientPool" ref="WebClientPool"/>
    </bean>
	
	<bean id="WebClientPool" class="com.mckesson.eig.roi.webservice.util.rest.RestWebClientPool">
        <property name="providers" ref="webClientProviderCollection" />
    </bean>
    
    <util:list id="webClientProviderCollection">
        <bean class="com.fasterxml.jackson.jaxrs.json.JacksonJsonProvider" />
    </util:list>
	
	<jaxws:endpoint id="SupplementaryService"
		implementor="com.mckesson.eig.roi.supplementary.service.ROISupplementaryServiceImpl"
		address="/SupplementaryService">
        <jaxws:inInterceptors>
	          <ref bean="AuthenticationInterceptor"/>
	          <ref bean="AuthorizationInterceptor"/>
	    </jaxws:inInterceptors>
	    <jaxws:properties>
    		<entry key="ws-security.ut.validator">
        		<bean class="com.mckesson.eig.wsfw.security.authentication.WssUsernameTokenValidator" />
    		</entry>
  		</jaxws:properties>
	</jaxws:endpoint>
	
	<jaxws:endpoint id="BillingAdminService"
