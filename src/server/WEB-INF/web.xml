<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE web-app PUBLIC "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN" "http://java.sun.com/j2ee/dtds/web-app_2_3.dtd">

<web-app id="Web_Test">
	<distributable>true</distributable>
    <display-name>ROI</display-name>
    <description>ROI</description>

    <filter>
    	<filter-name>AuthenticationFilter</filter-name>
      	<filter-class>com.mckesson.eig.roi.hpf.security.servlet.ROIAuthenticationFilter</filter-class>
     </filter>

    <filter-mapping>
      <filter-name>AuthenticationFilter</filter-name>
    <servlet-name>ReportConfigurationServlet</servlet-name>
    </filter-mapping>

    <filter-mapping>
      <filter-name>AuthenticationFilter</filter-name>
    <servlet-name>ROIFileUploadServlet</servlet-name>
    </filter-mapping>
	
    <filter-mapping>
      <filter-name>AuthenticationFilter</filter-name>
    <servlet-name>FileUploadServlet</servlet-name>
    </filter-mapping>

	<listener>
        <listener-class>
            org.apache.axis.transport.http.AxisHTTPSessionListener
        </listener-class>
        
         <listener-class>
	   		ch.qos.logback.classic.selector.servlet.ContextDetachingSCL
	   	</listener-class>
     </listener> 
	
    <!-- Servlets -->
    <servlet>
        <servlet-name>EIGConfigServlet</servlet-name>
        <display-name>EIG Config Servlet</display-name>
        <servlet-class>
            com.mckesson.eig.wsfw.ConfigurationServlet
        </servlet-class>
        <init-param>
            <param-name>eig.SpringConfigFile</param-name>
            <param-value>com/mckesson/eig/roi/spring.xml</param-value>
        </init-param>
        <load-on-startup>2</load-on-startup>
    </servlet>

    <servlet>
        <servlet-name>EIGAxisServlet</servlet-name>
        <display-name>EIG Axis Servlet</display-name>
        <servlet-class>
            com.mckesson.eig.wsfw.axis.SOAPServlet
        </servlet-class>
        <init-param>
            <param-name>axis.ServerConfigFile</param-name>
            <param-value>eig/roi/axis.wsdd</param-value>
        </init-param>
        <load-on-startup>4</load-on-startup>
    </servlet>

        <!-- Reports Servlet -->
     <servlet>
        <servlet-name>ReportConfigurationServlet</servlet-name>
        <display-name>Reports Configuration</display-name>
        <description>
            Used to perform initial configuration tasks
        </description>
        <servlet-class>
            com.mckesson.eig.roi.reports.servlet.ROIReportServlet
        </servlet-class>
        <init-param>
            <param-name>eig.Reports.SpringConfigFile</param-name>
            <param-value>com/mckesson/eig/roi/spring.xml</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
     </servlet>


     <servlet>
        <servlet-name>ROIFileUploadServlet</servlet-name>
        <display-name>uploadServlet</display-name>
        <servlet-class>
            com.mckesson.eig.roi.admin.service.ROIFileUploadServlet
        </servlet-class>
    </servlet>

    <servlet>
        <servlet-name>BaseFileDownloader</servlet-name>
        <display-name>downloadServlet</display-name>
        <servlet-class>
            com.mckesson.eig.common.filetransfer.services.BaseFileDownloader
        </servlet-class>
    </servlet>

    <servlet>
        <servlet-name>FileUploadServlet</servlet-name>
        <display-name>FileUploadServlet</display-name>
        <servlet-class>
            com.mckesson.eig.roi.ccd.service.CcdFileUploadServlet
        </servlet-class>
    </servlet>

    <!-- servlet mappings -->
    <servlet-mapping>
        <servlet-name>EIGConfigServlet</servlet-name>
        <url-pattern>/config/*</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>EIGAxisServlet</servlet-name>
        <url-pattern>/services/*</url-pattern>
    </servlet-mapping>

     <servlet-mapping>
        <servlet-name>ROIFileUploadServlet</servlet-name>
        <url-pattern>/filetransfer/*</url-pattern>
    </servlet-mapping>

     <servlet-mapping>
        <servlet-name>FileUploadServlet</servlet-name>
        <url-pattern>/upload/*</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>BaseFileDownloader</servlet-name>
        <url-pattern>/filedownload/*</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>ReportConfigurationServlet</servlet-name>
        <url-pattern>/reports/*</url-pattern>
    </servlet-mapping>

    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

