<?xml version="1.0" encoding="UTF-8"?>
<mapping xmlns:eig="urn:eig.mckesson.com">
	<!--  Document Types  -->

	<class name="com.mckesson.eig.roi.admin.model.DocTypeDesignations">
		<map-to xml="docTypeDesignation" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />

		<field name="designation"
			type="com.mckesson.eig.roi.admin.model.Designation"
			collection="arraylist">
			<bind-xml name="eig:designation" node="element" />
		</field>

	</class>

	<class name="com.mckesson.eig.roi.admin.model.Designation">
		<map-to xml="designation" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />

		<field name="type" type="string">
			<bind-xml name="eig:type" node="element" />
		</field>

		<field name="docTypeIds" type="long" collection="arraylist">
			<bind-xml name="eig:docTypeIds" node="element" />
		</field>
       		
		<field name="muDocTypes" type="com.mckesson.eig.roi.admin.model.MUDocTypeDto" collection="arraylist">
		    <bind-xml name="eig:muDocTypes" node="element" />
		</field>

	</class>
	<class name="com.mckesson.eig.roi.admin.model.MUDocTypeDto">
		<map-to xml="muDocTypes" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />

		<field name="muDocId" type="long">
			<bind-xml name="eig:muDocId" node="element" />
		</field>

        <field name="muDocName" type="string">
			<bind-xml name="eig:muDocName" node="element" />
		</field>
   </class>
   <class name="com.mckesson.eig.roi.admin.model.DocTypeAudit">
		<map-to xml="docTypeAudit" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />
	
		<field name="docType" type="string">
			<bind-xml name="eig:docType" node="element" />
		</field>

        <field name="docName" type="string">
			<bind-xml name="eig:docName" node="element" />
		</field>
		
		<field name="fromValue" type="string">
			<bind-xml name="eig:fromValue" node="element" />
		</field>
		
		<field name="toValue" type="string">
			<bind-xml name="eig:toValue" node="element" />
		</field>
		
		<field name="codeSetName" type="string">
			<bind-xml name="eig:codeSetName" node="element" />
		</field>
		
		<field name="nonDocumentTypeChangeAudit" type="string">
			<bind-xml name="eig:nonDocumentTypeChangeAudit" node="element" />
		</field>
   </class>
   <class name="com.mckesson.eig.roi.admin.model.DocTypeAuditList">
		<map-to xml="docTypeAuditList" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />
       		
		<field name="docTypeAudit" type="com.mckesson.eig.roi.admin.model.DocTypeAudit" collection="arraylist">
		    <bind-xml name="eig:docTypeAudit" node="element" />
		</field>
	</class>
	
</mapping>
