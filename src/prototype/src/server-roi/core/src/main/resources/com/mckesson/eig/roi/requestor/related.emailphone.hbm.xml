<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping auto-import="false">

    <class name="com.mckesson.eig.roi.requestor.model.RelatedEmailPhone"
           table="ROI_RequestorToEmailPhone"
           dynamic-update="true"
           optimistic-lock="version">

        <id name="id" >
            <column name="ROI_RequestorToEmailPhone_Seq" sql-type="int"/>
            <generator class="identity"/>
        </id>

        <version name="recordVersion" column="Record_Version" type="integer" />

        <property name="emailPhoneType" >
            <column name="ROI_EmailPhoneType_Seq" sql-type="int" not-null="true"/>
        </property>

        <property name="createdBy" >
            <column name="Created_By_Seq" sql-type="int" not-null="true"/>
        </property>

        <property name="modifiedDate" >
            <column name="Modified_Dt" sql-type="smalldatetime" not-null="true"/>
        </property>

        <property name="modifiedBy" >
            <column name="Modified_By_Seq" sql-type="int" not-null="true"/>
        </property>

        <many-to-one name="emailPhone"
                     column="ROI_EmailPhone_Seq"
                     cascade="all"
                     lazy="false"
                     class="com.mckesson.eig.roi.base.model.EmailPhone" />

    </class>

</hibernate-mapping>
