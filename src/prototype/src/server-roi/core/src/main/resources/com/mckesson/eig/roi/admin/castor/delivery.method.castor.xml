<?xml version="1.0" encoding="UTF-8"?>
<mapping xmlns:eig="urn:eig.mckesson.com">
	<class name="com.mckesson.eig.roi.admin.model.DeliveryMethod">
		<map-to xml="deliveryMethodDetails" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />

		<field name="id" type="long">
			<bind-xml name="eig:id" node="element" />
		</field>

		<field name="name" type="string">
			<bind-xml name="eig:name" node="element" />
		</field>

		<field name="desc" type="string">
			<bind-xml name="eig:description" node="element" />
		</field>

		<field name="url" type="string">
			<bind-xml name="eig:url" node="element" />
		</field>

		<field name="isDefault" type="boolean">
			<bind-xml name="eig:default" node="element" />
		</field>

		<field name="recordVersion" type="int">
			<bind-xml name="eig:recordVersion" node="element" />
		</field>

	</class>

	<class name="com.mckesson.eig.roi.admin.model.DeliveryMethodList">
		<map-to xml="deliveryMethods" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />

		<field name="deliveryMethods"
			type="com.mckesson.eig.roi.admin.model.DeliveryMethod"
			collection="arraylist">
			<bind-xml name="eig:deliveryMethodList" node="element" />
		</field>

	</class>
</mapping>
