<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
	"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
	"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
  <class name="com.mckesson.eig.roi.admin.model.InvoiceDueDays"
  		table="ROI_Invoice_DueDate"
        dynamic-update="true"
        optimistic-lock="version">

		 <id name="id" >
            <column name="ROI_Invoice_DueDate_Seq" sql-type="int"/>
            <generator class="identity"/>
        </id>

        <version name="recordVersion" column="Record_Version" type="integer" />

        <property name="modifiedDate">
            <column name="Modified_Dt" sql-type="smalldatetime" not-null="true"/>
        </property>

        <property name="modifiedBy" >
            <column name="Modified_By_Seq" sql-type="int" not-null="true"/>
        </property>

        <property name="invoiceDueDays" >
            <column name="NoOfDays" sql-type="int" not-null="true"/>
        </property>

        <property name="customDate" >
            <column name="CustomDays" sql-type="bit" not-null="true"/>
        </property>
  </class>

  <query name="getInvoiceDueDays">
      <![CDATA[
        select due from com.mckesson.eig.roi.admin.model.InvoiceDueDays due
      ]]>
    </query>
    
    <query name="retrieveInvoiceDueDays">
      <![CDATA[
      	select due.invoiceDueDays from com.mckesson.eig.roi.admin.model.InvoiceDueDays due
      	WHERE due.id != 1
      	ORDER by due.invoiceDueDays
      ]]>
    </query>  
 
</hibernate-mapping>