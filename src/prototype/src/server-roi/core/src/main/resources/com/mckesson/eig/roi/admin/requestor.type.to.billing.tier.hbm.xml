<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
 <class name="com.mckesson.eig.roi.admin.model.RelatedBillingTier"
       table="ROI_RequestorTypeToBillingTier"
       dynamic-update="true"
       optimistic-lock="version" >

    <id name="id" >
        <column name="ROI_RequestorTypeToBillingTier_Seq" sql-type="int"/>
        <generator class="identity"/>
    </id>
    <version name="recordVersion" column="Record_Version" type="integer" />

    <property name="createdBy" >
        <column name="Created_By_Seq" sql-type="int" not-null="true"/>
    </property>

    <property name="modifiedDate" >
        <column name="Modified_Dt" sql-type="smalldatetime" not-null="true"/>
    </property>

    <property name="modifiedBy" >
        <column name="Modified_By_Seq" sql-type="int" not-null="true"/>
    </property>

    <property name="billingTierId" >
        <column name="ROI_BillingTier_Seq" sql-type="int" not-null="true"/>
    </property>

    <property name="isHPF">
        <column name="HPF" sql-type="bit" not-null="true"></column>
    </property>

    <property name="isHECM">
        <column name="HECM" sql-type="bit" not-null="true"></column>
    </property>

    <property name="isCEVA">
        <column name="CEVA" sql-type="bit" not-null="true"></column>
    </property>

    <property name="isSupplemental">
        <column name="Supplemental" sql-type="bit" not-null="true"></column>
    </property>

 </class>
</hibernate-mapping>
