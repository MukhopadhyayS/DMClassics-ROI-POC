<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:aop="http://www.springframework.org/schema/aop"
	xmlns:tx="http://www.springframework.org/schema/tx"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
                        http://www.springframework.org/schema/beans/spring-beans-2.0.xsd
                        http://www.springframework.org/schema/tx
                        http://www.springframework.org/schema/tx/spring-tx-2.0.xsd
                        http://www.springframework.org/schema/aop
                        http://www.springframework.org/schema/aop/spring-aop-2.0.xsd">

	<bean id="asposeLicense" 
		class="com.mckesson.eig.roi.thirdparty.licenses.AsposeLicenseImpl" 
		scope="singleton"/>	

	<bean
		id="com.mckesson.eig.roi.admin.service.BillingAdminServiceImpl"
		class="com.mckesson.eig.roi.admin.service.BillingAdminServiceImpl"
		lazy-init="true" />

	<bean id="com.mckesson.eig.roi.admin.service.ROIAdminServiceImpl"
		class="com.mckesson.eig.roi.admin.service.ROIAdminServiceImpl"
		lazy-init="true" />

	<bean
		id="com.mckesson.eig.common.filetransfer.services.BaseFileDownloader_Retriever"
		class="com.mckesson.eig.roi.admin.service.ROIContentRetriever"
		lazy-init="true" />


	<bean
		id="com.mckesson.eig.roi.requestor.service.RequestorServiceImpl"
		class="com.mckesson.eig.roi.requestor.service.RequestorServiceImpl"
		lazy-init="true" />

	<bean id="com.mckesson.eig.roi.ccd.service.CcdConversionServiceImpl"
		class="com.mckesson.eig.roi.ccd.service.CcdConversionServiceImpl"
		lazy-init="true" />

    <!--  Reports related configuration -->
    <bean id="com.mckesson.eig.reports.service.ReportService"
          class="com.mckesson.eig.roi.reports.service.ROIReportServiceImpl" />
	
	 <bean id="DOCX_LetterGenerator"
          class="com.mckesson.eig.roi.billing.xdocreport.service.DocXLetterGenerator"
          lazy-init="true" />
          
	<bean id="ODT_LetterGenerator"
          class="com.mckesson.eig.roi.billing.xdocreport.service.ODTLetterGenerator"
          lazy-init="true" />

    <bean
        id="com.mckesson.eig.roi.supplementary.service.ROISupplementaryServiceImpl"
        class="com.mckesson.eig.roi.supplementary.service.ROISupplementaryServiceImpl"
        lazy-init="true" />

    <bean id="FileDownloader_FTHelper"
          class="com.mckesson.eig.roi.base.service.FileDownloader">
    </bean>

    <bean id="com.mckesson.eig.roi.configuredays.service.ConfigureDaysServiceImpl"
			class="com.mckesson.eig.roi.configuredays.service.ConfigureDaysServiceImpl"
			lazy-init="true" />
		
    <bean id="com.mckesson.eig.roi.muroioutbound.service.MUROIOutboundServiceImpl"
    	class="com.mckesson.eig.roi.muroioutbound.service.MUROIOutboundServiceImpl"
		lazy-init="true" />
		
    <bean id="com.mckesson.eig.roi.admin.service.ROIAttachmentServiceImpl"
          class="com.mckesson.eig.roi.admin.service.ROIAttachmentServiceImpl">
    </bean>
    
     <bean id="com.mckesson.eig.roi.request.service.RequestCoreServiceImpl"
          class="com.mckesson.eig.roi.request.service.RequestCoreServiceImpl">
    </bean>

	<bean id="com.mckesson.eig.roi.billing.service.BillingCoreServiceImpl"
          class="com.mckesson.eig.roi.billing.service.BillingCoreServiceImpl">
    </bean>

	<bean id="com.mckesson.eig.roi.billing.service.OverDueInvoiceCoreServiceImpl"
          class="com.mckesson.eig.roi.billing.service.OverDueInvoiceCoreServiceImpl">
    </bean>
    <bean id="com.mckesson.eig.roi.muroioutbound.service.MUCreateROIOutboundServiceCoreImpl"
          class="com.mckesson.eig.roi.muroioutbound.service.MUCreateROIOutboundServiceCoreImpl"
    lazy-init="true" />
    
	<bean id="com.mckesson.eig.roi.journal.service.JournalServiceImpl"
          class="com.mckesson.eig.roi.journal.service.JournalServiceImpl">
    </bean>

	<bean id="com.mckesson.eig.roi.journal.service.JournalTemplateServiceImpl"
          class="com.mckesson.eig.roi.journal.service.JournalTemplateServiceImpl">
    </bean>
    <bean id="com.mckesson.eig.roi.muroioutbound.service.MUUpdateROIOutboundServiceCoreImpl"
    	class="com.mckesson.eig.roi.muroioutbound.service.MUUpdateROIOutboundServiceCoreImpl"
	lazy-init="true" />
	
	 <bean id="com.mckesson.eig.roi.output.service.ROIOutputServiceImpl"
    	 class="com.mckesson.eig.roi.output.service.ROIOutputServiceImpl"
    	 lazy-init="true">
        <property name="webClientPool" ref="WebClientPool"/>
    </bean>
    
    <bean id="com.mckesson.eig.roi.inuse.service.InUseService"
        class="com.mckesson.eig.roi.inuse.service.InUseServiceImpl"
        lazy-init="false"
        init-method="initService" >
        <property name="scheduler" ref="InUseScheduler" />
        <property name="inUseDAO" ref="InUseDAO" />
    </bean>
</beans>
