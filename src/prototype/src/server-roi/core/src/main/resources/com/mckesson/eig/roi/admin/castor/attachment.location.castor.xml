<?xml version="1.0" encoding="UTF-8"?>
<mapping xmlns:eig="urn:eig.mckesson.com">
	<class name="com.mckesson.eig.roi.admin.model.AttachmentLocation">
		<map-to xml="attachmentLocation" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />

		<field name="attachmentID" type="long">
			<bind-xml name="eig:attachmentID" node="element" />
		</field>

		<field name="attachmentLocation" type="string">
			<bind-xml name="eig:attachmentLocation" node="element" />
		</field>

	</class>
</mapping>