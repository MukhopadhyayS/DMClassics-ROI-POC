<?xml version="1.0" encoding="UTF-8"?>
<mapping xmlns:eig="urn:eig.mckesson.com">
	<class name="com.mckesson.eig.roi.admin.model.PageLevelTier">
		<map-to xml="pageLevelTier" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />

		<field name="id" type="long">
			<bind-xml name="eig:pageLevelTierId" node="element" />
		</field>

		<field name="page" type="int">
			<bind-xml name="eig:page" node="element" />
		</field>

		<field name="pageCharge" type="float">
			<bind-xml name="eig:pageCharge" node="element" />
		</field>

		<field name="recordVersion" type="int">
			<bind-xml name="eig:recordVersion" node="element" />
		</field>

	</class>

	<class name="com.mckesson.eig.roi.admin.model.BillingTier">
		<map-to xml="bt" ns-prefix="eig" ns-uri="urn:eig.mckesson.com" />

		<field name="id" type="long">
			<bind-xml name="eig:billingTierId" node="element" />
		</field>

		<field name="name" type="string">
			<bind-xml name="eig:name" node="element" />
		</field>

		<field name="description" type="string">
			<bind-xml name="eig:description" node="element" />
		</field>

		<field name="associated" type="boolean">
			<bind-xml name="eig:associated" node="element" />
		</field>

		<field name="baseCharge" type="float">
			<bind-xml name="eig:baseCharge" node="element" />
		</field>

		<field name="defaultPageCharge" type="float">
			<bind-xml name="eig:defaultPageCharge" node="element" />
		</field>

		<field name="recordVersion" type="int">
			<bind-xml name="eig:recordVersion" node="element" />
		</field>
		
		<field name="salesTax" type="char">
			<bind-xml name="eig:salesTax" node="element" />
		</field>

		<field name="mediaType"
			type="com.mckesson.eig.roi.admin.model.MediaType">
			<bind-xml name="eig:mediaType" node="element" />
		</field>

        <field name="mediaTypeId" type="long">
            <bind-xml name="eig:mediaTypeId" node="element" />
        </field>

        <field name="mediaTypeName" type="string">
            <bind-xml name="eig:mediaTypeName" node="element" />
        </field>

		<field name="pageLevelTier"
			type="com.mckesson.eig.roi.admin.model.PageLevelTier"
			collection="set">
			<bind-xml name="eig:pageLevelTier" node="element" />
		</field>
	</class>

	<class name="com.mckesson.eig.roi.admin.model.BillingTiersList">

		<map-to xml="billingTiers" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />

		<field name="billingTiers"
			type="com.mckesson.eig.roi.admin.model.BillingTier"
			collection="arraylist">
			<bind-xml name="eig:billingTiers" node="element" />
		</field>

	</class>
</mapping>
