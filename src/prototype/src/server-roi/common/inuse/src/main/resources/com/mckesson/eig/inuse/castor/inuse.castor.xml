<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE databases PUBLIC "-//EXOLAB/Castor Mapping DTD Version 1.0//EN"
        "http://castor.exolab.org/mapping.dtd">

<mapping xmlns:eig="urn:eig.mckesson.com">

	<class name="com.mckesson.eig.inuse.model.InUseRecord">
        <map-to xml="inUseRecord" ns-prefix="eig" ns-uri="urn:eig.mckesson.com"/>

        <field name="recordSequence" type="long">
            <bind-xml name="eig:recordSequence" node="element" />
        </field>

        <field name="objectID" type="string">
            <bind-xml name="eig:objectID" node="element" />
        </field>

        <field name="objectType" type="string">
            <bind-xml name="eig:objectType" node="element" />
        </field>

        <field name="applicationID" type="string">
            <bind-xml name="eig:applicationID" node="element" />
        </field>

        <field name="userID" type="string">
            <bind-xml name="eig:userID" node="element" />
        </field>

        <field name="expiresMinutes" type="int">
            <bind-xml name="eig:expiresMinutes" node="element" />
        </field>

        <field name="recordVersion" type="int">
          <bind-xml name="eig:recordVersion" node="element" />
        </field>

        <field name="createdDate" type="date">
            <bind-xml name="eig:createdDate" node="element"/>
        </field>

        <field name="createdBy" type="long">
          <bind-xml name="eig:createdBy" node="element" />
        </field>

        <field name="modifiedDate" type="date">
            <bind-xml name="eig:modifiedDate" node="element"/>
        </field>

        <field name="modifiedBy" type="long">
          <bind-xml name="eig:modifiedBy" node="element" />
        </field>
    </class>

    <class name="com.mckesson.eig.inuse.model.InUseRecordList">

        <map-to xml="inUseRecords" ns-prefix="eig" ns-uri="urn:eig.mckesson.com"/>

        <field name="list" type="com.mckesson.eig.inuse.model.InUseRecord" collection="arraylist">
            <bind-xml name="eig:inUseRecordList" node="element" />
        </field>
    </class>
</mapping>
