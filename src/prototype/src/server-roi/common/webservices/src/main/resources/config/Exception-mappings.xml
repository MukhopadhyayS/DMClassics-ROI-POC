<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE databases PUBLIC "-//EXOLAB/Castor Mapping DTD Version 1.0//EN"
		"http://castor.exolab.org/mapping.dtd">

<mapping xmlns:eig="urn:eig.mckesson.com">

	<!-- ****************************************************************
	* House
	***************************************************************** -->
	<class name="com.mckesson.eig.wsfw.test.service.House">
		<map-to xml="house" ns-prefix="eig" ns-uri="urn:eig.mckesson.com"/>
		
		<field name="streetAddress" type="string">
			<bind-xml name="eig:streetAddress" node="element" />
		</field>
		
		<field name="city" type="string">
			<bind-xml name="eig:city" node="element" />
		</field>

		<field name="state" type="string">
			<bind-xml name="eig:state" node="element" />
		</field>

		<field name="zip" type="int">
			<bind-xml name="eig:zip" node="element" />
		</field>

	  	<field name="rooms" type="com.mckesson.eig.wsfw.test.service.Room" collection="arraylist">
				<bind-xml name="eig:room" location="rooms" node="element"/>
		</field>

	 </class>
 	
	<!-- ****************************************************************
	* Room
	***************************************************************** -->
 	<class name="com.mckesson.eig.wsfw.test.service.Room">
		<map-to xml="room" ns-prefix="eig" ns-uri="urn:eig.mckesson.com"/>

		<field name="name" type="string">
			<bind-xml name="eig:name" node="element" />
		</field>

		<field name="length" type="int">
			<bind-xml name="eig:length" node="element" />
		</field>
	
		<field name="width" type="int">
			<bind-xml name="eig:width" node="element" />
		</field>
 	</class>
 	
</mapping>

