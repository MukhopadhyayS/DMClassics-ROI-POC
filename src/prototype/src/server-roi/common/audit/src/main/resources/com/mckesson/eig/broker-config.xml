<!-- START SNIPPET: xbean -->
<beans xmlns="http://activemq.apache.org/schema/core">

  <bean xmlns="" id="oracle-ds" class="org.apache.commons.dbcp.BasicDataSource" destroy-method="close">
    <property name="driverClassName" value="oracle.jdbc.driver.OracleDriver"/>
    <property name="url" value="jdbc:oracle:thin:@127.0.0.1:1521:hecm"/>
    <property name="username" value="activemq"/>
    <property name="password" value="activemq_pazz"/>
    <property name="poolPreparedStatements" value="true"/>
    <property name="initialSize" value="5"/>
    <property name="maxActive" value="15"/>
    <property name="maxIdle" value="10"/>
    <property name="minIdle" value="5"/>
    <property name="minEvictableIdleTimeMillis" value="60000"/>
    <property name="testOnBorrow" value="true"/>
    <property name="validationQuery" value="select 1 from dual"/>
  </bean>

  <broker useJmx="true" brokerName="hecmBroker">

	<!-- In ActiveMQ 4, you can setup destination policies. note: this xml format may still change a bit -->
    <destinationPolicy>
      <policyMap><policyEntries>

          <policyEntry queue="queue.eigAudit">
            <deadLetterStrategy>
		      <sharedDeadLetterStrategy>
			    <deadLetterQueue>
			      <queue name="queue/eigDLQ" physicalName="queue.eigDLQ"/>
		        </deadLetterQueue>
		      </sharedDeadLetterStrategy>
	        </deadLetterStrategy>
            <dispatchPolicy>
              <strictOrderDispatchPolicy />
            </dispatchPolicy>
            <subscriptionRecoveryPolicy>
              <lastImageSubscriptionRecoveryPolicy />
            </subscriptionRecoveryPolicy>
          </policyEntry>

          <policyEntry queue="queue.loadContentQueue">
            <deadLetterStrategy>
		      <sharedDeadLetterStrategy>
			    <deadLetterQueue>
			      <queue name="queue/eigDLQ2" physicalName="queue.eigDLQ2"/>
		        </deadLetterQueue>
		      </sharedDeadLetterStrategy>
	        </deadLetterStrategy>
            <dispatchPolicy>
              <strictOrderDispatchPolicy />
            </dispatchPolicy>
            <subscriptionRecoveryPolicy>
              <lastImageSubscriptionRecoveryPolicy />
            </subscriptionRecoveryPolicy>
          </policyEntry>

      </policyEntries></policyMap>
    </destinationPolicy>


    <persistenceAdapter>
	  <journaledJDBC journalLogFiles="5" dataSource="#oracle-ds" useDatabaseLock="false" />
    </persistenceAdapter>

    <transportConnectors>
      <!-- prefixing a connector with discovery: causes the connector to be advertiesed over rendezvous -->
      <transportConnector name="hecmBroker" uri="tcp://localhost:61616" discoveryUri="multicast://default"/>
    </transportConnectors>


    <managementContext>
        <!-- we'll use an existing one (JBoss) instead of creating one -->
        <managementContext createConnector="false"/>
    </managementContext>
    
  </broker>

</beans>
