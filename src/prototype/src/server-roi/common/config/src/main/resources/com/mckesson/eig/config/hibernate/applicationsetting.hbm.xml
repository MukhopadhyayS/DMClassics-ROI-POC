<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="com.mckesson.eig.config.model">

  <class name="ApplicationSetting" table="CONFIG_APP_INFO" schema="HECM_AUD">

    <id name="appId" column="CONFIG_APP_SEQ">
      <generator class="increment"/>
    </id>

    <property name="appName"           column="CONFIG_APP_NAME"     type="string" />
  <property name="settings"            column="CONFIG_APP_SETTINGS" type="com.mckesson.eig.config.dao.HibernateXmlType" />
    <property name="modifiedDateTime"  column="MODIFY_DATETIME"     type="date" />

  </class>

  <sql-query name="getDBDate">
    SELECT sysdate
    FROM dual
  </sql-query>

</hibernate-mapping>
