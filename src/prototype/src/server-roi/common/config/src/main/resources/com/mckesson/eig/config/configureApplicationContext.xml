<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:aop="http://www.springframework.org/schema/aop"
  xmlns:tx="http://www.springframework.org/schema/tx"
  xsi:schemaLocation="http://www.springframework.org/schema/beans
                           http://www.springframework.org/schema/beans/spring-beans-2.0.xsd
                           http://www.springframework.org/schema/tx
                           http://www.springframework.org/schema/tx/spring-tx-2.0.xsd
                           http://www.springframework.org/schema/aop
                           http://www.springframework.org/schema/aop/spring-aop-2.0.xsd">

  <bean id="log_initializer" class="com.mckesson.eig.utility.log.log4j.Log4JInitializer">
      <property name="byXml">
        <value>com/mckesson/eig/config/logging/config.logging.xml</value>
      </property>
    </bean>

    <bean id="com.mckesson.eig.config.service.ConfigureLogService"
    class="com.mckesson.eig.config.service.ConfigureLogService"
    scope="singleton"/>

    <bean id="com.mckesson.eig.config.service.ComponentServiceImpl"
    class="com.mckesson.eig.config.service.ComponentServiceImpl"
    scope="singleton"/>

    <bean id="Configuration_Controller"
    class="com.mckesson.eig.config.controller.ConfigureLogController"
    scope="singleton"/>

    <bean id="com.mckesson.eig.audit.local.AuditLocalService"
    class="com.mckesson.eig.audit.local.AuditLocalService"
    lazy-init="true"
    scope="singleton"/>

    <bean id="com.mckesson.eig.config.service.ApplicationSettingService"
    class="com.mckesson.eig.config.service.ApplicationSettingServiceImpl"
    lazy-init="true"
    scope="singleton"/>

    <!-- Audit Queue Confifuration -->
  <bean id="eig_auditq_config"
      class="com.mckesson.eig.wsfw.jms.MessagePoster">
      <property name="queue">
        <ref bean="auditQueue"/>
      </property>
      <property name="connectionFactory">
        <ref bean="connectionFactory"/>
      </property>
  </bean>

  <bean id="auditQueue"
    class="org.springframework.jndi.JndiObjectFactoryBean">
    <property name="jndiTemplate">
      <ref bean="jndiTemplate" />
    </property>
    <property name="jndiName">
      <value>queue/eigAudit</value>
    </property>
  </bean>

  <bean id="connectionFactory"
        class="org.springframework.jndi.JndiObjectFactoryBean">
    <property name="jndiTemplate">
      <ref bean="jndiTemplate" />
    </property>
    <property name="jndiName">
      <value>java:activemq/QueueConnectionFactory</value>
    </property>
  </bean>

  <bean id="jndiTemplate"
    class="org.springframework.jndi.JndiTemplate">
    <property name="environment">
      <props>
        <prop key="java.naming.factory.initial">
          org.apache.activemq.jndi.ActiveMQInitialContextFactory
        </prop>
        <prop key="java.naming.provider.url">
          tcp://127.0.0.1:61616
        </prop>
        <prop key="queue.queue/eigAudit">queue.eigAudit</prop>
      </props>
    </property>
  </bean>

    <bean id="hecm_component" class="com.mckesson.eig.config.model.LogConfigurationDetail">

        <property name="componentName">
            <value>Hecm Server</value>
        </property>
        <property name="componentSeq">
            <value>1</value>
        </property>
        <property name="logFile">
            <value>com/mckesson/hecm/logging/hecm.logging.xml</value>
        </property>
        <property name="appenderList">
            <list>
                <value>eigLogAppender</value>
                <value>eigMetricsAppender</value>
                <value>eigLoadContentAppender</value>
            </list>
        </property>
      <property name="categoryList">
        <list>
          <value>com.quickstream</value>
          <value>com.mckesson.hecm</value>
          <value>com.mckesson.eig</value>
          <value>com.mckesson.eig.utility.metric</value>
          <value>com.mckesson.hecm.service.content.logging</value>
        </list>
      </property>
    </bean>

    <bean id="worklist_component" class="com.mckesson.eig.config.model.LogConfigurationDetail">

           <property name="componentName">
        <value>Worklist Server</value>
      </property>
      <property name="componentSeq">
            <value>2</value>
      </property>
      <property name="logFile">
        <value>com/mckesson/eig/workflow/logging.xml</value>
      </property>
      <property name="appenderList">
        <list>
          <value>workflowLogAppender</value>
          </list>
      </property>
        <property name="categoryList">
        <list>
          <value>com.mckesson.eig.workflow.api</value>
          <value>com.mckesson.eig.workflow.service</value>
          <value>com.mckesson.eig.workflow.worklist.api</value>
          <value>com.mckesson.eig.workflow.worklist.service</value>
        </list>
      </property>
    </bean>

    <bean id="component_list" class="com.mckesson.eig.config.model.LogConfigurationDetailList" lazy-init="true">
      <property name="componentList">
        <list>
          <ref bean="hecm_component"/>
          <ref bean="worklist_component"/>
        </list>
        </property>
    </bean>

  <!-- Configurations for webservice security -->

    <!-- Authenticator for hecm -->
  <bean id="authenticator.appID"
    class="com.mckesson.eig.wsfw.security.service.test.MockAuthenticator" />

  <!--  Authorizer for hecm -->
  <bean id="authorizer.appID"
    class="com.mckesson.eig.wsfw.security.service.test.MockAuthorizer" />

  <bean id="PasswordEncryptionStrategy"
     class="com.mckesson.eig.wsfw.security.encryption.AESStrategy">
  </bean>

  <bean id="dataSource" class="org.springframework.jndi.JndiObjectFactoryBean">
          <description>Provides access to a datasource registered with JNDI.</description>
          <property name="jndiName">
              <value>java:/QspDS</value>
          </property>
  </bean>

  <bean id="sessionFactory" class="org.springframework.orm.hibernate3.LocalSessionFactoryBean">

      <property name="dataSource"><ref local="dataSource"/></property>
      <!-- Must references all OR mapping files. -->
      <property name="mappingResources">
        <list>
            <!--  Application Setting  -->
          <value>/com/mckesson/eig/config/hibernate/applicationsetting.hbm.xml</value>
        </list>
      </property>
      <property name="hibernateProperties">
        <props>
          <!-- SQL Server Dialect - Uncomment the next line to use SQL Server -->
          <!-- <prop key="hibernate.dialect">org.hibernate.dialect.SQLServerDialect</prop>-->
          <prop key="hibernate.dialect">org.hibernate.dialect.Oracle9Dialect</prop>
          <prop key="hibernate.connection.pool_size">10</prop>
          <prop key="hibernate.show_sql">true</prop>
          <prop key="hibernate.cache.provider_class">org.hibernate.cache.HashtableCacheProvider</prop>
          <prop key="hibernate.connection.release_mode">after_transaction</prop>
        </props>
      </property>
    </bean>

   <bean id="txManager" class="org.springframework.orm.hibernate3.HibernateTransactionManager">
      <property name="sessionFactory" ref="sessionFactory" />
   </bean>

   <tx:advice id="txAdvice" transaction-manager="txManager">
      <tx:attributes>
          <tx:method name="*" />
      </tx:attributes>
    </tx:advice>

    <aop:config proxy-target-class="true">
      <aop:advisor
          pointcut="execution(* com.mckesson.eig.config.service.ApplicationSettingServiceImpl.* (..))"
          advice-ref="txAdvice" />
    </aop:config>

    <bean id="com.mckesson.eig.config.audit.ConfigurationAuditManager"
          class="com.mckesson.eig.config.audit.ConfigurationAuditManager" lazy-init="true" />

    <bean id="com.mckesson.eig.config.service.ApplicationSettingServiceImpl"
        class="com.mckesson.eig.config.service.ApplicationSettingServiceImpl" />

    <bean id="com.mckesson.eig.config.dao.ApplicationSettingDAO" class="com.mckesson.eig.config.dao.ApplicationSettingDAOImpl">
      <property name="sessionFactory" ref="sessionFactory" />
    </bean>

    <bean id="com.mckesson.eig.config.service.NotificationServiceImpl" class="com.mckesson.eig.config.service.NotificationServiceImpl" lazy-init="true" scope="singleton"/>
</beans>
