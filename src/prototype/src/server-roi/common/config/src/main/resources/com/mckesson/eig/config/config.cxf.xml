<beans xmlns="http://www.springframework.org/schema/beans"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xmlns:jaxws="http://cxf.apache.org/jaxws"
      xmlns:tx="http://www.springframework.org/schema/tx"
      xmlns:cxf="http://cxf.apache.org/core"
      xsi:schemaLocation="http://www.springframework.org/schema/beans
                    http://www.springframework.org/schema/beans/spring-beans.xsd
                    http://cxf.apache.org/jaxws
                    http://cxf.apache.org/schemas/jaxws.xsd
                    http://cxf.apache.org/core
                    http://cxf.apache.org/schemas/core.xsd
                    http://www.springframework.org/schema/tx
                    http://www.springframework.org/schema/tx/spring-tx-2.0.xsd">

  <import resource="classpath:META-INF/cxf/cxf.xml" />
  <import resource="classpath:META-INF/cxf/cxf-extension-soap.xml"/>
  <import resource="classpath:META-INF/cxf/cxf-servlet.xml" />

  <import resource="classpath:com/mckesson/eig/config/configureApplicationContext.xml"/>

  <bean id="HeaderParameterRemover"
        class="com.mckesson.eig.wsfw.cxf.HeaderParameterRemover"/>

  <bean id="EIGIn" class="com.mckesson.eig.wsfw.cxf.EIGSessionInitializer"/>
  <bean id="SAAJIn" class="org.apache.cxf.binding.soap.saaj.SAAJInInterceptor"/>
  <bean id="AuthorizationIn" class="com.mckesson.eig.wsfw.cxf.ExtendedAuthorizationInterceptor"/>

  <bean id="EIGSoap11FaultOut" class="com.mckesson.eig.wsfw.cxf.EIGSoap11FaultOutInterceptor"/>

  <jaxws:endpoint id="config"
                  wsdlLocation="WEB-INF/config/webservices/configureLog_v1.wsdl"
                  implementor="#com.mckesson.eig.config.service.ConfigureLogService"
                  address="/services/configureLog">

    <jaxws:properties>
      <entry key="forceInvalidateSession" value="false"/>
    </jaxws:properties>

    <jaxws:invoker>
      <bean class="com.mckesson.eig.wsfw.cxf.BusinessServiceInvoker">
      <constructor-arg>
        <ref bean="com.mckesson.eig.config.service.ConfigureLogService"/>
      </constructor-arg>
      </bean>
    </jaxws:invoker>

    <jaxws:inInterceptors>
       <ref bean="SAAJIn"/>
       <ref bean="wss4jIn"/>
       <ref bean="AuthorizationIn"/>
       <ref bean="HeaderParameterRemover"/>
       <ref bean="EIGIn"/>
    </jaxws:inInterceptors>

  </jaxws:endpoint>

  <jaxws:endpoint id="component"
                  wsdlLocation="WEB-INF/config/webservices/configservercomponents_v1.wsdl"
                  implementor="#com.mckesson.eig.config.service.ComponentServiceImpl"
                  address="/services/component">

    <jaxws:properties>
      <entry key="forceInvalidateSession" value="false"/>
    </jaxws:properties>

    <jaxws:invoker>
      <bean class="com.mckesson.eig.wsfw.cxf.BusinessServiceInvoker">
      <constructor-arg>
        <ref bean="com.mckesson.eig.config.service.ComponentServiceImpl"/>
      </constructor-arg>
      </bean>
    </jaxws:invoker>

  <jaxws:inInterceptors>
    <ref bean="SAAJIn"/>
       <ref bean="wss4jIn"/>
       <ref bean="AuthorizationIn"/>
       <ref bean="HeaderParameterRemover"/>
       <ref bean="EIGIn"/>
  </jaxws:inInterceptors>
  </jaxws:endpoint>

  <jaxws:endpoint id="applicationsetting"
                  wsdlLocation="WEB-INF/config/webservices/applicationsetting_v1.wsdl"
                  implementor="#com.mckesson.eig.config.service.ApplicationSettingServiceImpl"
                  address="/services/applicationsetting">

    <jaxws:properties>
      <entry key="forceInvalidateSession" value="false"/>
    </jaxws:properties>

    <jaxws:invoker>
      <bean class="com.mckesson.eig.wsfw.cxf.BusinessServiceInvoker">
      <constructor-arg>
        <ref bean="com.mckesson.eig.config.service.ApplicationSettingServiceImpl"/>
      </constructor-arg>
      </bean>
    </jaxws:invoker>

  <jaxws:inInterceptors>
       <ref bean="SAAJIn"/>
       <ref bean="wss4jIn"/>
       <ref bean="AuthorizationIn"/>
       <ref bean="HeaderParameterRemover"/>
       <ref bean="EIGIn"/>
  </jaxws:inInterceptors>
  </jaxws:endpoint>

  <jaxws:endpoint id="notification"
                  wsdlLocation="WEB-INF/config/webservices/notification_v1.wsdl"                
                  implementor="#com.mckesson.eig.config.service.NotificationServiceImpl"
                  address="/services/notification">

    <jaxws:properties>
	   <entry key="forceInvalidateSession" value="false"/>
	</jaxws:properties>

    <jaxws:invoker>
        <bean class="com.mckesson.eig.wsfw.cxf.BusinessServiceInvoker">
            <constructor-arg>
                <ref bean="com.mckesson.eig.config.service.NotificationServiceImpl"/>
            </constructor-arg>
	   </bean>
    </jaxws:invoker>

    <jaxws:inInterceptors>
        <!--ref bean="SAAJIn"/>
        <ref bean="wss4jIn"/>
        <ref bean="AuthorizationIn"/-->
        <ref bean="HeaderParameterRemover"/>
        <ref bean="EIGIn"/>
    </jaxws:inInterceptors>
  </jaxws:endpoint>

  <bean id="cxf" class="org.apache.cxf.bus.CXFBusImpl">
      <property name="outFaultInterceptors">
          <list>
            <ref bean="EIGSoap11FaultOut"/>
          </list>
      </property>
  </bean>

  <bean id="wss4jIn" class="org.apache.cxf.ws.security.wss4j.WSS4JInInterceptor">
    <property name="properties">
      <map>
        <entry key="action"                value="UsernameToken Timestamp"/>
        <entry key="passwordType"          value="PasswordText" />
        <entry key="passwordCallbackClass" value="com.mckesson.eig.wsfw.security.webservice.AuthenticationHandler"/>
      </map>
    </property>
  </bean>

</beans>