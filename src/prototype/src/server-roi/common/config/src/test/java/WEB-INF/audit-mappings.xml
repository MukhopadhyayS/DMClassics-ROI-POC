<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE databases PUBLIC "-//EXOLAB/Castor Mapping DTD Version 1.0//EN"
    "http://castor.exolab.org/mapping.dtd">

<mapping xmlns:eig="urn:eig.mckesson.com">

  <!-- ****************************************************************
  * AuditEvent
  ***************************************************************** -->
  <class name="com.mckesson.eig.audit.model.AuditEvent">
    <map-to xml="auditEvent" ns-prefix="eig" ns-uri="urn:eig.mckesson.com"/>
    
    <field name="eventId" type="long">
      <bind-xml name="eig:eventId" node="element" />
    </field>
    
    <field name="domainId" type="long">
      <bind-xml name="eig:domainId" node="element" />
    </field>
    
    <field name="componentId" type="long">
      <bind-xml name="eig:componentId" node="element" />
    </field>    
  
    <field name="eventStart" type="date">
      <bind-xml name="eig:eventStart" node="element" />
    </field>
  
    <field name="eventEnd" type="date">
      <bind-xml name="eig:eventEnd" node="element" />
    </field>
    
    <field name="objectId" type="long">
      <bind-xml name="eig:objectId" node="element" />
    </field>
  
    <field name="revision1" type="long">
      <bind-xml name="eig:revision1" node="element" />
    </field>
  
    <field name="revision2" type="long">
      <bind-xml name="eig:revision2" node="element" />
    </field>
  
    <field name="revision3" type="long">
      <bind-xml name="eig:revision3" node="element" />
    </field>
  
    <field name="comment" type="string">
      <bind-xml name="eig:comment" node="element" />
    </field>

    <field name="eventStatus" type="long">
      <bind-xml name="eig:eventStatus" node="element" />
    </field>
  
    <field name="location" type="string">
      <bind-xml name="eig:location" node="element" />
    </field>

    <field name="userId" type="long">
      <bind-xml name="eig:userId" node="element" />
    </field>
  
    <field name="workflowReason" type="string">
      <bind-xml name="eig:workflowReason" node="element" />
    </field>
  
  </class>
  
      <!-- ****************************************************************
    * Component Info
    ***************************************************************** -->
    <class name="com.mckesson.eig.utility.components.model.ComponentInfo">
        <map-to xml="componentInfo" ns-prefix="eig" ns-uri="urn:eig.mckesson.com" />
        
        <field name="componentID" type="string">
            <bind-xml name="componentID" node="attribute" />
        </field>
        
        <field name="componentDisplayName" type="string">
            <bind-xml name="componentDisplayName" node="attribute" />
        </field>
        
        <field name="componentName" type="string">
            <bind-xml name="componentName" node="element" location="applicationInfo" />
        </field>        
    
        <field name="productName" type="string">
            <bind-xml name="productName" node="element" location="applicationInfo" />
        </field>
    
        <field name="productType" type="string">
            <bind-xml name="productType" node="element" location="applicationInfo" />
        </field>
        
        <field name="version" type="string">
            <bind-xml name="version" node="element" location="applicationInfo" />
        </field>
        
        <field name="applicationPath" type="string">
            <bind-xml name="path" node="element" location="applicationInfo" />
        </field>
        
        <field name="configurationInfo" type="string">
            <bind-xml name="configurationInfo" node="element" />
        </field>
        
        <field name="updatedHistories" type="com.mckesson.eig.utility.components.model.UpdateHistory" collection="arraylist">
            <bind-xml name="update" node="element" location="updateInfo"/>
        </field>
        
        <field name="logFilePath" type="string">
            <bind-xml name="file" node="element" location="logConfig" />
        </field>
        
        <field name="appenders" type="string" collection="array">
            <bind-xml name="appender" node="element" location="logConfig/appenders"/>
        </field>
        
        <field name="categories" type="string" collection="array">
            <bind-xml name="category" node="element" location="logConfig/categories"/>
        </field>
         
    </class>
    
  <!-- ****************************************************************
    * Update History
    ***************************************************************** -->
    <class name="com.mckesson.eig.utility.components.model.UpdateHistory">
        <map-to xml="update" ns-prefix="eig" ns-uri="urn:eig.mckesson.com"/>
        
        <field name="updatedOn" type="date">
            <bind-xml name="eig:date" node="element"/>
        </field>
        
        <field name="comments" type="string">
            <bind-xml name="eig:comments" node="element"/>
        </field>
        
        <field name="version" type="string">
            <bind-xml name="eig:version" node="element"/>
        </field>       
    </class>
    
  <!-- ****************************************************************
    * ComponentList
  ***************************************************************** -->
  <class name="com.mckesson.eig.utility.components.model.ComponentList">
    <map-to xml="componentList" ns-prefix="eig" ns-uri="urn:eig.mckesson.com" />

    <field name="components"  type="com.mckesson.eig.utility.components.model.ComponentInfo"  collection="arraylist">
      <bind-xml name="eig:componentInfo" node="element" />
    </field>
  </class>

</mapping>

