<project
	name="client.projects.include"
	default="build-client-projects"
	basedir="."
	description="Include this project in NAnt that build the client projects">

    <!-- property needed by nant to determine location of .NET assemblies-->
    <property name="nant.settings.currentframework" value="net-4.0"/>

	<!-- comma seperated list of C# projects REDEFINE in projects that include this project-->
	<property name="NAnt_ProjectList" value=""/>

	<target name="build-client-projects-for-install">
		<property name="BuildParam" value="build-client-projects-for-install"/>
		<call target="BuildAll"/>
	</target>

    <!--Build client projects-->
	<target name="build-client-projects">
		<property name="BuildParam" value="build-client-projects"/>
		<property name="nant.onfailure" value="OnFailure"/>

        <call target="BuildAll"/>
        <nant buildfile ="./client.build.common.xml" target ="GetBuildPercentages" failonerror ="true"/>
    </target>

    <!-- DoUnitTest runs the nunit tests for both debug and release builds only the run.client.test.cases property set to true -->
	<target name="DoUnitTest">
		<property name="BuildParam" value="DoUnitTest"/>
		<call target="BuildAll"/>
	</target>

    <!-- DoCompile compile the project source files in  debug and release mode-->
	<target name="DoCompile">
		<property name="BuildParam" value="DoCompile"/>
		<call target="BuildAll"/>
	</target>

	<!-- OnFailure sends an e-mail when the build fails -->
	<target name="OnFailure">
		<echo message="${project::get-name()} build failed" />
	</target>

	<!--BuildAll cleans the directores, and calls the build for the appplicaton and the tests-->
	<target
		name="BuildAll"
		description="Rebuild everything">

		<!-- Delete all the files in existing deployable-->
        <nant buildfile ="./client.build.common.xml" target ="CleanDeploy" failonerror ="true"/>
		
        <if test="${target::exists('BuildCS')}">
			<call target="BuildCS"/>
		</if>
	</target>

    <!-- Build all CS projects-->
    <target name ="BuildCS">

        <foreach
            item ="String"
            property ="Project"
            delim =","
            trim ="Both"
            in ="${NAnt_ProjectList}">

            <call target ="BuildNAnt"/>
        </foreach>
    </target>

    <!-- Call the project specific build.xml file to build-->
    <target name ="BuildNAnt">
        <property name="dir.client" value="${project::get-base-directory()}\.."/>
        <echo message ="********* Building : ${project::get-base-directory()}\${Project}\build.xml *********"/>
        <nant buildfile ="${dir.client}\${Project}\build.xml" inheritall ="true" target ="${BuildParam}" failonerror ="true"/>
    </target>
</project>