end;


////////////////////////////////////////////////////////////////////////////////
// The Installed event is sent after the feature Fax Service
// is uninstalling.
////////////////////////////////////////////////////////////////////////////////
export prototype FaxService_UnInstalling();
function FaxService_UnInstalling()
begin
	LogEnterMessage("FaxService_UnInstalling()");
	UninstallFaxService(FAX_OLD_SERVICE_NAME,0);
	//UninstallFaxService(FAX_NEW_SERVICE_NAME,0);
 	LogExitMessage("FaxService_UnInstalling()");
end;

////////////////////////////////////////////////////////////////////////////////
// The Installed event is sent after the feature Fax Service
// is uninsatlled.
////////////////////////////////////////////////////////////////////////////////
export prototype FaxService_UnInstalled();
function FaxService_UnInstalled()
begin
	LogEnterMessage("FaxService_UnInstalled()");
	DeleteDir(FAX_SERVICE_HOME, ALLCONTENTS);
 	LogExitMessage("FaxService_UnInstalled()");
end;


////////////////////////////////////////////////////////////////////////////////
// The Installed event is sent after the feature Config Util
// is installed.
////////////////////////////////////////////////////////////////////////////////
export prototype ConfigUtil_Installed();
function ConfigUtil_Installed()
begin
	LogEnterMessage("ConfigUtil_Installed()");
	ModifyConfigureROIServerProperites();
	CustomizeConfigUtilProps();   
	CreateConfigUtilBat();
	ModifyAutoConfiguratorBat();
 	LogExitMessage("ConfigUtil_Installed()");
end;


////////////////////////////////////////////////////////////////////////////////
// The Installed event is sent after the feature Config Util
// is uninstalled.
////////////////////////////////////////////////////////////////////////////////
export prototype ConfigUtil_UnInstalled();
function ConfigUtil_UnInstalled()
begin
	LogEnterMessage("ConfigUtil_UnInstalled()");
	DeleteDir(CONFIG_UTIL_HOME, ALLCONTENTS);
 	LogExitMessage("ConfigUtil_UnInstalled()");
end;

////////////////////////////////////////////////////////////////////////////////
// The Installed event is sent after the feature Output Server
// is installed.
////////////////////////////////////////////////////////////////////////////////
export prototype OutputServer_Installed();
function OutputServer_Installed()
begin
	LogEnterMessage("OutputServer_Installed()");
	ModifyStartOutputBat();
 	//ModifyOutputJbossFile();
	ModifyJBossPort();
	ModifyConfigureUtilProperitesForOutput();
	CreateOutputServerShortcut();    
	// Create Output JBoss as windows service
	InstallOutputJBossService(); 
	ModifyMPFWConfiguration(TARGETDIR ^ "output.jboss", DEFAULT_OUTPUT_MPFW_APPLICATION_NAME);  
	
 	LogExitMessage("OutputServer_Installed()");
end;
//---------------------------------------------------------------------------
// The UnInstalling event is sent just before the feature 
// Output Service Server is uninstalled.
//---------------------------------------------------------------------------
 
export prototype OutputServiceServer_UnInstalling();
function OutputServiceServer_UnInstalling()
begin   
	LogEnterMessage("OutputServer_UnInstalling()"); 
	UnInstallOutputJBossService(OUTPUT151_JBOSS_SERVICE_NAME);              
	UnInstallOutputJBossService(OUTPUT160_JBOSS_SERVICE_NAME);
	//UnInstallOutputJBossService(OUTPUT_NEW_JBOSS_SERVICE_NAME);
	LogEnterMessage("OutputServer_UnInstalling()");
end;
//---------------------------------------------------------------------------
// The UnInstalling event is sent just before the feature 
// ROI Server is uninstalled.
//---------------------------------------------------------------------------
 
export prototype ROIServer_UnInstalling();
function ROIServer_UnInstalling()
begin      
	LogEnterMessage("ROIServer_UnInstalling()");
    UnInstallROIJBossService(ROI151_JBOSS_SERVICE_NAME);
	UnInstallROIJBossService(ROI160_JBOSS_SERVICE_NAME);
	//UnInstallROIJBossService(ROI_NEW_JBOSS_SERVICE_NAME);
    LogEnterMessage("ROIServer_UnInstalling()");
end;  


////////////////////////////////////////////////////////////////////////////////
// The Installing event is sent just before the feature
