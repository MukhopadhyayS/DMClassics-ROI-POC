
#include "Misc.rul"
#include "Declare.rul"

////////////////////////////////////////////////////////////////////////////////
// The Installing event is sent just before the feature
// jboss is installing.
////////////////////////////////////////////////////////////////////////////////
export prototype Jboss_Installing();
function Jboss_Installing()
begin
	LogEnterMessage("Jboss_Installing()");
	// installs jdk
	InstallJDK();
	//InstallJRE();
	LogExitMessage("Jboss_Installing()");
end;

////////////////////////////////////////////////////////////////////////////////
// The Installed event is sent after the feature jboss
// is installed.
////////////////////////////////////////////////////////////////////////////////
export prototype Jboss_Installed();
function Jboss_Installed()
begin
	LogEnterMessage("Jboss_Installed()");
 	// creating Registry key.
 	CreateJbossRegKey();
 	ModifyJbossFile();
 	//ModifyROIJBossPort();
 	LogExitMessage("Jboss_Installed()");
end;



////////////////////////////////////////////////////////////////////////////////
// The Installed event is sent after the feature jboss
// is uninstalled.
////////////////////////////////////////////////////////////////////////////////
export prototype Jboss_UnInstalled();
function Jboss_UnInstalled()
begin
	LogEnterMessage("Jboss_UnInstalled()");                     
	DeleteJbossDirOnUninstallation(); 
	//UninstallJDK();
 	LogExitMessage("Jboss_UnInstalled()");
end;


////////////////////////////////////////////////////////////////////////////////
// The Installing event is sent just before the feature
// ROI Server is installing.
////////////////////////////////////////////////////////////////////////////////
export prototype ROIServer_Installing();
function ROIServer_Installing()
begin
	LogEnterMessage("ROIServer_Installing()");
	LogExitMessage("ROIServer_Installing()");
end;

////////////////////////////////////////////////////////////////////////////////
// The Installed event is sent after the feature ROI Server
// is installed.
////////////////////////////////////////////////////////////////////////////////
export prototype ROIServer_Installed();
function ROIServer_Installed()
begin
	LogEnterMessage("ROIServer_Installed()");
	//ModifyROIJBossPort();
	//ModifyConfigureROIServerProperites();  
	ModifyJbossShutdownBatFile();
	InstallROIJBossService();    
	ModifyMPFWConfiguration(TARGETDIR ^ "jboss", DEFAULT_ROI_MPFW_APPLICATION_NAME);  
 	LogExitMessage("ROIServer_Installed()");
end;

