<project default="build-server-install" basedir="../">

    <property name="dir.src" value="../" />
	<property name="dir.build" value="${basedir}\..\build" />
	<property name="dir.database" value="${basedir}\..\database" />
    <property file="${dir.build}/props/${build.config.file.name}" />
	<property file="${dir.build}/props/base.properties" />
	<property name="war.name" value="eig-output"/>
	<property name="ear.name" value="eig-output.ear"/>

	<import file="${dir.build}/starteam.xml" />
	<import file="${dir.build}/cvs.xml" />
	<import file="${dir.build}/svn.xml" />
	
	<property environment="env"/>
	<path id="svnant.classpath">
	  <pathelement location="${env.ANT_HOME}/lib/svnant.jar"/>
	  <pathelement location="${env.ANT_HOME}/lib/svnClientAdapter.jar"/>
	  <pathelement location="${env.ANT_HOME}/lib/svnkit.jar"/>
	  <pathelement location="${env.ANT_HOME}/lib/svnjavahl.jar"/>
	</path>
	
	<typedef resource="org/tigris/subversion/svnant/svnantlib.xml" classpathref="svnant.classpath" />
	<svnSetting javahl="false" svnkit="true"  username="${svn.username}"  password="${svn.password}"  id="svn.settings" />

    <!-- **********************************************************************
             *  Target : build.server.install
             *  target to do all the server install build activities in sequence
             ********************************************************************** -->
    <target name="build-server-install">

    	<!-- <antcall target="update-server-components"/>  -->
    	<antcall target="copy-server-components"/>
		<!--<antcall target="copy-PublicPrivateKeyGenerator-utility" /-->
        <!--antcall target="copy-config-util"/-->
        <antcall target="copy-config-files"/>
    	<antcall target="update-set-up-bat"/>
    	<antcall target="update-roi-install-bat"/>
        <if>
            <equals arg1="${build.install.kit}" arg2="true" />
            <then>
                <echo message="Preparing install kit..." />
                <antcall target="build-install-kit"/>
            </then>
        </if>

    </target>

    <!-- **********************************************************************
             *  Target : prepare-install-kit
             *  target to prepare install kit by checkking out install scripts
                this target is specifically to be invoked by hudson
     ********************************************************************** -->

    <target name="prepare-install-kit">

        <antcall target="refresh-install-script" />

    	<antcall target="display-properties" />

        <property file="${dir.build}/props/roi.install.properties" />

    	<!--antcall target="copy-raw-install-files-to-local" /-->

        <antcall target="build-install-kit" />

        <property file="${dir.build}/version.txt" />

        <!-- calls email task to initiate an email for install -->
        <ant antfile="${source.local.root.path}/build/send.email.xml" target="notify-install-build">
             <property name="basedir" value="${source.local.root.path}" />
        </ant>

     </target>


    <!-- **********************************************************************
         *  Target : copy-server-components
         *  target to copy the required server components to install area
         ********************************************************************** -->
    <target name="copy-server-components">

        <!-- cleans the server components -->
        <delete failonerror="false">
            <fileset dir="${basedir}/bin/server/"/>
        </delete>

		<property file="${dir.build}/version.txt" />
	    	
        <!-- Copies to the install area -->
        <copy todir="${basedir}/bin/MPFServer/webapps" preservelastmodified="true" includeEmptyDirs="false">
            <fileset dir="${dir.src}/server/3rdparty" includes="alert.war"/>
            <fileset dir="${dir.src}/server/bin" includes="roi.war"/>
            <!--fileset dir="${dir.src}/server/3rdparty" includes="audit.war"/>
            <fileset dir="${dir.src}/server/3rdparty" includes="inuse.war"/>
            <fileset dir="${dir.src}/server/3rdparty" includes="eig-output.ear"/-->
        </copy>
    </target>
	<target name="copy-PublicPrivateKeyGenerator-utility">
			<echo message="**** Copying PublicPrivateKeyGenerator files to install area ****" />
			<property file="${hpf.install.location}/InstallShieldSource/HPF/version.txt" />
			<mkdir dir="${basedir}/bin/PublicPrivateKeyGenerator" />
			<echo message="Copying Install Files to shared location..." />
			<echo message="Copying Install Files ${hpf.install.location}/installs" />
			<echo message="Copying build Files ${Major}.${Minor}.${ServicePack}.${Build}" />
			<copy todir="${basedir}/bin/PublicPrivateKeyGenerator" preservelastmodified="true" includeEmptyDirs="false">
		            <fileset dir="${hpf.install.location}/installs/${Major}.${Minor}.${ServicePack}.${Build}/HPF/Support/PublicPrivateKeyGenerator" />
		    </copy>
	    </target>

	 <!-- **********************************************************************
	         *  Target : update-server-components
	         *  target to update-server-components the required server components to install area
	         ********************************************************************** -->
	    <target name="update-server-components">

	    	<!-- copies the new roi-hpf auth jar files to install area -->
	    	<echo message="**** Unzipping output files to install area ****" />
	    	<unzip src="${dir.src}/server/3rdparty/eig-output.ear" dest="${dir.src}/server/3rdparty/eig-output" />
	    	<unzip src="${dir.src}/server/3rdparty/eig-output/eig-output.war" dest="${dir.src}/server/3rdparty/eig-output/eig-output" />
	    	<delete file="${dir.src}/server/3rdparty/eig-output/eig-output/WEB-INF/lib/roi-hpf-auth.jar" />
	    	<copy todir="${dir.src}/server/3rdparty/eig-output/eig-output/WEB-INF/lib" preservelastmodified="true" includeEmptyDirs="false">
	    	      <fileset dir="${dir.src}/server/lib" includes="roi-hpf-auth.jar"/>
	    	</copy>
	    	<antcall target="build-war" />
	    	<antcall target="build-ear" />
	    </target>

    <!-- **********************************************************************
             *  Target : copy-config-util
             *  target to copy the roi.config.util to install area
             ********************************************************************** -->
    <target name="copy-config-util">

        <delete failonerror="false">
            <fileset dir="${basedir}/bin/server/roi.config.util" />
        </delete>

        <copy todir="${basedir}/bin/server/roi.config.util" preservelastmodified="true" includeEmptyDirs="false">
            <fileset dir="${basedir}/roi.config.util/bin/roi.config.util"/>
        </copy>
    </target>

	 <!-- **********************************************************************
	             *  Target : build-war
	             *  target to build-war
	             ********************************************************************** -->
	    <target name="build-war">
	    	<property file="${dir.build}/version.txt" />
	    	<delete file="${dir.src}/server/3rdparty/eig-output/eig-output.war" />
	    	<war destfile="${dir.src}/server/3rdparty/eig-output/${war.name}.war" webxml="${dir.src}/server/3rdparty/eig-output/eig-output/WEB-INF/web.xml">
				<manifest>
					<attribute name="Implementation-Title" value="${Product} ${war.name}.war" />
					<attribute name="Implementation-Version" value="${build.major}.${build.minor}.${build.servicePack}.${build.number}" />
					<attribute name="Implementation-Build-Date" value="${build.date}" />
					<attribute name="Implementation-Vendor" value="${Company}" />
				</manifest>
	    		 <fileset dir="${dir.src}/server/3rdparty/eig-output/eig-output"/>
	    	</war>
	    	<delete dir="${dir.src}/server/3rdparty/eig-output/eig-output" />
	    </target>

	 <!-- **********************************************************************
	             *  Target : build-ear
	             *  target to build-ear
	             ********************************************************************** -->
	    <target name="build-ear">
	    	 <property file="${dir.build}/version.txt" />
	    	<delete file="${dir.src}/server/3rdparty/eig-output.ear" />
	    	<ear destfile="${dir.src}/server/3rdparty/${ear.name}" appxml="${dir.src}/server/3rdparty/eig-output/META-INF/application.xml">
	    	      <manifest>
	    	        <attribute name="Implementation-Title" value="${project.name} ${ear.name}" />
	    	        <attribute name="Implementation-Version" value="${build.major}.${build.minor}.${build.servicePack}.${build.number}"/>
	    	        <attribute name="Implementation-Build-Date" value="${build.date}" />
	    	        <attribute name="Implementation-Vendor" value="${Company}" />
	    	      </manifest>
	    		 <fileset dir="${dir.src}/server/3rdparty/eig-output"/>
	    	</ear>
	    	<delete dir="${dir.src}/server/3rdparty/eig-output" />
	    </target>


    <!-- **********************************************************************
             *  Target : copy-config-files
             *  target to copy the config files to install area
             ********************************************************************** -->
    <target name="copy-config-files">

        <!-- deletes the old config files from install area -->
        <!--delete dir="${basedir}/bin/server/config/var" />
        <delete dir="${basedir}/bin/server/output.config/var" /-->

        <!-- copies the new config files to install area -->
		<!-- CR# 381,475 - Copies the install Config files to Output alone -->
        <!--echo message="**** Unzipping Alert config files to install area  ****" />
		<property file="${dir.build}/version.txt" />
        <unzip src="${dir.src}/server/3rdparty/alert-config.zip" dest="${basedir}/bin/MPFServer/mpfconfig"/-->
		
		<copy todir="${basedir}/bin/MPFServer/mpfconfig" preservelastmodified="true" includeEmptyDirs="false">
            <fileset dir="${dir.src}/server/res">
				<include name="**/oc*.properties"/>
			</fileset>
        </copy>
        <!--echo message="**** Unzipping Audit config files to install area ****" />
        <unzip src="${dir.src}/server/3rdparty/audit-config.zip" dest="${basedir}/bin/server/output.config"/>

        <echo message="**** Unzipping In Use config files to install area  ****" />
        <unzip src="${dir.src}/server/3rdparty/InUse-config.zip" dest="${basedir}/bin/server/config"/>

        <echo message="**** Unzipping Output config files to install area  ****" />
        <unzip src="${dir.src}/server/3rdparty/eig-output.zip" dest="${basedir}/bin/server/output.config"/>

        <echo message="**** Unzipping ROI config files to install area  ****" />
        <unzip src="${dir.src}/server/bin/eig.roi.config.zip" dest="${basedir}/bin/server/config"/-->

    </target>

    <!-- build the install shield project -->
    <target name="build-install-kit">

        <!--property name="executable" value="${dir.install.Shield}/IsCmdBld.exe"/>
        <property name="startDir" value="${basedir}"/>
        <property name="cmdLine" value='-p "roi.installer.ism" -r "ROI" -c COMP'/>

        <echo message="Starting ${executable} ${cmdLine} in ${startDir} "/>

        <exec
            executable="${executable}"
            dir="${startDir}"
            resolveexecutable="true"
            searchpath="true"
            failifexecutionfails="true"
            failonerror="true"
        >
            <arg line="${cmdLine}"/>
        </exec-->
		<property file="${dir.build}/version.txt" />
		<zip destfile="${dir.bin}/ROI_${build.major}_${build.minor}_${build.servicePack}_${build.number}.zip" defaultexcludes="true">
			<zipfileset dir="${installshield.project.local.input.folder}" >
				<exclude name="*" />
			</zipfileset>
		</zip>
    </target>

    <!-- **********************************************************************
             *  Target : update-set-up-bat
             *  target to update UpdateSetUp2.bat client app folder with current version
             ********************************************************************** -->
    <target name="update-set-up-bat">
    	<property file="${dir.build}/version.txt" />
        <property name="client.config.version" value="Application Files/McK.EIG.ROI.Client.App_${build.major}_${build.minor}_${build.servicePack}_${build.number}" />
        <property name="client.version" value="${build.major}.${build.minor}.${build.servicePack}.${build.number}" />
        <replaceregexp file="bin/MPFServer/webapps/ROOT/ROIClient/UpdateSetUp2.bat"
                       match="clientAppFolder=(.*)"
                       replace="clientAppFolder=${client.config.version}"
                       byline="true"/>

        <replaceregexp file="bin/MPFServer/webapps/ROOT/ROIClient/UpdateSetUp2.bat"
                       match="clientVersion=(.*)"
                       replace="clientVersion=${client.version}"
                       byline="true"/>

    </target>
	
	<!-- **********************************************************************
             *  Target : update-roi-install-bat 16_2_0_218
             *  target to update install-ROI.bat client app folder with current version
             ********************************************************************** -->
    <target name="update-roi-install-bat">
    	<property file="${dir.build}/version.txt" />
        <property name="install.release.version" value="${build.major}_${build.minor}_${build.servicePack}_${build.number}" />
        <property name="client.version" value="${build.major}.${build.minor}.${build.servicePack}.${build.number}" />
        <replaceregexp file="bin/install-ROI.bat"
                       match="set RELEASE=(.*)"
                       replace="set RELEASE=${install.release.version}"
                       byline="true"/>
    </target>

