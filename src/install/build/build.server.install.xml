		</unzip-->
		<!-- Deletes the temporary portal war file-->
		<!--delete file="${installshield.project.local.input.folder}/server/hpfw.components/portal.tmp.war"/-->

    <!--/target-->

     <!-- **********************************************************************
                 *  Target : clean-folder
                 *  target to to clean a specified directory
                 ********************************************************************** -->
     <target name="clean-folder">
            <echo message="Cleaning... ${dir.to.clean}" />
            <delete failonerror="false" includeemptydirs="true">
                <fileset dir="${dir.to.clean}" defaultexcludes="yes" includes="**/*">
                    <include name="${include.name}" />
                </fileset>
            </delete>
      </target>

     <!-- **********************************************************************
          *  Target : refresh-install-script
          *  target to refresh-install-script
          ********************************************************************** -->
     <target name="refresh-install-script">
		<if>
			<equals arg1="${refresh.install.source}" arg2="true" />
			<then>
				<echo message="delete ROI install zip file in bin folder" />
				<delete failonerror="false" includeemptydirs="true">
					<fileset dir="${source.local.root.path}/install/bin" defaultexcludes="no">
						<include name="ROI_${build.major}_${build.minor}_${build.servicePack}_${build.number}.zip" />
					</fileset>
				</delete>
				
				<echo message="Clears version.txt file" />
				<delete file="${source.local.root.path}/${dir.roi.build}/version.txt" />
				<echo message="Refresh Version.txt" />
				
				<if>
					<equals arg1="${checkout.source}" arg2="svn" />
					<then>
						<echo message="refresh version.txt from svn... ${svn.branch.path}/build/version.txt" />
						<ant antfile="${dir.src}/build/svn.xml" target="get-file-from-svn">
							 <property name="svn.path" value="${svn.branch.path}/build/version.txt" />
							 <property name="checkout.dest.path" value="${source.local.root.path}/${dir.roi.build}/version.txt" />
							 <property name="svn.includes.pattern" value="version.txt" />
							 <property name="svn.label" value="" />
						 </ant> 
						 
					</then>
				</if>
			   <echo message="refresh version.txt complete." />
				<if>
					<equals arg1="${checkout.source}" arg2="starteam" />
					<then>
						<echo message="refresh version.txt from starteam..." />
						<ant antfile="${dir.src}/build/starteam.xml" target="get">
							 <property name="starteam.file.path" value="${dir.roi.build}" />
							 <property name="starteam.local.file.path" value="${source.local.root.path}/${dir.roi.build}" />
							 <property name="starteam.includes.pattern" value="version.txt" />
							 <property name="starteam.label" value="" />
						 </ant>
					</then>
			   </if>
				<echo message="Clears ROI Build Properties" />
				<antcall target="clean-folder">
					 <param name="dir.to.clean" value="${source.local.root.path}/${install.properties.path}" />
				</antcall>
				
				<if>
					<equals arg1="${checkout.source}" arg2="svn" />
					<then>
						<echo message="Refreshing Build Properties from SVN... ${svn.branch.path}/${install.properties.path}" />
						<antcall target="get-from-svn">
							<param name="svn.path" value="${svn.branch.path}/${install.properties.path}" />
							<param name="checkout.dest.path" value="${source.local.root.path}/${install.properties.path}" />
							<param name="alias.name" value="${install.properties.path}" />
							<param name="label.name" value="" />
						</antcall>
					</then>
				</if>
				<if>
					<equals arg1="${checkout.source}" arg2="cvs" />
					<then>
						<echo message="Refreshing Build Properties from CVS..." />
						<antcall target="get-from-cvs">
							<param name="cvs.path" value="${cvs.branch.path}/${install.properties.path}" />
							<param name="checkout.dest.path" value="${source.local.root.path}" />
							<param name="alias.name" value="${install.properties.path}" />
							<param name="label.name" value="" />
						</antcall>
					</then>
				</if>
				<if>
					<equals arg1="${checkout.source}" arg2="starteam" />
					<then>
						<echo message="Refreshing Build Properties from starteam..." />
						<ant antfile="${dir.src}/build/starteam.xml" target="get">
							 <property name="starteam.file.path" value="${install.properties.path}" />
							 <property name="starteam.local.file.path" value="${source.local.root.path}/${install.properties.path}" />
							 <property name="starteam.includes.pattern" value="" />
							 <property name="starteam.label" value="" />
						 </ant>
					</then>
			   </if>
			   
			   <!-- 
				<echo message="Clear Install files" />
			   <antcall target="clean-folder">
					 <param name="dir.to.clean" value="${source.local.root.path}/${svn.install.path}" />
				</antcall>

				<if>
					<equals arg1="${checkout.source}" arg2="svn" />
					<then>
						<echo message="Clearing ROI Install files from svn..." />
