							<param name="svn.path" value="${svn.branch.path}/${svn.install.path}" />
							<param name="checkout.dest.path" value="${source.local.root.path}/${svn.install.path}" />
							<param name="alias.name" value="${svn.install.path}" />
							<param name="label.name" value="" />
					   </antcall>

					</then>
				</if>
				
				<if>
					<equals arg1="${checkout.source}" arg2="cvs" />
					<then>
						<echo message="Clearing ROI Install files from cvs..." />
