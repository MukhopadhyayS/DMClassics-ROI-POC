<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE databases PUBLIC "-//EXOLAB/Castor Mapping DTD Version 1.0//EN"
        "http://castor.exolab.org/mapping.dtd">

<mapping>

	<class name="com.mckesson.eig.roi.config.util.model.EndPointTypeList">
        <map-to xml="endpointTypes"  ns-prefix="eig"
            ns-uri="urn:eig.mckesson.com" />

        <field name="sourceTypes" type="com.mckesson.eig.roi.config.util.model.SourceType"
               collection="arraylist">
            <bind-xml name="sourceTypeDef" node="element" />
        </field>

        <field name="destinationTypes" type="com.mckesson.eig.roi.config.util.model.DestinationType"
               collection="arraylist">
            <bind-xml name="destTypeDef" node="element" />
        </field>

	</class>

    <class name="com.mckesson.eig.roi.config.util.model.SourceType">
        <map-to xml="sourceTypeDef"  ns-prefix="eig"
            ns-uri="urn:eig.mckesson.com" />

        <field name="type" type="string">
            <bind-xml name="type" node="element" />
        </field>

       <field name="enabled" type="boolean">
            <bind-xml name="enabled" node="element" />
        </field>

    </class>

    <class name="com.mckesson.eig.roi.config.util.model.DestinationType">
        <map-to xml="destTypeDef"  ns-prefix="eig"
            ns-uri="urn:eig.mckesson.com" />

        <field name="type" type="string">
            <bind-xml name="type" node="element" />
        </field>

       <field name="enabled" type="boolean">
            <bind-xml name="enabled" node="element" />
        </field>

    </class>

    <class name="com.mckesson.eig.roi.config.util.model.EndPointDefList">
        <map-to xml="endpointDefs"  ns-prefix="eig"
            ns-uri="urn:eig.mckesson.com" />

        <field name="sourceDefs" type="com.mckesson.eig.roi.config.util.model.SourceDef"
               collection="arraylist">
            <bind-xml name="sourceDef" node="element" />
        </field>

        <field name="destinationDefs" type="com.mckesson.eig.roi.config.util.model.DestinationDef"
               collection="arraylist">
            <bind-xml name="destDef" node="element" />
        </field>

    </class>

    <class name="com.mckesson.eig.roi.config.util.model.SourceDef">
        <map-to xml="sourceDef"  ns-prefix="eig"
            ns-uri="urn:eig.mckesson.com" />

        <field name="type" type="string">
            <bind-xml name="type" node="element" />
        </field>

       <field name="name" type="string">
            <bind-xml name="name" node="element" />
        </field>

       <field name="description" type="string">
            <bind-xml name="description" node="element" />
        </field>

        <field name="properties" type="com.mckesson.eig.roi.config.util.model.Properties">
            <bind-xml name="properties" node="element" />
        </field>

    </class>

    <class name="com.mckesson.eig.roi.config.util.model.DestinationDef">
        <map-to xml="destDef"  ns-prefix="eig"
            ns-uri="urn:eig.mckesson.com" />

        <field name="type" type="string">
            <bind-xml name="type" node="element" />
        </field>

        <field name="name" type="string">
            <bind-xml name="name" node="element" />
        </field>

        <field name="description" type="string">
            <bind-xml name="description" node="element" />
        </field>

        <field name="deviceId" type="string">
            <bind-xml name="deviceID" node="element" />
        </field>

        <field name="properties" type="com.mckesson.eig.roi.config.util.model.Properties">
            <bind-xml name="properties" node="element" />
        </field>

    </class>

    <class name="com.mckesson.eig.roi.config.util.model.Properties">
        <map-to xml="properties"  ns-prefix="eig"
            ns-uri="urn:eig.mckesson.com" />

        <field name="property"  type="org.exolab.castor.mapping.MapItem" collection="map">
            <bind-xml name="property" node="element" />
        </field>

    </class>

    <class name="org.exolab.castor.mapping.MapItem">
        <map-to xml="property" ns-prefix="eig"
            ns-uri="urn:eig.mckesson.com" />

        <field name="key" type="string">
            <bind-xml name="name" node="element" />
        </field>

        <field name="value" type="string">
            <bind-xml name="value" node="element" />
        </field>
    </class>

</mapping>
