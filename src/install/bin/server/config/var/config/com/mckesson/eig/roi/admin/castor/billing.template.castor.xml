<?xml version="1.0" encoding="UTF-8"?>
<mapping xmlns:eig="urn:eig.mckesson.com">
	<class name="com.mckesson.eig.roi.admin.model.BillingTemplate">
		<map-to xml="billingTemplate" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />

		<field name="id" type="long">
			<bind-xml name="eig:id" node="element" />
		</field>

		<field name="name" type="string">
			<bind-xml name="eig:name" node="element" />
		</field>

		<field name="associated" type="boolean">
			<bind-xml name="eig:associated" node="element" />
		</field>

		<field name="recordVersion" type="int">
			<bind-xml name="eig:recordVersion" node="element" />
		</field>

        <field name="feeTypeIds"
            type="long"
            collection="arraylist">
            <bind-xml name="eig:feeTypeIds" node="element" />
        </field>

		<field name="relatedFeeTypes"
			type="com.mckesson.eig.roi.admin.model.RelatedFeeType"
			collection="set">
			<bind-xml name="eig:relatedFeeTypes" node="element" />
		</field>

	</class>

	<class name="com.mckesson.eig.roi.admin.model.RelatedFeeType">
		<map-to xml="relatedFeeTypes" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />

		<field name="id" type="long">
			<bind-xml name="eig:id" node="element" />
		</field>

		<field name="feeTypeId" type="long">
			<bind-xml name="eig:feeTypeId" node="element" />
		</field>

		<field name="billingTemplateId" type="long">
			<bind-xml name="eig:billingTemplateId" node="element" />
		</field>

		<field name="recordVersion" type="int">
			<bind-xml name="eig:recordVersion" node="element" />
		</field>

	</class>

	<class
		name="com.mckesson.eig.roi.admin.model.BillingTemplatesList">
		<map-to xml="billingTemplates" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />

		<field name="billingTemplates"
			type="com.mckesson.eig.roi.admin.model.BillingTemplate"
			collection="arraylist">
			<bind-xml name="eig:billingTemplates" node="element" />
		</field>

	</class>
	
	<class
		name="com.mckesson.eig.roi.admin.model.BillingPaymentInfo">
		<map-to xml="billingPaymentInfo" ns-prefix="eig" ns-uri="urn:eig.mckesson.com" />

		<field name="paymentMethods" type="com.mckesson.eig.roi.admin.model.PaymentMethodList">
			<bind-xml name="eig:paymentMethodList" node="element" />
		</field>
		
		<field name="billingTemplates" type="com.mckesson.eig.roi.admin.model.BillingTemplatesList">
			<bind-xml name="eig:billingTemplateList" node="element" />
		</field>
		
		<field name="feeTypes" type="com.mckesson.eig.roi.admin.model.FeeTypesList">
			<bind-xml name="eig:feeTypeList" node="element" />
		</field>
		
		<field name="deliveryMethods" type="com.mckesson.eig.roi.admin.model.DeliveryMethodList">
			<bind-xml name="eig:deliveryMethodList" node="element" />
		</field>
		
		<field name="weight" type="com.mckesson.eig.roi.admin.model.Weight">
			<bind-xml name="eig:weight" node="element" />
		</field>
		
		<field name="reasons" type="com.mckesson.eig.roi.admin.model.ReasonsList">
			<bind-xml name="eig:reasonsList" node="element" />
		</field>
		
		<field name="requestorType" type="com.mckesson.eig.roi.admin.model.RequestorType">
			<bind-xml name="eig:requestorType" node="element" />
		</field>
		
		<field name="countries" type="com.mckesson.eig.roi.admin.model.Country" collection="arraylist" >
			<bind-xml name="eig:countries" node="element" />
		</field>
	</class>
</mapping>

