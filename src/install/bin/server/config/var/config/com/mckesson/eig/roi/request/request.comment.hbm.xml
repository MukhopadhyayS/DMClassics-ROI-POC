<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>

    <class name="com.mckesson.eig.roi.request.model.Comment"
           table="ROI_RequestCoreEvent"
           dynamic-update="true"
           optimistic-lock="version" polymorphism="explicit">

        <id name="id">
            <column name="ROI_RequestCoreEvent_Seq" sql-type="int"/>
            <generator class="identity"/>
        </id>

        <version name="recordVersion" column="Record_Version" type="integer" />

        <property name="name">
            <column name="Name" sql-type="varchar(60)" not-null="true" />
        </property>

        <property name="description">
            <column name="Description" sql-type="varchar(255)" not-null="true" />
        </property>

        <property name="createdBy">
            <column name="Created_By_Seq" sql-type="int" not-null="true" />
        </property>

        <property name="modifiedDate">
            <column name="Modified_Dt" sql-type="smalldatetime" not-null="true" />
        </property>

        <property name="modifiedBy">
            <column name="Modified_By_Seq" sql-type="int" not-null="true" />
        </property>

        <property name="requestId">
            <column name="ROI_RequestCore_Seq" sql-type="int" not-null="true" />
        </property>

    </class>
</hibernate-mapping>
