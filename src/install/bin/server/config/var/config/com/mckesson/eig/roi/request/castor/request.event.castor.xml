<?xml version="1.0" encoding="UTF-8"?>
<mapping xmlns:eig="urn:eig.mckesson.com">
	<class name="com.mckesson.eig.roi.request.model.RequestEvent">
		<map-to xml="events" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />

		<field name="requestId" type="long">
			<bind-xml name="eig:requestId" node="element" />
		</field>

		<field name="name" type="string">
			<bind-xml name="eig:name" node="element" />
		</field>

		<field name="type" type="string">
			<bind-xml name="eig:type" node="element" />
		</field>

		<field name="description" type="string">
			<bind-xml name="eig:description" node="element" />
		</field>

		<field name="originator" type="string">
			<bind-xml name="eig:originator" node="element" />
		</field>

		<field name="modifiedDate" type="date">
			<bind-xml name="eig:modifiedDate" node="element" />
		</field>
	</class>
	
	<class name="com.mckesson.eig.audit.model.AuditEvent">
		<map-to xml="auditEvent" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />

		<field name="eventId" type="long">
			<bind-xml name="eig:eventId" node="element" />
		</field>
		
		<field name="domainId" type="long">
			<bind-xml name="eig:domainId" node="element" />
		</field>
		
		<field name="componentId" type="long">
			<bind-xml name="eig:componentId" node="element" />
		</field>
		
		<field name="userId" type="long">
			<bind-xml name="eig:userId" node="element" />
		</field>

		<field name="eventStart" type="date">
			<bind-xml name="eig:eventStart" node="element" />
		</field>

		<field name="eventEnd" type="date">
			<bind-xml name="eig:eventEnd" node="element" />
		</field>

		<field name="eventStatus" type="long">
			<bind-xml name="eig:eventStatus" node="element" />
		</field>

		<field name="location" type="string">
			<bind-xml name="eig:location" node="element" />
		</field>
		
		<field name="objectId" type="long">
			<bind-xml name="eig:objectId" node="element" />
		</field>
		
		<field name="comment" type="string">
			<bind-xml name="eig:comment" node="element" />
		</field>
		
		<field name="workflowReason" type="string">
			<bind-xml name="eig:workflowReason" node="element" />
		</field>
		
		<field name="actionCode" type="string">
			<bind-xml name="eig:actionCode" node="element" />
		</field>
		
		<field name="encounter" type="string">
			<bind-xml name="eig:encounter" node="element" />
		</field>
		
		<field name="facility" type="string">
			<bind-xml name="eig:facility" node="element" />
		</field>
		
		<field name="mrn" type="string">
			<bind-xml name="eig:mrn" node="element" />
		</field>
	</class>

	<class name="com.mckesson.eig.roi.request.model.RequestEvents">
		<map-to xml="requestEvents" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />

		<field name="events"
			type="com.mckesson.eig.roi.request.model.RequestEvent"
			collection="arraylist">
			<bind-xml name="eig:events" node="element" />
		</field>

		<field name="count" type="int">
			<bind-xml name="eig:eventsCount" node="element" />
		</field>

	</class>

    <class name="com.mckesson.eig.roi.request.model.EventTypes">
        <map-to xml="eventType" ns-prefix="eig" ns-uri="urn:eig.mckesson.com" />

        <field name="eventTypes" type="string" collection="arraylist">
            <bind-xml name="eig:eventType" node="element" />
        </field>
    </class>

    <class name="com.mckesson.eig.roi.request.model.AuditAndEventList">
        <map-to xml="auditAndEventList" ns-prefix="eig" ns-uri="urn:eig.mckesson.com" />

        <field name="requestEvent" type="com.mckesson.eig.roi.request.model.RequestEvent" collection="arraylist">
            <bind-xml name="eig:events" node="element" />
        </field>

        <field name="auditEvent" type="com.mckesson.eig.audit.model.AuditEvent" collection="arraylist">
            <bind-xml name="eig:auditEvent" node="element" />
        </field>
    </class>

</mapping>
