<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>

    <class name="com.mckesson.eig.roi.requestor.model.RequestorDetail"
           table="ROI_RequestorRestriction"
           dynamic-update="true"
           optimistic-lock="version">

        <id name="id">
            <column name="ROI_RequestorRestriction_Seq" sql-type="int"/>
            <generator class="identity"/>
        </id>

        <version name="recordVersion" column="Record_Version" type="integer" />

        <property name="system" >
            <column name="System" sql-type="varchar(256)" not-null="true"/>
        </property>

        <property name="systemDb" >
            <column name="SystemDataBase" sql-type="varchar(256)" not-null="true"/>
        </property>

        <property name="systemTable" >
            <column name="SystemTable" sql-type="varchar(256)" not-null="true"/>
        </property>

        <property name="systemColumn" >
            <column name="SystemColumn" sql-type="varchar(256)" not-null="true"/>
        </property>

        <property name="systemType" >
            <column name="SystemType" sql-type="varchar(256)" not-null="true"/>
        </property>

        <property name="value" >
            <column name="Value" sql-type="varchar(256)" not-null="true"/>
        </property>

        <property name="reason" >
            <column name="Reason" sql-type="varchar(256)" not-null="true"/>
        </property>

        <property name="createdBy" >
            <column name="Created_By_Seq" sql-type="int" not-null="true"/>
        </property>

        <property name="modifiedDate" >
            <column name="Modified_Dt" sql-type="smalldatetime" not-null="true"/>
        </property>

        <property name="modifiedBy" >
            <column name="Modified_By_Seq" sql-type="int" not-null="true"/>
        </property>

    </class>

</hibernate-mapping>
