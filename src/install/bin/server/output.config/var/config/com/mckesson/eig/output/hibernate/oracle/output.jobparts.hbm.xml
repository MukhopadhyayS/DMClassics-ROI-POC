<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
 <class dynamic-update="true"
  name="com.mckesson.eig.output.model.JobPart" table="Output_JobParts">
  <id name="partID" column="Output_JobParts_Seq">
  	<generator class="sequence">
    	<param name="sequence">Output_Jobparts_Seq</param>
    </generator>
  </id>
  <property generated="never" lazy="false" name="statusID">
   <column name="osjp_status_seq" not-null="true" sql-type="int"/>
  </property>
  <property generated="never" lazy="false" name="pages">
   <column name="osjp_pages" not-null="true" sql-type="int"/>
  </property>
  <property generated="never" lazy="false" name="contentSourceName">
   <column name="osjp_item_id" not-null="true" sql-type="char(64)"/>
  </property>
  <many-to-one name="outputJob" class="com.mckesson.eig.output.model.OutputJob"
    column="osjp_osj_seq" not-null="true" cascade="none" insert="false" update="false"/>
 </class>
 <query name="retrievePartByID">
		select part from com.mckesson.eig.output.model.JobPart part
		where part.partID = ?
 </query>
 <query name="retrievePartByJobID">
    select part from com.mckesson.eig.output.model.JobPart part
    where part.outputJob.jobSeq = ?
 </query>

</hibernate-mapping>
