<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
    <class name="com.mckesson.eig.output.model.OutputSearchLoV"
           table="OUTPUT_SEARCH_LOV"
           dynamic-update="true">

		<id name="id" column="OUTPUT_SEARCH_LOV_SEQ">
      		<generator class="sequence">
          		<param name="sequence">Output_Search_Lov_Seq</param>
      		</generator>
		</id>

        <property name="parentId">
            <column name="PARENT_SEQ" sql-type="int"/>
        </property>

	   <property name="childId">
            <column name="CHILD_SEQ" sql-type="int"/>
        </property>

        <property name="name">
            <column name="NAME" sql-type="char(50)"/>
        </property>

        <property name="value">
            <column name="VALUE" sql-type="char(50)"/>
        </property>

        <property name="createdBy">
            <column name="CREATED_BY_SEQ" sql-type="int"/>
        </property>

        <property name="modifiedBy">
            <column name="MODIFIED_BY_SEQ" sql-type="int"/>
        </property>

	   <property name="createdDate">
            <column name="CREATED_DT" sql-type="smalldatetime"/>
        </property>

        <property name="modifiedDate">
            <column name="MODIFIED_DT" sql-type="smalldatetime"/>
        </property>

        <property name="organization">
            <column name="ORGANIZATION_SEQ" sql-type="int"/>
        </property>
	</class>
	
	<query name="retrieveSearchLoVByID">
	      select lov from com.mckesson.eig.output.model.OutputSearchLoV lov
	      where lov.parentId = ? 
    	</query>
</hibernate-mapping>
