<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:aop="http://www.springframework.org/schema/aop"
       xmlns:tx="http://www.springframework.org/schema/tx"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
                           http://www.springframework.org/schema/beans/spring-beans-2.0.xsd
                           http://www.springframework.org/schema/tx
                           http://www.springframework.org/schema/tx/spring-tx-2.0.xsd
                           http://www.springframework.org/schema/aop
                           http://www.springframework.org/schema/aop/spring-aop-2.0.xsd">

    <import resource="classpath:com/mckesson/eig/workflow/spring.xml" />

	<bean id="log_initializer" class="com.mckesson.eig.utility.log.log4j.Log4JInitializer">
		<property name="byXml" value="com/mckesson/eig/workflow/test/unit.test.logging.xml" />
	</bean>

    <bean id="dataSource" class="org.apache.commons.dbcp.BasicDataSource" destroy-method="close">
        <property name="driverClassName"><value>oracle.jdbc.driver.OracleDriver</value></property>
        <property name="url"><value>jdbc:oracle:thin:@127.0.0.1:1521:hecm</value></property>
        <property name="username"><value>hecm_wlist</value></property>
        <property name="password"><value>hecm_wlistpazz</value></property>
    </bean>

    <bean id="authenticator.appID"
       class="com.mckesson.eig.workflow.security.MockAuthenticator" />

    <bean id="authorizer.appID"
       class="com.mckesson.eig.workflow.security.MockAuthorizer" />

    <bean id="AuthenticationServiceLoader"
       class="com.mckesson.eig.workflow.security.MockAuthenticationServiceLocator"/>

    <bean id="AuthorizationServiceLocator"
       class="com.mckesson.eig.workflow.security.MockAuthorizationServiceLocator"/>

    <bean id="wsSecurityAuthorizationTable"
       class="com.mckesson.eig.workflow.security.MockAuthorizationTable"/>

     <bean id="ContentProcessVariablePluginService"
		class="com.mckesson.eig.workflow.service.MockContentProcessVariablePluginService" />

     <bean id="com.mckesson.eig.workflow.service.ApplicationPluginService"
		class="com.mckesson.eig.workflow.security.MockApplicationPluginService" />


</beans>
