<?xml version="1.0" encoding="UTF-8"?>

<process-definition  xmlns="urn:jbpm.org:jpdl-3.2"  name="testwlsubprocess">

	<start-state name="start-state1">
		<transition to="state2"></transition>
	</start-state>


	<state name="state1">
		<transition to="end-state1"></transition>
	</state>

	<process-state name="process-state1">
		<sub-process name="eig.worklist"/>
		<variable access="read,write,required" name="variable1"></variable>
		<variable access="read,write" name="variable2"></variable>
		<transition to="state1"></transition>
	</process-state>

	<state name="state2">
		<transition to="process-state1"></transition>
	</state>


	<end-state name="end-state1"></end-state>


</process-definition>