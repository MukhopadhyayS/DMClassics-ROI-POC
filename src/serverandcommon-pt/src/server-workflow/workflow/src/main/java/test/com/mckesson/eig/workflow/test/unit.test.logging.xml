<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE log4j:configuration SYSTEM "log4j.dtd">

<log4j:configuration xmlns:log4j="http://jakarta.apache.org/log4j/">

    <appender name="workflowLogAppender"
      class="org.apache.log4j.RollingFileAppender">
      <param name="File" value="unit.tests.eig.workflow.log" />
      <param name="Append" value="true" />
      <param name="MaxFileSize" value="20MB" />
      <param name="MaxBackupIndex" value="10" />
      <layout class="org.apache.log4j.PatternLayout">
        <param name="ConversionPattern" value="%d{DATE} | %t | %X{ipaddress} | %X{userid} | %X{transactionid} | %c{1} | %m%n " />
      </layout>
    </appender>

    <appender name="workflowConsoleAppender"
              class="org.apache.log4j.ConsoleAppender">
      <layout class="org.apache.log4j.PatternLayout">
        <param name="ConversionPattern" value="%d{DATE} | %t | %X{ipaddress} | %X{userid} | %X{transactionid} | %c{1} | %m%n " />
      </layout>
    </appender>

    <appender name="eigMetricsAppender"
	    class="org.apache.log4j.RollingFileAppender">
	    <param name="File" value="unit.tests.eig-metrics.workflow.log" />
	    <param name="Append" value="true" />
	    <param name="MaxFileSize" value="10MB" />
	    <param name="MaxBackupIndex" value="20" />
	    <layout class="org.apache.log4j.PatternLayout">
		    <param name="ConversionPattern" value="%d{DATE} | %t | %X{ipaddress} | %X{userid} | %X{transactionid} | %c{1} | %m%n " />
	    </layout>
    </appender>

  <category name="com.mckesson.eig.utility.metric" additivity="false">
    <priority value="info" />
    <appender-ref ref="eigMetricsAppender" />
  </category>

  <category name="com.eig.workflow.servlet" additivity="false">
    <priority value="debug" />
    <appender-ref ref="workflowLogAppender" />
    <appender-ref ref="workflowConsoleAppender" />
  </category>

  <category name="com.mckesson.eig.workflow.api" additivity="false">
    <priority value="debug" />
    <appender-ref ref="workflowLogAppender" />
    <appender-ref ref="workflowConsoleAppender" />
  </category>

  <category name="com.mckesson.eig.workflow.service" additivity="false">
    <priority value="debug" />
    <appender-ref ref="workflowLogAppender" />
    <appender-ref ref="workflowConsoleAppender" />
  </category>

  <category name="com.mckesson.eig.workflow.worklist.api" additivity="false">
    <priority value="debug" />
    <appender-ref ref="workflowLogAppender" />
    <appender-ref ref="workflowConsoleAppender" />
  </category>

  <category name="com.mckesson.eig.workflow.worklist.service" additivity="false">
    <priority value="debug" />
    <appender-ref ref="workflowLogAppender" />
    <appender-ref ref="workflowConsoleAppender" />
  </category>

  <category name="com.mckesson.eig.workflow.engine">
    <priority value="debug" />
    <appender-ref ref="workflowLogAppender" />
    <appender-ref ref="workflowConsoleAppender" />
  </category>

  <category name="com.mckesson.eig.workflow.processinstance">
    <priority value="debug" />
    <appender-ref ref="workflowLogAppender" />
    <appender-ref ref="workflowConsoleAppender" />
  </category>

  <category name="org.apache">
    <priority value="warn" />
    <appender-ref ref="workflowLogAppender" />
    <appender-ref ref="workflowConsoleAppender" />
  </category>

  <category name="org.hibernate">
    <priority value="warn" />
    <appender-ref ref="workflowLogAppender" />
    <appender-ref ref="workflowConsoleAppender" />
  </category>

  <category name="servletunit">
    <priority value="warn" />
    <appender-ref ref="workflowLogAppender" />
    <appender-ref ref="workflowConsoleAppender" />
  </category>

  <category name="org.exolab.castor">
    <priority value="warn" />
    <appender-ref ref="workflowLogAppender" />
    <appender-ref ref="workflowConsoleAppender" />
  </category>

  <category name="org.springframework">
    <priority value="warn" />
    <appender-ref ref="workflowLogAppender" />
    <appender-ref ref="workflowConsoleAppender" />
  </category>

  <category name="org.castor">
    <priority value="warn" />
    <appender-ref ref="workflowLogAppender" />
    <appender-ref ref="workflowConsoleAppender" />
  </category>

  <category name="org.jbpm">
    <priority value="warn" />
    <appender-ref ref="workflowLogAppender" />
    <appender-ref ref="workflowConsoleAppender" />
  </category>

</log4j:configuration>