<?xml version="1.0" encoding="UTF-8"?>

<process-definition
  xmlns="urn:jbpm.org:jpdl-3.2"  name="eig.worklist">

   <start-state name="start">
      <task name="eig workflow task"/>
      <transition name="save" to="draft"></transition>
      <transition name="save and release" to="new">
        <action name="task.save.release" class="com.mckesson.eig.workflow.worklist.TaskEventNotifier"></action>
      </transition>
   </start-state>
   <state name="draft">
      <transition name="release" to="new">
        <action name="task.release" class="com.mckesson.eig.workflow.worklist.TaskEventNotifier"></action>
      </transition>
      <transition name="update" to="draft"/>
   </state>
   <state name="new">
      <transition name="own" to="in progress">
            <action name="task.overdue" class="com.mckesson.eig.workflow.worklist.OverdueTaskHandler"></action>
      </transition>
      <transition name="deactivate" to="draft"/>
   </state>
   <state name="in progress">
      <transition name="return to worklist" to="new">
         <action name="task.disown" class="com.mckesson.eig.workflow.worklist.DisownTask"></action>
      </transition>
      <transition name="complete" to="completed">
      </transition>
    <transition to="new" name="reassign">
		<action name="task.reassign" class="com.mckesson.eig.workflow.worklist.TaskEventNotifier"></action>
	</transition>
    <transition to="overdue" name="mark as overdue"></transition>
   </state>
   <state name="overdue">
      <transition name="complete" to="completed">
      </transition>
   </state>
   <end-state name="completed"/>
</process-definition>
