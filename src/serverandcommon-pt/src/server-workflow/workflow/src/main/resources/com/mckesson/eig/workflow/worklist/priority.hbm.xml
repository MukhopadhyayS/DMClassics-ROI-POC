<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping  package="com.mckesson.eig.workflow.worklist.api">

  <class name="Priority"
         table="WF_TASK_PRIORITY"
         schema="HECM_WLIST">

    <id name="priorityID" column="PRIORITY_ID"/>

    <property name="displayNameKey" column="DISPLAY_NAME"/>
    <property name="sortOrder" column="SORT_ORDER"/>

  </class>

  <query name="getPriorityList">
    <![CDATA[
      select p from Priority p
    ]]>
  </query>

</hibernate-mapping>
