<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping  package="com.mckesson.eig.workflow.worklist.api">

  <class name="TaskACL"
         table="WF_WORKLIST_ASSIGN"
         schema="HECM_WLIST"
         optimistic-lock="version"
         dynamic-update="true">

    <id name="taskACLID" column="WORKLIST_ASSIGN_ID">
        <generator class="sequence">
            <param name="sequence">WF_WORKLIST_ASSIGN_SEQ</param>
        </generator>
    </id>

    <version name="version" column="RECORD_VERSION" type="integer" />

<!-- <composite-id>
        <key-property name="actor"/>
        <key-property name="worklist"/>
    </composite-id>

    <composite-id>
         <key-many-to-one name="worklist" class="com.mckesson.eig.workflow.worklist.api.Worklist" column="ASSIGNED_WORKLIST_ID"/>
    <key-many-to-one name="actor" class="com.mckesson.eig.workflow.api.Actor" column="ASSIGNED_ACTOR_ID"/>
    </composite-id> -->

    <property name="canComplete" type="yes_no" column="CAN_COMPLETE" />
    <property name="canCreate"   type="yes_no" column="CAN_CREATE"   />
    <property name="canReassign" type="yes_no" column="CAN_REASSIGN" />
    <property name="canDelete"   type="yes_no" column="CAN_DELETE"   />
	<property name="doEmailAlert" type="yes_no" column="DO_EMAIL_ALERT" />

    <!--many-to-one name="worklist"
                 column="WORKLIST_ID"
                 class="com.mckesson.eig.workflow.worklist.api.Worklist"/-->

    <many-to-one name="actor"
                 column="ACTOR_ID"
                 class="com.mckesson.eig.workflow.api.Actor"/>

  </class>

</hibernate-mapping>
