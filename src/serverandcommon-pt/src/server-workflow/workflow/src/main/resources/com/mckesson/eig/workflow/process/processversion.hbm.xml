<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping  package="com.mckesson.eig.workflow.process.api">

  <class name="ProcessVersion"
         table="WF_PROCESS_VERSION"
         schema="HECM_WLIST"
         >

     <composite-id>
        <key-property name="versionId" column="VERSION_ID"  type="long" />
        <key-many-to-one name="process"
                         column="PROCESS_ID"
                         class="com.mckesson.eig.workflow.process.api.Process" />
     </composite-id>

    <property name="processName"           column="NAME"           type="string" />
    <property name="processDescription"    column="DESCRIPTION"    type="string" />


	<property name="processGraphDocument" type="com.mckesson.eig.workflow.process.api.hibernate.HibernateXmlType" >
            <column name="PROCESS_GRAPH"/>

    </property>

	<property name="processDefinitionDocument" type="com.mckesson.eig.workflow.process.api.hibernate.HibernateXmlType" >
		<column name="PROCESS_DEFINITION" />
    </property>

    <property name="lockedBy"              column="LOCKED_BY"              type="string" />
    <property name="status"                column="STATUS"                 type="string" />
    <property name="isValid"               column="IS_ACTIVE"              type="yes_no" />
    <property name="effectiveDate"         column="EFFECTIVE_DATE"         type="timestamp" />
    <property name="expirationDate"        column="EXPIRATION_DATE"        type="timestamp" />
    <property name="maxInstanceDuration"   column="MAX_INSTANCE_DURATION"  type="integer" />
    <property name="retentionPeriod"       column="RETENTION_PERIOD"       type="integer" />
    <property name="notifyExceptions"      column="NOTIFY_EXCEPTIONS"      type="character" />
    <property name="exceptionEmailAddress" column="EXCEPTION_EMAILADDRESS" type="string" />
    <property name="createdTS"             column="CREATE_DATETIME"        type="timestamp" />
    <property name="updatedTS"             column="MODIFY_DATETIME"        type="timestamp" />
    <property name="processVersionId"      column="ID_"                     type="long" />

    <set name="processAttributes" inverse="true" cascade="all,delete-orphan" schema="HECM_WLIST" table="WF_PROCESS_ATTRIBUTES">
         <key update="false">
            <column name="VERSION_ID" />
            <column name="PROCESS_ID" />
         </key>
         <one-to-many  class="ProcessAttribute"/>
    </set>

  </class>

  <query name="getProcessVersion">
      <![CDATA[
        SELECT pv
        FROM   com.mckesson.eig.workflow.process.api.ProcessVersion AS pv
        WHERE pv.process.processId = :PROCESS_ID AND
              pv.versionId = (SELECT MAX(procV.versionId)
                             FROM com.mckesson.eig.workflow.process.api.ProcessVersion procV
                             WHERE procV.process.processId = pv.process.processId)
      ]]>
  </query>

    <query name="getProcessVersionAndAttributes">
      <![CDATA[
        SELECT pv
        FROM   com.mckesson.eig.workflow.process.api.ProcessVersion AS pv
          INNER JOIN pv.processAttributes AS processAttributes
        WHERE pv.process.processId = :PROCESS_ID
        AND   pv.versionId = (SELECT MAX(procV.versionId)
                             FROM com.mckesson.eig.workflow.process.api.ProcessVersion procV
                             WHERE procV.process.processId = pv.process.processId)

	]]>
  </query>

</hibernate-mapping>
