<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping  package="com.mckesson.eig.workflow.processinstance.api">

  <class name="ProcessInstanceHistory"
         table="WF_PROCESS_INSTANCE_HISTORY"
         schema="HECM_WLIST">

	<composite-id>
		<key-property name="processId"            column="PROCESS_ID"              type="long"/>
		<key-property name="versionId"            column="VERSION_ID"              type="int"/>
        <key-property name="processInstanceId"    column="PROCESS_INSTANCE_ID"     type="long"/>
        <key-property name="eventLevel"           column="EVENT_LEVEL"             type="string"/>
	 	<key-property name="eventName" 		      column="EVENT_NAME"              type="string"/>
	 	<key-property name="eventDatetime"        column="EVENT_DATETIME"          type="timestamp" />
	 	<key-property name="eventOriginator"      column="EVENT_ORIGINATOR"        type="string"/>
		<key-property name="eventStatus"          column="EVENT_STATUS"            type="string"/>
	 	<key-property name="eventComments"        column="EVENT_COMMENTS"          type="string"/>
	    <key-property name="modifiedByUserId"     column="MODIFIEDBY_USER_ID"      type="long" />
     	<key-property name="modifyDateTime"       column="MODIFY_DATETIME"         type="timestamp" />
     	<key-property name="createDateTime"       column="CREATE_DATETIME"         type="timestamp" />
     </composite-id>

  </class>

</hibernate-mapping>
