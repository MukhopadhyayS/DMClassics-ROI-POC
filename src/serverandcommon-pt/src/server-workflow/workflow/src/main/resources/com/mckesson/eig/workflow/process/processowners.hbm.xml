<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping  package="com.mckesson.eig.workflow.process.api">

  <class name="ProcessOwner"
         table="WF_PROCESS_OWNERS"
         schema="HECM_WLIST">

    <composite-id>
        <key-property name="processId" column="PROCESS_ID" type="long"/>
        <key-many-to-one name="actor"
                         column="ACTOR_ID"
                         class="com.mckesson.eig.workflow.api.Actor"/>
    </composite-id>
    <property name="createdTS" column="CREATE_DATETIME" type="timestamp" />
    <property name="updatedTS" column="MODIFY_DATETIME" type="timestamp" />
  </class>

</hibernate-mapping>
