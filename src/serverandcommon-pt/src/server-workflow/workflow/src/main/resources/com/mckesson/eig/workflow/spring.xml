<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:aop="http://www.springframework.org/schema/aop"
	xmlns:tx="http://www.springframework.org/schema/tx"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
                           http://www.springframework.org/schema/beans/spring-beans-2.0.xsd
                           http://www.springframework.org/schema/tx
                           http://www.springframework.org/schema/tx/spring-tx-2.0.xsd
                           http://www.springframework.org/schema/aop
                           http://www.springframework.org/schema/aop/spring-aop-2.0.xsd">

	<bean id="log_initializer" class="com.mckesson.eig.utility.log.log4j.Log4JInitializer">
		<property name="byXml" value="com/mckesson/eig/workflow/logging.xml" />
	</bean>

	<bean id="deploymentInfo" class="com.mckesson.eig.utility.components.DeploymentEntropy" init-method="revealDeployment">
		<constructor-arg>
	  		<value>eig.workflow.war</value>
		</constructor-arg>
  	</bean>

	<bean id="com.mckesson.eig.audit.local.AuditLocalService" class="com.mckesson.eig.audit.local.AuditLocalService"
		lazy-init="true" />

	<bean id="eig_auditq_config" class="com.mckesson.eig.wsfw.jms.MessagePoster">
		<property name="queue">
			<ref bean="auditQueue" />
		</property>
		<property name="connectionFactory">
			<ref bean="connectionFactory" />
		</property>
	</bean>

	<bean id="auditQueue" class="org.springframework.jndi.JndiObjectFactoryBean">
		<property name="jndiTemplate">
			<ref bean="jndiTemplate" />
		</property>
		<property name="jndiName">
			<value>queue/eigAudit</value>
		</property>
	</bean>

	<bean id="connectionFactory" class="org.springframework.jndi.JndiObjectFactoryBean">
		<property name="jndiTemplate">
			<ref bean="jndiTemplate" />
		</property>
		<property name="jndiName">
			<value>java:activemq/QueueConnectionFactory</value>
		</property>
	</bean>

	<bean id="jndiTemplate" class="org.springframework.jndi.JndiTemplate">
		<property name="environment">
			<props>
				<prop key="java.naming.factory.initial">
					org.apache.activemq.jndi.ActiveMQInitialContextFactory
        </prop>
				<prop key="java.naming.provider.url">
					tcp://127.0.0.1:61616
        </prop>
				<prop key="queue.queue/eigAudit">
					queue.eigAudit
        </prop>
			</props>
		</property>
	</bean>

	<bean id="dataSource" class="org.springframework.jndi.JndiObjectFactoryBean">
		<description>Provides access to a datasource registered with
			JNDI.</description>
		<property name="jndiName" value="java:/QspDS" />
	</bean>

	<bean id="hibernateSessionFactory"
		class="org.springframework.orm.hibernate3.LocalSessionFactoryBean">
		<property name="dataSource" ref="dataSource" />
		<property name="configLocation"
			value="classpath:com/mckesson/eig/workflow/hibernate.xml" />
	</bean>

	<bean id="txManager"
		class="org.springframework.orm.hibernate3.HibernateTransactionManager">
		<property name="sessionFactory" ref="hibernateSessionFactory" />
	</bean>

	<tx:advice id="txAdvice" transaction-manager="txManager">
		<tx:attributes>
			<!-- tx:method name="get*" read-only="true" /-->
			<tx:method name="*" />
		</tx:attributes>
	</tx:advice>

	<aop:config proxy-target-class="true">
		<aop:advisor
			pointcut="execution(* com.mckesson.eig.workflow.worklist.service.WorklistServiceImpl.* (..))"
			advice-ref="txAdvice" />
	</aop:config>

	<aop:config proxy-target-class="true">
		<aop:advisor
			pointcut="execution(* com.mckesson.eig.workflow.worklist.service.TaskServiceImpl.* (..))"
			advice-ref="txAdvice" />
	</aop:config>

	<aop:config proxy-target-class="true">
		<aop:advisor
			pointcut="execution(* com.mckesson.eig.workflow.process.service.ProcessListServiceImpl.* (..))"
			advice-ref="txAdvice" />
	</aop:config>

	<aop:config proxy-target-class="true">
		<aop:advisor
			pointcut="execution(* com.mckesson.eig.workflow.processinstance.service.ProcessInstanceServiceImpl.* (..))"
			advice-ref="txAdvice" />
	</aop:config>

	<aop:config proxy-target-class="true">
		<aop:advisor
			pointcut="execution(* com.mckesson.eig.workflow.process.service.ProcessServiceImpl.* (..))"
			advice-ref="txAdvice" />
	</aop:config>

	<aop:config proxy-target-class="true">
		<aop:advisor
			pointcut="execution(* com.mckesson.eig.workflow.security.service.SecurityServiceImpl.* (..))"
			advice-ref="txAdvice" />
	</aop:config>

	<bean id="auditManager" class="com.mckesson.eig.workflow.service.WorkflowAuditManger"
		lazy-init="true" />

	<bean id="com.mckesson.eig.workflow.worklist.service.WorklistServiceImpl"
		class="com.mckesson.eig.workflow.worklist.service.WorklistServiceImpl" />

	<bean id="com.mckesson.eig.workflow.worklist.service.TaskServiceImpl"
		class="com.mckesson.eig.workflow.worklist.service.TaskServiceImpl" />

	<bean id="com.mckesson.eig.workflow.worklist.service.ComponentServiceImpl"
		class="com.mckesson.eig.workflow.worklist.service.ComponentServiceImpl" />

	<bean
		id="com.mckesson.eig.workflow.process.service.ProcessListServiceImpl"
		class="com.mckesson.eig.workflow.process.service.ProcessListServiceImpl" />

	<bean
		id="com.mckesson.eig.workflow.processinstance.service.ProcessInstanceServiceImpl"
		class="com.mckesson.eig.workflow.processinstance.service.ProcessInstanceServiceImpl" />

	<bean id="com.mckesson.eig.workflow.process.service.ProcessServiceImpl"
		class="com.mckesson.eig.workflow.process.service.ProcessServiceImpl" />

	<bean id="com.mckesson.eig.workflow.security.service.SecurityServiceImpl"
		class="com.mckesson.eig.workflow.security.service.SecurityServiceImpl" />
	
	<bean id="TaslACLResolverPointcutAdviser"
        class="org.springframework.aop.support.RegexpMethodPointcutAdvisor">
        <property name="advice">
            <ref local="TaskACLResolver" />
        </property>
        <property name="patterns">
        	<list>
        		<value>com.mckesson.eig.workflow.worklist.service.WorklistServiceImpl.createWorklist</value>
        		<value>com.mckesson.eig.workflow.worklist.service.WorklistServiceImpl.createNewWorklist</value>
        		<value>com.mckesson.eig.workflow.worklist.service.WorklistServiceImpl.updateExistingWorklist</value>
        		<value>com.mckesson.eig.workflow.worklist.service.WorklistServiceImpl.updateWorklistACLs</value>
        	</list>
        </property>
    </bean>

	<bean id="TaskACLResolver"
        class="com.mckesson.eig.workflow.worklist.service.TaskACLResolver" />

	<bean id="TaskDAO" class="com.mckesson.eig.workflow.worklist.dao.TaskDAO">
		<property name="sessionFactory" ref="hibernateSessionFactory" />
	</bean>

	<bean id="WorklistDAO" class="com.mckesson.eig.workflow.worklist.dao.WorklistDAO">
		<property name="sessionFactory" ref="hibernateSessionFactory" />
	</bean>

	<bean id="com.mckesson.eig.workflow.process.dao.ProcessDAO" class="com.mckesson.eig.workflow.process.dao.ProcessDAO">
		<property name="sessionFactory" ref="hibernateSessionFactory" />
	</bean>

	<bean id="com.mckesson.eig.workflow.process.dao.ProcessListDAO"
		class="com.mckesson.eig.workflow.process.dao.ProcessListDAO">
		<property name="sessionFactory" ref="hibernateSessionFactory" />
	</bean>

	<bean id="com.mckesson.eig.workflow.processinstance.dao.ProcessInstanceDAO"
		class="com.mckesson.eig.workflow.processinstance.dao.ProcessInstanceDAO">
		<property name="sessionFactory" ref="hibernateSessionFactory" />
	</bean>

	<bean id="timerJob" class="com.mckesson.eig.workflow.dao.TaskScheduler"
		init-method="execute" lazy-init="false">
		<property name="sessionFactory" ref="hibernateSessionFactory" />
	</bean>

	<!-- Configurations for webservice security -->
	<bean id="authenticator.appID"
		class="com.mckesson.eig.wsfw.security.service.test.MockAuthenticator" />

	<bean id="authorizer.appID"
		class="com.mckesson.eig.wsfw.security.service.test.MockAuthorizer" />

	<bean id="PasswordEncryptionStrategy" class="com.mckesson.eig.wsfw.security.encryption.AESStrategy">
	</bean>

	<!-- Process Instance Consumer service bean -->
	<bean
		id="com.mckesson.eig.workflow.engine.service.ProcessInstanceJmsConsumer"
		class="com.mckesson.eig.workflow.engine.service.ProcessInstanceJmsConsumer" />

	<!-- HECM Plugin -->
	<bean id="ContentProcessVariablePluginService"
		class="com.mckesson.eig.workflow.service.MockContentProcessVariablePluginService" />

    <bean id="com.mckesson.eig.workflow.service.ApplicationPluginService"
        class="com.mckesson.eig.workflow.service.MockApplicationPluginService" />

 	<bean id="HECM.Production"
		class="com.mckesson.eig.workflow.security.MockPluginSecurityImpl"
		scope="prototype" lazy-init="true">
		<constructor-arg
			value="http://127.0.0.1:8080/hecm/services" />
	</bean>

 	<bean id="HECM.Test"
		class="com.mckesson.eig.workflow.security.MockPluginSecurityImpl"
		scope="prototype" lazy-init="true">
		<constructor-arg
			value="http://127.0.0.1:8888/hecm/services" />
	</bean>
	<!-- End of HECM Plugin -->

    <bean id="com.mckesson.eig.config.service.ApplicationSettingServiceImpl"
    	class="com.mckesson.eig.config.service.ApplicationSettingServiceImpl"
    	lazy-init="true"
    	scope="singleton"/>

    <bean id="com.mckesson.eig.config.service.NotificationService"
    	class="com.mckesson.eig.config.service.NotificationServiceImpl"
    	lazy-init="true"
    	scope="singleton"/>

    <bean id="com.mckesson.eig.config.dao.ApplicationSettingDAO" class="com.mckesson.eig.config.dao.ApplicationSettingDAOImpl">
    	<property name="sessionFactory" ref="hibernateSessionFactory" />
    </bean>
</beans>
