					<xsd:element name="priorityID" type="xsd:long" />
					<xsd:element minOccurs="0" name="reassignReason"
						type="xsd:string" />
					<xsd:element minOccurs="0" name="startDate"
						type="xsd:dateTime" />
					<xsd:element minOccurs="0" name="statusID"
						type="xsd:string" />
