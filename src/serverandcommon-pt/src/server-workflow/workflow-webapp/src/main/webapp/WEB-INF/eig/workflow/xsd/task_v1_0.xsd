			<xsd:extension base="task_v1_0:basicWorklistDO">
				<xsd:sequence>
					<xsd:element name="canStartEarly"
						type="xsd:boolean" />
					<xsd:element minOccurs="0" name="comments"
						type="xsd:string" />
					<xsd:element minOccurs="0" name="endDate"
						type="xsd:dateTime" />
					<xsd:element minOccurs="0" name="taskOwner"
