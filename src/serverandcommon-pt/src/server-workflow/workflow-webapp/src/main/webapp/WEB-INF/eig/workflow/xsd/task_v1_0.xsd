					<xsd:element name="isDesc" type="xsd:boolean" />
					<xsd:element minOccurs="0" name="ownerActors"
						type="task_v1_0:Actors" />
					<xsd:element name="primarySort" type="xsd:byte" />
					<xsd:element name="priorityID" type="xsd:int" />
					<xsd:element minOccurs="0" name="startDate"
						type="xsd:dateTime" />
					<xsd:element maxOccurs="unbounded" minOccurs="0"
						name="statusIDs" type="xsd:string" />
					<xsd:element minOccurs="0" name="taskName"
						type="xsd:string" />
					<xsd:element maxOccurs="unbounded" minOccurs="0"
						name="worklistIDs" type="xsd:long" />
				</xsd:sequence>
			</xsd:extension>
		</xsd:complexContent>
