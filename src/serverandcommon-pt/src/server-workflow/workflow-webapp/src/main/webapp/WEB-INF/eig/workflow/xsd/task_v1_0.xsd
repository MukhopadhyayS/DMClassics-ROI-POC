					<xsd:element maxOccurs="unbounded" minOccurs="0"
						name="taskStatusList" type="task_v1_0:TaskStatus" />
				</xsd:sequence>
			</xsd:extension>
		</xsd:complexContent>
	</xsd:complexType>
