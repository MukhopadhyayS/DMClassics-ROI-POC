<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC 
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
  <class name="com.mckesson.eig.audit.dao.hecm.AuditTrailDetail" table="AUDIT_TRAIL_DETAIL">
  
  <id name="auditTrailDetailSeq" type="long" column="AUDIT_TRAIL_DETAIL_SEQ" >
	<!--<generator class="increment"/>-->
	<!-- Once the Oracle sequences are in place use the code below instead of the above specified increment class -->
	 
		<generator class="sequence">
			<param name="sequence">AUDIT_TRAIL_DETAIL_SEQ</param>
		</generator>
	
  </id>
  
  <property name="auditTrailSeq">
     <column name="AUDIT_TRAIL_SEQ" />
  </property>
  
  <property name="auditColumnSeq">
    <column name="AUDIT_COLUMN_SEQ"/>
  </property>
  
  <property name="auditIntVal">
    <column name="AUDIT_INT_VAL"/>
  </property>
  
  <property name="auditDateVal">
    <column name="AUDIT_DATE_VAL"/>
  </property>
  
  <property name="auditCharVal">
    <column name="AUDIT_CHAR_VAL"/>
  </property>
  
  <property name="auditVarCharVal">
    <column name="AUDIT_VARCHAR_VAL"/>
  </property>
  
  <property name="auditNVarCharVal">
    <column name="AUDIT_NVARCHAR_VAL"/>
  </property>
    
  <property name="modifyDateTime">
    <column name="MODIFY_DATETIME"/>
  </property>
 </class>
</hibernate-mapping>


   

   
    
