<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC 
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
  <class name="com.mckesson.eig.audit.dao.hecm.AuditTrail" table="AUDIT_TRAIL">
  
  <id name="auditTrailSeq" type="long" column="AUDIT_TRAIL_SEQ" >
	<!--  <generator class="increment"/> -->
	<!-- Once the Oracle sequences are in place use the code below instead of the above specified increment class -->
	
		<generator class="sequence">
			<param name="sequence">AUDIT_TRAIL_SEQ</param>
		</generator>
	
  </id>
  
  <property name="eventId">
     <column name="AUDIT_EVENT_SEQ" />
  </property>
  
  <property name="domainId">
    <column name="ORG_ID"/>
  </property>
  
  <property name="componentId">
    <column name="COMPONENT_SEQ"/>
  </property>
  
  <property name="userId">
    <column name="USER_ID"/>
  </property>
  
  <property name="eventStart">
    <column name="EVENT_START"/>
  </property>
  
  <property name="eventEnd">
    <column name="EVENT_END"/>
  </property>
  
  <property name="comment">
    <column name="AUDIT_DESC"/>
  </property>
  
  <property name="eventStatus">
    <column name="STATUS"/>
  </property>
  
  <property name="location">
    <column name="LOCATION"/>
  </property>
  
  <property name="modifyDateTime">
    <column name="MODIFY_DATETIME"/>
  </property>
 </class>
</hibernate-mapping>


   

   
    
