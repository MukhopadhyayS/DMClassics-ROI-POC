<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-2.0.xsd">

	<bean id="log_initializer"
		class="com.mckesson.eig.utility.log.log4j.Log4JInitializer">
		<!--
			<property name="byXml">
			<value>wsfw.logging.xml</value>
			</property>
		-->
	</bean>

	<bean id="castor_context"
		class="com.mckesson.eig.wsfw.axis.CastorContext" lazy-init="true">
		<property name="mappingFile" value="webservice-mappings.xml" />
	</bean>

	<!-- Business Services -->
	<!-- because we are outside a true container, must use singleton scope -->
	<bean id="com.mckesson.eig.wsfw.test.service.HouseService"
		class="com.mckesson.eig.wsfw.test.service.HouseService"
		scope="singleton" />

	<bean id="com.mckesson.eig.wsfw.test.service.HelloWorldService"
		class="com.mckesson.eig.wsfw.test.service.HelloWorldService"
		scope="singleton" />

	<bean id="AuthenticationStrategy"
		class="com.mckesson.eig.wsfw.test.MockAuthenticationStrategy"
		lazy-init="true" />

    <bean id="AuthorizationStrategy" 
        class="com.mckesson.eig.wsfw.test.axis.MockAuthorizationStrategy" 
        lazy-init="true"/>

	<!-- Test JMS Queue for testing the AsynchronousServiceHandler -->
	<bean id="testQueue"
		class="com.mckesson.eig.utility.jms.JmsConfig">
		<property name="url">
			<value>vm://localhost</value>
		</property>
		<property name="jmsQueueName">
			<value>queue/testQueue</value>
		</property>
		<property name="physicalName">
			<value>queue.testQueue</value>
		</property>
		<property name="connectionFactory">
			<value>java:activemq/QueueConnectionFactory</value>
		</property>
	</bean>

	<bean id="messageListener"
		class="org.springframework.jms.listener.adapter.MessageListenerAdapter">
		<constructor-arg>
			<bean id="helloCaller"
				class="com.mckesson.eig.wsfw.axis.DirectServiceCaller">
				<constructor-arg value="WEB-INF/server-config.wsdd" />
				<constructor-arg value="helloJmsProcessor" />
			</bean>
		</constructor-arg>
		<property name="defaultListenerMethod" value="callService" />
		<!-- we don't want automatic message context extraction -->
		<property name="messageConverter">
			<null />
		</property>
	</bean>

	<bean id="jndiTemplate"
		class="org.springframework.jndi.JndiTemplate">
		<property name="environment">
			<props>
				<prop key="java.naming.factory.initial">
					org.mockejb.jndi.MockContextFactory
				</prop>
			</props>
		</property>
	</bean>

	<bean id="connectionFactory"
		class="org.springframework.jndi.JndiObjectFactoryBean">
		<property name="jndiTemplate">
			<ref bean="jndiTemplate" />
		</property>
		<property name="jndiName">
			<value>java:activemq/QueueConnectionFactory</value>
		</property>
	</bean>

	<bean id="destination"
		class="org.springframework.jndi.JndiObjectFactoryBean">
		<property name="jndiTemplate">
			<ref bean="jndiTemplate" />
		</property>
		<property name="jndiName">
			<value>queue/testQueue</value>
		</property>
	</bean>

	<bean id="transactionManager"
		class="org.springframework.jms.connection.JmsTransactionManager">
		<property name="connectionFactory" ref="connectionFactory" />
	</bean>

	<bean id="listenerContainer"
		class="org.springframework.jms.listener.DefaultMessageListenerContainer">
		<property name="concurrentConsumers" value="5" />
		<property name="connectionFactory" ref="connectionFactory" />
		<property name="destination" ref="destination" />
		<property name="messageListener" ref="messageListener" />
		<property name="transactionManager" ref="transactionManager" />
	</bean>

</beans>
