<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-2.0.xsd">

  <bean id="log_initializer"
    class="com.mckesson.eig.utility.log.log4j.Log4JInitializer">
    <!--
    <property name="byXml">
      <value>wsfw.logging.xml</value>
    </property>
    -->
  </bean>

  <bean id="castor_context" class="com.mckesson.eig.wsfw.axis.CastorContext" lazy-init="true">
    <property name="mappingFile" value="webservice-mappings.xml"/>
  </bean>
  
  <!-- Business Services -->
  <!-- because we are outside a true container, must use singleton scope -->  
  <bean id="com.mckesson.eig.wsfw.test.service.HouseService"
    class="com.mckesson.eig.wsfw.test.service.HouseService"
    scope="singleton"/>
    
  <bean id="com.mckesson.eig.wsfw.test.service.HelloWorldService"
    class="com.mckesson.eig.wsfw.test.service.HelloWorldService"
    scope="singleton"/>
    
  <bean id="com.mckesson.eig.wsfw.security.webservice.test.WelcomeService" 
    class="com.mckesson.eig.wsfw.security.webservice.test.WelcomeService"
    scope="singleton"/>      

  <bean id="AuthenticationStrategy" 
    class="com.mckesson.eig.wsfw.test.MockAuthenticationStrategy" 
    lazy-init="true"/>

    <bean id="AuthorizationStrategy" 
        class="com.mckesson.eig.wsfw.test.axis.MockAuthorizationStrategy" 
        lazy-init="true"/>
        
    <bean id="PasswordEncryptionStrategy" 
        class="com.mckesson.eig.wsfw.security.encryption.PassthroughStrategy" 
        lazy-init="true"/>
        
    <bean id="com.mckesson.eig.wsfw.security.webservice.test.SayhalloService"
        class="com.mckesson.eig.wsfw.security.webservice.test.SayhalloService"
        scope="singleton" />

    <bean id="com.mckesson.eig.wsfw.security.webservice.test.SayHiService"
        class="com.mckesson.eig.wsfw.security.webservice.test.SayHiService"
        scope="singleton" />

    <bean id="authenticator.1"
        class="com.mckesson.eig.wsfw.security.service.test.MockAuthenticator"
        lazy-init="true" />

    <bean id="authorizer.1" 
        class="com.mckesson.eig.wsfw.security.service.test.MockAuthorizer" 
        lazy-init="true"/>
        
  <!-- Test JMS Queue for testing the AsynchronousServiceHandler -->
  <bean id="testQueue"
      class="com.mckesson.eig.utility.jms.JmsConfig">
      <property name="url">
        <value>vm://localhost</value>
      </property>
      <property name="jmsQueueName">
        <value>queue/testQueue</value>
      </property>
      <property name="physicalName">
        <value>queue.testQueue</value>
      </property>      
      <property name="connectionFactory">
        <value>java:activemq/QueueConnectionFactory</value>
      </property>    
  </bean>

  
</beans>
