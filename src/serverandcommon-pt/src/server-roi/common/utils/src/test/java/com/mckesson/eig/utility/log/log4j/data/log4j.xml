<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE log4j:configuration SYSTEM "log4j.dtd">
<log4j:configuration xmlns:log4j='http://jakarta.apache.org/log4j/'>
  <appender name="eig_default_console" class="org.apache.log4j.ConsoleAppender">
	<layout class="org.apache.log4j.PatternLayout">
      <param name="ConversionPattern" value="[%d{DATE}] [%t] [%c{1}] %m%n"/>
    </layout>
  </appender>
  <category name="com.mckesson.eig" additivity="false">
    <priority value="debug" />
    <appender-ref ref="eig_default_console" />
  </category>
  <category name="org.apache" additivity="false">
    <priority value="info" />
    <appender-ref ref="eig_default_console" />
  </category>
  <category name="org.hibernate" additivity="false">
    <priority value="info" />
    <appender-ref ref="eig_default_console" />
  </category>
  <category name="servletunit" additivity="false">
    <priority value="debug" />
    <appender-ref ref="eig_default_console" />
  </category>
  <category name="net.sf.ehcache" additivity="false">
    <priority value="info" />
    <appender-ref ref="eig_default_console" />
  </category>
  <category name="org.exolab.castor" additivity="false">
    <priority value="info" />
    <appender-ref ref="eig_default_console" />
  </category>
  <category name="com.mchange" additivity="false">
    <priority value="info" />
    <appender-ref ref="eig_default_console" />
  </category>
  <root>
    <priority value ="debug" />
    <appender-ref ref="eig_default_console" />
  </root>
</log4j:configuration>