<?xml version="1.0" encoding="UTF-8"?>
 <beans xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
 xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-2.0.xsd">
  
  <bean id="log_initializer" class="com.mckesson.eig.utility.log.log4j.Log4JInitializer">
      <property name="byXml">
        <value>com/mckesson/eig/config/logging/config.logging.xml</value> 
      </property>
  </bean>
 
  <bean id="castor_context" class="com.mckesson.eig.wsfw.axis.CastorContext" lazy-init="true">
      <property name="mappingFile" value="com/mckesson/eig/config/webservices/webservice-mappings.xml" /> 
  </bean>
 
  <bean id="audit_castor_context" class="com.mckesson.eig.wsfw.axis.CastorContext" lazy-init="true">
    <property name="mappingFile" value="WEB-INF/audit-mappings.xml"/>
  </bean>

  <bean id="com.mckesson.eig.audit.local.AuditLocalService"
    class="com.mckesson.eig.config.audit.MockAuditLocalService"
    lazy-init="true"
    scope="singleton"/>
    
  <bean id="com.mckesson.eig.config.service.ConfigureLogService"
    class="com.mckesson.eig.config.service.ConfigureLogService"
    scope="singleton"/>
    
  <bean id="Configuration_Controller"
    class="com.mckesson.eig.config.controller.ConfigureLogController"
    scope="singleton"/>

   <bean id="authenticator.1"
        class="com.mckesson.eig.config.servlet.MockAuthenticator"
        lazy-init="true" />

   <bean id="authorizer.1" 
        class="com.mckesson.eig.config.servlet.MockAuthorizer" 
        lazy-init="true"/>
        
  <bean id="eig_auditq_config"
    class="com.mckesson.eig.utility.jms.JmsConfig">
    <property name="url">
      <value>tcp://localhost:61616</value>
    </property>
    <property name="jmsQueueName">
      <value>queue/eigAudit</value>
    </property>
    <property name="physicalName">
      <value>queue.eigAudit</value>
    </property>      
    <property name="connectionFactory">
    <!-- <value>java:activemq/ConnectionFactory</value> -->
      <value>java:activemq/QueueConnectionFactory</value>
    </property>    
  </bean>
    
  <bean id="hecm_component" class="com.mckesson.eig.config.model.LogConfigurationDetail">
       
        <property name="componentName">
      <value>hecm server</value>
    </property>
    <property name="componentSeq">
      <value>1</value>
    </property>
    <property name="logFile">
      <value>WEB-INF/hecm.logging.xml</value>
    </property>
    <property name="appenderList">
      <list>
        <value>eigLogAppender</value>
        <value>eigMetricsAppender</value>
      </list>
    </property>
    <property name="categoryList">
      <list>
        <value>com.quickstream</value>
        <value>com.mckesson.hecm</value>
        <value>com.mckesson.eig</value>
        <value>com.mckesson.eig.utility.metric</value>
      </list>
    </property>            
      </bean>

  <bean id="worklist_component" class="com.mckesson.eig.config.model.LogConfigurationDetail">
            
        <property name="componentName">
      <value>Worklist Server</value>
    </property>
    <property name="componentSeq">
      <value>2</value>
    </property>
    <property name="logFile">
      <value>com/mckesson/hecm/logging/worklist.logging.xml</value>
    </property>
    <property name="appenderList">
      <list>
        <value>eigLogAppender</value>
      </list>
    </property>
    <property name="categoryList">
      <list>
        <value>com.mckesson.hecm</value>
        <value>com.mckesson.eig</value>
      </list>
    </property>            
    </bean>
    
    <bean id="component_list" class="com.mckesson.eig.config.model.LogConfigurationDetailList" lazy-init="true">
    <property name="componentList">
      <list>
        <ref bean="hecm_component"/>
          <ref bean="worklist_component"/>
      </list>
      </property>
    </bean>

    <bean id="PasswordEncryptionStrategy"
       class="com.mckesson.eig.wsfw.security.encryption.AESStrategy">
    </bean>
</beans>
