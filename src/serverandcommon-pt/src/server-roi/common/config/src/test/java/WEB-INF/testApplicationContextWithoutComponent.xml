<?xml version="1.0" encoding="UTF-8"?>
 <beans xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
 xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-2.0.xsd">
  
  <bean id="log_initializer" class="com.mckesson.eig.utility.log.log4j.Log4JInitializer">
      <property name="byXml">
        <value>com/mckesson/eig/config/logging/config.logging.xml</value> 
      </property>
  </bean>
 
  <bean id="castor_context" class="com.mckesson.eig.wsfw.axis.CastorContext" lazy-init="true">
      <property name="mappingFile" value="com/mckesson/eig/config/webservices/webservice-mappings.xml" /> 
  </bean>
 
  <bean id="audit_castor_context" class="com.mckesson.eig.wsfw.axis.CastorContext" lazy-init="true">
    <property name="mappingFile" value="WEB-INF/audit-mappings.xml"/>
  </bean>

  <bean id="com.mckesson.eig.config.service.LogConfigurationService"
    class="com.mckesson.eig.config.service.LogConfigurationService"
    scope="singleton"/>
  
  <bean id="com.mckesson.eig.config.service.ListViewLogService"
    class="com.mckesson.eig.config.service.ListViewLogService"
    scope="singleton"/>
    
  <bean id="com.mckesson.eig.config.controller.ListViewLogController"
    class="com.mckesson.eig.config.controller.ListViewLogController"
    scope="singleton"/>

  <bean id="Configuration_Controller"
    class="com.mckesson.eig.config.controller.LogConfigurationController"
    scope="singleton"/>

  <bean id="com.mckesson.eig.audit.local.AuditLocalService"
    class="com.mckesson.eig.audit.local.AuditLocalService"
    lazy-init="true"
    scope="singleton"/>
    
   <bean id="authenticator.1"
        class="com.mckesson.eig.config.servlet.MockAuthenticator"
        lazy-init="true" />

   <bean id="authorizer.1" 
        class="com.mckesson.eig.config.servlet.MockAuthorizer" 
        lazy-init="true"/>
        
  <bean id="eig_auditq_config"
    class="com.mckesson.eig.utility.jms.JmsConfig">
    <property name="url">
      <value>tcp://localhost:61616</value>
    </property>
    <property name="jmsQueueName">
      <value>queue/eigAudit</value>
    </property>
    <property name="physicalName">
      <value>queue.eigAudit</value>
    </property>      
    <property name="connectionFactory">
    <!-- <value>java:activemq/ConnectionFactory</value> -->
      <value>java:activemq/QueueConnectionFactory</value>
    </property>    
  </bean>
    
    <bean id="component_list" class="com.mckesson.eig.config.model.LogConfigurationDetailList" lazy-init="true">
    <property name="componentList">
      <list>
      </list>
      </property>
    </bean>
</beans>
