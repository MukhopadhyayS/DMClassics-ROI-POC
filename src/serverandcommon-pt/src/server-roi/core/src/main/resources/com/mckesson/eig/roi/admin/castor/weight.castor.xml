<?xml version="1.0" encoding="UTF-8"?>
<mapping xmlns:eig="urn:eig.mckesson.com">
	<!--  Weight -->
	<class name="com.mckesson.eig.roi.admin.model.Weight">
		<map-to xml="weightDetails" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />

		<field name="id" type="long">
			<bind-xml name="eig:id" node="element" />
		</field>

		<field name="recordVersion" type="int">
			<bind-xml name="eig:recordVersion" node="element" />
		</field>

		<field name="unitPerMeasure" type="long">
			<bind-xml name="eig:unitPerMeasure" node="element" />
		</field>

	</class>
</mapping>
