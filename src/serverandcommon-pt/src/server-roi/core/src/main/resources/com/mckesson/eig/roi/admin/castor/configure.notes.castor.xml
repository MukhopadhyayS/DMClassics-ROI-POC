<?xml version="1.0" encoding="UTF-8"?>
<mapping xmlns:eig="urn:eig.mckesson.com">
	<class name="com.mckesson.eig.roi.admin.model.Note">
		<map-to xml="noteDetails" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />

		<field name="id" type="long">
			<bind-xml name="eig:noteId" node="element" />
		</field>

		<field name="name" type="string">
			<bind-xml name="eig:name" node="element" />
		</field>

		<field name="description" type="string">
			<bind-xml name="eig:description" node="element" />
		</field>

		<field name="recordVersion" type="int">
			<bind-xml name="eig:recordVersion" node="element" />
		</field>

	</class>

	<class name="com.mckesson.eig.roi.admin.model.NotesList">
		<map-to xml="notes" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />

		<field name="notesList"
			type="com.mckesson.eig.roi.admin.model.Note"
			collection="arraylist">
			<bind-xml name="eig:noteDetails" node="element" />
		</field>

	</class>
</mapping>
