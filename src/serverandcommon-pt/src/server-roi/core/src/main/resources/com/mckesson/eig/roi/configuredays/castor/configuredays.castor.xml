<?xml version="1.0" encoding="UTF-8"?>
<mapping xmlns:eig="urn:eig.mckesson.com">


    <class name="com.mckesson.eig.roi.configuredays.model.ConfigureDaysDto">
        <map-to xml="configureDaysList" ns-prefix="eig" ns-uri="urn:eig.mckesson.com"/>

        <field name="dayName" type="string">
            <bind-xml name="eig:dayName" node="element"/>
        </field>
        
        <field name="dayStatus" type="string">
            <bind-xml name="eig:dayStatus" node="element"/>
        </field>
    </class>
    
    
    <class name="com.mckesson.eig.roi.configuredays.model.ConfigureDaysDtoList">
    		<map-to xml="configureDaysStatusReqElement" ns-prefix="eig" ns-uri="urn:eig.mckesson.com"/>
    
    		<field name="configureDaysDtoList"
    			type="com.mckesson.eig.roi.configuredays.model.ConfigureDaysDto"
    			collection="arraylist">
    			<bind-xml name="eig:configureDaysList" node="element" />
    		</field>
    </class>
    
</mapping>