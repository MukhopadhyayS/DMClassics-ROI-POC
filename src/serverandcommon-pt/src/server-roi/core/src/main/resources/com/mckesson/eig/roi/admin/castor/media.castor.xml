<?xml version="1.0" encoding="UTF-8"?>
<mapping xmlns:eig="urn:eig.mckesson.com">
 <class name="com.mckesson.eig.roi.admin.model.MediaType">
    <map-to xml="mediaTypeDetails" ns-prefix="eig" ns-uri="urn:eig.mckesson.com"/>

    <field name="id" type="long">
        <bind-xml name="eig:id" node="element" />
    </field>

    <field name="name" type="string">
      <bind-xml name="eig:name" node="element" />
    </field>

    <field name="description" type="string">
      <bind-xml name="eig:description" node="element" />
    </field>

    <field name="isAssociated" type="boolean">
      <bind-xml name="eig:isAssociated" node="element" />
    </field>

    <field name="recordVersion" type="int">
      <bind-xml name="eig:recordVersion" node="element" />
    </field>

  </class>

  <class name="com.mckesson.eig.roi.admin.model.MediaTypesList">
    <map-to xml="mediaTypes" ns-prefix="eig" ns-uri="urn:eig.mckesson.com"/>

    <field name="mediaTypesList" type="com.mckesson.eig.roi.admin.model.MediaType" collection="arraylist">
      <bind-xml name="eig:mediaTypeList" node="element" />
    </field>

  </class>
</mapping>  