<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping default-cascade="all,delete-orphan">

<class name="com.mckesson.eig.roi.base.model.Address"
        table="ROI_Address"
        dynamic-update="true"
        optimistic-lock="version">

   <id name="id">
        <column name="ROI_Address_Seq" sql-type="int"/>
         <generator class="identity"/>
   </id>

   <version name="recordVersion" column="Record_Version" type="integer" />

    <property name="address1" >
         <column name="AddressLine1" sql-type="varchar(256)" not-null="true" />
    </property>

    <property name="address2" >
         <column name="AddressLine2" sql-type="varchar(256)" not-null="true" />
    </property>

    <property name="address3" >
         <column name="AddressLine3" sql-type="varchar(256)" not-null="true" />
    </property>

     <property name="city" >
        <column name="City" sql-type="varchar(256)" not-null="true" />
    </property>

    <property name="postalCode" >
        <column name="PostalCode" sql-type="varchar(256)" not-null="true" />
    </property>

    <property name="state" >
        <column name="State" sql-type="varchar(256)" not-null="true" />
    </property>

    <property name="createdBy" >
         <column name="Created_By_Seq" sql-type="int" not-null="true"/>
    </property>

    <property name="modifiedDate" >
         <column name="Modified_Dt" sql-type="smalldatetime" not-null="true"/>
     </property>

    <property name="modifiedBy" >
         <column name="Modified_By_Seq" sql-type="int" not-null="true"/>
    </property>
    
     <property name="countrySeq" >
        <column name="ROI_CountryLovID" sql-type="int" not-null="true" />
    </property>

</class>

</hibernate-mapping>