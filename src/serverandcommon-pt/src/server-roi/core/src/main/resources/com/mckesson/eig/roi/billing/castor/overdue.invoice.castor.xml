<?xml version="1.0" encoding="UTF-8"?>
<mapping xmlns:eig="urn:eig.mckesson.com">
 <class name="com.mckesson.eig.roi.billing.model.SearchPastDueInvoiceCriteria">
    <map-to xml="PastDueInvoiceCriteria" ns-prefix="eig" ns-uri="urn:eig.mckesson.com"/>

    <field name="billingLocations"  collection="array" type="string">
        <bind-xml name="eig:billingLocations" node="element" />
    </field>

    <field name="requestorTypes" collection="array" type="java.lang.Long">
        <bind-xml name="eig:requestorTypes" node="element" />
    </field>
    
    <field name="requestorTypeNames"  collection="array" type="string">
        <bind-xml name="eig:requestorTypeNames" node="element" />
    </field>

    <field name="requestorName" type="string">
        <bind-xml name="eig:requestorName" node="element" />
    </field>

    <field name="overDueFrom" type="long">
      <bind-xml name="eig:overDueFrom" node="element" />
    </field>

    <field name="overDueTo" type="long">
      <bind-xml name="eig:overDueTo" node="element" />
    </field>

    <field name="overDueRestriction" type="com.mckesson.eig.roi.billing.model.OverDueRestriction">
      <bind-xml name="eig:overDueRestriction" node="element" />
    </field>

  </class>

  <class name="com.mckesson.eig.roi.billing.model.SearchPastDueInvoiceResult">
    <map-to xml="searchPastDueInvoiceResult" ns-prefix="eig" ns-uri="urn:eig.mckesson.com"/>

    <field name="maxCountExceeded" type="boolean">
      <bind-xml name="eig:maxCountExceeded" node="element" />
    </field>

    <field name="pastDueInvoices" type="com.mckesson.eig.roi.billing.model.PastDueInvoice" collection="arraylist">
      <bind-xml name="eig:PastDueInvoice" location="PastDueInvoiceList" node="element" />
    </field>

  </class>

  <class name="com.mckesson.eig.roi.billing.model.PastDueInvoice">
    <map-to xml="PastDueInvoice" ns-prefix="eig" ns-uri="urn:eig.mckesson.com"/>

    <field name="billingLocation" type="string">
      <bind-xml name="eig:billingLocation" node="element" />
    </field>

    <field name="invoiceNumber" type="long">
      <bind-xml name="eig:invoiceNumber" node="element" />
    </field>

    <field name="requestId" type="long">
      <bind-xml name="eig:requestId" node="element" />
    </field>

    <field name="overdueAmount" type="double">
      <bind-xml name="eig:overdueAmount" node="element" />
    </field>

    <field name="requestorName" type="string">
      <bind-xml name="eig:requestorName" node="element" />
    </field>

    <field name="phoneNumber" type="string">
      <bind-xml name="eig:phoneNumber" node="element" />
    </field>

    <field name="requestorType" type="string">
      <bind-xml name="eig:requestorType" node="element" />
    </field>

    <field name="requestorId" type="long">
      <bind-xml name="eig:requestorId" node="element" />
    </field>

    <field name="overDueDays" type="long">
      <bind-xml name="eig:overDueDays" node="element" />
    </field>

    <field name="invoiceAge" type="long">
      <bind-xml name="eig:invoiceAge" node="element" />
    </field>

  </class>
  
  <class name="com.mckesson.eig.roi.billing.model.RegeneratedInvoiceInfo">
    <map-to xml="regeneratedInvoiceInfo" ns-prefix="eig" ns-uri="urn:eig.mckesson.com"/>

    <field name="id" type="long">
      <bind-xml name="eig:id" node="element" />
    </field>

    <field name="outputMethod" type="string">
      <bind-xml name="eig:outputMethod" node="element" />
    </field>

    <field name="queuePassword" type="string">
      <bind-xml name="eig:queuePassword" node="element" />
    </field>

    <field name="invoice" type="boolean">
      <bind-xml name="eig:invoice" node="element" />
    </field>

   	<field name="properties" type="org.exolab.castor.mapping.MapItem" collection="map">
         <bind-xml name="eig:properties" node="element">
             <class name="org.exolab.castor.mapping.MapItem">
                 <field name="key" type="string">
                     <bind-xml name="eig:name" node="element" />
                 </field>
                 <field name="value" type="string">
                     <bind-xml name="eig:value" node="element" />
                 </field>
             </class>
         </bind-xml>
     </field>
     
  </class>
  
</mapping>