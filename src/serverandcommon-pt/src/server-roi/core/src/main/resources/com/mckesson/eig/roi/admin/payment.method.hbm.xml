<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>

<class name="com.mckesson.eig.roi.admin.model.PaymentMethod"
           table="ROI_PaymentMethod"
           dynamic-update="true"
           optimistic-lock="version" >

        <id name="id" >
            <column name="ROI_PaymentMethod_Seq" sql-type="int"/>
            <generator class="identity"/>
        </id>

        <version name="recordVersion" column="Record_Version" type="integer" />

        <property name="name" >
            <column name="Name" sql-type="varchar(60)" not-null="true" />
        </property>

        <property name="desc" >
            <column name="Description" sql-type="varchar(255)" />
        </property>

        <property name="isDisplay" >
            <column name="Display" sql-type="bit" not-null="true" />
        </property>

        <property name="active" >
            <column name="Active" sql-type="bit" not-null="true" />
        </property>

        <property name="createdBy" >
            <column name="Created_By_Seq" sql-type="int" not-null="true" />
        </property>

        <property name="modifiedBy" >
            <column name="Modified_By_Seq" sql-type="int" not-null="true" />
        </property>

        <property name="orgId" >
            <column name="Organization_Seq" sql-type="int" not-null="true" />
        </property>

        <property name="modifiedDt" >
            <column name="Modified_Dt" sql-type="smalldatetime" not-null="true" />
        </property>


     </class>

     <query name="getPaymentMethodByName">
       <![CDATA[
         select p from com.mckesson.eig.roi.admin.model.PaymentMethod p
         where p.name = ?0
       ]]>
     </query>

     <query name="retrieveAllPaymentMethods">
       <![CDATA[
         select p from com.mckesson.eig.roi.admin.model.PaymentMethod p
         order by p.name asc
       ]]>
     </query>

     <query name="retrieveAllPaymentMethodNames">
    <![CDATA[
      select payment.id, payment.name, payment.desc, payment.isDisplay
      from com.mckesson.eig.roi.admin.model.PaymentMethod payment
      order by payment.name asc
    ]]>
  </query>

</hibernate-mapping>