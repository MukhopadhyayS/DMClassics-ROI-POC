<!-- This build file contains the process includes run fxCop to check coding standard, run unit test cases, run code coverage and  genearte reports-->

<project default="clear-bulid-files" basedir =".">
        <target name="clear-bulid-files">
            <if test ="${property::exists('dirLocation')}">
              <delete>
                    <fileset basedir="${dirLocation}">
                       <includes name="**"/>  
                       <excludesfile name="exclude-dir-pattern.txt"/>  
                    </fileset>
              </delete>
             </if>
            <if test="${not property::exists('dirLocation')}">
                <echo message="Please enter the build files directory location."/>
            </if>
        </target>
</project>