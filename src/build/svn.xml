<project default="get-from-svn" basedir="../">

	<property file="build/props/${build.config.file.name}" />
    <property file="build/props/base.properties" />
	<taskdef resource="net/sf/antcontrib/antcontrib.properties" />
	
	<property environment="env"/>
	
	<path id="svnant.classpath">
	  <pathelement location="${env.ANT_HOME}/lib/svnant.jar"/>
	  <pathelement location="${env.ANT_HOME}/lib/svnClientAdapter.jar"/>
	  <pathelement location="${env.ANT_HOME}/lib/svnkit.jar"/>
	  <pathelement location="${env.ANT_HOME}/lib/svnjavahl.jar"/>
	</path>
	
	<typedef resource="org/tigris/subversion/svnant/svnantlib.xml" classpathref="svnant.classpath" />
	<svnSetting javahl="false" svnkit="true"  username="${svn.username}"  password="${svn.password}"  id="svn.settings" />
	
    <!-- **********************************************************************
             *  Target : get-from-svn
             *  target to pull source from svn
             ********************************************************************** -->
	<target name="get-from-svn" >
		
		<echo message="initial depth option: ${checkout.depth}"/>
		<if>
 		    <equals arg1="${checkout.depth}" arg2="" trim="true" />
			<then>
				<property name="${checkout.depth}" value="infinity" />
			</then>
		</if>
		
		<condition property="checkout.depth" else="infinity">
			<isset property="checkout.depth"/>
		</condition>
		
		<echo message="After validating: ${checkout.depth}"/>
	
		<if>
 		    <equals arg1="${label.name}" arg2="" trim="true" />
    		<then>   	
				<echo message="svn checkout: svn -r HEAD checkout --force ${svn.repository.path}/${svn.path} ${checkout.dest.path}" />
				<exec executable="svn" failonerror="true">
					<arg value="--username" />
					<arg value="${svn.username}" />
					<arg value="--password" />
					<arg value="${svn.password}" />
					<arg value="--no-auth-cache" />
					<arg value="-r" />
					<arg value="HEAD" />
					<arg value="--depth" />
					<arg value="${checkout.depth}" />
					<arg value="checkout" />
					<arg value="--force" />
					<arg value="&quot;${svn.repository.path}/${svn.path}&quot;" />
					<arg value="&quot;${checkout.dest.path}&quot;" />
				</exec>
    		</then>
    		<else>
                <echo message="svn checkout: svn checkout --force ${svn.repository.path}/${svn.path} ${svn.local.path}/${checkout.dest.path}" />
                <exec executable="svn" failonerror="true">
					<arg value="--username" />
					<arg value="${svn.username}" />
					<arg value="--password" />
					<arg value="${svn.password}" />
					<arg value="--no-auth-cache" />
					<arg value="-r" />
					<!--arg value="&quot;${label.name}&quot;" /-->
					<arg value="HEAD" />
					<arg value="--depth" />
					<arg value="${checkout.depth}" />
					<arg value="checkout" />
					<arg value="--force" />
					<arg value="&quot;${svn.repository.path}/${svn.path}&quot;" />
					<arg value="&quot;${checkout.dest.path}&quot;" />
				</exec>
    		</else>	
		</if>	
	</target>
	
	<!-- **********************************************************************
             *  Target : get-file-from-svn
             *  target to pull source from svn
             ********************************************************************** -->
	<target name="get-file-from-svn" >
		<echo message="Checking out file....."/>
		<if>
 		    <equals arg1="${label.name}" arg2="" trim="true" />
    		<then>
				<echo message="svn --force export -r HEAD '${svn.repository.path}/${svn.path}' ${checkout.dest.path}" />
				<exec executable="svn" failonerror="true">
					<arg value="--username" />
					<arg value="${svn.username}" />
					<arg value="--password" />
					<arg value="${svn.password}" />
					<arg value="--no-auth-cache" />
					<arg value="--force" />
					<arg value="export" />
					<arg value="-r" />
					<arg value="HEAD" />
					<arg value="&quot;${svn.repository.path}/${svn.path}&quot;" />
					<arg value="&quot;${checkout.dest.path}&quot;" />
				</exec>
    		</then>
    		<else>
				<echo message="svn --force export -r ${label.name} ${svn.repository.path}/${svn.path}' ${checkout.dest.path}" />
				<exec executable="svn" failonerror="true">
					<arg value="--username" />
					<arg value="${svn.username}" />
					<arg value="--password" />
					<arg value="${svn.password}" />
					<arg value="--no-auth-cache" />
					<arg value="--force" />
					<arg value="export" />
					<arg value="-r" />
					<!--arg value="&quot;${label.name}&quot;" /-->
					<arg value="HEAD" />
					<arg value="&quot;${svn.repository.path}/${svn.path}&quot;" />
					<arg value="&quot;${checkout.dest.path}&quot;" />
				</exec>
    		</else>
		</if>
	</target>
	
    <!-- **********************************************************************
             *  Target : checkin-svn
             *  target to check-in into svn
             ********************************************************************** -->
	<target name="checkin-file-svn" >
		<echo message="svn commit --force-log -m '${svn.checkin.comment}' ${checkin.file.path}" />
		<exec executable="svn" failonerror="true">
			<arg value="--username" />
			<arg value="${svn.username}" />
			<arg value="--password" />
			<arg value="${svn.password}" />
			<arg value="--no-auth-cache" />
			<arg value="commit" />
			<arg value="--force-log" />
			<arg value="-m" />
			<arg value="&quot;${svn.checkin.comment}&quot;" />
			<arg value="&quot;${checkin.file.path}&quot;" />
		</exec>
	</target>
	
	<target name="checkin-dir-svn" >
		<svn refid="svn.settings">
			<commit dir="${checkin.file.path}" message="${svn.checkin.comment}" />
		</svn>
	</target>
	
    <!-- **********************************************************************
             *  Target : tag-svn
             *  target to tag the source code
             ********************************************************************** -->
	<target name="tag-svn" >
		
	</target>

</project>