<project default="get-from-svn" basedir="../">

	<property file="build/props/${build.config.file.name}" />
    <property file="build/props/base.properties" />
	<taskdef resource="net/sf/antcontrib/antcontrib.properties" />
	
	<property environment="env"/>
	
    <!-- **********************************************************************
             *  Target : get-from-svn
             *  target to pull source from svn
             ********************************************************************** -->
	<target name="get-from-svn">
		<echo message="Updating from Git repository"/>
		<exec executable="git" dir="${checkout.dest.path}" failonerror="true">
			<arg value="pull"/>
			<arg value="origin"/>
			<arg value="main"/>
		</exec>
	</target>
	
	<!-- **********************************************************************
             *  Target : get-file-from-svn
             *  target to pull source from svn
             ********************************************************************** -->
	<target name="get-file-from-svn">
		<echo message="Fetching file from Git repository"/>
		<exec executable="git" dir="${source.local.root.path}" failonerror="true">
			<arg value="checkout"/>
			<arg value="HEAD"/>
			<arg value="--"/>
			<arg value="${svn.path}"/>
		</exec>
	</target>
	
    <!-- **********************************************************************
             *  Target : checkin-svn
             *  target to check-in into svn
             ********************************************************************** -->>
	
    <!-- **********************************************************************
             *  Target : tag-svn
             *  target to tag the source code
             ********************************************************************** -->
	<target name="tag-svn" >
		
	</target>

</project>
