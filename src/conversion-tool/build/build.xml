<project name="build-conversion-util" default="build" basedir="../">

	<property name="class.compatibility" value="1.5" />
	<property name="roi.conversion.jar" value="roi.conversion.util.jar" />
	<property name="main.class" value="com.mckesson.eig.roi.conversion.Main" />

	<path id="classpath">
		<fileset dir="lib">
			<include name="**/*.jar"/>
		</fileset>
	</path>

	<target name="build">
		<antcall target="compile" />
		<antcall target="create-jar" />
	</target>

	<target name="compile" depends="clean">
		<mkdir dir="${basedir}/target/classes" />
		<javac srcdir="src/main/java" includeAntRuntime="no" destdir="target/classes" debug="on" source="${class.compatibility}" target="${class.compatibility}" optimize="off" deprecation="on">
			<classpath>
				<path refid="classpath" />
			</classpath>
		</javac>
	</target>
	<target name="clean">
		<delete dir="${basedir}/target" failonerror="true"/>
	</target>
	
	<target name="create-jar">
		<mkdir dir="${basedir}/target/bin" />
		<mkdir dir="${basedir}/target/bin/common" />
		<mkdir dir="${basedir}/target/bin/conversion" />
		<mkdir dir="${basedir}/target/bin/preconversion" />
		<antcall target="copy-libs" />
		<antcall target="copy-config" />
		<antcall target="copy-scripts" />
		<jar jarfile="${basedir}/target/bin/common/roi-conversion-tool.jar">
			<fileset dir="${basedir}/target/classes" />
			<fileset dir="${basedir}/src/main/resources" 
						excludes="**/config/**" />
			<manifest>
                <!--attribute name="Main-Class" value="${main.class}"/-->
                <attribute name="Class-Path"
                	value="lib/bonecp-0.7.1.RELEASE.jar
                           lib/bonecp-provider-0.7.1.RELEASE.jar
                           lib/commons-collections.jar
                	       lib/dom4j-1.6.1.jar
                	       lib/google-collections-1.0.jar
                	       lib/hibernate3.jar
                	       lib/jta-1.1.jar
                	       lib/jtds-1.2.jar
						   lib/log4j-1.2.16.jar
						   lib/slf4j-api-1.7.0.jar
						   lib/slf4j-log4j12-1.7.0.jar
							.
                	       "/>
            </manifest>
		</jar>
	</target>
	<target name="copy-libs">
		<copy todir="${basedir}/target/bin/common/lib" preservelastmodified="true" includeEmptyDirs="false">
			<fileset dir="${basedir}/lib"/>
		</copy>
	</target>
	<target name="copy-scripts">
		<copy todir="${basedir}/target/bin/common/scripts" preservelastmodified="true" includeEmptyDirs="false">
			<fileset dir="${basedir}/scripts"/>
		</copy>
	</target>
	<target name="copy-config">
		<copy todir="${basedir}/target/bin/common/config" preservelastmodified="true" includeEmptyDirs="false">
			<fileset dir="${basedir}/src/main/resources/config"/>
		</copy>
		<copy todir="${basedir}/target/bin/conversion" file="${basedir}/build/roi-conversion-tool.bat" preservelastmodified="true" includeEmptyDirs="false" />
		<copy todir="${basedir}/target/bin" file="${basedir}/build/Readme.txt" preservelastmodified="true" includeEmptyDirs="false" />
		<copy todir="${basedir}/target/bin/preconversion" file="${basedir}/build/roi-preconversion-mapping.bat" preservelastmodified="true" includeEmptyDirs="false" />
		<copy todir="${basedir}/target/bin/preconversion" file="${basedir}/build/generate-facility-billing-location-mapping.bat" preservelastmodified="true" includeEmptyDirs="false" />
		<copy todir="${basedir}/target/bin/preconversion" file="${basedir}/build/generate-user-billing-location-mapping.bat" preservelastmodified="true" includeEmptyDirs="false" />
	</target>
</project>