<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
<class name="com.mckesson.eig.roi.admin.model.TaxPerFacility"
       table="ROI_SalesTaxPerFacility"
       dynamic-update="true"
       optimistic-lock="version" >

    <id name="id" >
        <column name="ROI_SalesTaxPerFacility_Seq" sql-type="int"/>
        <generator class="identity"/>
    </id>

    <version name="recordVersion" column="Record_Version" type="integer" />

    <property name="code" >
        <column name="Facility_Code" sql-type="varchar(60)" not-null="true" />
    </property>

    <property name="name" 
    			formula="(SELECT fac.FACILITY_NAME from FACILITY_FILE fac
    					WHERE fac.FACILITY_CODE = Facility_Code)">
    </property>

	<property name="taxPercentage" >
        <column name="TaxRate" sql-type="float" not-null="true" />
    </property>

	<property name="description" >
        <column name="Description" sql-type="varchar(255)"/>
    </property>

	<property name="default" >
        <column name="EnterpriseDefault" sql-type="char(1)" not-null="true"/>
    </property>

	<property name="createdBy" >
        <column name="Created_By_Seq" sql-type="int" not-null="true"/>
    </property>

    <property name="modifiedDate" >
        <column name="Modified_Dt" sql-type="smalldatetime" not-null="true"/>
    </property>

    <property name="modifiedBy" >
        <column name="Modified_By_Seq" sql-type="int" not-null="true"/>
    </property>


 </class>

  <query name="retrieveAllSalesTaxFacility">
    <![CDATA[
      select st from com.mckesson.eig.roi.admin.model.TaxPerFacility st
      order by st.code asc
    ]]>
  </query>

  <query name="retrieveAllSalesTaxFacilityCode">
    <![CDATA[
      select st.id, st.code
      from com.mckesson.eig.roi.admin.model.TaxPerFacility st
      order by st.code asc
    ]]>
  </query>

  <query name="getSalesTaxFacilityByCode">
    <![CDATA[
      select st from com.mckesson.eig.roi.admin.model.TaxPerFacility st
      where st.code = ?0
    ]]>
  </query>


   <query name="getDefaultAsTrue">
      <![CDATA[
        select salesTax from com.mckesson.eig.roi.admin.model.TaxPerFacility salesTax
         where salesTax.default = 'Y'
      ]]>
    </query>
    
   <query name="getFacilitiesByUser">
      <![CDATA[
        select distinct trim(uf.facility) from com.mckesson.eig.roi.hpf.model.User u,
         com.mckesson.eig.roi.hpf.model.UserFacility uf
         where u.loginId = ?0 and uf.userId = u.instanceId
      ]]>
    </query>

</hibernate-mapping>
