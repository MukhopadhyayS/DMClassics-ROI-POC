    <service name="securitylogoff" style="wrapped" use="literal" provider="Handler">

      <requestFlow>
            <handler type="java:com.mckesson.eig.wsfw.security.WsSecurityHandler" >
                <parameter name="action" value="UsernameToken Timestamp"/>
                <parameter name="passwordCallbackClass" value="com.mckesson.eig.wsfw.security.PasswordCallbackHandler"/>
            </handler>
        </requestFlow>

        <namespace>urn:eig.mckesson.com</namespace>
        <wsdlFile>/WEB-INF/eig/roi/securitylogoff.wsdl</wsdlFile>
        <parameter name="alias" value="SecurityLogoffService"/>
        <parameter name="wsdlTargetNamespace" value="urn:eig.mckesson.com"/>
        <parameter name="wsdlPortType" value="SecurityLogoffPortType"/>
        <parameter name="wsdlServiceElement" value="SecurityLogoffService"/>
        <parameter name="wsdlServicePort" value="securityLogoff"/>
        <parameter name="handlerClass" value="com.mckesson.eig.wsfw.axis.BusinessServiceHandler"/>
        <parameter name="className" value="com.mckesson.eig.roi.hpf.service.HPFSecurityAuthenticationService"/>
        <parameter name="allowedMethods" value="logoff"/>
        <parameter name="forceInvalidateSession" value="true"/>
        <parameter name="scope" value="session"/>
        <operation name="logoff" qname="eig:logoff" returnQName="eig:logoffResult">
      </operation>
    </service>

  <service name="BillingAdminService" style="wrapped" use="literal" provider="Handler">

       <requestFlow>
            <handler type="java:com.mckesson.eig.wsfw.security.WsSecurityHandler" >
                <parameter name="action" value="UsernameToken Timestamp"/>
                <parameter name="passwordCallbackClass" value="com.mckesson.eig.wsfw.security.PasswordCallbackHandler"/>
            </handler>
      <!-- Add the HPFSecurityAuthorizationHandler after the Authentication handler to the requestflow -->
           <handler type="HPFSecurityAuthorizationHandler" />
        </requestFlow>

        <namespace>urn:eig.mckesson.com</namespace>
        <wsdlFile>/WEB-INF/eig/roi/billing.admin.wsdl</wsdlFile>
        <parameter name="alias" value="BillingAdmin"/>
        <parameter name="wsdlTargetNamespace" value="urn:eig.mckesson.com"/>
        <parameter name="wsdlPortType" value="AdminPortType"/>
        <parameter name="wsdlServiceElement" value="BillingAdmin"/>
        <parameter name="wsdlServicePort" value="adminPort"/>
        <parameter name="handlerClass" value="com.mckesson.eig.wsfw.axis.BusinessServiceHandler"/>
        <parameter name="className" value="com.mckesson.eig.roi.admin.service.BillingAdminServiceImpl"/>
        <parameter name="allowedMethods" value="createMediaType,
                                                retrieveMediaType,
                                                retrieveAllMediaTypes,
                                                updateMediaType,
                                                deleteMediaType,
                                                createFeeType,
                                                deleteFeeType,
                                                retrieveFeeType,
                                                retrieveAllFeeTypes,
                                                updateFeeType,
                                                createPaymentMethod,
                                                retrievePaymentMethod,
                                                retrieveAllPaymentMethods,
                                                updatePaymentMethod,
                                                deletePaymentMethod,
                                                retrieveAllBillingTemplates,
                                                retrieveBillingTemplate,
                                                updateBillingTemplate,
                                                createBillingTemplate,
                                                deleteBillingTemplate,
                                                createBillingTier,
                                                retrieveBillingTier,
                                                retrieveAllBillingTiers,
                                                updateBillingTier,
                                                deleteBillingTier,
                                                retrieveBillingTiersByMediaTypeName,
                                                createTaxPerFacility,
                                                retrieveTaxPerFacility,
                                                retrieveAllTaxPerFacilities,
                                                retrieveAllTaxPerFacilitiesByUser,
                                                updateTaxPerFacility,
                                                deleteTaxPerFacility,
                                                retrieveBillingAndPaymentInfo "/>

        <parameter name="scope" value="session"/>

        <operation name="createMediaType"
                   qname="eig:createMediaType"
                   returnQName="eig:mediaTypeId"
                   returnType="xsd:long">
            <parameter qname="eig:mediaTypeDetails" type="eig:MediaType"/>
        </operation>

       <operation name="retrieveMediaType"
                   qname="eig:retrieveMediaType"
                   returnQName="eig:mediaTypeDetails"
                   returnType="eig:MediaType">
            <parameter qname="eig:mediaTypeId" type="xsd:long"/>
        </operation>

        <operation name="retrieveAllMediaTypes"
                   qname="eig:retrieveAllMediaTypes"
                   returnQName="eig:mediaTypes"
                   returnType="eig:MediaTypeList">
                <parameter qname="detailedFetch" type="xsd:boolean"/>
        </operation>

        <operation name="updateMediaType"
                   qname="eig:udpateMediaType"
                   returnQName="eig:udpateMediaTypeResponse"
                   returnType="eig:MediaType">
             <parameter qname="eig:mediaTypeDetails" type="eig:MediaType"/>
        </operation>

        <operation name="deleteMediaType"
                   qname="eig:deleteMediaType"
                   returnQName="xsd:void"
                   returnType="xsd:void">
             <parameter qname="eig:mediaTypeId" type="xsd:long"/>
        </operation>

         <operation name="createFeeType"
                    qname="eig:createFeeType"
                    returnQName="eig:feeTypeId"
                    returnQType="xsd:long">
          <parameter qname="eig:feeTypeDetails" type="eig:FeeType"/>
         </operation>

        <operation name="retrieveFeeType"
                    qname="eig:retrieveFeeType"
                    returnQName="eig:feeTypeDetails"
                    returnQType="eig:FeeType">
         <parameter name="eig:feeTypeId" type="xsd:long" />
         </operation>

         <operation name="deleteFeeType"
                   qname="eig:deleteFeeType"
                   returnQName="xsd:void"
                   returnType="xsd:void">
             <parameter qname="eig:feeTypeId" type="xsd:long"/>
        </operation>

          <operation name="retrieveAllFeeTypes"
                    qname="eig:retrieveAllFeeTypes"
                    returnQName="eig:feeTypes"
                    returnQType="eig:FeeTypes">
                <parameter qname="detailedFetch" type="xsd:boolean"/>
         </operation>

         <operation name="updateFeeType"
                    qname="eig:updateFeeType"
                    returnQName="eig:feeTypeDetails"
                    returnQType="eig:FeeType">
          <parameter qname="eig:feeTypeDetails" type="eig:FeeType" />
         </operation>

         <operation name="createPaymentMethod"
                   qname="eig:createPaymentMethod"
                   returnQName="eig:paymentMethodId"
                   returnType="xsd:long">
            <parameter qname="eig:paymentMethodDetails" type="eig:PaymentMethod"/>
        </operation>

        <operation name="retrievePaymentMethod"
                   qname="eig:retrievePaymentMethod"
                   returnQName="eig:paymentMethodDetails"
                   returnType="eig:PaymentMethod">
            <parameter qname="eig:paymentMethodId" type="xsd:long"/>
        </operation>

        <operation name="retrieveAllPaymentMethods"
                   qname="eig:retrieveAllPaymentMethods"
                   returnQName="eig:paymentMethods"
                   returnType="eig:PaymentMethodList">
                 <parameter qname="detailedFetch" type="xsd:boolean"/>
        </operation>

        <operation name="updatePaymentMethod"
                   qname="eig:updatePaymentMethod"
                   returnQName="eig:paymentMethodDetails"
                   returnType="eig:PaymentMethod">
             <parameter qname="eig:paymentMethodDetails" type="eig:PaymentMethod"/>
        </operation>

        <operation name="deletePaymentMethod"
                   qname="eig:deletePaymentMethod"
                   returnQName="xsd:void"
                   returnType="xsd:void">
           <parameter qname="eig:paymentMethodId" type="xsd:long"/>
        </operation>

        <operation name="createBillingTemplate"
                   qname="eig:createBillingTemplate"
                   returnQName="eig:billingTemplateId"
                   returnType="xsd:long">
            <parameter qname="eig:billingTempate" type="eig:BillingTemplate"/>
        </operation>

        <operation name="retrieveBillingTemplate"
                   qname="eig:retrieveBillingTemplate"
                   returnQName="eig:billingTemplate"
                   returnType="eig:BillingTemplate">
            <parameter qname="eig:billingTempalteId" type="xsd:long"/>
        </operation>

        <operation name="retrieveAllBillingTemplates"
                   qname="eig:retrieveAllBillingTemplates"
                   returnQName="eig:billingTemplates"
                   returnType="eig:BillingTemplateList">
                   <parameter qname="getAssociation" type="xsd:boolean"/>
        </operation>

        <operation name="updateBillingTemplate"
                   qname="eig:updateBillingTemplate"
                   returnQName="eig:updateBillingTemplateResponse"
                   returnType="eig:BillingTemplate">
             <parameter qname="eig:billingTempate" type="eig:BillingTemplate"/>
        </operation>

        <operation name="deleteBillingTemplate"
                   qname="eig:deleteBillingTemplate"
                   returnQName="xsd:void"
                   returnType="xsd:void">
             <parameter qname="eig:billingTemplateId" type="xsd:long"/>
        </operation>

           <!-- BillingTier operations -->
        <operation name="createBillingTier"
                   qname="eig:createBillingTier"
                   returnQName="eig:BillingTier"
                   returnType="eig:BillingTier">
             <parameter qname="eig:bt" type="eig:BillingTier"/>
        </operation>

        <operation name="retrieveBillingTier"
                   qname="eig:retrieveBillingTier"
                   returnQName="eig:bt"
                   returnType="eig:BillingTier">
              <parameter qname="eig:billingTierId" type="xsd:long"/>
        </operation>

        <operation name="retrieveAllBillingTiers"
                   qname="eig:retrieveAllBillingTiers"
                   returnQName="eig:billingTiers"
                   returnType="eig:BillingTierList">
                   <parameter qname="loadAssociation" type="xsd:boolean"/>
        </operation>

        <operation name="updateBillingTier"
                   qname="eig:updateBillingTier"
                   returnQName="eig:bt"
                   returnType="eig:BillingTier">
              <parameter qname="eig:bt" type="eig:BillingTier"/>
         </operation>

        <operation name="deleteBillingTier"
                   qname="eig:deleteBillingTier"
                   returnQName="xsd:void"
                   returnType="xsd:void">
               <parameter qname="eig:billingTierId" type="xsd:long"/>
         </operation>

         <operation name="retrieveBillingTiersByMediaTypeName"
                    qname="eig:retrieveBillingTiersByMediaTypeName"
                    returnQName="eig:billingTiers"
                    returnType="eig:BillingTierList">
            <parameter qname="eig:mediaTypeName" type="xsd:string" />
         </operation>

         <operation name="createTaxPerFacility"
                    qname="eig:TaxPerFacility"
                    returnQName="eig:TaxPerFacility"
                    returnType="xsd:long">
            <parameter qname="eig:createTaxPerFacility" type="eig:TaxPerFacility" />
         </operation>

         <operation name="updateTaxPerFacility"
                    qname="eig:TaxPerFacility"
                    returnQName="eig:TaxPerFacility"
                    returnType="eig:TaxPerFacility">
            <parameter qname="eig:updateTaxPerFacility" type="eig:TaxPerFacility" />
         </operation>

         <operation name="retrieveTaxPerFacility"
                    qname="eig:TaxPerFacility"
                    returnQName="eig:TaxPerFacility"
                    returnType="eig:TaxPerFacility">
            <parameter qname="eig:retrieveTaxPerFacility" type="xsd:long" />
         </operation>

         <operation name="retrieveAllTaxPerFacilities"
                    qname="eig:TaxPerFacility"
                    returnQName="eig:TaxPerFacilityList"
                    returnType="eig:TaxPerFacilityList">
         </operation>

         <operation name="retrieveAllTaxPerFacilitiesByUser"
                    qname="eig:TaxPerFacility"
                    returnQName="eig:TaxPerFacilityList"
                    returnType="eig:TaxPerFacilityList">
            <parameter qname="eig:retrieveAllTaxPerFacilitiesByUser" type="xsd:string" />
         </operation>

         <operation name="deleteTaxPerFacility"
                    qname="eig:TaxPerFacility"
                    returnQName="xsd:void"
                    returnType="xsd:void">
            <parameter qname="eig:deleteTaxPerFacility" type="xsd:long" />
         </operation>

         <operation name="retrieveBillingAndPaymentInfo"
                    qname="eig:retrieveBillingAndPaymentInfo"
                    returnQName="eig:billingPaymentInfo"
                    returnType="eig:BillingPaymentInfo">
            <parameter qname="eig:requestorTypeId" type="xsd:long" />
         </operation>

        <typeMapping qname="eig:MediaType"
            type="java:com.mckesson.eig.roi.admin.model.MediaType"
            serializer="com.mckesson.eig.wsfw.axis.CastorSerializerFactory"
            deserializer="com.mckesson.eig.wsfw.axis.CastorDeserializerFactory"
            encodingStyle=""
        />

        <typeMapping qname="eig:MediaTypeList"
            type="java:com.mckesson.eig.roi.admin.model.MediaTypesList"
            serializer="com.mckesson.eig.wsfw.axis.CastorSerializerFactory"
            deserializer="com.mckesson.eig.wsfw.axis.CastorDeserializerFactory"
            encodingStyle=""
        />

        <typeMapping qname="eig:FeeType"
                      type="java:com.mckesson.eig.roi.admin.model.FeeType"
                      serializer   ="com.mckesson.eig.wsfw.axis.CastorSerializerFactory"
                      deserializer ="com.mckesson.eig.wsfw.axis.CastorDeserializerFactory"
                      encodingStyle=""
         />
         <typeMapping qname="eig:FeeTypes"
                      type="java:com.mckesson.eig.roi.admin.model.FeeTypesList"
                      serializer="com.mckesson.eig.wsfw.axis.CastorSerializerFactory"
                      deserializer="com.mckesson.eig.wsfw.axis.CastorDeserializerFactory"
                      encodingStyle=""
          />

         <typeMapping qname="eig:PaymentMethod"
            type="java:com.mckesson.eig.roi.admin.model.PaymentMethod"
            serializer="com.mckesson.eig.wsfw.axis.CastorSerializerFactory"
            deserializer="com.mckesson.eig.wsfw.axis.CastorDeserializerFactory"
            encodingStyle=""
        />
        <typeMapping qname="eig:PaymentMethodList"
            type="java:com.mckesson.eig.roi.admin.model.PaymentMethodList"
            serializer="com.mckesson.eig.wsfw.axis.CastorSerializerFactory"
            deserializer="com.mckesson.eig.wsfw.axis.CastorDeserializerFactory"
            encodingStyle=""
        />

        <typeMapping qname="eig:BillingTemplate"
            type="java:com.mckesson.eig.roi.admin.model.BillingTemplate"
            serializer="com.mckesson.eig.wsfw.axis.CastorSerializerFactory"
            deserializer="com.mckesson.eig.wsfw.axis.CastorDeserializerFactory"
            encodingStyle=""
        />

        <typeMapping qname="eig:RelatedFeeType"
            type="java:com.mckesson.eig.roi.admin.model.RelatedFeeType"
            serializer="com.mckesson.eig.wsfw.axis.CastorSerializerFactory"
            deserializer="com.mckesson.eig.wsfw.axis.CastorDeserializerFactory"
            encodingStyle=""
        />

        <typeMapping qname="eig:BillingTemplateList"
            type="java:com.mckesson.eig.roi.admin.model.BillingTemplatesList"
            serializer="com.mckesson.eig.wsfw.axis.CastorSerializerFactory"
            deserializer="com.mckesson.eig.wsfw.axis.CastorDeserializerFactory"
            encodingStyle=""
        />

         <!-- Billing Tier Type Mappings-->
        <typeMapping qname="eig:BillingTier"
            type="java:com.mckesson.eig.roi.admin.model.BillingTier"
            serializer="com.mckesson.eig.wsfw.axis.CastorSerializerFactory"
            deserializer="com.mckesson.eig.wsfw.axis.CastorDeserializerFactory"
            encodingStyle=""
        />
        <typeMapping qname="eig:BillingTierList"
            type="java:com.mckesson.eig.roi.admin.model.BillingTiersList"
            serializer="com.mckesson.eig.wsfw.axis.CastorSerializerFactory"
            deserializer="com.mckesson.eig.wsfw.axis.CastorDeserializerFactory"
            encodingStyle=""
        />
         <typeMapping qname="eig:PageLevelTier"
            type="java:com.mckesson.eig.roi.admin.model.PageLevelTier"
            serializer="com.mckesson.eig.wsfw.axis.CastorSerializerFactory"
            deserializer="com.mckesson.eig.wsfw.axis.CastorDeserializerFactory"
            encodingStyle=""
        />

         <!-- Sales Tax Per Facility Mappings-->
         <typeMapping qname="eig:TaxPerFacility"
            type="java:com.mckesson.eig.roi.admin.model.TaxPerFacility"
            serializer="com.mckesson.eig.wsfw.axis.CastorSerializerFactory"
            deserializer="com.mckesson.eig.wsfw.axis.CastorDeserializerFactory"
            encodingStyle=""
        />
         <typeMapping qname="eig:TaxPerFacilityList"
            type="java:com.mckesson.eig.roi.admin.model.TaxPerFacilityList"
            serializer="com.mckesson.eig.wsfw.axis.CastorSerializerFactory"
            deserializer="com.mckesson.eig.wsfw.axis.CastorDeserializerFactory"
            encodingStyle=""
        />

         <typeMapping qname="eig:BillingPaymentInfo"
            type="java:com.mckesson.eig.roi.admin.model.BillingPaymentInfo"
            serializer="com.mckesson.eig.wsfw.axis.CastorSerializerFactory"
            deserializer="com.mckesson.eig.wsfw.axis.CastorDeserializerFactory"
            encodingStyle=""
        />

    </service>

    <service name="ROIAdminService" style="wrapped" use="literal" provider="Handler">
		 <requestFlow>
            <handler type="java:com.mckesson.eig.wsfw.security.WsSecurityHandler" >
                <parameter name="action" value="UsernameToken Timestamp"/>
                <parameter name="passwordCallbackClass" value="com.mckesson.eig.wsfw.security.PasswordCallbackHandler"/>
            </handler>
        <!-- Add the HPFSecurityAuthorizationHandler after the Authentication handler to the requestflow-->
           <handler type="HPFSecurityAuthorizationHandler" />
        </requestFlow>
    <namespace>urn:eig.mckesson.com</namespace>
    <wsdlFile>/WEB-INF/eig/roi/roi.admin.wsdl</wsdlFile>
        <parameter name="alias" value="ROIAdmin"/>
        <parameter name="wsdlTargetNamespace" value="urn:eig.mckesson.com"/>
        <parameter name="wsdlPortType" value="ROIAdminPortType"/>
        <parameter name="wsdlServiceElement" value="ROIAdminService"/>
        <parameter name="wsdlServicePort" value="adminPort"/>
        <parameter name="handlerClass" value="com.mckesson.eig.wsfw.axis.BusinessServiceHandler"/>
        <parameter name="className" value="com.mckesson.eig.roi.admin.service.ROIAdminServiceImpl"/>
        <parameter name="allowedMethods" value="createDeliveryMethod,
                                                retrieveDeliveryMethod,
                                                retrieveAllDeliveryMethods,
                                                updateDeliveryMethod,
                                                deleteDeliveryMethod,
                                                updateWeight,
                                                retrieveWeight,
                                                retrieveAllReasonsByType,
                                                retrieveReason,
                                                updateReason,
                                                createReason,
                                                deleteReason,
                                                retrieveAllRequestStatus,
                                                retrieveReasonsByStatus,
                                                createRequestorType,
                                                retrieveRequestorType,
                                                retrieveAllRequestorTypes,
                                                deleteRequestorType,
                                                updateRequestorType,
                                                designateDocumentTypes,
                                                createLetterTemplate,
                                                retrieveLetterTemplate,
                                                retrieveAllLetterTemplates,
                                                updateLetterTemplate,
                                                deleteLetterTemplate,
                                                createNote,
                                                retrieveNote,
                                                retrieveAllNotes,
                                                deleteNote,
                                                updateNote,
                                                retrieveSSNMask,
                                                retrieveROIAppData,
                                                updateSSNMask,
                                                retrieveDesignations,
                                                retrieveDocTypeIdsByDesignation,
                                                retrieveMUDocTypes,
                                                hasLetterTemplate,
                                                getUser,
                                                enableOutputService,
                                                retrieveOutputServerProperties,
                                                saveOutputServerProperties,
                                                retrieveAttachmentLocation,
                                                updateAttachmentLocation,
                                                updateInvoiceDueDays,
                                                retrieveInvoiceDueDays,                                              
                                                updateCountryCode,
                                                retrieveAllCountries,
                                                updateUnbillableRequestFlag,
                                                retrieveUnbillableRequestFlag,
                                                retrieveAllGenders"/>

        <parameter name="scope" value="session"/>

		<!-- getUser -->
        <operation name="getUser" qname="eig:getUser" returnQName="eig:user" returnType="eig:user">
			<parameter qname="eig:userId" type="xsd:string"/>
		</operation>

		<typeMapping qname="eig:user"
        			type="java:com.mckesson.eig.roi.hpf.model.User"
	        		serializer="com.mckesson.eig.wsfw.axis.CastorSerializerFactory"
		        	deserializer="com.mckesson.eig.wsfw.axis.CastorDeserializerFactory"
			        encodingStyle=""
		/>

        <!-- DeliveryMethod -->
        <operation name="createDeliveryMethod"
                   qname="eig:createDeliveryMethodRequest"
                   returnQName="eig:deliveryMethodId"
                   returnType="xsd:long">
            <parameter qname="eig:deliveryMethodDetails" type="eig:DeliveryMethod"/>
        </operation>

        <operation name="retrieveDeliveryMethod"
                   qname="eig:retrieveDeliveryMethod"
                   returnQName="eig:deliveryMethodDetails"
                   returnType="eig:DeliveryMethod">
            <parameter qname="eig:deliveryMethodId" type="xsd:long"/>
        </operation>

        <operation name="retrieveAllDeliveryMethods"
                   qname="eig:retrieveAllDeliveryMethods"
                   returnQName="eig:deliveryMethods"
                   returnType="eig:DeliveryMethodList">
                 <parameter qname="detailedFetch" type="xsd:boolean"/>
        </operation>

        <operation name="updateDeliveryMethod"
                   qname="eig:updateDeliveryMethod"
                   returnQName="eig:deliveryMethodDetails"
                   returnType="eig:DeliveryMethod">
             <parameter qname="eig:deliveryMethodDetails" type="eig:DeliveryMethod"/>
        </operation>

        <operation name="deleteDeliveryMethod"
                   qname="eig:deleteDeliveryMethod"
                   returnQName="xsd:void"
                   returnType="xsd:void">
           <parameter qname="eig:deliveryMethodId" type="xsd:long"/>
        </operation>

         <!--  Weight -->
        <operation name="updateWeight"
                   qname="eig:updateWeight"
                   returnQName="eig:weightDetails"
                   returnType="eig:Weight">
             <parameter qname="eig:weightDetails" type="eig:WeightDetail"/>
        </operation>

         <operation name="retrieveWeight"
                   qname="eig:retrieveWeight"
                   returnQName="eig:weightDetails"
                   returnType="eig:Weight">
 	</operation>

        <!--  Reason -->
        <operation name="createReason"
                   qname="eig:createReason"
                   returnQName="eig:reasonId"
                   returnType="xsd:long">
            <parameter qname="eig:reason" type="eig:Reason"/>
        </operation>

        <operation name="retrieveReason"
                   qname="eig:retrieveReason"
                   returnQName="eig:reason"
                   returnType="eig:Reason">
