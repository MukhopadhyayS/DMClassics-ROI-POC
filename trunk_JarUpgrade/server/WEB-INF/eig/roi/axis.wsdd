					returnType="xsd:boolean">
					<parameter qname="eig:ccdSourceDto" type="eig:CcdSourceDto"/>
			</operation>
			
			<operation name="retrieveCCD" 
					qname="eig:retrieveCCD" 
					returnQName="eig:ccdDocuments" 
					returnType="eig:CcdDocuments">
					<parameter qname="eig:retrieveParameters" type="eig:RetrieveCCDDtoList"/>
			</operation>
		
