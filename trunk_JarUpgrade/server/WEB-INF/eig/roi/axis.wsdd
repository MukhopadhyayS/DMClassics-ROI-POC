			<parameter name="className" value="com.mckesson.eig.roi.ccd.service.CcdConversionServiceImpl"/>
			<parameter name="allowedMethods" value="ccdConvert,getAvailableProviders,getExternalSources,createSource,deleteSource,updateSource,updateSourceConfig,retrieveCCD,testConfiguration,getExternalSourceNameForFacility"/>
			<parameter name="forceInvalidateSession" value="true"/>
			<parameter name="scope" value="session"/>
			<operation name="ccdConvert" 
					qname="eig:ccdConvert" 
					returnQName="eig:ccdConvertResult" 
					returnType="eig:ccdConvertResult" >
				<parameter qname="eig:uuid" type="xsd:string"/>
			</operation>
			
			<operation name="getAvailableProviders" 
					qname="eig:getAvailableProviders" 
					returnQName="eig:ccdSourceDtoList" 
					returnType="eig:CcdSourceDtoList" >
			</operation>

			<operation name="getExternalSources" 
					qname="eig:getExternalSources" 
					returnQName="eig:ccdSourceDtoList" 
					returnType="eig:CcdSourceDtoList" >
			</operation>
			
			<operation name="createSource" 
					qname="eig:createSource" 
					returnQName="eig:sourceId" 
					returnType="xsd:int">
					<parameter qname="eig:ccdSourceDto" type="eig:CcdSourceDto"/>
			</operation>
			
			<operation name="deleteSource" 
					qname="eig:deleteSource" 
					returnQName="eig:ccdDeleteRes" 
