    <service name="RequestorService" style="wrapped" use="literal" provider="Handler">
       <requestFlow>
            <handler type="java:com.mckesson.eig.wsfw.security.WsSecurityHandler" >
                <parameter name="action" value="UsernameToken Timestamp"/>
                <parameter name="passwordCallbackClass" value="com.mckesson.eig.wsfw.security.PasswordCallbackHandler"/>
            </handler>
        <!-- Add the HPFSecurityAuthorizationHandler after the Authentication handler to the requestflow -->
           <handler type="HPFSecurityAuthorizationHandler" />
        </requestFlow>

        <namespace>urn:eig.mckesson.com</namespace>
        <wsdlFile>/WEB-INF/eig/roi/requestor.wsdl</wsdlFile>
        <parameter name="alias" value="RequestorService"/>
        <parameter name="wsdlTargetNamespace" value="urn:eig.mckesson.com"/>
        <parameter name="wsdlPortType" value="RequestorPortType"/>
        <parameter name="wsdlServiceElement" value="RequestorService"/>
        <parameter name="wsdlServicePort" value="requestorPort"/>
        <parameter name="handlerClass" value="com.mckesson.eig.wsfw.axis.BusinessServiceHandler"/>
        <parameter name="className" value="com.mckesson.eig.roi.requestor.service.RequestorServiceImpl"/>
        <parameter name="allowedMethods" value="findRequestor,
                                                createRequestor,
                                                retrieveRequestor,
                                                updateRequestor,
                                                deleteRequestor,
                                                checkDuplicateRequestorName,
                                                searchMatchingRequestors,
                                                retrieveRequestorLetterHistory,
                                                viewRequestorLetter,
        										createRequestorLetterEntry,
        										retrieveRequestorInvoices,
        										retrieveAdjustmentInfo,
        										saveAdjustmentInfo,
        										createRequestorPayment,
        										updateRequestorPayment,
        										retrieveAdjustmentInfoByAdjustmentId,
        										retrieveRequestorPastInvoices,
        										generateRequestorStatement,
        										createRequestorStatement,
												retrieveRequestorSummaries,
												createRequestorRefund,
												viewRequestorDetails,
												retrieveUnappliedAmountDetails,
												viewRequestorRefund,
												deleteRequestorPayment"/>

        <operation name="findRequestor"
                   qname="eig:findRequestor"
                   returnQName="eig:requestorSearchResult"
                   returnType="eig:RequestorSearchResult">
            <parameter qname="eig:requestorSearchCriteria" type="eig:RequestorSearchCriteria"/>
        </operation>

        <operation name="createRequestor"
                   qname="eig:createRequestor"
                   returnQName="eig:requestorId"
                   returnType="xsd:long">
            <parameter qname="eig:requestor" type="eig:Requestor"/>
        </operation>

        <operation name="retrieveRequestor"
                   qname="eig:retrieveRequestor"
                   returnQName="eig:requestor"
                   returnType="eig:Requestor">
            <parameter qname="eig:requestorId" type="xsd:long"/>
            <parameter qname="eig:isSearchRetrieve" type="xsd:boolean"/>
        </operation>
        <operation name="updateRequestor"
                   qname="eig:updateRequestor"
                   returnQName="xsd:requestor"
                   returnType="xsd:Requestor">
            <parameter qname="eig:requestor" type="eig:Requestor"/>
        </operation>

        <operation name="deleteRequestor"
                   qname="eig:deleteRequestor"
                   returnQName="xsd:void"
                   returnType="xsd:void">
            <parameter qname="eig:requestorId" type="xsd:long"/>
        </operation>

        <operation name="checkDuplicateRequestorName"
                   qname="eig:checkDuplicateRequestorName"
                   returnQName="eig:available"
                   returnType="xsd:boolean">
            <parameter qname="eig:id" type="xsd:long"/>
            <parameter qname="eig:name" type="xsd:string"/>
        </operation>

        <operation name="searchMatchingRequestors"
                   qname="eig:searchMatchingRequestors"
                   returnQName="eig:requestorSearchResult"
                   returnType="eig:RequestorSearchResult">
            <parameter qname="eig:matchCriteriaList" type="eig:MatchCriteriaList"/>
        </operation>
        
        <operation name="retrieveRequestorLetterHistory"
				qname="eig:retrieveRequestorLetterHistory"
				returnQName="eig:RequestorLetterHistoryList"
				returnType="eig:RequestorLetterHistoryList" >
			<parameter qname="eig:requestorId" type="xsd:long"/>
		</operation>
		
		<operation name="viewRequestorLetter"
				qname="eig:viewRequestorLetter"
				returnQName="eig:docInfo"
				returnType="eig:DocInfo" >
			<parameter qname="eig:requestorLetterId" type="xsd:long"/>
			<parameter qname="eig:docType" type="xsd:string"/>
		</operation>
		
		<operation name="createRequestorLetterEntry"
				qname="eig:createRequestorLetterEntry"
				returnQName="eig:requestorLetterHistory"
				returnType="eig:RequestorLetterHistory" >
			<parameter qname="eig:RegeneratedInvoiceInfo" type="eig:RegeneratedInvoiceInfo"/>
		</operation>
 
	<operation name="retrieveRequestorInvoices"
		qname="eig:retrieveRequestorInvoices"
		returnQName="eig:requestorInvoicesList"
		returnType="eig:RequestorInvoicesList" >
		<parameter qname="eig:requestorId" type="xsd:long"/>
	</operation>
	
		 <operation name="retrieveAdjustmentInfo"
			qname="eig:retrieveAdjustmentInfo"
			returnQName="eig:adjustmentInfo"
			returnType="eig:AdjustmentInfo">
			<parameter qname="eig:requestorId" type="xsd:long"/>
	  </operation>
	  
	  <operation name="saveAdjustmentInfo"
			qname="eig:saveAdjustmentInfo"
			returnQName="xsd:void"
			returnType="xsd:void">
			<parameter qname="eig:adjustmentInfo" type="eig:AdjustmentInfo"/>
	 </operation>
	 
	<operation name="createRequestorPayment"
			qname="eig:createRequestorPayment"
			returnQName="xsd:void"
			returnType="xsd:void">
			<parameter qname="eig:requestorPaymentList" type="eig:RequestorPaymentList"/>
	</operation>

	<operation name="updateRequestorPayment"
			qname="eig:updateRequestorPayment"
			returnQName="xsd:void"
			returnType="xsd:void">
			<parameter qname="eig:requestorPaymentList" type="eig:RequestorPaymentList"/>
	</operation>
	
	<operation name="retrieveAdjustmentInfoByAdjustmentId"
