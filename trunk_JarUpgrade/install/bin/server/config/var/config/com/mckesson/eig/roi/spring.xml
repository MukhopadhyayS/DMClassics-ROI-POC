<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:aop="http://www.springframework.org/schema/aop"
	xmlns:tx="http://www.springframework.org/schema/tx"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
                        http://www.springframework.org/schema/beans/spring-beans-2.0.xsd
                        http://www.springframework.org/schema/tx
                        http://www.springframework.org/schema/tx/spring-tx-2.0.xsd
                        http://www.springframework.org/schema/aop
                        http://www.springframework.org/schema/aop/spring-aop-2.0.xsd">


	<!-- Common  Hibernate SessionFactory -->
	<bean id="sessionFactory"
		class="org.springframework.orm.hibernate3.LocalSessionFactoryBean">
		<property name="dataSource">
			<ref local="dataSource" />
		</property>
		<property name="configLocation"
			value="classpath:com/mckesson/eig/roi/hibernate.xml" />
	</bean>

	<!-- DAO-hibernate configuration starts here-->
	<bean id="dataSource"
		class="org.springframework.jndi.JndiObjectFactoryBean">
		<description>
			Provides access to a datasource registered with JNDI.
		</description>
		<property name="jndiName">
			<value>java:/ROI_DS</value>
		</property>
        <!--Turned Off to Allow hot redeployment of JNDI Objects  -->
        <property name="cache" value="false"/>
        <!--  For hot redeployment  -->
        <property name="proxyInterface" value="javax.sql.DataSource"/>
	</bean>
	
	<!-- Audit Configuration starts -->
	<bean id="defaultDataSourceMPF" parent="dataSource"/>
	
	<bean id="daoRegistry" class="com.mckesson.eig.iws.orm.SimpleDaoRegistry" >
		<property name="registry">
			<map>
				<entry key="AuditTrailHibernateDao">
					<ref bean="AuditTrailHibernateDao"/>
				</entry>
			</map>
		</property>
	</bean>

	<bean id="AuditTrailHibernateDao" class="com.mckesson.eig.audit.dao.hpf.AuditTrailHibernateDao">
		<property name="sessionFactory"><ref local="sessionFactory"/></property>
	</bean>

	<!-- Audit Configuration Ends -->
	
	<bean id="transactionManager"
		class="org.springframework.orm.hibernate3.HibernateTransactionManager">
		<property name="sessionFactory">
			<ref bean="sessionFactory" />
		</property>
	</bean>

	<!--  Common transactionContext . Please do not remove  -->

	<tx:advice id="txAdvice" transaction-manager="transactionManager">
		<tx:attributes>
		    <tx:method name="retrieve*" read-only="true"/>
            <tx:method name="search*" read-only="true"/>
            <tx:method name="find*" read-only="true"/>
            <tx:method name="get*" read-only="true"/>
			<tx:method name="*" />
		</tx:attributes>
	</tx:advice>

	<aop:config proxy-target-class="true">
		<aop:advisor
			pointcut="execution(* com.mckesson.eig.roi.admin.service.BillingAdminServiceImpl.* (..))"
			advice-ref="txAdvice" />
	</aop:config>

	<aop:config proxy-target-class="true">
		<aop:advisor
			pointcut="execution(* com.mckesson.eig.roi.admin.service.ROIAdminServiceImpl.* (..))"
			advice-ref="txAdvice" />
	</aop:config>

	<aop:config proxy-target-class="true">
		<aop:advisor
			pointcut="execution(* com.mckesson.eig.roi.requestor.service.RequestorServiceImpl.* (..))"
			advice-ref="txAdvice" />
	</aop:config>

	<aop:config proxy-target-class="true">
		<aop:advisor
			pointcut="execution(* com.mckesson.eig.roi.hpf.service.HPFSecurityAuthenticationService.* (..))"
			advice-ref="txAdvice" />
	</aop:config>

	<aop:config proxy-target-class="true">
        <aop:advisor
            pointcut="execution(* com.mckesson.eig.roi.reports.service.ROIReportServiceImpl.* (..))"
            advice-ref="txAdvice" />
    </aop:config>

    <aop:config proxy-target-class="true">
        <aop:advisor
            pointcut="execution(* com.mckesson.eig.roi.admin.service.ROIAttachmentServiceImpl.* (..))"
            advice-ref="txAdvice" />
    </aop:config>

 	<aop:config proxy-target-class="true">
        <aop:advisor
            pointcut="execution(* com.mckesson.eig.roi.request.service.RequestCoreServiceImpl.* (..))"
            advice-ref="txAdvice" />
    </aop:config>

 	<aop:config proxy-target-class="true">
        <aop:advisor
            pointcut="execution(* com.mckesson.eig.roi.billing.service.OverDueInvoiceCoreServiceImpl.* (..))"
            advice-ref="txAdvice" />
    </aop:config>

    <aop:config proxy-target-class="true">
        <aop:advisor
            pointcut="execution(* com.mckesson.eig.roi.supplementary.service.ROISupplementaryServiceImpl.* (..))"
            advice-ref="txAdvice" />
    </aop:config>
    
    <aop:config proxy-target-class="true">
        <aop:advisor
            pointcut="execution(* com.mckesson.eig.roi.billing.service.BillingCoreServiceImpl.* (..))"
            advice-ref="txAdvice" />
    </aop:config>
   
	<import resource="dao.spring.xml" />
	<import resource="service.spring.xml" />

	<!-- Logging services-->
	<bean id="log_initializer"
		class="com.mckesson.eig.utility.log.log4j.Log4JInitializer">
		<property name="byXml">
			<value>com/mckesson/eig/roi/logging.xml</value>
		</property>
	</bean>

	<bean id="globalIDInitializer" class="com.mckesson.eig.utility.log.log4j.GlobalIDInitializer" init-method="initAppGlobalID">
		<property name="dsSource" value="java:/ROI_DS"/>
		<property name="globalName" value="ROI Server"/>
		<property name="serverPort" value="8082" />
	</bean>

	<bean id="castor_context"
		class="com.mckesson.eig.wsfw.axis.CastorContext" lazy-init="true">
		<property name="mappingFile"
			value="com/mckesson/eig/roi/castor.xml" />
	</bean>

	<bean id="audit_castor_context"
		class="com.mckesson.eig.wsfw.axis.CastorContext" lazy-init="true">
		<property name="mappingFile"
			value="com/mckesson/eig/audit/webservices/webservice-mappings.xml" />
	</bean>
<!--
	<bean id="eig_auditq_config"
		class="com.mckesson.eig.utility.jms.JmsConfig">
		<property name="url" value="tcp://127.0.0.1:61616" />
		<property name="jmsQueueName" value="queue/eigAudit" />
		<property name="physicalName" value="queue.eigAudit" />
		<property name="connectionFactory"
			value="QueueConnectionFactory" />
	</bean>  -->

 <bean id="eig_auditq_config"
          class="com.mckesson.eig.wsfw.jms.MessagePoster">

      <property name="queue">
        <ref bean="auditQueue"/>
      </property>

      <property name="connectionFactory">
        <ref bean="connectionFactory"/>
      </property>

    </bean>

    <bean id="connectionFactory"
    class="org.springframework.jndi.JndiObjectFactoryBean">
    <property name="jndiTemplate">
      <ref bean="jndiTemplate" />
    </property>
    <property name="jndiName">
      <value>QueueConnectionFactory</value>
<!--      <value>java:/ConnectionFactory</value> -->
    </property>

  </bean>

  <bean id="auditQueue"
    class="org.springframework.jndi.JndiObjectFactoryBean">
    <property name="jndiTemplate">
      <ref bean="jndiTemplate" />
    </property>
    <property name="jndiName">
      <value>queue/eigAudit</value>
    </property>
  </bean>

  <bean id="jndiTemplate"
    class="org.springframework.jndi.JndiTemplate">
    <property name="environment">
      <props>
        <prop key="java.naming.factory.initial">
          org.apache.activemq.jndi.ActiveMQInitialContextFactory
        </prop>
        <prop key="java.naming.provider.url">
          tcp://127.0.0.1:61616?wireFormat.maxInactivityDuration=0
        </prop>
        <prop key="queue.queue/eigAudit">
          queue.eigAudit
        </prop>
      </props>
    </property>
  </bean>

	<bean id="BeanFactory"
		class="org.springframework.beans.factory.support.DefaultListableBeanFactory">
	</bean>

	<bean id="PasswordEncryptionStrategy"
		class="com.mckesson.eig.wsfw.security.encryption.PassthroughStrategy">
	</bean>

	<!--  Audit service -->
	<bean id="com.mckesson.eig.audit.local.AuditLocalService"
		class="com.mckesson.eig.audit.local.AuditLocalService"
		lazy-init="true" />
		
	<bean id="com.mckesson.eig.audit.dao.AuditDaoService"
		class="com.mckesson.eig.audit.dao.AuditDaoService"
		lazy-init="true" />

	<bean id="AuditManager"
		class="com.mckesson.eig.roi.base.service.ROIAuditManager"
		lazy-init="true" />

	<!-- Business Services -->
	<bean
		id="com.mckesson.eig.roi.hpf.service.HPFSecurityAuthenticationService"
		class="com.mckesson.eig.roi.hpf.service.HPFSecurityAuthenticationService"
		scope="singleton" lazy-init="true" />

	<bean id="AuthenticationStrategy"
		class="com.mckesson.eig.roi.hpf.service.HPFAuthenticationStrategy"
		lazy-init="true">
		<property name="authenticationUrl">
            <value>http://127.0.0.1:8080/portal/eig/iservices/configuration?wsdl</value>
        </property>
    </bean>

	<bean id="AuthorizationStrategy"
		class="com.mckesson.eig.roi.hpf.service.HPFAuthorizationStrategy"
		lazy-init="true" />

	<bean id="WebServiceAuthorizationTable"
		class="com.mckesson.eig.roi.hpf.service.WebServiceAuthorizationTable"
		lazy-init="true">
		<property name="mappingFile"
			value="com/mckesson/eig/roi/webservice-authorization.properties" />
	</bean>

     <bean id="HPFAuthenticationServiceLoader"
           class="com.mckesson.eig.roi.hpf.service.HPFAuthenticationServiceLoader"
           lazy-init="false">
           <constructor-arg value="http://127.0.0.1:8080/portal/eig/iservices/signin"/>
     </bean>

	<bean id="authenticator.roi"
          class="com.mckesson.eig.roi.hpf.service.ROIAuthenticator">
    </bean>
    
	<bean id="ccd.xslt.file" class="java.lang.String">
		<constructor-arg index="0" value="com/mckesson/eig/roi/ccd/xslt/ccd_fo.xsl" />
	</bean>	
	<bean id="ccr.xslt.file" class="java.lang.String">
		<constructor-arg index="0" value="com/mckesson/eig/roi/ccd/xslt/ccr_fo.xsl" />
	</bean>

	<bean id="paragon.ccd.xslt.file" class="java.lang.String">
		<constructor-arg index="0" value="com/mckesson/eig/roi/ccd/xslt/ccd_paragon_fo.xsl" />
	</bean>

	<bean id="ccdProviderFactory" class="com.mckesson.eig.roi.ccd.provider.CcdProviderFactory">
	</bean>
	
	
	<bean id="ccdProviderFactoryTrigger" class="org.springframework.scheduling.quartz.SimpleTriggerBean">
		<property name="jobDetail" ref="startCcdProviderFactory" />
		<property name="startDelay" value="30000"/>
    	<property name="repeatInterval" value="600000" />
	</bean>

	<bean id="startCcdProviderFactory" class="org.springframework.scheduling.quartz.MethodInvokingJobDetailFactoryBean">
		<property name="targetObject" ref="ccdProviderFactory" />
		<property name="targetMethod" value="retry" />
	</bean>

	    <!-- A list of Triggers to be scheduled and executed by Quartz -->
    <bean class="org.springframework.scheduling.quartz.SchedulerFactoryBean">
        <property name="triggers">
            <list>
                <ref bean="ccdProviderFactoryTrigger"/>
             </list>
        </property>
    </bean>
    
	<bean id="CELStopMessageLogger" 
	   class="com.mckesson.eig.roi.utils.CELStopMessageLogger"/>

	<bean id="CELStartMessageLogger" 
	   class="com.mckesson.eig.roi.utils.CELStartMessageLogger"
	   init-method="init"/>

    <bean id="shutdownHookList" class="java.util.ArrayList">
		<constructor-arg>
			<list>
				<ref bean="CELStopMessageLogger"/>
			</list>
		</constructor-arg>
    </bean>

    <bean class="com.mckesson.eig.roi.base.model.ShutdownBean">
		<constructor-arg index="0" ref="shutdownHookList" />
    </bean>
    
</beans>
