<?xml version="1.0" encoding="UTF-8"?>
<mapping xmlns:eig="urn:eig.mckesson.com">
 <class name="com.mckesson.eig.roi.admin.model.TaxPerFacility">
    <map-to xml="TaxPerFacility" ns-prefix="eig" ns-uri="urn:eig.mckesson.com"/>

    <field name="id" type="long">
        <bind-xml name="eig:id" node="element" />
    </field>

    <field name="code" type="string">
      <bind-xml name="eig:code" node="element" />
    </field>

    <field name="name" type="string">
      <bind-xml name="eig:name" node="element" />
    </field>

    <field name="description" type="string">
      <bind-xml name="eig:description" node="element" />
    </field>

    <field name="default" type="char">
      <bind-xml name="eig:default" node="element" />
    </field>

    <field name="taxPercentage" type="float">
      <bind-xml name="eig:taxPercentage" node="element" />
    </field>

    <field name="recordVersion" type="int">
      <bind-xml name="eig:recordVersion" node="element" />
    </field>

  </class>

  <class name="com.mckesson.eig.roi.admin.model.TaxPerFacilityList">
    <map-to xml="TaxPerFacilityList" ns-prefix="eig" ns-uri="urn:eig.mckesson.com"/>

    <field name="salesTaxFacilityList" type="com.mckesson.eig.roi.admin.model.TaxPerFacility" collection="arraylist">
      <bind-xml name="eig:TaxPerFacility" node="element" />
    </field>

  </class>
</mapping>