    <category name="com.mckesson.eig.alert.service.AlertHandler" additivity="false">
	    <priority value="info" />
	    <appender-ref ref="eigConsoleAppender" />
	    <appender-ref ref="eigLogAppender" />
	    <appender-ref ref="EMAIL" />
	    <appender-ref ref="eigDatabaseAppender" />
    </category>

