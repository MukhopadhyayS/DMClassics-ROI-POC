#include "ifx.h"
//#include "Declare.rul"

//////////////////////////////////////////////////////////////////////////////
//		PROTOTYPE FOR USER DEFINE FUNCTIONS.
//////////////////////////////////////////////////////////////////////////////
prototype BOOL installVCPlusRedist();
//////////////////////////////////////////////////////////////////////////////
//		GLOBAL VARIABLES.
//////////////////////////////////////////////////////////////////////////////

//////////////////////////////////////////////////////////////////////////////
//		User Defined Functions Implementations
//////////////////////////////////////////////////////////////////////////////

//////////////////////////////////////////////////////////////////////////////
//
//  FUNCTION:   installVCPlusRedist
//
//////////////////////////////////////////////////////////////////////////////
function BOOL installVCPlusRedist()
	NUMBER nReturn;
	BOOL bSuccess;
begin
    // do a quiet install of Microsoft Visual C++ 2008 Redistributable
	nReturn = LaunchAppAndWait(SRCDIR ^ "Support\\Microsoft_Visual_C++_2008_Redistributable_Package\\vcredist_x86.exe", "/q", WAIT);
	bSuccess = nReturn == 0;
	return bSuccess;
end;
