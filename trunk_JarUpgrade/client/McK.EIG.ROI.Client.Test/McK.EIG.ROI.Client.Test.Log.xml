<?xml version="1.0" encoding="utf-8" ?> 
<!-- threshold="All" -->
<log4net threshold="All" >
    
    <appender name="ConsoleAppender" type="log4net.Appender.ConsoleAppender">
        <layout type="log4net.Layout.PatternLayout">
            <param name="ConversionPattern" value="[%5p] %m%n"/>
        </layout>
		<filter type="log4net.Filter.LevelRangeFilter">
			<param name="LevelMin" value="DEBUG" />
			<param name="LevelMax" value="FATAL" />
		</filter>
    </appender>
	<appender 
		name = "FileAppender" 
		type="log4net.Appender.RollingFileAppender">
		<Layout type="log4net.Layout.PatternLayout">
			<param name = "ConversionPattern" value = "%d - [%5p] %m%n"/>
		</Layout>
		<param name="File" value = "McK.EIG.ROI.Client.Test.log"/>
		<param name="MaximumFileSize" value = "4MB"/>
		<param name="MaxSizeRollBackups" value = "10"/>
		<filter type="log4net.Filter.LevelRangeFilter">
			<param name="LevelMin" value="DEBUG" />
			<param name="LevelMax" value="FATAL" />
		</filter>
	</appender>
	<appender
		name = "MetricLogAppender"
		type="log4net.Appender.RollingFileAppender">
			<Layout type="log4net.Layout.PatternLayout">
				<param name = "ConversionPattern" value = "%d - [%5p] %m%n"/>
			</Layout>
			<param name="File" value = "McK.EIG.ROI.Client.Test.Metric.log"/>
			<param name="MaximumFileSize" value = "4MB"/>
			<param name="MaxSizeRollBackups" value = "10"/>
			<filter type="log4net.Filter.LoggerMatchFilter">
				<loggerToMatch value="MetricLogger"/>
		</filter>
	</appender>
	<appender 
		name = "EventLogAppender"
		type = "log4net.Appender.EventLogAppender">
		<Layout type="log4net.Layout.PatternLayout">
            <param name = "ConversionPattern" value = "%d - [%5p] %m%n"/>
		</Layout>
		<filter type="log4net.Filter.LevelRangeFilter">
			<param name="LevelMin" value="ERROR" />
			<param name="LevelMax" value="FATAL" />
		</filter>
	</appender>
    <logger name="EventLogger" additivity="true" level="ERROR">
        <appender-ref ref="EventLogAppender"/>
    </logger>
	<logger name="MetricLogger" additivity="false" level="DEBUG">
		<appender-ref ref="MetricLogAppender"/>
	</logger>
    <root>
        <level value="DEBUG" />
        <appender-ref ref="FileAppender"/>
    </root>

</log4net>
