	([ERAID] = @Original_ERAID))
	
SELECT RefId, CLP01, ISACtrl, STCtrl, GroupCtrl, LX, Status, PtName, Encounter, MRN, Facility, NPI, ERAID FROM hist_EOB WHERE (RefId = @RefId)

	
