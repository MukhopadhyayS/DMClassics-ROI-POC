IF EXISTS (SELECT 1 
			FROM [STATUS] 
			WHERE STATUS_ID = 1
				AND COLOR_BK IS NULL) 
								
	UPDATE [STATUS] 
	SET COLOR_BK = 10015106
	WHERE STATUS_ID = 1


/*** STATUS_ID = 7 - DECLINED ***/

IF EXISTS (SELECT 1 
			FROM [STATUS] 
			WHERE STATUS_ID = 7 
				AND COLOR_BK IS NULL)
				
	UPDATE [STATUS] 
	SET COLOR_BK = 1184475 
	WHERE STATUS_ID = 7


/*** STATUS_ID = 8 - PENDING DEFICIENCY ***/

IF EXISTS (SELECT 1 
			FROM [STATUS] 
			WHERE STATUS_ID = 8 
				AND COLOR_BK IS NULL)
				
	UPDATE [STATUS] 
	SET COLOR_BK = 16753771 
	WHERE STATUS_ID = 8


/*** STATUS_ID = 9 - DEFICIENCY ERROR ***/

IF EXISTS (SELECT 1 
			FROM [STATUS] 
			WHERE STATUS_ID = 9 
				AND COLOR_BK IS NULL)
				
	UPDATE [STATUS]
	SET COLOR_BK = 16540163 
	WHERE STATUS_ID = 9


	

