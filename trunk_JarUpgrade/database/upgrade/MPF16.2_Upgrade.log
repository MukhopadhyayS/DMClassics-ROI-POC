IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[SYSERRORS_GLOBAL]') AND type in (N'U'))
BEGIN
CREATE TABLE [dbo].[SYSERRORS_GLOBAL](
    [GlobalID] [bigint] NOT NULL,
	[OCCURRED] [datetime] NOT NULL DEFAULT getdate(),
	[ERROR_TYPE] [varchar] (10) NULL,
	[ERROR_DESC] [nvarchar](2048) NULL,
	[ERROR_NUMBER] INT NULL,
	[ERROR_SEVERITY] INT NULL,
	[ERROR_STATE] INT NULL,
	[ERROR_PROCEDURE] nvarchar(126) NULL,
	[ERROR_LINE] INT NULL,
	[ERROR_TRANSACTION_ID] [nvarchar](50) NULL,
	[ERROR_CLASS_NAME] [varchar](250) NULL
	CONSTRAINT SYSERRORS_GLOBAL_FK_SYSPARMS_GLOBAL
              FOREIGN KEY (GLOBALID)
                             REFERENCES  SYSPARMS_GLOBAL
)
END


IF NOT EXISTS (SELECT * FROM sys.indexes WHERE object_id = OBJECT_ID(N'[dbo].[SYSERRORS_GLOBAL]') AND name = N'IDX_SYSERRORS_GLOBAL_GlobalID_Occurred')
CREATE NONCLUSTERED INDEX IDX_SYSERRORS_GLOBAL_GlobalID_Occurred ON [dbo].[SYSERRORS_GLOBAL]
(
	[GlobalID], [OCCURRED] ASC
)


-- If IDX_SYSERRORS_GLOBAL_Occurred is NONCLUSTERED drop index
IF EXISTS (SELECT * FROM sys.indexes WHERE object_id = OBJECT_ID(N'[dbo].[SYSERRORS_GLOBAL]') AND name = N'IDX_SYSERRORS_GLOBAL_Occurred' and type_desc = 'NONCLUSTERED')
DROP INDEX [dbo].[SYSERRORS_GLOBAL].IDX_SYSERRORS_GLOBAL_Occurred


IF NOT EXISTS (SELECT * FROM sys.indexes WHERE object_id = OBJECT_ID(N'[dbo].[SYSERRORS_GLOBAL]') AND name = N'IDX_SYSERRORS_GLOBAL_Occurred')
CREATE CLUSTERED INDEX IDX_SYSERRORS_GLOBAL_Occurred ON [dbo].[SYSERRORS_GLOBAL]
(
	[OCCURRED] ASC
