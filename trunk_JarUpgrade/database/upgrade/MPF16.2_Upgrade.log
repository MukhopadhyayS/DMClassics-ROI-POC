	while @@TRANCOUNT > 0
	ROLLBACK TRANSACTION 

	-- Delete all the previous TXT files as an error has occurred 
	SET  @sqlcmd = 'del ' + @HBI_TargetDir + '\MPF_Daily_IndexingProductivity.txt'
	EXEC @Success =  master..xp_cmdshell @sqlcmd, NO_OUTPUT
END CATCH


