IF EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[EPRS_GetItem2Purge]') AND type in (N'P'))
DROP PROCEDURE [dbo].[EPRS_GetItem2Purge]


/* BEGIN-COPYRIGHT-COMMENT Do not remove or modify this line!
