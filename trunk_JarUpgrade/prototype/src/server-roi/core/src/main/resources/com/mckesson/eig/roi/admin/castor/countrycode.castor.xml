<?xml version="1.0" encoding="UTF-8"?>
<mapping xmlns:eig="urn:eig.mckesson.com">
	
	<class name="com.mckesson.eig.roi.admin.model.Country">
		<map-to xml="country" ns-prefix="eig"
			ns-uri="urn:eig.mckesson.com" />

		<field name="countryCode" type="string">
			<bind-xml name="eig:countryCode" node="element" />
		</field>

		<field name="countryName" type="string">
			<bind-xml name="eig:countryName" node="element" />
		</field>
		
		<field name="defaultCountry" type="boolean">
			<bind-xml name="eig:defaultCountry" node="element" />
		</field>
		
		<field name="countrySeq" type="long">
			<bind-xml name="eig:countrySeq" node="element" />
		</field>
				
	</class>
	
</mapping>
